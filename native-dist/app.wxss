page {
  min-height: 100%;
  background: #05080b;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  color: #111827;
}

view, text, input, button {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

/* hide page-level legacy tabbars; use components/sxf-tabbar only */
.legacy-tabbar,
.bottom-tabbar,
.custom-tabbar {
  display: none !important;
}