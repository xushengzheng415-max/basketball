.sxf-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 80;
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  box-sizing: border-box;
  width: 100%;
  height: calc(108rpx + env(safe-area-inset-bottom));
  padding: 8rpx 10rpx calc(8rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(5, 9, 12, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.32);
  transform: translateZ(0);
  backface-visibility: hidden;
}

.tab-item {
  display: flex;
  min-width: 0;
  height: 92rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  color: #aeb4bd;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  transition: color 140ms ease, opacity 140ms ease, transform 140ms ease;
}

.tab-item.active {
  color: #ff6a00;
  font-weight: 900;
}

.tab-item-press {
  opacity: 0.72;
  transform: translateY(2rpx) scale(0.96);
}

.tab-icon {
  display: block;
  width: 46rpx;
  height: 46rpx;
  flex: 0 0 46rpx;
  margin-bottom: 1rpx;
}

.tab-item.active .tab-icon {
  transform: translateY(-2rpx) scale(1.04);
}