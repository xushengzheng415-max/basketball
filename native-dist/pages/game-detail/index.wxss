page {
  min-height: 100%;
  background: #04080b;
}

.page-wrap {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #0b151e 0%, #04080b 72%);
}

.hero {
  padding: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #fff;
  background: #101b24;
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.28);
}

.eyebrow,
.title {
  display: block;
}

.eyebrow {
  color: #f5c542;
  font-size: 22rpx;
  font-weight: 900;
}

.title {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.matchup {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 60rpx minmax(0, 1fr);
  align-items: center;
  gap: 12rpx;
  margin-top: 22rpx;
}

.match-team {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 12rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.match-team.away {
  flex-direction: row-reverse;
  text-align: right;
}

.hero-logo {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #fff;
}

.hero-vs {
  color: #ff5a1f;
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.team-section {
  margin-top: 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  color: #fff;
}

.section-team {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 29rpx;
  font-weight: 900;
}

.section-logo {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #fff;
}

.starter-count {
  color: #f5c542;
  font-size: 22rpx;
  font-weight: 800;
}

.empty,
.player-row {
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 9rpx;
  background: #fff;
}

.empty {
  color: #98a2b3;
  font-size: 25rpx;
}

.player-row {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid transparent;
}

.player-row.starter {
  border-left-color: #ff5a1f;
  background: #fff8f4;
}

.player-info {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 10rpx;
}

.player-number {
  color: #667085;
  font-size: 23rpx;
  font-weight: 900;
}

.player-name {
  overflow: hidden;
  color: #18212f;
  font-size: 26rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-tag {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: #ff5a1f;
  background: #fff0e9;
  font-size: 19rpx;
  font-weight: 800;
}

.role-actions {
  display: flex;
  flex-shrink: 0;
  gap: 8rpx;
}

.role-btn {
  display: flex;
  width: 78rpx;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  border-radius: 7rpx;
  color: #ff5a1f;
  background: #fff0e9;
  font-size: 21rpx;
  font-weight: 900;
}

.role-btn.dark {
  color: #344054;
  background: #eef1f5;
}

.role-btn.active {
  color: #fff;
  background: #ff5a1f;
}

.role-btn.active.dark {
  background: #344054;
}
