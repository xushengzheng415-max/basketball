<view class="page-wrap" wx:if="{{game}}">
  <view class="hero">
    <text class="eyebrow">{{tournament.name}}</text>
    <text class="title">{{game.name}}</text>
    <view class="matchup">
      <view class="match-team">
        <image class="hero-logo" src="{{homeTeam.logoUrl}}" mode="aspectFit" />
        <text>{{game.homeTeamName}}</text>
      </view>
      <text class="hero-vs">VS</text>
      <view class="match-team away">
        <image class="hero-logo" src="{{awayTeam.logoUrl}}" mode="aspectFit" />
        <text>{{game.awayTeamName}}</text>
      </view>
    </view>
    <view class="match-actions">
      <view class="primary-action" bindtap="startScorer">进入计分板</view>
    </view>
  </view>

  <view class="team-section">
    <view class="section-head">
      <view class="section-team">
        <image class="section-logo" src="{{homeTeam.logoUrl}}" mode="aspectFit" />
        <text>{{game.homeTeamName}}</text>
      </view>
      <text class="starter-count">首发 {{homeStarterCount}} / 5</text>
    </view>
    <view wx:if="{{homeEmpty}}" class="empty">该球队还没有球员资料。</view>
    <view wx:for="{{homeRoster}}" wx:key="id" class="{{item.roleClass}}">
      <view class="player-info">
        <text class="player-number">#{{item.number}}</text>
        <text class="player-name">{{item.name}}</text>
        <text class="role-tag">{{item.roleText}}</text>
      </view>
      <view class="role-actions">
        <view class="{{item.starterButtonClass}}" data-side="home" data-id="{{item.id}}" data-role="starter" bindtap="chooseRole">首发</view>
        <view class="{{item.benchButtonClass}}" data-side="home" data-id="{{item.id}}" data-role="bench" bindtap="chooseRole">替补</view>
      </view>
    </view>
  </view>

  <view class="team-section">
    <view class="section-head">
      <view class="section-team">
        <image class="section-logo" src="{{awayTeam.logoUrl}}" mode="aspectFit" />
        <text>{{game.awayTeamName}}</text>
      </view>
      <text class="starter-count">首发 {{awayStarterCount}} / 5</text>
    </view>
    <view wx:if="{{awayEmpty}}" class="empty">该球队还没有球员资料。</view>
    <view wx:for="{{awayRoster}}" wx:key="id" class="{{item.roleClass}}">
      <view class="player-info">
        <text class="player-number">#{{item.number}}</text>
        <text class="player-name">{{item.name}}</text>
        <text class="role-tag">{{item.roleText}}</text>
      </view>
      <view class="role-actions">
        <view class="{{item.starterButtonClass}}" data-side="away" data-id="{{item.id}}" data-role="starter" bindtap="chooseRole">首发</view>
        <view class="{{item.benchButtonClass}}" data-side="away" data-id="{{item.id}}" data-role="bench" bindtap="chooseRole">替补</view>
      </view>
    </view>
  </view>
</view>

<view class="page-wrap" wx:else>
  <view class="empty">没有找到这场比赛，请返回赛事详情重新进入。</view>
</view>
