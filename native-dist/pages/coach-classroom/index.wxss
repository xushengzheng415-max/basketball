page{background:#05080b;color:#f4f6f7;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 86% 0,rgba(255,107,0,.24),transparent 28%),#05080b}.nav{height:198rpx;padding:106rpx 28rpx 0;box-sizing:border-box;display:flex;align-items:center}.back{width:68rpx;height:68rpx;display:flex;align-items:center;font-size:62rpx}.nav-title,.nav-sub,.eyebrow,.hero-title,.hero-sub,.clock text,.current-kicker,.current-title,.current-desc,.section-head text,.module-title,.module-desc,.attendance-title,.attendance-sub{display:block}.nav-title{font-size:32rpx;font-weight:900}.nav-sub{margin-top:4rpx;color:#7d858b;font-size:19rpx}.live{margin-left:auto;padding:9rpx 13rpx;border-radius:999rpx;background:rgba(82,207,117,.12);color:#55d779;font-size:17rpx}.live text{display:inline-block;width:12rpx;height:12rpx;margin-right:7rpx;border-radius:50%;background:#55d779}.scroll{height:calc(100vh - 198rpx)}.hero{display:flex;align-items:center;margin:8rpx 28rpx 15rpx;padding:24rpx;border-radius:22rpx;background:linear-gradient(145deg,#25170d,#11171a 55%,#0b0f12);border:1rpx solid rgba(255,122,0,.58)}.hero>view:first-child{flex:1}.eyebrow{color:#ff8a19;font-size:19rpx}.hero-title{margin-top:6rpx;font-size:31rpx;font-weight:900}.hero-sub{margin-top:7rpx;color:#858d92;font-size:18rpx}.clock{width:116rpx;text-align:center}.clock text:first-child{color:#ff951e;font-size:31rpx;font-weight:900}.clock text:last-child{margin-top:4rpx;color:#7d858b;font-size:16rpx}.current-card{margin:0 28rpx 17rpx;padding:24rpx;border-radius:22rpx;background:linear-gradient(145deg,#181f23,#0b1013);border:1rpx solid rgba(255,255,255,.14);box-shadow:0 18rpx 44rpx rgba(0,0,0,.32)}.current-head{display:flex;justify-content:space-between;align-items:flex-start}.current-kicker{color:#ff8a19;font-size:18rpx}.current-title{margin-top:5rpx;font-size:30rpx;font-weight:900}.minute{padding:8rpx 12rpx;border-radius:999rpx;background:rgba(255,122,0,.13);color:#ff941d;font-size:18rpx}.current-desc{margin-top:12rpx;color:#a9afb3;font-size:20rpx;line-height:1.5}.module-meta{display:flex;gap:10rpx;margin-top:16rpx}.module-meta text{padding:7rpx 10rpx;border-radius:999rpx;background:#20262a;color:#8e969b;font-size:16rpx}.progress-track{height:8rpx;margin-top:19rpx;border-radius:999rpx;background:#30363a;overflow:hidden}.progress-value{height:100%;background:linear-gradient(90deg,#ff5b00,#ffb127)}.current-actions{display:flex;gap:12rpx;margin-top:19rpx}.pause,.complete{height:68rpx;border-radius:14rpx;display:flex;align-items:center;justify-content:center;font-size:21rpx;font-weight:800}.pause{width:210rpx;border:1rpx solid #ff7a00;color:#ff8a19}.complete{flex:1;background:linear-gradient(90deg,#ff5b00,#ff981e)}.section-head{display:flex;align-items:flex-end;justify-content:space-between;margin:0 28rpx 11rpx}.section-head>view text:first-child{font-size:27rpx;font-weight:900}.section-head>view text:last-child{margin-top:4rpx;color:#767e84;font-size:17rpx}.section-head>text{color:#ff8a19;font-size:18rpx}.module-list{margin:0 28rpx;border-radius:20rpx;background:linear-gradient(145deg,#171d21,#0b0f12);border:1rpx solid rgba(255,255,255,.11);overflow:hidden}.module{position:relative;min-height:118rpx;padding:18rpx;display:flex;align-items:center;border-top:1rpx solid rgba(255,255,255,.08)}.module:first-child{border-top:0}.module-order{position:relative;z-index:2;width:48rpx;height:48rpx;border-radius:14rpx;display:flex;align-items:center;justify-content:center;background:#292f33;color:#899196;font-weight:900}.module.active .module-order{background:linear-gradient(135deg,#ff5b00,#ff9d21);color:#fff}.module.done .module-order{background:#1f4b2d;color:#58da7b}.module-line{position:absolute;left:41rpx;top:0;bottom:0;width:2rpx;background:#363d41}.module-line.done{background:#346b43}.module-main{flex:1;margin-left:15rpx}.module-title{font-size:22rpx;font-weight:800}.module-desc{margin-top:5rpx;color:#7d858b;font-size:16rpx}.module-main>view{display:flex;gap:8rpx;margin-top:8rpx}.module-main>view text{padding:4rpx 8rpx;border-radius:999rpx;background:#21272b;color:#81898e;font-size:14rpx}.module-state{margin-left:9rpx;color:#777f84;font-size:17rpx}.module.active .module-state{color:#ff8a19}.module.done .module-state{color:#55d779}.attendance-card{display:flex;align-items:center;margin:17rpx 28rpx 0;padding:21rpx;border-radius:19rpx;background:#11171a;border:1rpx solid rgba(255,122,0,.35)}.attendance-card>view:first-child{flex:1}.attendance-title{font-size:23rpx;font-weight:800}.attendance-sub{margin-top:5rpx;color:#7c848a;font-size:17rpx}.avatars{display:flex;align-items:center}.avatars image{width:52rpx;height:52rpx;margin-left:-13rpx;border-radius:50%;border:3rpx solid #151a1e}.avatars text{margin-left:8rpx;color:#ff8a19;font-size:18rpx}.safe{height:140rpx}.footer{position:fixed;z-index:5;left:0;right:0;bottom:0;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:rgba(7,10,12,.97);border-top:1rpx solid rgba(255,255,255,.1)}.finish{height:80rpx;border-radius:17rpx;display:flex;align-items:center;justify-content:center;background:linear-gradient(90deg,#ff5b00,#ff9a20);font-size:24rpx;font-weight:900}.finish.disabled{background:#242a2e;color:#747c82}.finish.ready{box-shadow:0 0 28rpx rgba(255,118,0,.24)}
