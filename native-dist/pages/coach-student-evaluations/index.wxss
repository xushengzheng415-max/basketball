page{background:#05080b;color:#f6f7f8;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 84% 0,rgba(255,110,0,.22),transparent 27%),#05080b}.nav{height:202rpx;padding:106rpx 210rpx 0 30rpx;display:flex;align-items:center;box-sizing:border-box}.back{width:70rpx;height:70rpx;display:flex;align-items:center;font-size:62rpx;line-height:1}.nav-title,.nav-sub,.eyebrow,.hero-title,.hero-copy,.section-title,.section-sub,.lesson,.date,.topic,.summary{display:block}.nav-title{font-size:32rpx;font-weight:900}.nav-sub{margin-top:4rpx;color:#7c858b;font-size:18rpx}.scroll{height:calc(100vh - 202rpx)}.hero{margin:8rpx 28rpx 16rpx;padding:24rpx;display:flex;align-items:center;border:1rpx solid rgba(255,122,0,.45);border-radius:22rpx;background:linear-gradient(140deg,rgba(255,122,0,.14),#11181c 48%,#080c0f)}.hero>view:first-child{flex:1}.eyebrow{color:#ff8a19;font-size:19rpx}.hero-title{margin-top:7rpx;font-size:31rpx;font-weight:900}.hero-copy{margin-top:7rpx;color:#899198;font-size:18rpx}.overall{width:104rpx;height:104rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;border:8rpx solid #ff7a00;border-left-color:#343b40;border-radius:50%}.overall text:first-child{font-size:29rpx;font-weight:900}.overall text:last-child{margin-top:2rpx;color:#969da2;font-size:15rpx}.summary-grid{display:grid;grid-template-columns:repeat(3,1fr);margin:0 28rpx 22rpx;border:1rpx solid rgba(255,255,255,.11);border-radius:18rpx;background:#11171b}.summary-grid view{padding:18rpx;text-align:center;border-right:1rpx solid rgba(255,255,255,.08)}.summary-grid view:last-child{border-right:0}.summary-grid text{display:block}.summary-grid text:first-child{color:#ff8a19;font-size:29rpx;font-weight:900}.summary-grid text:last-child{margin-top:5rpx;color:#80898f;font-size:17rpx}.section-head{margin:0 30rpx 13rpx;display:flex;align-items:center;justify-content:space-between}.section-title{font-size:28rpx;font-weight:900}.section-sub{margin-top:5rpx;color:#747d83;font-size:18rpx}.count{color:#ff8a19;font-size:18rpx}.review-card{margin:0 28rpx 17rpx;padding:22rpx;border:1rpx solid rgba(255,255,255,.11);border-radius:21rpx;background:linear-gradient(145deg,#171d21,#0a0e11)}.review-head{display:flex;align-items:flex-start;justify-content:space-between}.lesson{font-size:25rpx;font-weight:900}.date{margin-top:5rpx;color:#778086;font-size:17rpx}.score{text-align:right}.score text{display:block}.score text:first-child{color:#ff8a19;font-size:28rpx;font-weight:900}.score text:last-child{margin-top:2rpx;color:#ff9a22;font-size:18rpx;letter-spacing:2rpx}.topic{margin-top:16rpx;font-size:23rpx;font-weight:800}.summary{margin-top:9rpx;color:#a2a9ae;font-size:18rpx;line-height:1.58}.tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:13rpx}.tags text{padding:6rpx 10rpx;border-radius:999rpx;background:rgba(255,122,0,.12);color:#ff9323;font-size:16rpx}.review-foot{display:flex;align-items:center;justify-content:space-between;margin-top:16rpx;padding-top:14rpx;border-top:1rpx solid rgba(255,255,255,.08);color:#737c82;font-size:16rpx}.review-foot text:last-child{color:#ff8a19;font-size:18rpx}.safe{height:44rpx}
