<view class="page"><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="title has-back"><text class="back" bindtap="goBack">‹</text>课堂点名</view><view class="subtitle">U10提高班　18:30–20:00</view>
  <view class="stats"><view><text>♙　应到</text><text class="strong">12<text class="small">人</text></text></view><view><text>✓　到课</text><text class="strong">{{presentCount}}<text class="small">人</text></text></view><view><text>▤　请假</text><text class="strong">{{leaveCount}}<text class="small">人</text></text></view><view><text>!　缺勤</text><text class="strong">{{absentCount}}<text class="small">人</text></text></view></view>
  <view class="notice">♧　缺勤与异常将同步负责人</view>
  <view class="student" wx:for="{{students}}" wx:key="id"><text class="index">{{index + 1}}</text><image src="{{item.avatar}}" mode="aspectFill"/><view class="student-main"><text class="name">{{item.name}}</text><text class="number">#{{item.number}}</text></view><view class="actions"><text class="action {{item.presentClass}}" data-id="{{item.id}}" data-status="present" bindtap="onStatus">✓ 到课</text><text class="action {{item.leaveClass}}" data-id="{{item.id}}" data-status="leave" bindtap="onStatus">▤ 请假</text><text class="action {{item.absentClass}}" data-id="{{item.id}}" data-status="absent" bindtap="onStatus">! 缺勤</text></view><text wx:if="{{item.showRecord}}" class="record">记录情况　›</text></view>
  <view class="safe"></view></scroll-view><view class="footer"><view class="draft">暂存</view><view class="primary" bindtap="confirm">完成点名</view></view></view>
