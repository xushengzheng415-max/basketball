<view class="page"><view class="nav"><view class="back" bindtap="goBack"><text>‹</text></view><view><text class="nav-title">课堂点名</text><text class="nav-sub">U10提高班 · 18:30</text></view><view class="all" bindtap="markAll">全部到课</view></view><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}">
<view class="hero"><view><text class="eyebrow">点名进度</text><text class="title">已处理 {{presentCount}} / 5 人</text><text class="sub">到课与补课将计入本节课课消</text></view><view class="progress"><view class="ring"><text>{{consumeCount}}</text><text class="ring-label">计课消</text></view></view></view>
<view class="stats"><view><text class="stat-value">{{presentCount}}</text><text class="stat-label">到课</text></view><view><text class="stat-value">{{leaveCount}}</text><text class="stat-label">请假</text></view><view><text class="stat-value">{{absentCount}}</text><text class="stat-label">缺勤</text></view><view><text class="stat-value">{{makeupCount}}</text><text class="stat-label">补课</text></view></view>
<view class="notice">请先核对请假和补课学员，确认后系统将生成不可直接删除的课时流水。</view>
<view class="student-card" wx:for="{{students}}" wx:key="id"><image src="{{item.avatar}}" mode="aspectFill"/><view class="student-info"><text class="name">{{item.name}}　#{{item.number}}</text><text class="package">{{item.package}}</text></view><view class="status-row"><text class="status {{item.presentClass}}" data-id="{{item.id}}" data-status="present" bindtap="onStatus">到课</text><text class="status {{item.leaveClass}}" data-id="{{item.id}}" data-status="leave" bindtap="onStatus">请假</text><text class="status {{item.absentClass}}" data-id="{{item.id}}" data-status="absent" bindtap="onStatus">缺勤</text><text class="status {{item.makeupClass}}" data-id="{{item.id}}" data-status="makeup" bindtap="onStatus">补课</text></view></view>
<view class="consume"><view><text class="consume-title">本节课课消预览</text><text class="sub">正常到课与补课各扣1课时，请假不扣课</text></view><view><text class="consume-value">{{consumeCount}}</text><text class="consume-unit">人次</text></view></view><view class="safe"></view></scroll-view><view class="footer"><view class="confirm" bindtap="confirm">确认点名并开始上课</view></view></view>
