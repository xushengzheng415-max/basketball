page{background:#05080b;color:#f6f7f8;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 80% 0,rgba(255,115,0,.2),transparent 27%),#05080b}.nav{height:200rpx;padding:106rpx 30rpx 0;display:flex;align-items:center}.back{width:68rpx;font-size:62rpx}.nav-title,.nav-sub,.eyebrow,.title,.sub,.name,.package,.consume-title{display:block}.nav-title{font-size:32rpx;font-weight:800}.nav-sub{margin-top:4rpx;color:#81898f;font-size:19rpx}.all{margin-left:auto;transform:translateY(70rpx);padding:10rpx 18rpx;border:1rpx solid #ff7a00;border-radius:13rpx;color:#ff8a19;font-size:20rpx}.scroll{height:calc(100vh - 200rpx)}.hero{display:flex;align-items:center;margin:8rpx 28rpx 16rpx;padding:26rpx;border:1rpx solid rgba(255,122,0,.55);border-radius:22rpx;background:linear-gradient(145deg,#191f23,#0b0f12)}.hero>view:first-child{flex:1}.eyebrow{color:#ff8a19;font-size:21rpx}.title{margin-top:6rpx;font-size:32rpx;font-weight:800}.sub{margin-top:7rpx;color:#848c92;font-size:19rpx}.ring{width:106rpx;height:106rpx;border-radius:50%;border:10rpx solid #ff7a00;border-left-color:#353c40;display:flex;flex-direction:column;align-items:center;justify-content:center}.ring>text:first-child{font-size:31rpx;font-weight:800}.ring-label{font-size:17rpx;color:#90979c}.stats{display:grid;grid-template-columns:repeat(4,1fr);margin:0 28rpx 16rpx;border-radius:18rpx;background:#12181c;border:1rpx solid rgba(255,255,255,.1)}.stats view{text-align:center;padding:18rpx 4rpx;border-right:1rpx solid rgba(255,255,255,.09)}.stats view:last-child{border:0}.stat-value,.stat-label{display:block}.stat-value{color:#ff8a19;font-size:31rpx;font-weight:800}.stat-label{margin-top:4rpx;color:#7f878d;font-size:18rpx}.notice{margin:0 28rpx 16rpx;padding:16rpx 20rpx;border-radius:14rpx;background:rgba(255,177,25,.09);color:#d0a953;font-size:19rpx;line-height:1.5}.student-card{margin:0 28rpx 14rpx;padding:20rpx;display:grid;grid-template-columns:70rpx 1fr;column-gap:16rpx;border-radius:20rpx;background:linear-gradient(145deg,#171d21,#0c1013);border:1rpx solid rgba(255,255,255,.11)}.student-card image{width:70rpx;height:70rpx;border-radius:50%;border:2rpx solid #ff7a00}.student-info{align-self:center}.name{font-size:24rpx;font-weight:800}.package{margin-top:5rpx;color:#81898f;font-size:19rpx}.status-row{grid-column:1/3;display:grid;grid-template-columns:repeat(4,1fr);gap:10rpx;margin-top:16rpx}.status{padding:10rpx 0;text-align:center;border-radius:12rpx;background:#22282c;color:#899197;font-size:19rpx}.status.selected{background:linear-gradient(90deg,#ff5d00,#ff9420);color:#fff;font-weight:700}.consume{margin:0 28rpx 16rpx;padding:22rpx;display:flex;align-items:center;justify-content:space-between;border-radius:20rpx;background:#12181c;border:1rpx solid rgba(255,122,0,.45)}.consume-title{font-size:24rpx;font-weight:800}.consume>view:last-child{text-align:right}.consume-value{color:#ff8a19;font-size:38rpx;font-weight:800}.consume-unit{margin-left:6rpx;color:#92999f}.safe{height:135rpx}.footer{position:fixed;z-index:5;left:0;right:0;bottom:0;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:rgba(7,10,12,.97);border-top:1rpx solid rgba(255,255,255,.1)}.confirm{height:80rpx;border-radius:17rpx;background:linear-gradient(90deg,#ff5b00,#ff9a20);display:flex;align-items:center;justify-content:center;font-size:25rpx;font-weight:800}

.back{height:70rpx;display:flex;align-items:center;justify-content:flex-start;line-height:1}
