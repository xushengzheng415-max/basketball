page{background:#05090c;color:#f6f6f6}.page{min-height:100vh;background:linear-gradient(145deg,#070b0e,#05090b)}.scroll{height:calc(100vh - 126rpx);padding:60rpx 34rpx 0;box-sizing:border-box}.title{font-size:48rpx;font-weight:900}.subtitle{color:#a6a9ad;font-size:25rpx;margin:12rpx 0 30rpx}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12rpx}.stats>view{height:118rpx;border:1rpx solid #3b4045;border-radius:15rpx;background:linear-gradient(145deg,#1c2226,#12171a);padding:16rpx;box-sizing:border-box}.stats text{display:block;color:#b9bbbe;font-size:21rpx}.stats .strong{display:block;color:#ff7800;font-size:42rpx;margin-top:8rpx}.stats .small{font-size:20rpx;color:#b7b7b7;font-weight:400;margin-left:5rpx}.notice{margin:20rpx 0;padding:18rpx 22rpx;border-radius:12rpx;background:rgba(255,120,0,.12);color:#ff8a17;font-size:23rpx}.student{position:relative;min-height:98rpx;border:1rpx solid #353a3e;border-radius:15rpx;background:linear-gradient(135deg,#1b2024,#12171a);display:flex;align-items:center;padding:12rpx 16rpx;margin-bottom:8rpx;box-sizing:border-box}.student .index{width:34rpx;font-size:24rpx}.student image{width:66rpx;height:66rpx;border:2rpx solid #ff7800;border-radius:50%;margin-right:18rpx}.student-main{width:140rpx}.name,.number{display:block}.name{font-size:27rpx;font-weight:800}.number{font-size:19rpx;color:#aaa}.actions{display:flex;gap:8rpx;flex:1}.action{height:54rpx;min-width:92rpx;border-radius:10rpx;background:#292e32;color:#aeb1b4;display:flex;align-items:center;justify-content:center;font-size:21rpx}.action.selected{background:linear-gradient(100deg,#ff6800,#ff8c1b);color:#fff}.record{position:absolute;right:18rpx;bottom:3rpx;color:#ff850d;font-size:18rpx}.safe{height:40rpx}.footer{height:126rpx;display:flex;gap:20rpx;align-items:center;padding:18rpx 34rpx calc(18rpx + env(safe-area-inset-bottom));box-sizing:border-box;background:#070b0e;border-top:1rpx solid #252a2e}.draft,.primary{height:78rpx;border-radius:15rpx;display:flex;align-items:center;justify-content:center;font-size:29rpx;font-weight:800}.draft{width:280rpx;border:2rpx solid #ff7800;color:#ff7800}.primary{flex:1;background:linear-gradient(100deg,#ff6500,#ff8f1d)}

.title.has-back{display:flex;align-items:center;gap:18rpx}.title .back{font-size:58rpx;font-weight:400;line-height:1}
