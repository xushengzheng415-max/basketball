.colon {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
  width: 26rpx;
  height: 132rpx;
  margin: 0 4rpx;
}
.colon text {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff6a00;
  box-shadow: 0 0 16rpx rgba(255,106,0,.64);
}
.colon.mini {
  gap: 8rpx;
  width: 10rpx;
  height: 44rpx;
  margin: 0 2rpx;
}
.colon.mini text { width: 5rpx; height: 5rpx; }

.score-page > .mc-panel {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1.05fr 1.15fr 1fr 128rpx;
  gap: 16rpx;
  height: 122rpx;
  margin: 0 20rpx 10rpx;
  padding: 12rpx;
  border-radius: 14rpx;
}
.mc-section { min-width: 0; }
.voice-grid,
.sound-grid,
.key-grid {
  display: grid;
  gap: 8rpx;
}
.voice-grid { grid-template-columns: repeat(4, minmax(0,1fr)); }
.sound-grid { grid-template-columns: repeat(6, minmax(0,1fr)); }
.key-grid { grid-template-columns: repeat(3, minmax(0,1fr)); }
.voice-chip,
.voice-now,
.sound-btn,
.key-grid view {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 34rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,.08);
  color: #fff;
  font-size: 18rpx;
  font-weight: 900;
}
.sound-btn image { display: none; }
.playing-text,
.key-head {
  display: flex;
  justify-content: space-between;
  margin-top: 6rpx;
  color: rgba(255,255,255,.68);
  font-size: 18rpx;
  font-weight: 800;
}
.mc-settings {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: linear-gradient(180deg,#ff7a00,#f24800);
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}
.mc-settings text { display: block; }

