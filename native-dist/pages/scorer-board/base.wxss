page { width: 100%; height: 100%; background: #050607; }
.setup-page, .score-page { position: relative; min-height: 100vh; color: #fff; background: #050607; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
.setup-bg, .score-bg { position: fixed; inset: 0; width: 100%; height: 100%; opacity: 0.96; }
.setup-bg { z-index: 0; opacity: 1; }
.setup-mask { position: fixed; inset: 0; z-index: 0; background: linear-gradient(180deg, rgba(0,0,0,.12), rgba(0,0,0,.04) 55%, rgba(0,0,0,0)); pointer-events: none; }
.setup-nav { position: relative; z-index: 2; height: 124rpx; display: flex; align-items: center; padding: 58rpx 30rpx 0; box-sizing: border-box; }
.setup-back { width: 58rpx; height: 58rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255,255,255,.28); border-radius: 30rpx; background: rgba(0,0,0,.46); color: #fff; font-size: 44rpx; font-weight: 900; line-height: 1; }
.setup-card { position: relative; z-index: 2; margin: 34rpx 34rpx 0; padding: 28rpx; border: 1rpx solid rgba(255,106,0,.62); border-radius: 18rpx; background: rgba(8,10,12,.88); box-shadow: 0 20rpx 50rpx rgba(0,0,0,.36); }
.setup-title-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 24rpx; }
.setup-eyebrow, .setup-title, .setup-desc, .setup-field text { display: block; }
.setup-eyebrow { color: #ff7a00; font-size: 22rpx; font-weight: 900; }
.setup-title { margin-top: 8rpx; font-size: 42rpx; font-weight: 900; }
.setup-desc { margin-top: 8rpx; color: rgba(255,255,255,.7); font-size: 24rpx; }
.setup-start { flex-shrink: 0; min-width: 150rpx; padding: 20rpx 24rpx; border-radius: 14rpx; background: linear-gradient(180deg,#ff7a00,#f24800); color: #fff; text-align: center; font-size: 28rpx; font-weight: 900; }
.setup-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; margin-top: 28rpx; }
.setup-field { min-width: 0; }
.setup-field.wide { grid-column: span 2; }
.setup-field > text { margin-bottom: 10rpx; color: #f5f7fb; font-size: 24rpx; font-weight: 900; }
.setup-field input { height: 72rpx; box-sizing: border-box; padding: 0 20rpx; border: 1rpx solid rgba(255,255,255,.16); border-radius: 12rpx; color: #101820; background: rgba(255,255,255,.96); font-size: 28rpx; }
.setup-team-source { display: grid; grid-template-columns: 1fr 1fr; gap: 8rpx; margin-bottom: 8rpx; }
.setup-team-source > view { display: flex; align-items: center; justify-content: center; height: 42rpx; border: 1rpx solid rgba(255,255,255,.14); border-radius: 8rpx; color: rgba(255,255,255,.62); background: rgba(255,255,255,.05); font-size: 20rpx; font-weight: 800; }
.setup-team-source > view.active { border-color: #ff6410; color: #fff; background: rgba(255,100,16,.22); }
.stepper, .mode-row, .preset-row { display: flex; align-items: center; gap: 12rpx; }
.stepper view, .stepper text, .mode, .preset { display: flex; align-items: center; justify-content: center; border-radius: 10rpx; background: rgba(255,255,255,.1); color: #fff; font-weight: 900; }
.stepper view { width: 62rpx; height: 62rpx; background: #263548; }
.stepper text { flex: 1; height: 62rpx; }
.preset-row { margin-top: 12rpx; }
.preset { flex: 1; height: 48rpx; font-size: 22rpx; }
.mode { flex: 1; height: 64rpx; }
.mode.active, .preset.active { background: #ff5a1f; }

.score-topbar, .main-board, .bottom-panels, .three-progress { position: relative; z-index: 1; }
.score-topbar { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; height: 94rpx; padding: 16rpx 28rpx 10rpx; box-sizing: border-box; }
.top-left, .top-center, .top-actions { display: flex; align-items: center; min-width: 0; }
.top-left { gap: 18rpx; }
.top-center { flex: 1; justify-content: center; gap: 24rpx; font-size: 32rpx; font-weight: 900; }
.top-actions { justify-content: flex-end; gap: 14rpx; }
.round-icon { display: flex; align-items: center; justify-content: center; min-width: 62rpx; height: 62rpx; padding: 0 14rpx; border: 1rpx solid rgba(255,255,255,.3); border-radius: 999rpx; background: rgba(0,0,0,.48); color: #fff; font-size: 25rpx; font-weight: 900; box-sizing: border-box; }
.top-left .round-icon { width: 62rpx; padding: 0; font-size: 54rpx; line-height: 1; }
.score-title { font-size: 36rpx; font-weight: 900; white-space: nowrap; }
.live-badge { padding: 8rpx 18rpx; border-radius: 10rpx; background: linear-gradient(180deg,#ff4b4b,#db1d1d); box-shadow: 0 0 14rpx rgba(255,0,0,.45); font-size: 28rpx; }
.match-title { white-space: nowrap; }
.period-text, .orange, .number { color: #ff6a00; }
.top-clock { font-family: DIN Alternate, Arial, sans-serif; font-size: 42rpx; }
.top-next { font-size: 44rpx; }
.status-pill { display: flex; align-items: center; height: 54rpx; padding: 0 22rpx; border: 1rpx solid rgba(255,255,255,.25); border-radius: 999rpx; background: rgba(0,0,0,.42); color: #fff; font-size: 24rpx; font-weight: 800; white-space: nowrap; }

.main-board { display: grid; box-sizing: border-box; }
.lineup-shell, .drawer-panel, .team-panel, .center-panel, .tech-panel, .mc-panel, .bottom-recent { box-sizing: border-box; border: 1rpx solid rgba(255,106,0,.74); background: linear-gradient(180deg,rgba(18,22,25,.92),rgba(4,6,8,.9)); box-shadow: 0 12rpx 34rpx rgba(0,0,0,.34); }
.lineup-shell { position: relative; display: flex; gap: 0; border: 0; background: transparent; box-shadow: none; }
.drawer-panel { border-radius: 14rpx; overflow: hidden; }
.drawer-panel.starters { padding: 16rpx 14rpx; }
.drawer-panel.bench { display: flex; flex-direction: column; gap: 10rpx; padding: 14rpx 16rpx; color: rgba(255,255,255,.76); font-size: 20rpx; }
.drawer-title { display: block; margin-bottom: 14rpx; color: #f3f4f6; font-size: 24rpx; font-weight: 900; }
.player-card { display: flex; align-items: center; justify-content: space-between; min-height: 118rpx; margin-bottom: 12rpx; padding: 10rpx 12rpx; border: 1rpx solid rgba(255,255,255,.18); border-radius: 10rpx; background: rgba(255,255,255,.06); }
.player-card image { width: 74rpx; height: 74rpx; border-radius: 50%; }
.player-copy { min-width: 0; }
.number, .player-name, .position { display: block; }
.number { font-size: 25rpx; font-weight: 900; }
.player-name { margin-top: 2rpx; color: #fff; font-size: 24rpx; font-weight: 900; }
.position { margin-top: 2rpx; color: #d1d5db; font-size: 21rpx; font-weight: 700; }
.drawer-handle { display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255,106,0,.9); background: linear-gradient(180deg,#ff8a00,#9a3d00); color: #fff; font-size: 28rpx; font-weight: 900; box-shadow: 0 0 18rpx rgba(255,106,0,.28); }
.drawer-handle text { display: block; }

.team-panel { padding: 26rpx 28rpx 24rpx; border-radius: 16rpx; text-align: center; }
.team-head { display: flex; align-items: center; justify-content: center; gap: 18rpx; min-height: 96rpx; }
.team-logo { width: 90rpx; height: 90rpx; }
.team-name { font-size: 40rpx; font-weight: 900; white-space: nowrap; }
.big-score { display: block; margin-top: 8rpx; font-family: Impact, DIN Alternate, Arial Black, sans-serif; font-size: 188rpx; line-height: .86; letter-spacing: 4rpx; color: #ff6500; font-weight: 900; text-shadow: 0 0 28rpx rgba(255,102,0,.45); }
.away .big-score { color: #f5f5f5; text-shadow: 0 0 22rpx rgba(255,255,255,.22); }
.pulse { animation: scorePulse .42s ease-out; }
@keyframes scorePulse { 0%{transform:scale(1)}45%{transform:scale(1.14)}100%{transform:scale(1)} }
.team-meta { display: grid; grid-template-columns: 1fr 1rpx 1fr; align-items: center; margin: 18rpx 0 22rpx; padding: 16rpx 0; border: 1rpx solid rgba(255,255,255,.18); border-radius: 12rpx; background: rgba(0,0,0,.24); }
.team-meta view { min-width: 0; }
.team-meta text { display: block; color: #d9d9d9; font-size: 24rpx; font-weight: 700; }
.team-meta .orange { margin-top: 2rpx; color: #ff6a00; font-size: 42rpx; font-weight: 900; }
.meta-line { width: 1rpx; height: 58rpx; background: rgba(255,255,255,.18); }
.score-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx; }
.score-actions > view { display: flex; align-items: center; justify-content: center; min-height: 96rpx; border-radius: 10rpx; font-size: 43rpx; font-weight: 900; }
.home-actions > view { color: #fff; background: linear-gradient(180deg,#ff7b12,#f24800); }
.away-actions > view { color: #0b0b0b; background: linear-gradient(180deg,#fff,#e5e5e5); }
.score-actions .score-plus-one { grid-column: span 3; min-height: 140rpx; font-size: 76rpx; }
.score-actions .small-action { flex-direction: column; gap: 8rpx; min-height: 104rpx; font-size: 24rpx; }
.score-actions .small-action text:first-child { font-size: 34rpx; line-height: 1; }

.center-panel { padding: 20rpx 22rpx; border-radius: 16rpx; text-align: center; }
.quarter-row { display: flex; align-items: center; justify-content: center; gap: 26rpx; }
.quarter-row view { display: flex; align-items: center; justify-content: center; min-width: 58rpx; min-height: 58rpx; color: #d7d7d7; font-size: 42rpx; font-weight: 900; }
.quarter-row .quarter-box { min-width: 128rpx; border: 1rpx solid rgba(255,255,255,.25); border-radius: 10rpx; color: #ff6a00; background: rgba(0,0,0,.35); font-size: 42rpx; }
.main-clock { display: block; margin-top: 8rpx; font-family: Impact, DIN Alternate, Arial Black, sans-serif; font-size: 118rpx; line-height: 1; letter-spacing: 4rpx; color: #f8f8f8; text-shadow: 0 0 18rpx rgba(255,255,255,.28); }
.center-actions, .period-step-row { display: grid; gap: 14rpx; margin-top: 18rpx; }
.center-actions { grid-template-columns: 1.35fr .9fr; }
.period-step-row { grid-template-columns: 1fr .72fr 1fr; }
.center-actions view, .period-step-row view, .swap-btn { display: flex; align-items: center; justify-content: center; min-height: 78rpx; border-radius: 10rpx; background: linear-gradient(180deg,#24282d,#101316); color: #fff; font-size: 28rpx; font-weight: 900; }
.center-actions .primary { background: linear-gradient(180deg,#ff7b12,#f24800); }
.swap-btn { flex-direction: column; gap: 8rpx; min-height: 124rpx; margin-top: 18rpx; border: 1rpx solid rgba(255,106,0,.78); background: linear-gradient(180deg,rgba(255,106,0,.92),rgba(118,48,0,.88)); }
.swap-btn text:first-child { font-size: 36rpx; }
.swap-btn text:last-child { color: rgba(255,255,255,.78); font-size: 22rpx; font-weight: 700; }
.recent-list { color: #e5e7eb; font-size: 22rpx; text-align: left; }
.recent-head, .event-row { display: grid; grid-template-columns: 1fr 1.1fr .9fr .8fr; gap: 10rpx; align-items: center; min-height: 42rpx; border-bottom: 1rpx solid rgba(255,255,255,.1); }
.recent-head { color: #fff; font-size: 26rpx; font-weight: 900; }
.event-row text:nth-child(2), .event-row text:nth-child(3), .event-row text:nth-child(4) { color: #ff6a00; font-weight: 900; }

.bottom-panels { display: grid; gap: 20rpx; box-sizing: border-box; }
.panel-title { display: flex; align-items: center; gap: 12rpx; margin-bottom: 14rpx; font-size: 32rpx; font-weight: 900; }
.panel-title text:first-child { width: 7rpx; height: 38rpx; border-radius: 999rpx; background: #ff6a00; }
.tech-panel, .mc-panel, .bottom-recent { border-radius: 14rpx; padding: 18rpx; }
.tech-panel { display: grid; grid-template-columns: repeat(6, 1fr); gap: 18rpx; }
.tech-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12rpx; min-height: 124rpx; border: 1rpx solid rgba(255,255,255,.15); border-radius: 10rpx; background: linear-gradient(180deg,rgba(255,255,255,.1),rgba(255,255,255,.04)); color: #fff; font-size: 30rpx; font-weight: 900; }
.tech-btn image { width: 52rpx; height: 52rpx; }
.mc-actions { display: grid; grid-template-columns: repeat(6, 1fr); gap: 14rpx; }
.mc-actions view { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; min-height: 96rpx; border: 1rpx solid rgba(255,255,255,.15); border-radius: 10rpx; background: rgba(255,255,255,.06); color: #fff; font-size: 24rpx; font-weight: 900; }
.mc-actions .active { border-color: #ff6a00; background: linear-gradient(180deg,rgba(255,106,0,.34),rgba(255,106,0,.08)); }
.mc-footer { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; margin-top: 18rpx; padding-top: 14rpx; border-top: 1rpx solid rgba(255,255,255,.12); font-size: 25rpx; font-weight: 800; }
.volume-row { display: flex; align-items: center; gap: 12rpx; min-width: 420rpx; }
.volume-row slider { flex: 1; }
.volume-row view { display: flex; align-items: center; justify-content: center; min-width: 150rpx; height: 58rpx; border-radius: 8rpx; background: rgba(255,255,255,.12); }
.three-progress { position: fixed; left: 50%; top: 92rpx; transform: translateX(-50%); z-index: 10; width: 420rpx; padding: 12rpx; border-radius: 12rpx; background: rgba(0,0,0,.72); text-align: center; }
.progress-track { height: 10rpx; margin-top: 8rpx; border-radius: 999rpx; background: rgba(255,255,255,.18); overflow: hidden; }
.progress-bar { height: 100%; background: #ff6a00; }

.landscape { min-height: 100vh; }
.landscape .main-board { grid-template-columns: 174rpx 82rpx minmax(260rpx, 1fr) minmax(300rpx, 1.12fr) minmax(260rpx, 1fr) 82rpx 174rpx; gap: 14rpx; padding: 10rpx 10rpx 0; }
.landscape .lineup-shell.left { display: grid; grid-template-columns: 174rpx 82rpx; grid-template-rows: 1fr 214rpx; grid-column: 1 / 3; grid-row: 1; }
.landscape .lineup-shell.right { display: grid; grid-template-columns: 82rpx 174rpx; grid-template-rows: 1fr 214rpx; grid-column: 6 / 8; grid-row: 1; }
.landscape .lineup-shell.left .starters { grid-column: 1; grid-row: 1 / 3; }
.landscape .lineup-shell.left .drawer-handle { grid-column: 2; grid-row: 1; border-radius: 0 18rpx 18rpx 0; writing-mode: vertical-rl; letter-spacing: 2rpx; }
.landscape .lineup-shell.left .bench { grid-column: 2; grid-row: 2; border-radius: 12rpx; }
.landscape .lineup-shell.right .drawer-handle { grid-column: 1; grid-row: 1; border-radius: 18rpx 0 0 18rpx; writing-mode: vertical-rl; letter-spacing: 2rpx; }
.landscape .lineup-shell.right .starters { grid-column: 2; grid-row: 1 / 3; }
.landscape .lineup-shell.right .bench { grid-column: 1; grid-row: 2; border-radius: 12rpx; }
.landscape .team-panel.home { grid-column: 3; }
.landscape .center-panel { grid-column: 4; }
.landscape .team-panel.away { grid-column: 5; }
.landscape .bottom-panels { grid-template-columns: 1.15fr 1fr; padding: 20rpx 112rpx 18rpx; }
.landscape .bottom-panels > .panel-title { grid-column: 1; margin: 0 0 -8rpx; }
.landscape .tech-panel { grid-column: 1; }
.landscape .mc-panel { grid-column: 2; grid-row: 1 / 3; }
.landscape .bottom-recent { display: none; }
.landscape .center-recent { margin-top: 18rpx; }

.portrait { min-height: 100vh; overflow-y: auto; }
.portrait .score-topbar { height: 136rpx; padding: 18rpx 28rpx 10rpx; flex-wrap: wrap; }
.portrait .top-left { width: 100%; justify-content: space-between; }
.portrait .score-title { font-size: 38rpx; }
.portrait .top-center { order: 3; flex: 1 1 100%; gap: 18rpx; font-size: 30rpx; }
.portrait .top-actions { position: absolute; top: 24rpx; right: 28rpx; }
.portrait .status-pill { display: none; }
.portrait .main-board { grid-template-columns: 88rpx 1fr 220rpx 1fr 88rpx; grid-template-rows: auto auto; gap: 0; padding: 0 0 0; }
.portrait .lineup-shell.left { grid-column: 1; grid-row: 1; flex-direction: column; }
.portrait .lineup-shell.right { grid-column: 5; grid-row: 1; flex-direction: column; }
.portrait .lineup-shell .starters { width: 88rpx; max-height: 690rpx; padding: 8rpx 6rpx; border-radius: 0 10rpx 10rpx 0; }
.portrait .lineup-shell.right .starters { border-radius: 10rpx 0 0 10rpx; }
.portrait .drawer-title { margin-bottom: 6rpx; font-size: 16rpx; text-align: center; }
.portrait .player-card { flex-direction: column-reverse; min-height: 124rpx; margin-bottom: 8rpx; padding: 6rpx 4rpx; text-align: center; }
.portrait .player-card image { width: 48rpx; height: 48rpx; }
.portrait .number { font-size: 18rpx; }
.portrait .player-name { font-size: 16rpx; }
.portrait .position { font-size: 14rpx; }
.portrait .drawer-handle { position: absolute; top: 128rpx; width: 58rpx; height: 222rpx; writing-mode: vertical-rl; border-radius: 0 18rpx 18rpx 0; font-size: 24rpx; }
.portrait .lineup-shell.left .drawer-handle { left: 86rpx; }
.portrait .lineup-shell.right .drawer-handle { right: 86rpx; border-radius: 18rpx 0 0 18rpx; }
.portrait .lineup-shell .bench { width: 88rpx; margin-top: 6rpx; padding: 10rpx 6rpx; font-size: 16rpx; }
.portrait .team-panel { min-height: 680rpx; padding: 16rpx 10rpx; border-radius: 0; }
.portrait .team-panel.home { grid-column: 2; grid-row: 1; }
.portrait .team-panel.away { grid-column: 4; grid-row: 1; }
.portrait .team-head { flex-direction: column; min-height: 116rpx; gap: 6rpx; }
.portrait .team-logo { width: 86rpx; height: 86rpx; }
.portrait .team-name { font-size: 30rpx; }
.portrait .big-score { margin-top: 4rpx; font-size: 150rpx; letter-spacing: 0; }
.portrait .team-meta { margin: 12rpx 0 18rpx; }
.portrait .team-meta text { font-size: 20rpx; }
.portrait .team-meta .orange { font-size: 38rpx; }
.portrait .score-actions { gap: 10rpx; }
.portrait .score-actions > view { min-height: 88rpx; font-size: 38rpx; }
.portrait .score-actions .score-plus-one { min-height: 140rpx; font-size: 72rpx; }
.portrait .score-actions .small-action { min-height: 86rpx; font-size: 24rpx; }
.portrait .center-panel { grid-column: 3; grid-row: 1; padding: 12rpx 10rpx; border-radius: 0; }
.portrait .quarter-row { gap: 12rpx; }
.portrait .quarter-row view { min-width: 44rpx; min-height: 48rpx; font-size: 34rpx; }
.portrait .quarter-row .quarter-box { min-width: 108rpx; font-size: 36rpx; }
.portrait .main-clock { font-size: 72rpx; letter-spacing: 1rpx; }
.portrait .center-actions { grid-template-columns: 1fr; gap: 12rpx; }
.portrait .period-step-row { grid-template-columns: 1fr; gap: 10rpx; }
.portrait .center-actions view, .portrait .period-step-row view { min-height: 70rpx; font-size: 26rpx; }
.portrait .swap-btn { min-height: 120rpx; }
.portrait .swap-btn text:first-child { font-size: 30rpx; }
.portrait .center-recent { display: none; }
.portrait .bottom-panels { grid-template-columns: 1fr; padding: 22rpx 32rpx 48rpx; }
.portrait .tech-panel { grid-template-columns: repeat(6, 1fr); gap: 14rpx; }
.portrait .tech-btn { min-height: 108rpx; font-size: 26rpx; }
.portrait .mc-actions { grid-template-columns: repeat(6, 1fr); }
.portrait .mc-footer { flex-direction: column; align-items: stretch; }
.portrait .volume-row { min-width: 0; }

@media (max-width: 700px) {
  .landscape .main-board { grid-template-columns: 92rpx 42rpx 1fr 180rpx 1fr 42rpx 92rpx; gap: 4rpx; padding: 0 4rpx; }
  .landscape .score-topbar { height: 58rpx; padding: 4rpx 10rpx; gap: 8rpx; }
  .landscape .score-title { font-size: 18rpx; }
  .landscape .top-center { gap: 8rpx; font-size: 17rpx; }
  .landscape .top-clock { font-size: 22rpx; }
  .landscape .round-icon { min-width: 34rpx; height: 34rpx; padding: 0 6rpx; font-size: 14rpx; }
  .landscape .top-left .round-icon { width: 34rpx; font-size: 32rpx; }
  .landscape .status-pill { height: 32rpx; padding: 0 8rpx; font-size: 13rpx; }
  .landscape .live-badge { padding: 3rpx 8rpx; font-size: 15rpx; }
  .landscape .drawer-panel.starters { padding: 5rpx; }
  .landscape .drawer-panel.bench { padding: 5rpx; font-size: 11rpx; }
  .landscape .drawer-title { margin-bottom: 4rpx; font-size: 12rpx; }
  .landscape .player-card { min-height: 54rpx; margin-bottom: 4rpx; padding: 3rpx; }
  .landscape .player-card image { width: 30rpx; height: 30rpx; }
  .landscape .number { font-size: 13rpx; }
  .landscape .player-name { font-size: 12rpx; }
  .landscape .position { font-size: 11rpx; }
  .landscape .drawer-handle { font-size: 15rpx; }
  .landscape .team-panel { padding: 8rpx; }
  .landscape .team-head { min-height: 52rpx; gap: 6rpx; }
  .landscape .team-logo { width: 48rpx; height: 48rpx; }
  .landscape .team-name { font-size: 22rpx; }
  .landscape .big-score { font-size: 92rpx; letter-spacing: 0; }
  .landscape .team-meta { margin: 6rpx 0 8rpx; padding: 5rpx 0; }
  .landscape .team-meta text { font-size: 13rpx; }
  .landscape .team-meta .orange { font-size: 21rpx; }
  .landscape .score-actions { gap: 5rpx; }
  .landscape .score-actions > view { min-height: 40rpx; font-size: 20rpx; border-radius: 5rpx; }
  .landscape .score-actions .score-plus-one { min-height: 55rpx; font-size: 32rpx; }
  .landscape .score-actions .small-action { min-height: 44rpx; font-size: 13rpx; gap: 2rpx; }
  .landscape .center-panel { padding: 7rpx; }
  .landscape .quarter-row { display: none; }
  .landscape .main-clock { margin-top: 0; font-size: 56rpx; letter-spacing: 1rpx; }
