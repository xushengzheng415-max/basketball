  min-width: 6.8vw;
  border-color: rgba(255, 106, 0, 0.52);
  color: rgba(255, 255, 255, 0.82);
}

.score-page.landscape-board .roster-drawer-toggle.active {
  border-color: #ff6a00;
  color: #fff;
  background: rgba(255, 106, 0, 0.22);
  box-shadow: 0 0 1vh rgba(255, 106, 0, 0.2);
}

.score-page.landscape-board .board-grid {
  transition: grid-template-columns 280ms ease, gap 280ms ease;
}

.score-page.landscape-board .board-grid > .roster-panel {
  min-width: 0;
  transition: opacity 180ms ease, transform 280ms ease, padding 280ms ease;
}

.score-page.landscape-board .board-grid.roster-collapsed {
  grid-template-columns: 0 minmax(0, 1fr) 25vw minmax(0, 1fr) 0 !important;
  gap: 0.75vw !important;
}

.score-page.landscape-board .board-grid.roster-collapsed > .roster-panel {
  width: 0;
  padding-left: 0 !important;
  padding-right: 0 !important;
  border-width: 0 !important;
  opacity: 0;
  overflow: hidden;
  pointer-events: none;
}

.score-page.landscape-board .board-grid.roster-collapsed > .roster-panel.left {
  transform: translateX(-110%);
}

.score-page.landscape-board .board-grid.roster-collapsed > .roster-panel.right {
  transform: translateX(110%);
}

.score-page.landscape-board .board-grid.roster-open > .roster-panel {
  width: auto;
  opacity: 1;
  transform: translateX(0);
}

