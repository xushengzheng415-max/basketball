page {
  background: #020609;
}

.education-page {
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
  background: #020609;
  padding-bottom: calc(126rpx + env(safe-area-inset-bottom));
}

.hero-section {
  position: relative;
  height: 434rpx;
  overflow: hidden;
  color: #fff;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 434rpx;
}

.page-title,
.version-badge,
.hero-title,
.hero-subtitle {
  position: absolute;
  z-index: 1;
}

.page-title {
  top: 89rpx;
  left: 0;
  width: 100%;
  color: #fff;
  font-size: 35rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
}

.version-badge {
  top: 174rpx;
  left: 35rpx;
  display: flex;
  width: 144rpx;
  height: 44rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #fff;
  background: #ff4f0f;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.hero-title {
  top: 259rpx;
  left: 43rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 49rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.title-hot {
  color: #ff520f;
}

.title-light {
  color: #fff;
}

.hero-subtitle {
  top: 340rpx;
  left: 43rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.25;
  white-space: nowrap;
}

.support-panel,
.current-panel {
  width: 718rpx;
  margin-right: auto;
  margin-left: auto;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff 0%, #f9fafb 100%);
  box-shadow: 0 16rpx 34rpx rgba(0, 0, 0, 0.28);
}

.support-panel {
  min-height: 746rpx;
  padding: 32rpx 28rpx 22rpx;
}

.section-head {
  display: flex;
  height: 46rpx;
  align-items: center;
  gap: 14rpx;
}

.orange-line {
  width: 5rpx;
  height: 31rpx;
  border-radius: 999rpx;
  background: #ff520f;
}

.section-title {
  color: #171b23;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 202rpx);
  gap: 25rpx 24rpx;
  margin-top: 30rpx;
  justify-content: center;
}

.feature-card {
  display: flex;
  height: 264rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid #e4e7ec;
  border-radius: 14rpx;
  background: linear-gradient(145deg, #fff 0%, #f8f9fb 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.feature-icon {
  width: 112rpx;
  height: 112rpx;
}

.feature-title {
  display: block;
  width: 100%;
  margin-top: 19rpx;
  overflow: hidden;
  color: #171b23;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.planning-pill {
  display: flex;
  width: 114rpx;
  height: 41rpx;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  border-radius: 999rpx;
  color: #8b93a3;
  background: #f0f1f3;
  font-size: 24rpx;
  font-weight: 900;
}

.planning-notice {
  display: flex;
  height: 56rpx;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
  border-radius: 14rpx;
  color: #8b93a3;
  background: #f5f6f8;
  font-size: 23rpx;
  font-weight: 700;
}

.notice-icon {
  display: flex;
  width: 25rpx;
  height: 25rpx;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 2rpx solid #8b93a3;
  border-radius: 50%;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1;
}

.notice-copy {
  white-space: nowrap;
}

.current-panel {
  min-height: 308rpx;
  margin-top: 18rpx;
  padding: 31rpx 50rpx 25rpx;
  text-align: center;
}

.clipboard-icon {
  position: relative;
  width: 45rpx;
  height: 51rpx;
  margin: 0 auto;
  box-sizing: border-box;
  border: 4rpx solid #d9dce2;
  border-radius: 8rpx;
}

.clip-top {
  position: absolute;
  top: -9rpx;
  left: 11rpx;
  width: 23rpx;
  height: 12rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #d9dce2;
}

.clip-line {
  width: 22rpx;
  height: 4rpx;
  margin: 11rpx auto 0;
  border-radius: 999rpx;
  background: #d9dce2;
}

.clip-line.short {
  width: 16rpx;
}

.current-title {
  display: block;
  margin-top: 23rpx;
  color: #171b23;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.2;
}

.current-desc {
  display: block;
  margin-top: 18rpx;
  color: #8b93a3;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.event-button {
  position: relative;
  display: flex;
  height: 76rpx;
  align-items: center;
  justify-content: center;
  margin-top: 31rpx;
  overflow: hidden;
  border-radius: 10rpx;
  color: #fff;
  background: linear-gradient(90deg, #ff4f0f 0%, #ff5a10 62%, #ff6b1f 100%);
  font-size: 31rpx;
  font-weight: 900;
}

.event-button text {
  position: relative;
  z-index: 1;
}

.button-ball {
  position: absolute;
  right: -27rpx;
  bottom: -48rpx;
  width: 153rpx;
  height: 153rpx;
  box-sizing: border-box;
  border: 6rpx solid rgba(255, 138, 62, 0.48);
  border-radius: 50%;
}

.button-ball::before,
.button-ball::after {
  content: '';
  position: absolute;
  background: rgba(255, 138, 62, 0.48);
}

.button-ball::before {
  left: 70rpx;
  top: -8rpx;
  width: 5rpx;
  height: 164rpx;
  transform: rotate(27deg);
}

.button-ball::after {
  left: -10rpx;
  top: 62rpx;
  width: 164rpx;
  height: 5rpx;
  transform: rotate(-22deg);
}

.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  padding: 12rpx 0 calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(5, 9, 12, 0.96);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #aeb4bd;
  font-size: 21rpx;
}

.tab-item.active {
  color: #ff6a00;
}

.tab-icon {
  display: block;
  width: 44rpx;
  height: 44rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
}