page{background:#05080b;color:#f7f7f8;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 90% 0,rgba(255,115,0,.22),transparent 25%),#05080b}.nav{height:192rpx;padding:106rpx 30rpx 0;display:flex;align-items:center}.back{width:70rpx;font-size:62rpx}.nav-title{font-size:34rpx;font-weight:800}.more{margin-left:auto;transform:translateY(70rpx);letter-spacing:5rpx}.scroll{height:calc(100vh - 192rpx)}.hero{margin:10rpx 28rpx 18rpx;padding:28rpx;border:1rpx solid rgba(255,124,13,.55);border-radius:24rpx;background:linear-gradient(135deg,#1b2024,#0b0f12)}.hero-top,.info-grid,.head,.student,.duration,.record-row{display:flex;align-items:center}.hero-top{justify-content:space-between}.state,.title,.subject,.card-title,.sub,.name{display:block}.state{color:#ff8a19;font-size:22rpx}.title{margin-top:8rpx;font-size:40rpx;font-weight:800}.subject{margin-top:8rpx;color:#9aa1a6;font-size:23rpx}.date{box-sizing:border-box;width:96rpx;height:118rpx;padding:10rpx 0;border:1rpx solid #ff7a00;border-radius:18rpx;background:rgba(255,122,0,.08);text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden}.date-day{display:block;color:#fff;font-size:34rpx;font-weight:800;line-height:1}.date-month{display:block;margin-top:7rpx;color:#ff8a19;font-size:21rpx;font-weight:700;line-height:1}.date-week{display:block;margin-top:6rpx;color:#9ca3a8;font-size:18rpx;line-height:1}.info-grid{margin-top:28rpx;padding-top:22rpx;border-top:1rpx solid rgba(255,255,255,.12)}.info-grid view{flex:1;border-right:1rpx solid rgba(255,255,255,.1);text-align:center}.info-grid view:last-child{border:0}.info-value,.info-label{display:block}.info-value{font-size:24rpx;font-weight:700}.info-label{margin-top:7rpx;color:#7d858b;font-size:18rpx}.card{margin:0 28rpx 18rpx;padding:26rpx 24rpx;border-radius:22rpx;background:linear-gradient(145deg,#171d21,#0b0f12);border:1rpx solid rgba(255,255,255,.12)}.head{justify-content:space-between;margin-bottom:18rpx}.card-title{font-size:29rpx;font-weight:800}.sub{margin-top:6rpx;color:#80888e;font-size:20rpx}.edit,.pending{color:#ff8a19;font-size:21rpx}.goal{padding:20rpx;border-radius:16rpx;background:rgba(255,122,0,.1);border-left:5rpx solid #ff7a00;color:#d7dbdd;font-size:22rpx;line-height:1.6}.module{display:flex;align-items:center;min-height:76rpx;border-bottom:1rpx solid rgba(255,255,255,.08);font-size:22rpx}.index{width:36rpx;height:36rpx;margin-right:14rpx;border-radius:50%;background:#ff7a00;text-align:center;line-height:36rpx;font-size:18rpx}.mins{margin-left:auto;color:#ff8a19}.duration{justify-content:space-between;margin-top:16rpx}.duration>text:first-child{color:#888f95}.duration-value{color:#ff8a19;font-weight:700}.student{min-height:96rpx;border-top:1rpx solid rgba(255,255,255,.08)}.student image{width:64rpx;height:64rpx;margin-right:16rpx;border-radius:50%;border:2rpx solid #ff7a00}.student view{flex:1}.name{font-size:23rpx;font-weight:700}.student-state{color:#ff8a19;font-size:20rpx}.arrow{margin-left:12rpx;color:#777;font-size:38rpx}.record-row{justify-content:space-between;padding:18rpx 0;border-top:1rpx solid rgba(255,255,255,.08);font-size:22rpx}.record-row text{color:#8c949a}.record-value{font-weight:500}.safe{height:140rpx}.footer{position:fixed;z-index:5;left:0;right:0;bottom:0;display:flex;gap:16rpx;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:rgba(7,10,12,.96);border-top:1rpx solid rgba(255,255,255,.12)}.outline,.primary{height:78rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:26rpx;font-weight:800}.outline{width:220rpx;border:1rpx solid #ff7a00;color:#ff8a19}.primary{flex:1;background:linear-gradient(90deg,#ff5b00,#ff9b20)}

.back{height:70rpx;display:flex;align-items:center;justify-content:flex-start;line-height:1}
