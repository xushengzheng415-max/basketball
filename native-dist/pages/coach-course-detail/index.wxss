page{background:#05090c;color:#f7f7f7}.page{min-height:100vh}.scroll{height:calc(100vh - 115rpx);padding:35rpx 32rpx;box-sizing:border-box}.brand{height:70rpx;color:#ff7800;font-size:30rpx;font-weight:800}.title{font-size:38rpx;font-weight:900;margin:34rpx 0}.title text{font-size:56rpx;margin-right:24rpx}.hero,.panel{border:1rpx solid #3b4044;border-radius:23rpx;background:linear-gradient(135deg,#191e21,#0c1114)}.hero{display:flex;align-items:center;padding:32rpx;border-color:#8d490e}.big-ball{width:140rpx;height:140rpx;border-radius:50%;border:2rpx solid #8e480b;display:flex;align-items:center;justify-content:center;color:#ff7800;font-size:120rpx;margin-right:32rpx}.grow{flex:1}.hero-title,.time,.meta{display:block}.hero-title{font-size:42rpx;font-weight:900}.time{color:#ff820b;border:1rpx solid #75400f;border-radius:24rpx;padding:8rpx 15rpx;width:max-content;margin:18rpx 0}.meta{color:#a9acaf}.count{font-size:28rpx;border:1rpx solid #7c4617;border-radius:15rpx;padding:12rpx}.count::first-letter{color:#ff7800}.panel{padding:24rpx;margin-top:22rpx}.panel-title{font-size:31rpx;font-weight:800;margin-bottom:14rpx}.row{display:flex;justify-content:space-between;align-items:center;padding:24rpx;border:1rpx solid #30363a;border-bottom:0;font-size:27rpx}.row:last-child{border-bottom:1rpx solid #30363a;border-radius:0 0 14rpx 14rpx}.row:first-of-type{border-radius:14rpx 14rpx 0 0}.row .small{color:#aaa;margin-left:20rpx}.green{color:#39bd5a}.student-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16rpx}.student-stats view{height:120rpx;border:1rpx solid #373d41;border-radius:16rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#aaa}.student-stats .strong{font-size:37rpx;color:#39be55;margin-top:10rpx}.student-stats .orange{color:#ff8109}.student-stats .red{color:#f04a40}.safe{height:30rpx}.footer{height:115rpx;margin:0 32rpx 20rpx;border-radius:16rpx;background:linear-gradient(100deg,#ff6500,#ff8f1c);display:flex;align-items:center;justify-content:center;font-size:33rpx;font-weight:900}
