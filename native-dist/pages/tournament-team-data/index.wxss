page { min-height: 100%; background: #020b18; }
.event-page { position: relative; min-height: 100vh; padding: 0 24rpx 48rpx; overflow: hidden; color: #fff; box-sizing: border-box; font-family: -apple-system,BlinkMacSystemFont,"PingFang SC",sans-serif; }
.page-background { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; }.nav-bar,.event-hero,.tabs,.stats-card,.section-card,.section-heading,.performance-row,.empty-panel { position: relative; z-index: 1; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; height: 96rpx; padding-top: env(safe-area-inset-top); box-sizing: content-box; }.back-button,.nav-placeholder { display: flex; align-items: center; width: 70rpx; height: 70rpx; }.back-button image { width: 32rpx; height: 48rpx; }.nav-title { font-size: 31rpx; font-weight: 900; letter-spacing: 2rpx; }
.event-hero { min-height: 260rpx; padding: 9rpx 28rpx 20rpx; box-sizing: border-box; }.hero-row { display: flex; align-items: center; }.event-logo { width: 140rpx; height: 140rpx; flex-shrink: 0; }.event-name { margin-left: 25rpx; font-size: 42rpx; line-height: 54rpx; font-weight: 1000; }.team-row { margin-top: 14rpx; }.mini-team-logo { width: 118rpx; height: 118rpx; margin-right: 25rpx; }.team-name { font-size: 37rpx; font-weight: 900; }.hero-dot { margin: 0 12rpx; color: #6dcc47; }.hero-note { color: #aab4c3; font-size: 25rpx; }
.tabs { display: flex; height: 65rpx; padding: 3rpx; border: 3rpx solid rgba(142,154,173,.38); border-radius: 36rpx; background: rgba(8,22,39,.72); box-sizing: border-box; }.tab { display: flex; flex: 1; align-items: center; justify-content: center; border-radius: 31rpx; color: #aeb6c5; font-size: 28rpx; font-weight: 800; }.tab.active { color: #fff; background: linear-gradient(100deg,#ff8d13,#ff5308); box-shadow: 0 5rpx 15rpx rgba(255,84,8,.28); }
.stats-card { display: flex; flex-wrap: wrap; margin-top: 17rpx; padding: 22rpx 18rpx; border: 1rpx solid rgba(148,162,184,.4); border-radius: 22rpx; background: linear-gradient(120deg,rgba(9,26,46,.96),rgba(6,23,42,.86)); box-sizing: border-box; }.stat-cell { display: flex; align-items: center; flex-direction: column; width: 20%; min-height: 112rpx; border-right: 1rpx solid rgba(139,157,181,.28); box-sizing: border-box; }.stat-cell:nth-child(5),.stat-cell:last-child { border-right: 0; }.stat-cell.wide { width: 25%; min-height: 105rpx; padding-top: 10rpx; }.stat-cell image { width: 38rpx; height: 38rpx; }.stat-label { margin-top: 7rpx; color: #a9b3c3; font-size: 21rpx; white-space: nowrap; }.stat-value { margin-top: 6rpx; font-size: 37rpx; line-height: 45rpx; font-weight: 900; }.stat-value.small { font-size: 32rpx; }.green { color: #6dcc47; }.red { color: #ff4e48; }.orange { color: #ff7b18; }.blue { color: #68a0ff; }.stats-separator { width: 100%; height: 1rpx; margin: 11rpx 4rpx 8rpx; background: rgba(148,162,184,.34); }
.section-card { border: 1rpx solid rgba(148,162,184,.38); border-radius: 22rpx; background: linear-gradient(120deg,rgba(8,25,45,.96),rgba(6,22,39,.88)); overflow: hidden; box-sizing: border-box; }.trend-card { margin-top: 17rpx; padding: 17rpx 22rpx 13rpx; }.section-title { display: block; font-size: 28rpx; font-weight: 900; }.chart-wrap { position: relative; height: 224rpx; margin-top: 8rpx; }.event-trend-canvas { width: 100%; height: 164rpx; }.trend-labels { display: flex; justify-content: space-around; }.trend-label { display: flex; flex: 1; flex-direction: column; align-items: center; color: #9ca8ba; font-size: 16rpx; line-height: 22rpx; }.trend-result { display: flex; align-items: center; justify-content: center; width: 28rpx; height: 28rpx; margin-bottom: 2rpx; border-radius: 50%; color: #fff; font-size: 16rpx; }.chart-empty { position: absolute; top: 70rpx; width: 100%; color: #8390a2; font-size: 23rpx; text-align: center; }
.section-heading { margin: 21rpx 10rpx 10rpx; font-size: 29rpx; line-height: 39rpx; font-weight: 900; }.performance-row { display: grid; grid-template-columns: 1fr 1fr; gap: 9rpx; }.attack-card,.highlight-card { min-height: 111rpx; padding: 14rpx 16rpx; border: 1rpx solid rgba(148,162,184,.38); border-radius: 18rpx; background: rgba(8,25,45,.92); box-sizing: border-box; }.performance-title { display: block; color: #acb6c6; font-size: 21rpx; font-weight: 700; }.performance-number { font-size: 39rpx; line-height: 49rpx; font-weight: 900; }.performance-unit { margin-left: 8rpx; color: #9da9ba; font-size: 18rpx; }.progress { height: 10rpx; border-radius: 7rpx; background: rgba(138,153,175,.2); overflow: hidden; }.progress-fill { height: 100%; border-radius: 7rpx; }.progress-fill.attack { width: 72%; background: linear-gradient(90deg,#ff8b15,#ff5a08); }.progress-fill.defense { width: 66%; background: linear-gradient(90deg,#64a0ff,#4982df); }.highlight-card { grid-column: 1 / 3; display: flex; align-items: center; justify-content: space-around; }.highlight { display: flex; align-items: center; flex-direction: column; min-width: 30%; border-right: 1rpx solid rgba(139,157,181,.28); }.highlight:last-child { border-right: 0; }.highlight image { width: 31rpx; height: 31rpx; }.highlight text { margin-top: 5rpx; color: #aab4c4; font-size: 18rpx; }.highlight strong { margin-top: 4rpx; font-size: 29rpx; }
.game-row { display: grid; grid-template-columns: 64rpx 105rpx 1fr 70rpx 1fr 32rpx; align-items: center; min-height: 59rpx; padding: 0 12rpx; border-bottom: 1rpx solid rgba(139,157,181,.22); box-sizing: border-box; }.game-row:last-child { border-bottom: 0; }.game-sequence,.game-date { color: #9aa6b8; font-size: 17rpx; }.game-team { display: flex; align-items: center; min-width: 0; color: #aeb8c8; font-size: 19rpx; }.game-team.left { justify-content: flex-end; }.game-team image { width: 34rpx; height: 34rpx; margin: 0 6rpx; }.game-team text { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }.game-score { color: #fff; font-size: 23rpx; font-weight: 900; text-align: center; }.game-score.win { color: #ff7418; }.result-badge { display: flex; align-items: center; justify-content: center; width: 29rpx; height: 29rpx; border: 2rpx solid; border-radius: 50%; font-size: 16rpx; font-weight: 800; box-sizing: border-box; }.result-badge.w { color: #8fdd62; border-color: #73d241; }.result-badge.l { color: #ff625d; border-color: #ff4944; }.result-badge.d { color: #9eb4c9; border-color: #7790a6; }.trend-result.result-badge { position: static; }
.list-empty,.empty-panel { padding: 52rpx 20rpx; color: #8592a4; font-size: 23rpx; text-align: center; }.empty-panel { margin-top: 20rpx; border: 1rpx dashed rgba(148,162,184,.38); border-radius: 22rpx; background: rgba(8,25,45,.8); }
.progress-fill.attack,.progress-fill.defense { width: 0; }
.highlight .highlight-value { margin-top: 4rpx; color: #ffffff; font-size: 29rpx; font-weight: 900; }
.highlight .highlight-value.blue { color: #68a0ff; }
.highlight .highlight-value.orange { color: #ff7b18; }
