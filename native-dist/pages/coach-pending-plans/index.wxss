page{background:#05080b;color:#f5f6f7;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 88% 3%,rgba(255,112,0,.22),transparent 28%),#05080b}.nav{height:202rpx;padding:106rpx 210rpx 0 30rpx;display:flex;align-items:center;box-sizing:border-box}.back{width:70rpx;height:70rpx;display:flex;align-items:center;font-size:62rpx;line-height:1}.nav-title,.nav-sub,.eyebrow,.hero-title,.hero-copy,.class-name,.lesson{display:block}.nav-title{font-size:32rpx;font-weight:800}.nav-sub{margin-top:4rpx;color:#7d858b;font-size:18rpx}.scroll{height:calc(100vh - 202rpx)}.hero{margin:8rpx 28rpx 18rpx;padding:25rpx;border:1rpx solid rgba(255,122,0,.46);border-radius:22rpx;background:linear-gradient(140deg,rgba(255,122,0,.16),#11181d 48%,#080c0f)}.eyebrow{color:#ff8a19;font-size:19rpx}.hero-title{margin-top:8rpx;font-size:32rpx;font-weight:900}.hero-copy{margin-top:8rpx;color:#8b949a;font-size:19rpx;line-height:1.55}.plan-card{margin:0 28rpx 18rpx;padding:24rpx;border:1rpx solid rgba(255,255,255,.12);border-radius:22rpx;background:linear-gradient(145deg,#181e22,#0b0f12)}.card-head{display:flex;align-items:flex-start;justify-content:space-between}.class-name{font-size:29rpx;font-weight:900}.lesson{margin-top:7rpx;color:#a5abb0;font-size:20rpx}.status{padding:7rpx 12rpx;border-radius:999rpx;background:rgba(255,174,29,.12);color:#ffb01d;font-size:17rpx}.meta-grid{display:grid;grid-template-columns:1fr 1fr;margin-top:20rpx;border-top:1rpx solid rgba(255,255,255,.08);border-bottom:1rpx solid rgba(255,255,255,.08)}.meta-grid view{padding:17rpx 0}.meta-grid view+view{padding-left:18rpx;border-left:1rpx solid rgba(255,255,255,.08)}.meta-grid text{display:block}.meta-grid text:first-child{color:#757e84;font-size:17rpx}.meta-grid text:last-child{margin-top:6rpx;font-size:20rpx;font-weight:700}.remaining{margin-top:18rpx;padding:13rpx 16rpx;border-radius:12rpx;background:rgba(255,122,0,.09);color:#ff9629;font-size:19rpx}.missing{margin-top:18rpx}.missing-title{display:block;margin-bottom:8rpx;color:#9da4a9;font-size:18rpx}.missing view{display:flex;align-items:center;margin-top:6rpx;color:#d8dbdd;font-size:19rpx}.dot{margin-right:10rpx;color:#ff7a00}.primary{height:76rpx;margin-top:22rpx;display:flex;align-items:center;justify-content:center;border-radius:15rpx;background:linear-gradient(90deg,#ff5b00,#ff9a20);font-size:23rpx;font-weight:900}.safe{height:44rpx}
