page{background:#05090c;color:#f7f7f7}.page{min-height:100vh;background:radial-gradient(circle at 90% 5%,rgba(255,104,0,.18),transparent 30%),#070b0e}.scroll{height:100vh;padding:90rpx 38rpx 30rpx;box-sizing:border-box}.title{font-size:52rpx;font-weight:900}.subtitle{color:#969a9e;font-size:24rpx;margin:12rpx 0 28rpx}.tabs{width:290rpx;height:64rpx;border:1rpx solid #3c4145;border-radius:34rpx;display:flex}.tabs text{flex:1;display:flex;align-items:center;justify-content:center;color:#aaa}.tabs .active{border:1rpx solid #ff7800;border-radius:32rpx;color:#ff8008;background:rgba(255,120,0,.08)}.plan{margin-top:28rpx;border:1rpx solid #85440d;border-radius:23rpx;background:linear-gradient(145deg,#181d20,#0d1215);padding:25rpx}.plan.empty{border-color:#363b3f}.head,.progress-head{display:flex;justify-content:space-between;align-items:center}.class-name{font-size:34rpx;font-weight:800;border-left:7rpx solid #ff7600;padding-left:13rpx}.status{padding:8rpx 18rpx;border-radius:24rpx;background:rgba(255,122,0,.12);color:#ff911f}.meta{color:#b0b3b6;margin:22rpx 0;font-size:23rpx}.missing{height:132rpx;border-radius:14rpx;background:#171c1f;display:flex;align-items:center;padding:18rpx;box-sizing:border-box}.missing>view:first-child{flex:1}.missing text{display:block;color:#aeb0b2;margin:8rpx}.ring{width:92rpx;height:92rpx;border:8rpx solid #ff8a14;border-left-color:#343a3e;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:25rpx;font-weight:800}.ring .small{font-size:15rpx;color:#aaa}.progress-head{color:#aaa;margin-top:40rpx}.progress-head text:last-child{color:#ff850c}.track{height:12rpx;background:#24292d;border-radius:8rpx;margin:12rpx 0 26rpx}.track view{height:100%;background:linear-gradient(90deg,#ff6500,#ff961f);border-radius:8rpx}.primary{height:72rpx;border-radius:13rpx;background:linear-gradient(100deg,#ff6500,#ff8f1d);display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:800;margin-top:20rpx}.primary.outline{background:rgba(255,118,0,.05);border:2rpx solid #ff7800;color:#ff7800}.safe{height:40rpx}

.title.has-back{display:flex;align-items:center;gap:18rpx}.title .back{font-size:58rpx;font-weight:400;line-height:1}
