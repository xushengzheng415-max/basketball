<view class="page"><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}"><view class="title has-back"><text class="back" bindtap="goBack">‹</text>待完成计划</view><view class="subtitle">计划结构将用于课后评价与成长报告</view><view class="tabs"><text class="active">今天 1</text><text>本周 3</text></view><view class="plan {{item.emptyClass}}" wx:for="{{plans}}" wx:key="id"><view class="head"><text class="class-name">{{item.className}}</text><text class="status">{{item.status}}</text></view><view class="meta">◷ {{item.time}}　｜　⌖ {{item.venue}}</view><view wx:if="{{item.showMissing}}" class="missing"><view><text>缺少内容</text><text>•　{{item.missingLabel}}</text></view><view class="ring">{{item.progress}}%<text class="small">完成度</text></view></view><view wx:else class="progress-head"><text>完成度</text><text>{{item.progress}}%</text></view><view wx:if="{{!item.showMissing}}" class="track"><view style="width:{{item.progress}}%"></view></view><view class="primary {{item.buttonClass}}" data-id="{{item.id}}" bindtap="editPlan">{{item.button}}</view></view><view class="safe"></view></scroll-view></view>
