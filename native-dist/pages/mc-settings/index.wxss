page {
  height: 100%;
  background: #050607;
}

.page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #ffffff;
  background: #050607;
}

.page-bg {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0.92;
}

.nav {
  position: relative;
  z-index: 2;
  display: flex;
  height: 176rpx;
  padding: 76rpx 28rpx 20rpx;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.back-button,
.nav-space {
  width: 72rpx;
  height: 72rpx;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-button image {
  width: 36rpx;
  height: 36rpx;
}

.nav-title {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
}

.content {
  position: relative;
  z-index: 1;
  height: calc(100vh - 176rpx);
  padding: 0 22rpx;
  box-sizing: border-box;
}

.master-panel {
  margin-bottom: 16rpx;
  padding: 14rpx 26rpx;
  border: 1rpx solid rgba(255, 91, 0, 0.75);
  border-radius: 18rpx;
  color: #111111;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.22);
}

.master-row {
  display: flex;
  min-height: 88rpx;
  align-items: center;
  border-bottom: 1rpx solid #dedede;
}

.master-row:last-child {
  border-bottom: 0;
}

.master-title {
  flex: 1;
  font-size: 29rpx;
  font-weight: 800;
}

.master-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 18rpx;
}

.master-label {
  flex: none;
  font-size: 25rpx;
  font-weight: 700;
}

.volume-slider {
  flex: 1;
  margin: 0 8rpx 0 22rpx;
}

.volume-value {
  width: 76rpx;
  color: #202020;
  font-size: 24rpx;
  text-align: right;
}

.package-value {
  flex: 1;
  overflow: hidden;
  margin-left: 20rpx;
  color: #373737;
  font-size: 23rpx;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chevron {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
  filter: brightness(0.25);
}

.dark-panel {
  margin-top: 16rpx;
  padding: 18rpx 20rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.19);
  border-radius: 16rpx;
  background: rgba(9, 11, 12, 0.9);
  box-shadow: inset 0 0 32rpx rgba(255, 255, 255, 0.02);
}

.section-title {
  display: flex;
  height: 52rpx;
  align-items: center;
  font-size: 28rpx;
  font-weight: 800;
}

.section-badge {
  margin-left: auto;
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(255, 101, 15, 0.5);
  border-radius: 20rpx;
  color: #ff6a18;
  font-size: 17rpx;
  font-weight: 700;
}

.section-badge.pending {
  border-color: rgba(255, 255, 255, 0.2);
  color: #92959a;
}

.title-mark {
  width: 6rpx;
  height: 32rpx;
  margin-right: 14rpx;
  border-radius: 3rpx;
  background: #ff570d;
}

.sound-row,
.rule-row {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  padding: 8rpx 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.11);
  border-radius: 12rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.025));
  box-sizing: border-box;
}

.category-row,
.rule-row {
  margin-top: 9rpx;
}

.icon-tile {
  display: flex;
  flex: 0 0 62rpx;
  width: 62rpx;
  height: 62rpx;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 11rpx;
  background: rgba(0, 0, 0, 0.25);
}

.icon-tile image {
  width: 40rpx;
  height: 40rpx;
}

.icon-tile.small {
  flex-basis: 56rpx;
  width: 56rpx;
  height: 56rpx;
  color: #ff650f;
  font-size: 28rpx;
  font-weight: 900;
}

.icon-tile.small image {
  width: 35rpx;
  height: 35rpx;
}

.sound-copy {
  min-width: 0;
  flex: 1;
}

.sound-name {
  display: block;
  margin-bottom: 4rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.select-trigger {
  display: flex;
  max-width: 220rpx;
  align-items: center;
  color: #a9aaad;
  font-size: 20rpx;
}

.select-trigger text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-trigger image {
  flex: 0 0 18rpx;
  width: 18rpx;
  height: 18rpx;
  margin-left: 5rpx;
}

.play-button {
  display: flex;
  flex: 0 0 52rpx;
  width: 52rpx;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.play-button image {
  width: 25rpx;
  height: 25rpx;
}

.play-button.playing {
  border-color: #ff5b0b;
  background: rgba(255, 75, 11, 0.15);
}

.mode-button {
  display: flex;
  flex: 0 0 116rpx;
  width: 116rpx;
  height: 50rpx;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.17);
  border-radius: 8rpx;
  color: #e8e8e8;
  font-size: 18rpx;
}

.mode-button image {
  width: 24rpx;
  height: 24rpx;
  margin-right: 5rpx;
}

.row-switch {
  flex: 0 0 auto;
  margin-left: 8rpx;
  transform: scale(0.72);
  transform-origin: center right;
}

.voice-copy {
  display: block;
  margin: 10rpx 10rpx 0;
  color: #85888d;
  font-size: 18rpx;
  line-height: 1.45;
}

.voice-mode-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 10rpx;
}

.voice-mode-option {
  min-width: 0;
  padding: 12rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.035);
  box-sizing: border-box;
}

.voice-mode-option.active {
  border-color: #ff650f;
  background: rgba(255, 101, 15, 0.13);
  box-shadow: inset 0 0 18rpx rgba(255, 101, 15, 0.06);
}

.voice-mode-name,
.voice-mode-note {
  display: block;
}

.voice-mode-name {
  color: #f5f5f5;
  font-size: 21rpx;
  font-weight: 800;
}

.voice-mode-note {
  margin-top: 3rpx;
  color: #85888d;
  font-size: 16rpx;
  line-height: 1.35;
}

.rule-name {
  flex: 1;
  font-size: 23rpx;
  font-weight: 700;
}

.rule-copy {
  min-width: 0;
  flex: 1;
}

.rule-copy .rule-name {
  display: block;
}

.rule-hint {
  display: block;
  margin-top: 4rpx;
  color: #85888d;
  font-size: 17rpx;
  line-height: 1.35;
}

.custom-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 8rpx;
}

.custom-slot {
  min-width: 0;
  height: 154rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 12rpx;
  background: linear-gradient(145deg, rgba(255, 91, 11, 0.11), rgba(255, 255, 255, 0.025));
  box-sizing: border-box;
}

.slot-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.slot-number {
  display: flex;
  width: 34rpx;
  height: 34rpx;
  align-items: center;
  justify-content: center;
  border-radius: 7rpx;
  color: #ffffff;
  background: #ff520b;
  font-size: 18rpx;
  font-weight: 800;
}

.slot-play {
  display: flex;
  width: 38rpx;
  height: 38rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
}

.slot-play image {
  width: 20rpx;
  height: 20rpx;
}

.custom-name {
  display: block;
  overflow: hidden;
  margin: 8rpx 0;
  font-size: 21rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.slot-actions {
  display: grid;
  grid-template-columns: 38rpx minmax(0, 1fr) 38rpx;
  gap: 6rpx;
}

.move-button,
.replace-button {
  display: flex;
  height: 34rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 6rpx;
  color: #b8bbc0;
  font-size: 17rpx;
}

.replace-button {
  color: #ff6a18;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 8rpx;
}

.shortcut-slot {
  position: relative;
  display: flex;
  min-width: 0;
  height: 108rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.13);
  border-radius: 11rpx;
  background: rgba(255, 255, 255, 0.045);
}

.shortcut-key {
  color: #ff620f;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.shortcut-name {
  overflow: hidden;
  width: 90%;
  margin-top: 8rpx;
  font-size: 18rpx;
  font-weight: 700;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shortcut-edit {
  position: absolute;
  top: 7rpx;
  right: 8rpx;
  color: #777b80;
  font-size: 14rpx;
}

.save-button {
  display: flex;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  margin: 20rpx 0 0;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(90deg, #ff3d05, #ff620d);
  box-shadow: 0 12rpx 28rpx rgba(255, 71, 5, 0.2);
  font-size: 31rpx;
  font-weight: 800;
}

.bottom-safe {
  height: calc(env(safe-area-inset-bottom) + 32rpx);
}

.modal-mask {
  position: fixed;
  z-index: 20;
  inset: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.68);
}

.modal-sheet {
  width: 100%;
  max-height: 68vh;
  padding: 24rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  border-radius: 24rpx 24rpx 0 0;
  color: #ffffff;
  background: #131516;
  box-sizing: border-box;
}

.modal-head {
  display: flex;
  height: 64rpx;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  font-weight: 800;
}

.modal-close {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  align-items: center;
  justify-content: center;
  color: #a9aaad;
  font-size: 42rpx;
}

.modal-list {
  max-height: 52vh;
}

.modal-option {
  display: flex;
  min-height: 88rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 10rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-option-name {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
}

.modal-option-note {
  display: block;
  margin-top: 4rpx;
  color: #ff6a1a;
  font-size: 18rpx;
}

.modal-option image {
  width: 22rpx;
  height: 22rpx;
}

@media (max-width: 360px) {
  .mode-button {
    flex-basis: 102rpx;
    width: 102rpx;
    font-size: 16rpx;
  }

  .icon-tile {
    flex-basis: 56rpx;
    width: 56rpx;
    height: 56rpx;
    margin-right: 10rpx;
  }

  .select-trigger {
    max-width: 170rpx;
  }
}
