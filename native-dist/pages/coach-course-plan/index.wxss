page{background:#05080b;color:#f5f6f7;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 80% 0,rgba(255,112,0,.22),transparent 26%),#05080b}.nav{height:202rpx;padding:106rpx 30rpx 0;display:flex;align-items:center}.back{width:68rpx;font-size:62rpx}.nav-title,.nav-sub,.eyebrow,.course-title,.course-desc,.title,.sub,.module-title,.module-desc,.check-title,.check-sub{display:block}.nav-title{font-size:32rpx;font-weight:800}.nav-sub{margin-top:4rpx;color:#7d858b;font-size:19rpx}.template{margin-left:auto;transform:translateY(70rpx);padding:10rpx 17rpx;border:1rpx solid #ff7a00;border-radius:13rpx;color:#ff8a19;font-size:20rpx}.scroll{height:calc(100vh - 202rpx)}.course-card,.setting-card,.module-card,.check-card{margin:0 28rpx 16rpx;border-radius:22rpx;background:linear-gradient(145deg,#181e22,#0b0f12);border:1rpx solid rgba(255,255,255,.12)}.course-card{padding:26rpx;display:flex;align-items:center}.course-card>view:first-child{flex:1}.eyebrow{color:#ff8a19;font-size:20rpx}.course-title{margin-top:7rpx;font-size:31rpx;font-weight:800}.course-desc{margin-top:10rpx;color:#8d959b;font-size:21rpx;line-height:1.55}.duration-ring{width:116rpx;height:116rpx;margin-left:20rpx;border-radius:50%;border:10rpx solid #ff7a00;border-left-color:#31383d;display:flex;flex-direction:column;align-items:center;justify-content:center}.duration-ring>text:first-child{font-size:31rpx;font-weight:800}.ring-label{font-size:16rpx;color:#858d93}.duration-ring.warning{border-color:#ffb21c;border-left-color:#343a3e}.setting-card{display:grid;grid-template-columns:1fr 1fr;padding:8rpx 22rpx}.setting{padding:18rpx 8rpx;border-bottom:1rpx solid rgba(255,255,255,.08)}.setting:nth-child(odd){border-right:1rpx solid rgba(255,255,255,.08)}.setting text{display:block;color:#7d858b;font-size:19rpx}.setting-value{margin-top:6rpx!important;color:#f5f6f7!important;font-size:21rpx!important;font-weight:700}.setting-value.orange{color:#ff8a19!important}.section-head{display:flex;align-items:center;justify-content:space-between;margin:26rpx 30rpx 14rpx}.title{font-size:29rpx;font-weight:800}.sub{margin-top:5rpx;color:#767e84;font-size:19rpx}.add{color:#ff8a19;font-size:21rpx}.module-card{position:relative;display:flex;padding:22rpx}.order{width:46rpx;height:46rpx;margin-right:16rpx;border-radius:14rpx;background:linear-gradient(145deg,#ff9925,#ff5b00);text-align:center;line-height:46rpx;font-weight:800}.module-main{flex:1}.module-head{display:flex;align-items:center}.module-title{font-size:25rpx;font-weight:800}.drag{margin-left:auto;color:#727a80;font-size:34rpx}.module-desc{margin-top:7rpx;color:#92999f;font-size:20rpx;line-height:1.5}.chips{display:flex;gap:10rpx;margin-top:14rpx}.chips text{padding:5rpx 12rpx;border-radius:999rpx;background:rgba(255,122,0,.12);color:#ff8a19;font-size:17rpx}.delete{position:absolute;right:-8rpx;top:-8rpx;width:34rpx;height:34rpx;border-radius:50%;background:#3b2020;color:#ff6a50;text-align:center;line-height:31rpx}.check-card{display:flex;align-items:center;justify-content:space-between;padding:22rpx;border-color:rgba(68,202,104,.5)}.check-card.warning{border-color:rgba(255,178,28,.6)}.check-title{font-size:23rpx;font-weight:800}.check-sub{margin-top:6rpx;color:#7f878d;font-size:19rpx}.check-icon{width:48rpx;height:48rpx;border-radius:50%;background:#45c96d;text-align:center;line-height:48rpx}.warning .check-icon{background:#ffad16}.safe{height:142rpx}.footer{position:fixed;z-index:5;left:0;right:0;bottom:0;display:flex;gap:16rpx;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:rgba(7,10,12,.97);border-top:1rpx solid rgba(255,255,255,.1)}.draft,.confirm{height:78rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:25rpx;font-weight:800}.draft{width:220rpx;border:1rpx solid #ff7a00;color:#ff8a19}.confirm{flex:1;background:linear-gradient(90deg,#ff5b00,#ff9a20)}

.back{height:70rpx;display:flex;align-items:center;justify-content:flex-start;line-height:1}

.module-card{transition:transform .16s ease,border-color .16s ease,box-shadow .16s ease}
.module-card.dragging{z-index:4;transform:scale(1.025);border-color:#ff7a00;box-shadow:0 16rpx 42rpx rgba(255,105,0,.24);background:linear-gradient(145deg,#232126,#111417)}
.module-card.dragging .drag{color:#ff8a19}
.editor-mask{position:fixed;z-index:20;left:0;right:0;top:0;bottom:0;display:flex;align-items:flex-end;background:rgba(0,0,0,.76)}
.editor-panel{box-sizing:border-box;width:100%;max-height:88vh;padding:30rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));border-radius:32rpx 32rpx 0 0;border-top:1rpx solid rgba(255,142,31,.65);background:linear-gradient(160deg,#171d21,#090c0f 72%);box-shadow:0 -20rpx 60rpx rgba(0,0,0,.48)}
.editor-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24rpx}
.editor-title,.editor-sub,.field-label{display:block}
.editor-title{font-size:32rpx;font-weight:800}
.editor-sub{margin-top:6rpx;color:#81898f;font-size:20rpx}
.editor-close{width:52rpx;height:52rpx;border-radius:50%;background:#2a2020;color:#ff755c;text-align:center;line-height:48rpx;font-size:36rpx}
.field{margin-top:22rpx}
.field-label{margin-bottom:12rpx;color:#c8cccf;font-size:22rpx;font-weight:700}
.field input,.field textarea{box-sizing:border-box;width:100%;padding:18rpx 20rpx;border:1rpx solid rgba(255,255,255,.13);border-radius:15rpx;background:#101519;color:#f5f6f7;font-size:23rpx;line-height:1.55}
.field textarea{min-height:108rpx}
.option-row{display:flex;flex-wrap:wrap;gap:12rpx}
.option{min-width:90rpx;padding:12rpx 14rpx;border:1rpx solid rgba(255,255,255,.14);border-radius:13rpx;background:#11161a;color:#969da2;text-align:center;font-size:20rpx}
.option.active{border-color:#ff7a00;background:rgba(255,122,0,.16);color:#ff941e;font-weight:700}
.option-row.intensity .option{flex:1;min-width:120rpx}
.editor-actions{display:flex;gap:14rpx;margin-top:30rpx}
.editor-cancel,.editor-save{height:76rpx;border-radius:15rpx;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:800}
.editor-cancel{width:190rpx;border:1rpx solid rgba(255,255,255,.18);color:#aeb3b7}
.editor-save{flex:1;background:linear-gradient(90deg,#ff5b00,#ff9a20);color:#fff}

.drag-handle{width:76rpx;height:58rpx;margin-left:auto;border:1rpx solid rgba(255,122,0,.22);border-radius:13rpx;background:#141a1e;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#7f888d}.drag-handle text:first-child{height:25rpx;color:#ff8a19;font-size:30rpx;line-height:22rpx}.drag-handle text:last-child{font-size:14rpx}.module-card.dragging .drag-handle{border-color:#ff7a00;background:rgba(255,122,0,.16);color:#ff9a20}.editor-panel{height:88vh;max-height:88vh;display:flex;flex-direction:column}.editor-head{flex-shrink:0}.editor-scroll{height:calc(88vh - 190rpx);min-height:0}.template-section{padding-bottom:4rpx}.template-head{display:flex;align-items:center;justify-content:space-between}.template-head text:first-child{font-size:22rpx;font-weight:800}.template-head text:last-child{color:#7c858a;font-size:17rpx}.template-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:11rpx;margin-top:13rpx}.template-item{min-height:76rpx;padding:13rpx 14rpx;border:1rpx solid rgba(255,255,255,.12);border-radius:14rpx;background:#101519}.template-item text{display:block}.template-item text:first-child{font-size:20rpx;font-weight:700}.template-item text:last-child{margin-top:5rpx;color:#747d82;font-size:15rpx}.template-item.active{border-color:#ff7a00;background:rgba(255,122,0,.13)}.template-item.active text:first-child{color:#ff961e}.template-item.active text:last-child{color:#c98a3c}.editor-scroll-safe{height:24rpx}.editor-actions{flex-shrink:0;margin-top:16rpx;padding-top:15rpx;border-top:1rpx solid rgba(255,255,255,.08)}
