page{background:#05090c;color:#f7f7f7}.page{min-height:100vh;background:radial-gradient(circle at 90% 8%,rgba(255,112,0,.13),transparent 28%),#070b0e}.scroll{height:calc(100vh - 118rpx);padding:55rpx 30rpx 20rpx;box-sizing:border-box}.title{display:flex;align-items:center;font-size:53rpx;font-weight:900;margin-bottom:34rpx}.title>text{font-size:58rpx;margin-right:28rpx}.title .small{display:block;color:#aaa;font-size:25rpx;font-weight:400;margin-top:10rpx}.goal,.module,.growth,.notice{border:1rpx solid #373d41;border-radius:22rpx;background:linear-gradient(135deg,#191e21,#0d1215)}.goal{display:flex;align-items:center;padding:30rpx}.goal>view:first-child{flex:1}.label{display:block;color:#ff7800;font-size:25rpx}.goal-title{display:block;font-size:34rpx;font-weight:900;margin:18rpx 0}.desc{display:block;color:#a7aaad;font-size:22rpx;line-height:1.55}.ring{width:120rpx;height:120rpx;border:10rpx solid #ff7800;border-left-color:#32383c;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center}.ring .strong{font-size:38rpx}.ring .small{font-size:17rpx;color:#aaa}.section-title{font-size:31rpx;font-weight:900;margin:30rpx 0 14rpx}.module{display:flex;align-items:center;padding:22rpx;margin-bottom:12rpx}.order{width:40rpx;height:40rpx;border-radius:8rpx;background:#ff7800;display:flex;align-items:center;justify-content:center;font-weight:800}.module-icon{width:76rpx;height:76rpx;border-radius:50%;border:1rpx solid #684018;color:#ff7800;font-size:58rpx;display:flex;align-items:center;justify-content:center;margin:0 22rpx}.module-main{flex:1}.module-title{display:block;font-size:28rpx;font-weight:800}.minutes{border-left:1rpx solid #333;padding-left:20rpx;color:#ff7800}.minutes .strong{font-size:35rpx}.minutes .small{display:block;color:#aaa;margin-top:10rpx}.growth{padding:25rpx;margin-top:28rpx;border-color:#66401c;background:rgba(255,116,0,.07)}.growth>view{display:flex;gap:18rpx;margin-top:20rpx}.growth view text{flex:1;text-align:center;border:1rpx solid #71400f;border-radius:28rpx;padding:13rpx;color:#ff850c}.notice{padding:24rpx;margin-top:20rpx;color:#a9abad;line-height:1.6}.safe{height:30rpx}.footer,.editor-actions{display:flex;gap:20rpx}.footer{height:118rpx;padding:18rpx 30rpx;box-sizing:border-box}.outline,.primary{height:78rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:800}.outline{width:330rpx;border:2rpx solid #ff7800;color:#ff7800}.primary{flex:1;background:linear-gradient(100deg,#ff6500,#ff901d)}.editor-mask{position:fixed;inset:0;background:rgba(0,0,0,.78);display:flex;align-items:flex-end;z-index:20}.editor{width:100%;padding:32rpx;background:#0b1013;border-radius:28rpx 28rpx 0 0;border-top:1rpx solid #ff7800}.editor-title{display:flex;justify-content:space-between;font-size:34rpx;font-weight:900}.field{margin-top:22rpx}.field>text{display:block;color:#aaa;margin-bottom:10rpx}.field input,.field textarea{width:100%;box-sizing:border-box;border:1rpx solid #363c40;border-radius:13rpx;background:#151a1e;padding:20rpx}.field textarea{height:120rpx}.options{display:flex;gap:10rpx}.option{flex:1;border:1rpx solid #3a4044;border-radius:10rpx;padding:14rpx;text-align:center}.option.active{border-color:#ff7800;color:#ff7800}.editor-actions{margin-top:28rpx}

.drag-handle{width:54rpx;height:74rpx;margin:0 12rpx;display:flex;align-items:center;justify-content:center;color:#8d9296;font-size:38rpx;letter-spacing:-8rpx}.module.dragging{border-color:#ff7800;background:#21170f;box-shadow:0 0 18rpx rgba(255,120,0,.32);transform:scale(1.01)}
