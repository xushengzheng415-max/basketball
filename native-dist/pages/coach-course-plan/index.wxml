<view class="page"><view class="nav"><view class="back" bindtap="goBack"><text>‹</text></view><view><text class="nav-title">课程计划搭建</text><text class="nav-sub">U10提高班 · 5月23日</text></view><text class="template" bindtap="openAddModule">模板库</text></view><scroll-view class="scroll" scroll-y="{{scrollEnabled}}" enhanced show-scrollbar="{{false}}">
<view class="course-card"><view><text class="eyebrow">本节课目标</text><text class="course-title">控球强化与攻防转换</text><text class="course-desc">提升弱侧手控球稳定性，完成控球后的快速观察与出球。</text></view><view class="duration-ring {{totalClass}}"><text>{{totalMinutes}}</text><text class="ring-label">/ 90分钟</text></view></view>
<view class="setting-card"><view class="setting"><text>训练等级</text><text class="setting-value">U10 · 进阶</text></view><view class="setting"><text>训练器材</text><text class="setting-value">篮球16个、标志桶12个 ›</text></view><view class="setting"><text>组织方式</text><text class="setting-value">个人 / 2人组 / 3v3 ›</text></view><view class="setting"><text>总体强度</text><text class="setting-value orange">中高强度</text></view></view>
<view class="section-head"><view><text class="title">训练模块</text><text class="sub">按住右侧拖拽手柄上下移动，点击内容可编辑</text></view><text class="add" bindtap="openAddModule">＋ 添加模块</text></view>
<view class="module-card {{item.draggingClass}}" wx:for="{{modules}}" wx:key="id"><view class="order">{{item.order}}</view><view class="module-main" data-id="{{item.id}}" bindtap="openEditModule"><view class="module-head"><text class="module-title">{{item.title}}</text><view class="drag-handle" data-id="{{item.id}}" data-index="{{index}}" catchtouchstart="startDrag" catchtouchmove="moveDrag" catchtouchend="finishDrag" catchtouchcancel="finishDrag"><text>≡</text><text>拖动</text></view></view><text class="module-desc">{{item.desc}}</text><view class="chips"><text>{{item.minutes}}分钟</text><text>{{item.intensity}}强度</text><text>点击编辑</text></view></view><text class="delete" data-id="{{item.id}}" catchtap="removeModule">×</text></view>
<view class="check-card {{totalClass}}"><view><text class="check-title">计划总时长 {{totalMinutes}} 分钟</text><text class="check-sub">{{totalState}} · 保存后仍可在课前修改</text></view><text class="check-icon">✓</text></view><view class="safe"></view></scroll-view><view class="footer"><view class="draft" bindtap="saveDraft">保存草稿</view><view class="confirm" bindtap="confirmPlan">确认课程计划</view></view>

<view class="editor-mask" wx:if="{{editorVisible}}" catchtap="closeEditor"><view class="editor-panel" catchtap="noop"><view class="editor-head"><view><text class="editor-title">{{editorTitle}}</text><text class="editor-sub">选择训练模板或自定义模块内容</text></view><text class="editor-close" bindtap="closeEditor">×</text></view><scroll-view class="editor-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view class="template-section"><view class="template-head"><text>训练模板</text><text>选中后仍可自由修改</text></view><view class="template-grid"><view class="template-item {{item.activeClass}}" wx:for="{{moduleTemplates}}" wx:key="id" data-id="{{item.id}}" bindtap="selectTemplate"><text>{{item.shortTitle}}</text><text wx:if="{{item.showPresetInfo}}">{{item.minutes}}分钟 · {{item.intensity}}强度</text><text wx:else>名称与内容自由填写</text></view></view></view><view class="field"><text class="field-label">模块名称</text><input value="{{editorForm.title}}" data-field="title" bindinput="onEditorInput" maxlength="20" placeholder="可输入自定义名称，如：半场攻防转换"/></view><view class="field"><text class="field-label">训练说明</text><textarea value="{{editorForm.desc}}" data-field="desc" bindinput="onEditorInput" maxlength="80" auto-height placeholder="填写动作、规则、分组或器材要求"/></view><view class="field"><text class="field-label">训练时长</text><view class="option-row"><text class="option {{item.activeClass}}" wx:for="{{durationOptions}}" wx:key="value" data-value="{{item.value}}" bindtap="selectMinutes">{{item.label}}分钟</text></view></view><view class="field"><text class="field-label">训练强度</text><view class="option-row intensity"><text class="option {{item.activeClass}}" wx:for="{{intensityOptions}}" wx:key="value" data-value="{{item.value}}" bindtap="selectIntensity">{{item.label}}强度</text></view></view><view class="editor-scroll-safe"></view></scroll-view><view class="editor-actions"><view class="editor-cancel" bindtap="closeEditor">取消</view><view class="editor-save" bindtap="saveModule">保存模块</view></view></view></view></view>
