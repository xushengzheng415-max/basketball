<view class="page"><scroll-view class="scroll" scroll-y="{{scrollEnabled}}" enhanced show-scrollbar="{{false}}"><view class="title"><text bindtap="goBack">‹</text><view>查看计划<text class="small">U10提高班 · 今日训练</text></view></view><view class="goal"><view><text class="label">本节目标</text><text class="goal-title">控球强化与攻防转换</text><text class="desc">提升弱侧手控球稳定性，完成控球后的快速观察与出球。</text></view><view class="ring"><text class="strong">{{totalMinutes}}</text><text class="small">/ 90分钟</text></view></view><view class="section-title">训练模块</view><view class="module {{item.draggingClass}}" wx:for="{{modules}}" wx:key="id" data-id="{{item.id}}" bindtap="openEditModule"><text class="order">{{item.order}}</text><view class="module-icon">●</view><view class="module-main"><text class="module-title">{{item.title}}</text><text class="desc">{{item.desc}}</text></view><view class="drag-handle" data-id="{{item.id}}" data-index="{{index}}" catchtouchstart="startDrag" catchtouchmove="moveDrag" catchtouchend="finishDrag" catchtouchcancel="finishDrag" catchtap="noop">☷</view><view class="minutes"><text class="strong">{{item.minutes}}</text>分钟<text class="small">{{item.intensity}}强度</text></view></view><view class="growth"><text class="label">本节成长目标</text><view><text>🏀 弱手运球</text><text>♧ 快速决策</text><text>♙ 团队协作</text></view></view><view class="notice">ⓘ　本节训练的结构化数据将用于生成课后成长报告，帮助你更好地了解学员进步情况。</view><view class="safe"></view></scroll-view><view class="footer"><view class="outline" bindtap="openAddModule">✎ 编辑模块</view><view class="primary" bindtap="confirmPlan">▷ 开始上课</view></view>
<view class="editor-mask" wx:if="{{editorVisible}}" catchtap="closeEditor"><view class="editor" catchtap="noop"><view class="editor-title">编辑训练模块 <text bindtap="closeEditor">×</text></view><view class="field"><text>模块</text><input value="{{editorForm.title}}" data-field="title" bindinput="onEditorInput"/></view><view class="field"><text>预计</text><view class="options"><text class="option {{item.activeClass}}" wx:for="{{durationOptions}}" wx:key="value" data-value="{{item.value}}" bindtap="selectMinutes">{{item.label}}分钟</text></view></view><view class="field"><text>训练目标</text><textarea value="{{editorForm.desc}}" data-field="desc" bindinput="onEditorInput"/></view><view class="field"><text>强度</text><view class="options"><text class="option {{item.activeClass}}" wx:for="{{intensityOptions}}" wx:key="value" data-value="{{item.value}}" bindtap="selectIntensity">{{item.label}}</text></view></view><view class="editor-actions"><view class="outline" data-id="{{editingId}}" bindtap="removeModule">删除模块</view><view class="primary" bindtap="saveModule">保存修改</view></view></view></view></view>
