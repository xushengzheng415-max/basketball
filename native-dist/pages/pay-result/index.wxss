.result {
  min-height: 100vh;
  padding: 44rpx 28rpx;
  text-align: center;
}
.success-icon {
  display: flex;
  width: 120rpx;
  height: 120rpx;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  border-radius: 50%;
  color: #fff;
  background: #21a67a;
  font-size: 72rpx;
  font-weight: 900;
}
.title, .desc {
  display: block;
}
.title {
  margin-top: 24rpx;
  color: #101820;
  font-size: 44rpx;
  font-weight: 900;
}
.desc {
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
}
.card {
  margin-top: 34rpx;
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  background: #fff;
  text-align: left;
}
.row {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf1f5;
  color: #667085;
  font-size: 24rpx;
}
.row:last-child {
  border-bottom: 0;
}
.row text:last-child {
  max-width: 430rpx;
  color: #18212f;
  font-weight: 800;
  text-align: right;
}
.amount {
  color: #f05a28 !important;
  font-family: DIN Alternate, Arial, sans-serif;
  font-size: 30rpx;
}
.primary {
  display: flex;
  height: 92rpx;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  border-radius: 10rpx;
  color: #fff;
  background: #f05a28;
  font-size: 30rpx;
  font-weight: 900;
}
