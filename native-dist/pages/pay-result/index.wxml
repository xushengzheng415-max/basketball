<view class="result">
  <view class="success-icon">✓</view>
  <text class="title">支付成功</text>
  <text class="desc">订单已生成，正式接入微信支付后会自动开通对应权益。</text>

  <view class="card">
    <view class="row">
      <text>订单号</text>
      <text>{{order.orderNo}}</text>
    </view>
    <view class="row">
      <text>服务项目</text>
      <text>{{order.product.name}}</text>
    </view>
    <view class="row">
      <text>支付金额</text>
      <text class="amount">¥{{order.product.price}}</text>
    </view>
    <view class="row">
      <text>支付时间</text>
      <text>{{order.paidAt}}</text>
    </view>
  </view>

  <view class="primary" bindtap="backHome">返回首页</view>
</view>