page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:7rpx;color:#d4d8db;font-size:18rpx}.back-button image{width:27rpx;height:27rpx}.page-scroll{height:100%}.content{padding:18rpx 30rpx 0}.page-heading{display:flex;justify-content:space-between;align-items:center}.page-heading text:first-child{font-size:39rpx;font-weight:900}.page-heading text:last-child{font-size:21rpx}.metric-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12rpx;margin-top:20rpx}.metric-grid>view,.package-card,.rules-card,.pc-tip{border:1rpx solid #574017;border-radius:14rpx;background:linear-gradient(135deg,#182026,#0d1216)}.metric-grid>view{text-align:center;padding:18rpx}.metric-grid>view text{display:block}.metric-grid>view text:first-child{color:#ff8500;font-size:36rpx}.metric-grid>view text:nth-child(2){margin-top:8rpx;color:#aeb5ba;font-size:18rpx}.metric-grid>view text:last-child{margin-top:5rpx;font-size:34rpx;font-weight:800}.section-title{margin:22rpx 4rpx 10rpx;font-size:26rpx;font-weight:800}.package-card{display:grid;grid-template-columns:145rpx 1fr 105rpx;gap:15rpx;align-items:center;margin-top:12rpx;padding:15rpx}.package-card>image{width:140rpx;height:115rpx;border-radius:10rpx}.package-copy>text{font-size:26rpx;font-weight:800}.package-copy>view:nth-child(2){display:flex;gap:18rpx;margin-top:12rpx}.package-copy>view:nth-child(2) text{font-size:16rpx}.package-copy>view:last-child{display:flex;gap:12rpx;margin-top:12rpx;padding-top:10rpx;border-top:1rpx solid #343d43;color:#91999f;font-size:16rpx}.package-copy>view:last-child text:last-child{padding:3rpx 8rpx;border:1rpx solid #5d451c;border-radius:7rpx;color:#ff8500}.package-side{text-align:right}.package-side text{display:block}.package-side text:first-child{color:#ff8500;font-size:29rpx;font-weight:800}.package-side text:nth-child(2){margin-top:12rpx;color:#4bd05a;font-size:17rpx}.package-side text:last-child{margin-top:18rpx;font-size:30rpx}.rules-card{display:grid;grid-template-columns:1fr 1fr;padding:16rpx}.rules-card>view{display:grid;grid-template-columns:55rpx 1fr;gap:10rpx;padding:15rpx;border-top:1rpx solid #343d43;border-left:1rpx solid #343d43}.rules-card>view:nth-child(-n+2){border-top:0}.rules-card>view:nth-child(odd){border-left:0}.rules-card>view>text{color:#ff8500;font-size:35rpx}.rules-card>view>view text{display:block}.rules-card>view>view text:first-child{font-size:20rpx;font-weight:700}.rules-card>view>view text:last-child{margin-top:6rpx;color:#8f979d;font-size:15rpx;line-height:1.4}.primary-button{margin-top:18rpx;height:76rpx;line-height:76rpx;border-radius:10rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:25rpx;font-weight:800}.pc-tip{margin-top:14rpx;padding:15rpx;color:#a0a7ac;font-size:16rpx}.safe-space{height:45rpx}
