page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97)}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:7rpx;color:#ff8500;font-size:20rpx}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:18rpx 28rpx 0}.page-heading text{display:block}.page-heading text:first-child{font-size:43rpx;font-weight:900}.page-heading text:last-child{display:inline-block;margin-top:8rpx;padding:5rpx 10rpx;border:1rpx solid #ff8500;border-radius:7rpx;color:#ff8500;font-size:16rpx}.course-hero,.section-card,.progress-card{border:1rpx solid #394248;border-radius:15rpx;background:linear-gradient(135deg,#182026,#0d1216)}.course-hero{margin-top:16rpx;padding:20rpx}.course-hero>text{display:block}.course-hero>text:first-child{display:inline-block;padding:4rpx 8rpx;border-radius:6rpx;background:#51300e;color:#ff8500;font-size:16rpx}.course-hero>text:nth-child(2){margin-top:8rpx;font-size:31rpx;font-weight:800}.hero-info{display:grid;grid-template-columns:repeat(3,1fr);margin-top:18rpx}.hero-info>view{padding-left:18rpx;border-left:1rpx solid #3a4349}.hero-info>view:first-child{padding-left:0;border-left:0}.hero-info text{display:block;color:#a0a7ac;font-size:16rpx}.hero-info text:last-child{margin-top:5rpx;color:#fff;font-size:22rpx}.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);margin:16rpx -20rpx -20rpx;padding:16rpx 20rpx;border-top:1rpx solid #343d43}.hero-stats>view{text-align:center}.hero-stats text{display:block}.hero-stats text:first-child{color:#858d93;font-size:14rpx}.hero-stats text:last-child{margin-top:5rpx;font-size:22rpx}.hero-stats>view:last-child text:last-child{color:#55d15a}.section-card{margin-top:14rpx;padding:18rpx}.section-title{padding-left:9rpx;border-left:5rpx solid #ff8500;font-size:23rpx;font-weight:800}.info-grid{display:grid;grid-template-columns:repeat(4,1fr);margin-top:15rpx}.info-grid>view{display:grid;grid-template-columns:45rpx 1fr;gap:8rpx}.info-grid>view>text{color:#ff8500;font-size:31rpx}.info-grid>view>view text{display:block}.info-grid>view>view text:first-child{color:#8e969c;font-size:14rpx}.info-grid>view>view text:last-child{margin-top:4rpx;font-size:18rpx}.coach-card>view:last-child{display:grid;grid-template-columns:60rpx 1fr 1fr;align-items:center;margin-top:15rpx}.coach-card image{width:52rpx;height:52rpx;border-radius:50%}.coach-card>view:last-child>view text{display:block}.coach-card>view:last-child>view text:first-child{font-size:20rpx}.coach-card>view:last-child>view text:first-child text{display:inline;padding:3rpx 7rpx;border:1rpx solid #ff8500;border-radius:6rpx;color:#ff8500;font-size:13rpx}.coach-card>view:last-child>view text:last-child{margin-top:4rpx;color:#8e969c;font-size:14rpx}.progress-card{display:grid;grid-template-columns:170rpx 85rpx repeat(3,1fr) 100rpx;align-items:center;margin-top:13rpx;padding:16rpx}.progress-card>text{font-size:22rpx;font-weight:800}.ring{width:62rpx;height:62rpx;border:9rpx solid #ff8500;border-right-color:#3f484e;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16rpx}.ring.green{border-color:#55d15a;border-right-color:#3f484e}.progress-card>view:not(.ring){text-align:center}.progress-card>view:not(.ring) text{display:block}.progress-card>view:not(.ring) text:first-child{color:#858d93;font-size:14rpx}.progress-card>view:not(.ring) text:last-child{margin-top:4rpx;font-size:20rpx}.progress-card button{height:45rpx;line-height:45rpx;border:1rpx solid #ff8500;border-radius:8rpx;background:transparent;color:#ff8500;font-size:15rpx}.section-heading{display:flex;justify-content:space-between}.section-heading text:first-child{font-size:22rpx;font-weight:800}.section-heading text:last-child{color:#ff8500;font-size:16rpx}.change-row{display:grid;grid-template-columns:45rpx 1fr 100rpx;align-items:center;margin-top:9rpx;padding:10rpx;border:1rpx solid #684817;border-radius:8rpx}.change-row>text:first-child{color:#ff8500;font-size:28rpx}.change-row>view text{display:block}.change-row>view text:first-child{font-size:18rpx}.change-row>view text:first-child text{display:inline;padding:2rpx 6rpx;border:1rpx solid #ff8500;border-radius:5rpx;color:#ff8500;font-size:12rpx}.change-row>view text:last-child{margin-top:4rpx;color:#858d93;font-size:14rpx}.change-row>text:last-child{color:#858d93;font-size:14rpx;text-align:right}.bottom-actions{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin-top:13rpx}.bottom-actions button{height:70rpx;line-height:70rpx;border-radius:9rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:23rpx;font-weight:800}.bottom-actions button:last-child{border:1rpx solid #ff5151;background:transparent;color:#ff5151}.safe-space{height:45rpx}
