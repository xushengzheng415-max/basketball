<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /><text>返回课程总览</text></view></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content">
  <view class="page-heading"><text>课程详情</text><text>校区负责人 · 监督管理</text></view>
  <view class="course-hero"><text>{{course.badge}}</text><text>{{course.title}}</text><view class="hero-info"><view><text>{{course.date}}</text><text>{{course.time}}</text></view><view><text>{{course.campus}}</text><text>{{course.venue}}</text></view><view><text>执行教练</text><text>{{course.coach}}</text></view></view><view class="hero-stats"><view><text>计划人数</text><text>{{course.planned}}人</text></view><view><text>实际人数</text><text>{{course.actual}}人</text></view><view><text>执行状态</text><text>● 正常</text></view></view></view>
  <view class="section-card"><view class="section-title">课程信息</view><view class="info-grid"><view wx:for="{{info}}" wx:key="label"><text>{{item.symbol}}</text><view><text>{{item.label}}</text><text>{{item.value}}</text></view></view></view></view>
  <view class="section-card coach-card"><view class="section-title">教练与班级</view><view><image src="{{avatar}}" mode="aspectFill" /><view><text>{{course.coach}}　<text>执行教练</text></text><text>课程级别：{{course.level}}</text></view><view><text>{{course.badge}}</text><text>计划学员{{course.planned}}人</text></view></view></view>
  <view class="progress-card"><text>点名完成情况</text><view class="ring green">{{course.attendance}}%</view><view><text>计划人数</text><text>{{course.planned}}人</text></view><view><text>已点名</text><text>{{course.actual}}人</text></view><view><text>未点名</text><text>待核对</text></view><button bindtap="attendance">查看点名</button></view>
  <view class="progress-card"><text>课程计划完成情况</text><view class="ring orange">75%</view><view><text>计划内容</text><text>8项</text></view><view><text>已完成</text><text>6项</text></view><view><text>未完成</text><text>2项</text></view><button bindtap="change">调整课程</button></view>
  <view class="progress-card"><text>课后评价进度</text><view class="ring orange">40%</view><view><text>待评价学员</text><text>6人</text></view><view><text>已评价学员</text><text>4人</text></view><button>查看评价</button></view>
  <view class="section-card"><view class="section-heading"><text>课程变更记录</text><text>查看全部 ›</text></view><view class="change-row" wx:for="{{changes}}" wx:key="time"><text>↻</text><view><text>{{item.title}}　<text>{{item.tag}}</text></text><text>{{item.detail}}</text></view><text>{{item.time}}</text></view></view>
  <view class="bottom-actions"><button bindtap="change">调整课程</button><button bindtap="cancel">停课处理</button></view><view class="safe-space"></view>
</view></scroll-view></view>
