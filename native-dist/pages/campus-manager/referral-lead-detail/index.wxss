page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx}.back-button{position:absolute;left:24rpx;bottom:0;width:60rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:29rpx;height:29rpx}.page-scroll{height:100%}.content{padding:18rpx 32rpx 0}.lead-card,.progress-card,.action-card{border:1rpx solid #394248;border-radius:17rpx;background:linear-gradient(135deg,#182026,#0d1216)}.lead-card{padding:24rpx}.lead-heading{display:grid;grid-template-columns:110rpx 1fr 110rpx;gap:18rpx;align-items:center;padding-bottom:20rpx;border-bottom:1rpx solid #343d43}.lead-icon{width:98rpx;height:98rpx;border:2rpx solid #414a50;border-radius:50%;display:flex;align-items:center;justify-content:center}.lead-icon image{width:55rpx;height:55rpx}.lead-heading>view:nth-child(2)>view{display:flex;align-items:center;gap:10rpx}.lead-heading>view:nth-child(2)>view text:first-child{font-size:30rpx;font-weight:800}.lead-heading>view:nth-child(2)>view text:last-child{padding:5rpx 9rpx;border:1rpx solid #ff8500;border-radius:8rpx;color:#ff8500;font-size:15rpx}.lead-heading>view:nth-child(2)>text{display:block;margin-top:10rpx;color:#b4b9bd;font-size:21rpx}.lead-heading>view:last-child text{display:block}.lead-heading>view:last-child text:first-child{color:#929aa0;font-size:16rpx}.lead-heading>view:last-child text:last-child{margin-top:7rpx;font-size:22rpx}.info-row{display:flex;justify-content:space-between;padding:18rpx 8rpx;border-top:1rpx solid #343d43;font-size:20rpx}.info-row:first-of-type{border-top:0}.info-row text:first-child{color:#b0b6ba}.progress-card{margin-top:18rpx;padding:24rpx}.progress-card>text,.action-card>text:first-child{font-size:27rpx;font-weight:800}.progress-line{display:grid;grid-template-columns:repeat(3,1fr);margin-top:35rpx}.progress-line>view{position:relative;text-align:center;color:#7d858b;font-size:35rpx}.progress-line>view:before{content:"";position:absolute;left:-50%;right:50%;top:22rpx;height:4rpx;background:#5a6369}.progress-line>view:first-child:before{display:none}.progress-line>view.done{color:#ff8500}.progress-line>view.done:before{background:#ff8500}.progress-line text{display:block}.progress-line text:first-of-type{margin-top:10rpx;color:#d1d5d7;font-size:20rpx}.progress-line text:last-child{margin-top:5rpx;color:#858d93;font-size:15rpx}.note-row{display:grid;grid-template-columns:150rpx 1fr 40rpx;margin-top:30rpx;padding:18rpx;border:1rpx solid #3d464c;border-radius:10rpx;font-size:19rpx}.note-row text:nth-child(2){color:#8e969c}.action-card{margin-top:18rpx;padding:24rpx}.action-card>text:nth-child(2){display:block;margin-top:8rpx;color:#929aa0;font-size:19rpx}.action-row{display:grid;grid-template-columns:70rpx 1fr 45rpx;align-items:center;margin-top:13rpx;padding:18rpx;border:1rpx solid #3d464c;border-radius:12rpx}.action-row.active{border-color:#ff8500;background:rgba(255,130,0,.06)}.action-row>text:first-child{color:#ff8500;font-size:35rpx}.action-row>view text{display:block}.action-row>view text:first-child{font-size:23rpx}.action-row>view text:last-child{margin-top:5rpx;color:#8f979d;font-size:17rpx}.action-row>text:last-child{color:#ff8500;font-size:25rpx}.primary-button{margin-top:20rpx;height:80rpx;line-height:80rpx;border-radius:12rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:27rpx;font-weight:800}.safe-space{height:45rpx}
