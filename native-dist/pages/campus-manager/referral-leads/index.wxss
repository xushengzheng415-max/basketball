page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97)}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:8rpx;color:#d7dade;font-size:20rpx}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:18rpx 34rpx 0}.page-heading{font-size:45rpx;font-weight:900}.metric-grid{display:grid;grid-template-columns:repeat(3,1fr);margin-top:24rpx;padding:20rpx;border:1rpx solid #ff8500;border-radius:18rpx;background:linear-gradient(135deg,#182026,#0d1216)}.metric-grid>view{display:flex;align-items:center;justify-content:center;gap:15rpx;border-left:1rpx solid #343d43}.metric-grid>view:first-child{border-left:0}.metric-grid>view>text{color:#ff8500;font-size:36rpx}.metric-grid>view>view text{display:block}.metric-grid>view>view text:first-child{color:#aeb5ba;font-size:20rpx}.metric-grid>view>view text:last-child{margin-top:4rpx;font-size:38rpx;font-weight:800}.tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:18rpx;margin-top:20rpx}.tabs view{height:62rpx;line-height:62rpx;border:1rpx solid #3f484e;border-radius:14rpx;text-align:center;color:#aeb5ba;font-size:21rpx}.tabs view.active{border-color:#ff8500;color:#ff8500;background:linear-gradient(135deg,rgba(255,130,0,.32),rgba(255,130,0,.08))}.lead-card{display:grid;grid-template-columns:110rpx 1fr 160rpx;gap:16rpx;align-items:center;margin-top:15rpx;padding:20rpx;border:1rpx solid #394248;border-radius:17rpx;background:linear-gradient(135deg,#182026,#0d1216)}.lead-icon{width:98rpx;height:98rpx;border:2rpx solid #424b51;border-radius:50%;display:flex;align-items:center;justify-content:center}.lead-icon image{width:54rpx;height:54rpx}.lead-copy>view{display:flex;align-items:center;gap:10rpx}.lead-copy>view text:first-child{font-size:27rpx;font-weight:800}.lead-copy>view text:last-child{padding:4rpx 8rpx;border:1rpx solid #ff8500;border-radius:8rpx;color:#ff8500;font-size:15rpx}.lead-copy>text{display:block;margin-top:8rpx;color:#a2a9ae;font-size:17rpx}.owner{align-self:start;margin-top:8rpx;color:#b8bdc0;font-size:17rpx}.lead-card button{grid-column:3;height:54rpx;line-height:54rpx;border-radius:10rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:19rpx}.source-note{text-align:center;margin-top:18rpx;color:#8e969c;font-size:18rpx}.primary-button{margin-top:18rpx;height:78rpx;line-height:78rpx;border-radius:12rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:28rpx;font-weight:800}.safe-space{height:45rpx}
