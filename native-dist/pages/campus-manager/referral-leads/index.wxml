<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /><text>返回工作台</text></view></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content"><view class="page-heading">转介绍线索</view><view class="metric-grid"><view wx:for="{{metrics}}" wx:key="label"><text>{{item.symbol}}</text><view><text>{{item.label}}</text><text>{{item.value}}</text></view></view></view><view class="tabs"><view class="{{item.activeClass}}" wx:for="{{tabs}}" wx:key="key" data-key="{{item.key}}" bindtap="switchTab">{{item.label}}</view></view><view class="lead-card" wx:for="{{leads}}" wx:key="name"><view class="lead-icon"><image src="{{icons.user}}" mode="aspectFit" /></view><view class="lead-copy"><view><text>{{item.name}}</text><text>新线索</text></view><text>⌘ 来源：{{item.source}}</text><text>♙ 孩子年龄：{{item.age}}</text><text>☎ 手机号：{{item.phone}}</text></view><view class="owner">♙ 负责人：{{item.owner}}</view><button bindtap="openLead">去跟进</button></view><view class="source-note">ⓘ 线索来源于家长分享与赛事内容</view><button class="primary-button" bindtap="next">处理下一条</button><view class="safe-space"></view></view></scroll-view></view>
