page{height:100%;background:#05080b;color:#f4f5f6}.page{height:100vh;overflow:hidden;background:radial-gradient(circle at 80% 0,rgba(255,112,0,.08),transparent 28%),linear-gradient(180deg,#080c10,#05080b)}.nav{position:absolute;z-index:8;left:0;right:0;box-sizing:content-box;display:flex;align-items:center;justify-content:center}.nav>text{font-size:28rpx;font-weight:850}.back{position:absolute;left:28rpx;display:flex;align-items:center;gap:10rpx;font-size:19rpx}.back image{width:26rpx;height:26rpx}.scroll{height:100%}.content{padding:0 30rpx}.intro{text-align:center;margin:10rpx 0 21rpx}.intro text{display:block}.intro text:first-child{font-size:39rpx;font-weight:900;letter-spacing:3rpx}.intro text:last-child{margin-top:9rpx;color:#aeb3b7;font-size:18rpx}.form-card{margin-bottom:14rpx;padding:0 20rpx 15rpx;border:1rpx solid #343b41;border-radius:14rpx;background:linear-gradient(105deg,#12181d,#0f1419)}.card-title{height:62rpx;display:flex;align-items:center;gap:11rpx;color:#ff7900;font-size:24rpx;font-weight:850}.card-title image{width:29rpx;height:29rpx}.field{min-height:68rpx;display:grid;grid-template-columns:145rpx 1fr;align-items:center}.field>text{font-size:20rpx;font-weight:750}.field>text text{color:#ff5349}.input-box,.picker{height:58rpx;padding:0 15rpx;box-sizing:border-box;display:flex;align-items:center;border:1rpx solid #495158;border-radius:9rpx;background:#171d22}.input-box input{flex:1;height:58rpx;color:#fff;font-size:18rpx}.input-box>text{color:#8e969c;font-size:15rpx}.picker{justify-content:space-between;color:#aeb4b8;font-size:18rpx}.picker>text:first-child:not(:empty){color:#f3f4f5}.picker>text:nth-last-child(2){flex:1}.picker>text:last-child{font-size:26rpx}.stage-field{align-items:start;padding-top:8rpx}.stage-field>text{padding-top:24rpx}.stage-options{display:grid;grid-template-columns:repeat(3,1fr);gap:17rpx}.stage{height:75rpx;display:flex;align-items:center;justify-content:center;gap:8rpx;border:1rpx solid #4a5258;border-radius:10rpx;font-size:18rpx}.stage view{width:34rpx;height:40rpx;line-height:40rpx;text-align:center;border:2rpx solid #cfd2d5;border-radius:25% 25% 40% 40%;font-size:11rpx}.stage.active{border-color:#ff7900;background:linear-gradient(100deg,#ff6000,#ff8c12);color:#fff}.stage.active view{border-color:#fff}.compact-card{padding-bottom:8rpx}.weekdays{display:grid;grid-template-columns:repeat(7,1fr);gap:9rpx}.day{height:50rpx;line-height:50rpx;text-align:center;border:1rpx solid #485057;border-radius:8rpx;color:#c1c5c8;font-size:16rpx}.day.active{border-color:#ff7900;background:linear-gradient(100deg,#ff6200,#ff8a0f);color:#fff}.stepper{display:grid;grid-template-columns:57rpx 145rpx 57rpx 40rpx;align-items:center;gap:17rpx}.stepper view,.stepper>text:nth-child(2){height:57rpx;line-height:57rpx;text-align:center;border:1rpx solid #4a5258;border-radius:9rpx;font-size:22rpx}.stepper .plus{border-color:#ff7900;background:linear-gradient(100deg,#ff6200,#ff8a0f);font-size:29rpx}.stepper>text:last-child{font-size:18rpx}.time-select{display:grid;grid-template-columns:1fr 45rpx 1fr;align-items:center;text-align:center}.time-select picker view{height:58rpx;line-height:58rpx;border:1rpx solid #4a5258;border-radius:9rpx;background:#171d22;font-size:20rpx}.time-select>text{color:#8f969c}.duration{margin:-2rpx 0 6rpx 145rpx;color:#858d93;font-size:16rpx}.actions{display:grid;grid-template-columns:1fr 1fr;gap:17rpx;margin-top:18rpx}.actions view{height:70rpx;line-height:70rpx;text-align:center;border:1rpx solid #ff7900;border-radius:10rpx;color:#ff7900;font-size:22rpx;font-weight:750}.actions view:last-child{background:linear-gradient(100deg,#ff5e00,#ff8b10);color:#fff}.safe{height:35rpx}
