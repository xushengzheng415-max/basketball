<view class="page"><view class="nav" style="padding-top:{{navTop}}px;height:{{navHeight}}px"><view class="back" bindtap="goBack"><image src="{{icons.back}}"/><text>返回排课</text></view></view><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height:{{navSpacer}}px"></view><view class="content">
  <view class="headline"><view><text>排课冲突处理</text><text>智能检测排课冲突，选择最优解决方案</text></view><view class="count-card"><image src="{{icons.warning}}"/><view><text>2</text><text>处冲突</text><text>需要处理</text></view></view></view>
  <view class="conflict" wx:for="{{conflicts}}" wx:key="id"><view class="conflict-title"><text>{{item.number}}</text><text>{{item.title}}</text></view><view class="conflict-note">●　{{item.note}}</view>
    <view class="compare"><view class="course-card"><text>{{item.current.flag}}</text><text>{{item.current.title}}</text><text>◷　{{item.current.time}}</text><text>⌖　{{item.current.venue}}</text><text>♙　{{item.current.coach}}</text><view><text>♧　{{item.current.people}}</text><text class="normal">● {{item.current.status}}</text></view></view><view class="versus">VS</view><view class="course-card other"><text>{{item.other.flag}}</text><text>{{item.other.title}}</text><text>◷　{{item.other.time}}</text><text>⌖　{{item.other.venue}}</text><text>♙　{{item.other.coach}}</text><view><text>♧　{{item.other.people}}</text><text class="bad">● {{item.other.status}}</text></view></view></view>
    <view class="suggestion"><text>♧　建议方案</text><text>{{item.suggestion}}</text></view>
    <view class="resolve-actions"><view data-id="{{item.id}}" data-action="current" bindtap="resolveConflict"><text>▣</text><view><text>调整本课程</text><text>修改本课程时间</text></view></view><view data-id="{{item.id}}" data-action="other" bindtap="resolveConflict"><text>↔</text><view><text>调整冲突课程</text><text>修改冲突课程时间</text></view></view><view data-id="{{item.id}}" data-action="ignore" bindtap="resolveConflict"><text>▤</text><view><text>忽略并记录</text><text>保留冲突并记录原因</text></view></view></view>
  </view>
  <view class="finish" bindtap="finish">✓　完成冲突处理</view><view class="safe"></view>
</view></scroll-view></view>
