page{height:100%;background:#05080b;color:#f3f4f5}.page{height:100vh;overflow:hidden;background:radial-gradient(circle at 90% 4%,rgba(255,104,0,.12),transparent 30%),linear-gradient(180deg,#080b0e,#05080b)}.nav{position:absolute;z-index:8;left:0;right:0;box-sizing:content-box;display:flex;align-items:center}.back{margin-left:29rpx;display:flex;align-items:center;gap:10rpx;font-size:17rpx}.back image{width:26rpx;height:26rpx}.scroll{height:100%}.content{padding:0 27rpx}.headline{min-height:176rpx;display:grid;grid-template-columns:1fr 210rpx;align-items:center}.headline>view:first-child text{display:block}.headline>view:first-child text:first-child{font-size:46rpx;font-weight:900;letter-spacing:2rpx}.headline>view:first-child text:last-child{margin-top:13rpx;color:#a6adb2;font-size:19rpx}.count-card{height:112rpx;padding:0 20rpx;display:flex;align-items:center;gap:16rpx;border:1rpx solid #ff7900;border-radius:13rpx;background:#11171b}.count-card image{width:57rpx;height:57rpx}.count-card view{display:grid;grid-template-columns:auto auto}.count-card view text:first-child{grid-row:1/3;color:#ff7900;font-size:47rpx;font-weight:900}.count-card view text:nth-child(2){align-self:end;font-size:17rpx}.count-card view text:last-child{color:#a9b0b5;font-size:15rpx}.conflict{margin-bottom:20rpx;padding:23rpx 20rpx;border:1rpx solid #343d43;border-radius:14rpx;background:linear-gradient(105deg,#11181d,#0d1317)}.conflict-title{display:flex;align-items:center;gap:22rpx}.conflict-title text:first-child{padding:10rpx 21rpx;border-radius:7rpx;background:linear-gradient(100deg,#ff5e00,#ff8b10);font-size:18rpx;font-weight:750}.conflict-title text:last-child{font-size:27rpx;font-weight:850}.conflict-note{margin:15rpx 0 18rpx;color:#aeb4b8;font-size:16rpx}.conflict-note::first-letter{color:#ff7900}.compare{position:relative;display:grid;grid-template-columns:1fr 1fr;gap:24rpx}.course-card{min-height:252rpx;padding:21rpx;box-sizing:border-box;border:1rpx solid #414950;border-radius:11rpx;background:#151b20}.course-card>text{display:block}.course-card>text:first-child{width:max-content;padding:6rpx 13rpx;border-radius:6rpx;background:#ff6500;font-size:15rpx}.course-card.other>text:first-child{background:#e44343}.course-card>text:nth-child(2){margin:20rpx 0;font-size:25rpx;font-weight:800}.course-card>text:nth-child(n+3){margin-top:13rpx;color:#c2c6c9;font-size:17rpx}.course-card>view{margin-top:18rpx;padding-top:16rpx;display:flex;justify-content:space-between;border-top:1rpx solid #3a4248;font-size:16rpx}.normal{color:#48cc50}.bad{color:#ff5b39}.versus{position:absolute;z-index:2;left:50%;top:47%;width:51rpx;height:51rpx;margin-left:-26rpx;line-height:51rpx;text-align:center;border:2rpx solid #ff7900;border-radius:50%;background:#0a0e11;color:#ff7900;font-size:20rpx;font-weight:850}.suggestion{margin:20rpx 2rpx 15rpx;display:flex;gap:14rpx;font-size:15rpx}.suggestion text:first-child{color:#ff7900;font-weight:750}.suggestion text:last-child{color:#aeb4b8}.resolve-actions{display:grid;grid-template-columns:repeat(3,1fr);gap:13rpx}.resolve-actions>view{min-height:86rpx;padding:13rpx;box-sizing:border-box;display:flex;align-items:center;gap:12rpx;border:1rpx solid #444c52;border-radius:9rpx}.resolve-actions>view>text{color:#ff7900;font-size:29rpx}.resolve-actions>view>view text{display:block}.resolve-actions>view>view text:first-child{font-size:17rpx;font-weight:700}.resolve-actions>view>view text:last-child{margin-top:5rpx;color:#929a9f;font-size:13rpx}.resolve-actions>view:last-child>text{color:#e6e8ea}.finish{height:79rpx;line-height:79rpx;margin:8rpx 0 0;text-align:center;border-radius:10rpx;background:linear-gradient(100deg,#ff5d00,#ff8b10);font-size:29rpx;font-weight:850}.safe{height:35rpx}
