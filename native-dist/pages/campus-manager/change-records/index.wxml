<view class="page"><view class="nav" style="padding-top:{{navTop}}px;height:{{navHeight}}px"><view class="back" bindtap="goBack"><image src="{{icons.back}}"/><text>返回排课</text></view></view><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height:{{navSpacer}}px"></view><view class="content">
  <view class="headline"><text>课程变更记录</text><text>记录课程相关变更，所有调整可追溯、可管理</text></view>
  <view class="filters"><view wx:for="{{filters}}" wx:key="*this" data-index="{{index}}" bindtap="chooseFilter"><text>{{index}}</text><text>{{item}}</text><text>⌄</text></view></view>
  <view class="record-count">共 4 条变更记录</view>
  <view class="timeline"><view class="record" wx:for="{{records}}" wx:key="type"><view class="timeline-icon">{{item.icon}}</view><view class="record-card"><view class="record-head"><view><text>{{item.type}}</text><text class="{{item.statusClass}}">{{item.status}}</text></view><text>{{item.time}}</text></view><view class="change"><view><text>变更前</text><text wx:for="{{item.before}}" wx:for-item="line" wx:key="*this">{{line}}</text></view><text class="arrow">→</text><view><text>变更后</text><text wx:for="{{item.after}}" wx:for-item="line" wx:key="*this">{{line}}</text></view></view><view class="record-foot"><view><text>发起人</text><image src="{{item.initiatorAvatar}}" mode="aspectFill"/><view><text>{{item.initiator}}</text><text>{{item.initiatorRole}}</text></view></view><view><text>审批人</text><image src="{{item.approverAvatar}}" mode="aspectFill"/><view><text>{{item.approver}}</text><text>{{item.approverRole}}</text></view></view><view data-type="{{item.type}}" bindtap="viewDetail">查看详情</view></view></view></view></view>
  <view class="actions"><view bindtap="exportRecords">⇩　导出记录</view><view bindtap="filterRecords"><image src="{{icons.filter}}"/>筛选记录</view></view><view class="safe"></view>
</view></scroll-view></view>
