page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97)}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:8rpx;color:#aeb5ba;font-size:20rpx}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:18rpx 30rpx 0}.page-heading text{display:block}.page-heading text:first-child{font-size:43rpx;font-weight:900}.page-heading text:last-child{margin-top:8rpx;color:#90989e;font-size:20rpx}.publish-card{margin-top:18rpx;padding:20rpx;border:1rpx solid #394248;border-radius:17rpx;background:linear-gradient(135deg,#182026,#0d1216)}.label{color:#8e969c;font-size:17rpx}.event-title{display:flex;align-items:center;gap:12rpx;margin-top:8rpx}.event-title text:first-child{font-size:31rpx;font-weight:800}.event-title text:last-child{padding:5rpx 9rpx;border:1rpx solid #ff8500;border-radius:7rpx;color:#ff8500;font-size:15rpx}.score-card{display:grid;grid-template-columns:1fr 1.2fr 1fr 1.3fr;align-items:center;margin-top:16rpx;padding:20rpx;border:2rpx solid #ff8500;border-radius:14rpx;background-size:cover;background-position:center;box-shadow:inset 0 0 0 1000rpx rgba(4,8,11,.78)}.score-card>view{text-align:center}.score-card>view>text{display:block}.score-card>view>text:first-child{font-size:39rpx}.score-card>view:nth-child(2)>text:first-child{font-size:34rpx;font-weight:800}.score-card>view:nth-child(2)>text:first-child text{color:#ff8500}.score-card>view>text:last-child{margin-top:6rpx;font-size:18rpx}.mvp{border-left:1rpx solid #424b51}.mvp>text:first-child{color:#ff8500;font-size:18rpx!important}.mvp image{width:62rpx;height:62rpx;margin:7rpx auto 0;border:2rpx solid #ff8500;border-radius:50%}.mvp>text:nth-child(3){font-size:22rpx!important;font-weight:800}.mvp>text:last-child{font-size:14rpx!important}.block-title{display:block;margin:20rpx 0 12rpx;font-size:24rpx;font-weight:800}.content-list{border:1rpx solid #394248;border-radius:12rpx;padding:0 15rpx}.content-list>view{display:grid;grid-template-columns:45rpx 1fr 35rpx;align-items:center;padding:14rpx 0;border-top:1rpx solid #343d43}.content-list>view:first-child{border-top:0}.content-list>view>view:first-child{color:#ff8500;font-size:27rpx}.content-list>view>view:nth-child(2) text{display:block}.content-list>view>view:nth-child(2) text:first-child{font-size:20rpx}.content-list>view>view:nth-child(2) text:last-child{margin-top:4rpx;color:#858d93;font-size:15rpx}.content-list>view>text{width:28rpx;height:28rpx;border-radius:6rpx;background:#ff8500;line-height:28rpx;text-align:center}.scope-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}.scope-grid>view{padding:15rpx;border:1rpx solid #3d464c;border-radius:10rpx}.scope-grid>view.active{border-color:#ff8500;background:rgba(255,130,0,.07)}.scope-grid text{display:block}.scope-grid text:first-child{font-size:19rpx}.scope-grid text:last-child{margin-top:5rpx;color:#858d93;font-size:15rpx}.privacy{margin-top:13rpx;padding:14rpx;border-radius:9rpx;background:#141b20;color:#ff8500;font-size:17rpx}.privacy text{display:block;margin-top:4rpx;color:#858d93;font-size:14rpx}.caption-preview{display:flex;gap:14rpx;padding:14rpx;border:1rpx solid #394248;border-radius:10rpx}.caption-preview image{width:130rpx;height:105rpx;border-radius:8rpx}.caption-preview>text{flex:1;color:#b7bcc0;font-size:17rpx;line-height:1.55}.caption-preview>text text{display:block;color:#ff8500}.bottom-actions{display:grid;grid-template-columns:1fr 1fr;gap:15rpx;margin-top:16rpx}.bottom-actions button{height:74rpx;line-height:74rpx;border:1rpx solid #ff8500;border-radius:14rpx;background:transparent;color:#ff8500;font-size:23rpx;font-weight:800}.bottom-actions button:last-child{background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff}.safe-space{height:45rpx}
