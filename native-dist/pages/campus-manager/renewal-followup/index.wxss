page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:29rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;width:60rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:29rpx;height:29rpx}.page-scroll{height:100%}.content{padding:18rpx 20rpx 0}.summary-card,.form-card{border:1rpx solid #394248;border-radius:16rpx;background:linear-gradient(135deg,#182026,#0d1216)}.summary-card{padding:22rpx}.section-title{padding-left:10rpx;border-left:5rpx solid #ff8500;font-size:25rpx;font-weight:800}.student{display:flex;align-items:center;margin-top:20rpx}.student>image{width:82rpx;height:82rpx;border-radius:50%}.student>view{flex:1;margin-left:16rpx}.student>view>view{display:flex;align-items:center;gap:10rpx}.student>view>view text:first-child{font-size:27rpx;font-weight:800}.student>view>view text:nth-child(2){padding:3rpx 7rpx;border-radius:4rpx;background:#264d85;color:#72a8ff;font-size:15rpx}.student>view>text{display:block;margin-top:8rpx;color:#a0a7ac;font-size:17rpx}.student>view>text text{color:#ff8500}.student>text{padding:7rpx 12rpx;border:1rpx solid #ff8500;border-radius:8rpx;color:#ff8500;font-size:17rpx}.summary-grid{display:grid;grid-template-columns:repeat(3,1fr);margin-top:20rpx;padding-top:16rpx;border-top:1rpx solid #343d43}.summary-grid>view{text-align:center;border-left:1rpx solid #343d43}.summary-grid>view:first-child{border-left:0}.summary-grid text{display:block}.summary-grid text:first-child{color:#858d93;font-size:15rpx}.summary-grid text:last-child{margin-top:6rpx;color:#ff8500;font-size:18rpx}.form-card{margin-top:18rpx;padding:20rpx}.form-row{display:grid;grid-template-columns:190rpx 1fr;align-items:center;padding:20rpx 0;border-top:1rpx solid #343d43}.form-row:first-child{border-top:0}.form-row>text{font-size:19rpx}.methods,.results{display:grid;gap:10rpx}.methods{grid-template-columns:repeat(3,1fr)}.results{grid-template-columns:repeat(5,1fr)}.methods text,.results text{height:52rpx;line-height:52rpx;border:1rpx solid #4b555b;border-radius:8rpx;text-align:center;color:#b7bcc0;font-size:17rpx}.methods text.active,.results text.active{border-color:#ff8500;color:#ff8500;background:rgba(255,130,0,.07)}.textarea-row{align-items:start}.textarea-row textarea{width:100%;height:100rpx;padding:12rpx;border:1rpx solid #4a5359;border-radius:8rpx;box-sizing:border-box;color:#fff;font-size:17rpx}.select-value{height:54rpx;line-height:54rpx;padding:0 15rpx;border:1rpx solid #4a5359;border-radius:8rpx;color:#969da3;font-size:17rpx}.upload-row>view>text{color:#858d93;font-size:15rpx}.upload{width:92rpx;height:92rpx;margin-top:12rpx;border:1rpx solid #596269;border-radius:8rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:28rpx}.upload text{font-size:14rpx}.primary-button{margin-top:18rpx;height:76rpx;line-height:76rpx;border-radius:10rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:24rpx;font-weight:800}.safe-space{height:50rpx}
