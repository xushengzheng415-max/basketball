page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;width:60rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:18rpx 30rpx 0}.page-heading text{display:block}.page-heading text:first-child{font-size:40rpx;font-weight:900}.page-heading text:last-child{margin-top:8rpx;color:#90989e;font-size:19rpx}.class-hero,.section-card{border:1rpx solid #394248;border-radius:18rpx;background:linear-gradient(135deg,#182026,#0d1216)}.class-hero{position:relative;display:grid;grid-template-columns:90rpx 1fr;margin-top:18rpx;padding:22rpx;border-color:#ff8500}.ball{font-size:56rpx}.class-hero>view:nth-child(2) text{display:block}.class-hero>view:nth-child(2) text:first-child{font-size:33rpx;font-weight:800}.class-hero>view:nth-child(2) text:last-child{margin-top:8rpx;color:#a2a9ae;font-size:20rpx}.summary-grid{grid-column:1/3;display:grid;grid-template-columns:repeat(3,1fr);margin-top:20rpx;padding:18rpx;border:1rpx solid #3d464c;border-radius:12rpx}.summary-grid>view{text-align:center;border-left:1rpx solid #3d464c}.summary-grid>view:first-child{border-left:0}.summary-grid text{display:inline}.summary-grid text:first-child{font-size:34rpx;font-weight:800}.summary-grid text:nth-child(2){margin-left:5rpx;font-size:18rpx}.summary-grid text:last-child{display:block;margin-top:5rpx;color:#8e969c;font-size:16rpx}.section-card{margin-top:15rpx;padding:22rpx}.section-title{font-size:26rpx;font-weight:800;margin-bottom:15rpx}.theme-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:13rpx}.theme-grid text{padding:17rpx;border:1rpx solid #6b451c;border-radius:11rpx;text-align:center;color:#ff8500;font-size:20rpx}.highlight-row{display:flex;gap:12rpx;margin-top:13rpx;color:#b5babd;font-size:19rpx}.highlight-row text:first-child{color:#ff8500}.student-row{display:flex;align-items:center;gap:15rpx;margin-top:13rpx}.student-row>view:first-child{width:55rpx;height:55rpx;border:2rpx solid #596269;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#8e969c}.student-row>view:last-child text{display:block}.student-row>view:last-child text:first-child{font-size:21rpx}.student-row>view:last-child text:last-child{margin-top:4rpx;color:#929aa0;font-size:17rpx}.quote{display:grid;grid-template-columns:50rpx 1fr;gap:12rpx;padding:16rpx;border:1rpx solid #394248;border-radius:11rpx;background:#141b20}.quote>view:first-child{width:42rpx;height:42rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:#8a3f0b}.quote>view:nth-child(2) text{display:block}.quote>view:nth-child(2) text:first-child{font-size:19rpx}.quote>view:nth-child(2) text:last-child{color:#858d93;font-size:15rpx}.quote>text{grid-column:1/3;color:#c3c7ca;font-size:19rpx;line-height:1.6}.bottom-actions{display:grid;grid-template-columns:1fr 1fr;gap:15rpx;margin-top:16rpx}.bottom-actions button{height:74rpx;line-height:74rpx;border:1rpx solid #ff8500;border-radius:14rpx;background:transparent;color:#ff8500;font-size:23rpx;font-weight:800}.bottom-actions button:last-child{background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff}.safe-space{height:45rpx}
