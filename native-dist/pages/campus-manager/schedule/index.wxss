page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:7rpx;color:#ff8500;font-size:19rpx}.back-button image{width:27rpx;height:27rpx}.page-scroll{height:100%}.content{padding:18rpx 26rpx 0}.selector-grid{display:grid;grid-template-columns:1fr 1fr;gap:16rpx}.selector-grid>view,.stat-grid,.week-strip,.course-card,.quick-card,.pc-tip{border:1rpx solid #394248;border-radius:14rpx;background:linear-gradient(135deg,#182026,#0d1216)}.selector-grid>view{display:grid;grid-template-columns:38rpx 1fr 24rpx;align-items:center;padding:17rpx}.selector-grid image{width:31rpx;height:31rpx}.selector-grid text{font-size:20rpx}.stat-grid{display:grid;grid-template-columns:1fr 1fr;margin-top:14rpx;overflow:hidden}.stat-grid>view{display:flex;justify-content:space-between;align-items:center;padding:18rpx;border-top:1rpx solid #343d43;border-left:1rpx solid #343d43}.stat-grid>view:nth-child(-n+2){border-top:0}.stat-grid>view:nth-child(odd){border-left:0}.stat-grid>view>text:first-child{font-size:19rpx}.stat-grid>view>text:nth-child(2){color:#ff8500;font-size:36rpx;font-weight:800}.stat-grid>view>text:nth-child(2) text{font-size:16rpx}.week-strip{display:grid;grid-template-columns:repeat(7,1fr);margin-top:14rpx;padding:8rpx}.week-strip>view{text-align:center;padding:9rpx 4rpx;border-radius:9rpx}.week-strip>view.active{border:1rpx solid #ff8500;background:rgba(255,130,0,.2)}.week-strip text{display:block;font-size:16rpx}.week-strip text:last-child{margin-top:5rpx;color:#b8bdc0}.day-heading{display:flex;justify-content:space-between;margin:17rpx 2rpx 10rpx}.day-heading text:first-child{font-size:23rpx;font-weight:800}.day-heading text:last-child{color:#9aa1a6;font-size:17rpx}.course-card{display:grid;grid-template-columns:90rpx 54rpx 1fr 75rpx;gap:11rpx;align-items:center;margin-top:10rpx;padding:14rpx}.course-time{font-size:18rpx;line-height:1.4}.course-card>image{width:48rpx;height:48rpx;border-radius:50%}.course-copy>text{display:block}.course-copy>text:first-child{font-size:21rpx;font-weight:800}.course-copy>text:nth-child(2){margin-top:4rpx;color:#a1a8ad;font-size:16rpx}.course-copy>text:last-child{margin-top:6rpx;color:#a1a8ad;font-size:15rpx}.green{color:#59cf55!important}.orange{color:#ff8500!important}.course-card>view:last-child button{height:38rpx;line-height:38rpx;margin-top:5rpx;border:1rpx solid #ff8500;border-radius:7rpx;background:transparent;color:#ff8500;font-size:14rpx}.alert-row{margin-top:10rpx;padding:14rpx 18rpx;border:1rpx solid #ff8500;border-radius:10rpx;background:rgba(255,130,0,.08);font-size:18rpx}.alert-row text{float:right;color:#ff8500}.alert-row.red{border-color:#ff5151;color:#ff5151}.quick-card{margin-top:13rpx;padding:16rpx}.quick-card>view:first-child{display:flex;justify-content:space-between}.quick-card>view:first-child text:first-child{font-size:21rpx;font-weight:700}.quick-card>view:first-child text:last-child{color:#ff8500;font-size:15rpx}.quick-card>view:last-child{display:grid;grid-template-columns:repeat(3,1fr);gap:10rpx;margin-top:12rpx}.quick-card button{height:72rpx;border:1rpx solid #3d464c;border-radius:8rpx;background:transparent;color:#fff;font-size:17rpx}.quick-card button text{display:block;margin-top:4rpx;color:#858d93;font-size:13rpx}.pc-tip{margin-top:12rpx;padding:14rpx;color:#a0a7ac;font-size:16rpx}.pc-tip text{float:right;color:#4c96ff}.primary-button{margin-top:12rpx;height:74rpx;line-height:74rpx;border-radius:10rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:25rpx;font-weight:800}.safe-space{height:45rpx}
