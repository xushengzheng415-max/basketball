<view class="page-shell">
  <view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;">
    <view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /><text>返回负责人首页</text></view>
    <text>{{pageTitle}}</text>
  </view>
  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view style="height: {{navSpacer}}px;"></view>
    <view class="content">
      <view class="selector-grid"><view>浦东校区</view><view>本月</view></view>
      <view class="filter-tip" wx:if="{{filterTip}}" style="margin-top:18rpx;padding:16rpx 20rpx;border:1rpx solid rgba(255,133,31,.34);border-radius:14rpx;background:rgba(255,126,15,.08);color:#ff9638;font-size:19rpx;">{{filterTip}}</view>
      <view class="metric-grid"><view wx:for="{{metrics}}" wx:key="label"><text>{{item.symbol}}</text><view><text>{{item.label}}</text><text>{{item.value}}<text>个</text></text></view></view></view>
      <view class="tabs"><view class="{{item.activeClass}}" wx:for="{{tabs}}" wx:key="key" data-key="{{item.key}}" bindtap="switchTab">{{item.label}}</view></view>
      <view class="anomaly-card" wx:for="{{anomalies}}" wx:key="id">
        <view class="level {{item.tone}}"><text>⚠</text><text>{{item.level}}</text></view>
        <view class="anomaly-copy"><text>{{item.title}}</text><view><text>{{item.classInfo}}</text><text>{{item.person}}</text><text>影响　{{item.impact}}</text></view><view><text>触发规则：{{item.rule}}</text><text>责任人：{{item.owner}}</text><text>证据：{{item.evidence}}</text></view></view>
        <button data-id="{{item.id}}" bindtap="openAnomaly">{{item.action}} ›</button>
      </view>
      <view class="rules-card"><view class="section-heading"><text>智能校验规则</text><text>规则说明 ›</text></view><view class="rule-grid"><view wx:for="{{rules}}" wx:key="name"><text>{{item.name}}</text><view><view></view></view></view></view></view>
      <view class="records-card"><view class="section-heading"><text>最近更正记录</text><text data-id="record-001" bindtap="openRecord">查看更多 ›</text></view><view class="record-row" wx:for="{{records}}" wx:key="id" data-id="{{item.id}}" bindtap="openRecord"><text>{{item.name}}</text><text>更正时间　{{item.time}}</text><text>更正内容　{{item.content}}</text><text>{{item.status}}</text></view></view>
      <button class="primary-button" bindtap="batch">批量复核</button>
      <view class="safe-space"></view>
    </view>
  </scroll-view>
</view>
