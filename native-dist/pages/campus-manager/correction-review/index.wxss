page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97)}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:8rpx;color:#aeb5ba;font-size:22rpx}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:20rpx 28rpx 0}.page-heading>view{display:flex;align-items:center;gap:16rpx}.page-heading>view text:first-child{padding:7rpx 10rpx;border:1rpx solid #ff8500;border-radius:6rpx;color:#ff8500;font-size:20rpx}.page-heading>view text:last-child{font-size:42rpx;font-weight:900}.page-heading>text{display:block;margin-top:9rpx;color:#90989e;font-size:21rpx}.section-card{margin-top:18rpx;padding:20rpx;border:1rpx solid #394248;border-radius:16rpx;background:linear-gradient(135deg,#182026,#0d1216)}.section-title{padding-left:10rpx;border-left:6rpx solid #ff8500;font-size:26rpx;font-weight:800;margin-bottom:16rpx}.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:30rpx}.info-grid>view+view{border-left:1rpx solid #3a4349;padding-left:30rpx}.info-grid text{display:block;margin-top:7rpx}.info-grid>view>text:nth-child(odd){color:#8f979d;font-size:18rpx}.info-grid>view>text:nth-child(even){font-size:20rpx}.info-grid>view>text:nth-child(2) text{display:inline;padding:3rpx 8rpx;border:1rpx solid #ff8500;border-radius:8rpx;color:#ff8500;font-size:15rpx}.compare-table{border:1rpx solid #3a4349;border-radius:10rpx;overflow:hidden}.table-head,.table-row{display:grid;grid-template-columns:.7fr 1.4fr .25fr 1.4fr}.table-head{background:linear-gradient(90deg,#252d32,rgba(83,47,16,.55));color:#ff9a20;font-size:18rpx;font-weight:700}.table-head text,.table-row text{padding:11rpx;border-left:1rpx solid #333c42}.table-row{border-top:1rpx solid #333c42;color:#aeb5ba;font-size:17rpx}.table-row text:first-child{color:#d7dade}.table-row text:last-child{color:#ff8c00}.evidence-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12rpx}.evidence-grid>view{position:relative;height:106rpx;border:1rpx solid #455057;border-radius:8rpx;overflow:hidden}.evidence-grid image{width:100%;height:100%}.evidence-grid>view>text{position:absolute;left:0;right:0;bottom:0;padding:5rpx 8rpx;background:rgba(0,0,0,.65);font-size:16rpx}.evidence-count{display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:28rpx;color:#b8bdc0}.evidence-count text{position:static!important;background:none!important;font-size:16rpx!important}.reason-text{color:#b8bdc1;font-size:20rpx;line-height:1.55}.impact-grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx}.impact-grid>view{padding:16rpx;border:1rpx solid #4d4438;border-radius:10rpx}.impact-grid text{display:block}.impact-grid text:first-child{font-size:20rpx;font-weight:800}.impact-grid text:nth-child(2){margin-top:7rpx;color:#58cf65;font-size:19rpx}.impact-grid>view:last-child text:nth-child(2){color:#ff8500;text-align:right}.impact-grid text:last-child{margin-top:8rpx;color:#8e969c;font-size:16rpx}.check-row{display:grid;grid-template-columns:1fr 1.7fr .65fr;gap:10rpx;padding:11rpx;border-top:1rpx solid #353e44;color:#9fa6ab;font-size:16rpx}.check-row text:first-child{color:#e0e3e5}.check-row text:last-child{color:#62d44f;text-align:right}.check-result{padding:13rpx;border:1rpx solid #ff8500;border-radius:8rpx;background:rgba(255,130,0,.06)}.check-result text{display:block}.check-result text:first-child{color:#ff8500;font-size:20rpx;font-weight:700}.check-result text:last-child{margin-top:3rpx;color:#91999f;font-size:16rpx}.field-label{display:block;margin:10rpx 0;color:#9ca3a8;font-size:18rpx}.decision-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}.decision{height:66rpx;display:flex;align-items:center;justify-content:center;gap:7rpx;border:1rpx solid #4b555c;border-radius:10rpx;color:#b5babd;font-size:19rpx}.decision.active{border-color:#ff8500;color:#ff8500;background:rgba(255,130,0,.08)}textarea{width:100%;height:90rpx;padding:13rpx;border:1rpx solid #414a50;border-radius:8rpx;box-sizing:border-box;color:#fff;font-size:18rpx}.section-card button{margin-top:14rpx;height:72rpx;line-height:72rpx;border-radius:9rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:24rpx;font-weight:800}.safe-space{height:50rpx}
