<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /><text>返回</text></view></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content">
  <view class="page-heading"><view><text>M44</text><text>更正审核</text></view><text>请核对更正申请内容并完成审核</text></view>
  <view class="section-card"><view class="section-title">申请信息</view><view class="info-grid"><view><text>申请人</text><text>👤 李同学　<text>学员</text></text><text>所属校区</text><text>华南理工大学（五山校区）</text></view><view><text>提交时间</text><text>2025-05-20 14:32</text><text>课程</text><text>周三 19:00 基础班（室外场）</text></view></view></view>
  <view class="section-card"><view class="section-title">更正对比</view><view class="compare-table"><view class="table-head"><text></text><text>原始数据</text><text>→</text><text>申请更正为</text></view><view class="table-row" wx:for="{{comparisons}}" wx:key="label"><text>{{item.label}}</text><text>{{item.before}}</text><text>→</text><text>{{item.after}}</text></view></view></view>
  <view class="section-card"><view class="section-title">凭证材料</view><view class="evidence-grid"><view><image src="{{courtPhoto}}" mode="aspectFill" /><text>聊天记录</text></view><view><image src="{{courtPhoto}}" mode="aspectFill" /><text>场地照片</text></view><view><image src="{{courtPhoto}}" mode="aspectFill" /><text>通知截图</text></view><view class="evidence-count">＋<text>共 3 张</text></view></view></view>
  <view class="section-card"><view class="section-title">申请原因</view><text class="reason-text">因教练临时调整场地与时间，该课调整为补课并由王教练代课。</text></view>
  <view class="section-card"><view class="section-title">影响评估</view><view class="impact-grid"><view><text>◉ 课时平衡</text><text>无影响</text><text>更正后不影响学员已完成课时统计。</text></view><view><text>＄ 收入影响</text><text>+￥80</text><text>由常规课调整为补课，需退回差价。</text></view></view></view>
  <view class="section-card"><view class="section-title">规则校验</view><view class="check-row" wx:for="{{checks}}" wx:key="label"><text>⊙ {{item.label}}</text><text>{{item.detail}}</text><text>✓ 符合</text></view><view class="check-result"><text>校验结果：通过</text><text>符合更正规则要求</text></view></view>
  <view class="section-card"><view class="section-title">审核决策</view><text class="field-label">审核结果</text><view class="decision-grid"><view class="decision {{item.activeClass}}" wx:for="{{decisions}}" wx:key="key" data-key="{{item.key}}" bindtap="chooseDecision"><text>{{item.symbol}}</text><text>{{item.label}}</text></view></view><text class="field-label">审核备注（选填）</text><textarea maxlength="100" placeholder="请输入备注（选填）" value="{{note}}" bindinput="onNoteInput" /><button bindtap="confirmReview">确认审核</button></view><view class="safe-space"></view>
</view></scroll-view></view>
