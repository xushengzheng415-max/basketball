<view class="page-shell">
  <view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;">
    <view class="back-control" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /><text>返回课程总览</text></view>
  </view>
  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view style="height: {{navSpacer}}px;"></view>
    <view class="content">
      <view class="page-head">
        <text class="role-tag">校区负责人</text>
        <text class="page-title">点名监督</text>
        <text class="greeting">下午好，王校长</text>
      </view>

      <view wx:if="{{taskMode}}" class="task-guide">
        <view class="task-guide-head">
          <view><text class="task-guide-tag">待办处理</text><text>超时未点名课程</text></view>
          <text>{{taskGuide.progress}} / 3</text>
        </view>
        <view wx:if="{{taskGuide.completed}}" class="task-guide-complete">已完成全部业务动作，该待办已自动结束</view>
        <view wx:else>
          <view class="task-guide-row" wx:for="{{taskGuide.remainingSteps}}" wx:key="order">
            <view class="task-guide-number">{{item.order}}</view>
            <text>{{item.label}}</text>
          </view>
          <view wx:if="{{showTaskAction}}" style="display:flex;align-items:center;justify-content:center;min-height:68rpx;margin-top:14rpx;padding:0 18rpx;border-radius:13rpx;background:linear-gradient(100deg,#ff5c00,#ff921d);color:#fff;font-size:19rpx;font-weight:800;text-align:center;" aria-role="button" bindtap="runTaskAction">{{taskActionText}}</view>
          <text class="task-guide-note">{{taskActionHint}}</text>
        </view>
      </view>

      <view class="summary-card">
        <view class="summary-icon"><text>✓</text></view>
        <view class="metric" wx:for="{{metrics}}" wx:key="label">
          <text class="metric-label">{{item.label}}</text>
          <view class="metric-value tone-{{item.tone}}"><text>{{item.value}}</text><text>{{item.suffix}}</text></view>
        </view>
      </view>

      <view class="section-heading">
        <view><image src="{{icons.clock}}" mode="aspectFit" /><text>超时未点名</text></view>
        <text>2节超时</text>
      </view>

      <view class="course-card" wx:for="{{overdueCourses}}" wx:key="id" data-id="{{item.id}}" bindtap="openDetail">
        <view class="coach-avatar">{{item.symbol}}</view>
        <view class="course-main">
          <text class="course-title">{{item.title}}</text>
          <view class="course-meta"><image src="{{icons.user}}" mode="aspectFit" /><text>负责教练：{{item.coach}}</text></view>
          <view class="course-meta"><image src="{{icons.location}}" mode="aspectFit" /><text>{{item.venue}}</text></view>
          <view class="course-meta"><image src="{{icons.clock}}" mode="aspectFit" /><text>{{item.time}}</text></view>
        </view>
        <view class="course-side">
          <view class="overdue-copy">超时 <text class="tone-{{item.tone}}">{{item.minutes}}</text> 分钟</view>
          <button catchtap="remindCoach" data-coach="{{item.coach}}">提醒教练</button>
        </view>
      </view>

      <view class="section-heading anomaly-heading">
        <view><image src="{{icons.warning}}" mode="aspectFit" /><text>点名异常</text></view>
        <text>今日汇总</text>
      </view>
      <view class="anomaly-panel">
        <view class="anomaly-item" wx:for="{{anomalies}}" wx:key="label">
          <view class="anomaly-symbol tone-bg-soft-{{item.tone}}">{{item.symbol}}</view>
          <text>{{item.label}}</text>
          <view class="anomaly-value tone-{{item.tone}}"><text>{{item.value}}</text><text>{{item.suffix}}</text></view>
        </view>
      </view>

      <button class="primary-button" bindtap="remindAll"><text class="bell">♢</text>提醒全部待点名教练</button>
      <view class="safe-space"></view>
    </view>
  </scroll-view>
</view>
