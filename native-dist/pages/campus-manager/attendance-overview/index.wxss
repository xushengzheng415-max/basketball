page{height:100%;background:#05080b;color:#f6f7f8}.page-shell{height:100vh;overflow:hidden;background:radial-gradient(circle at 82% 4%,rgba(255,112,0,.11),transparent 25%),linear-gradient(180deg,#05080b,#080c10)}.custom-nav{position:absolute;z-index:10;left:0;right:0;box-sizing:content-box;pointer-events:none}.back-control{pointer-events:auto;display:flex;align-items:center;gap:7rpx;width:max-content;min-height:62rpx;margin-left:28rpx;padding:0 16rpx;border:1rpx solid #2b3239;border-radius:32rpx;background:rgba(5,8,11,.82);font-size:22rpx;color:#d9dde1}.back-control image{width:22rpx;height:22rpx}.page-scroll{height:100%}.content{padding:0 38rpx;box-sizing:border-box}.page-head{padding:8rpx 2rpx 24rpx}.role-tag{display:inline-flex;padding:7rpx 14rpx;border:1rpx solid #ff7200;border-radius:8rpx;color:#ff850f;font-size:18rpx}.page-title,.greeting{display:block}.page-title{margin-top:18rpx;font-size:42rpx;line-height:1.15;font-weight:800}.greeting{margin-top:8rpx;color:#9ca2a8;font-size:22rpx}.summary-card{display:grid;grid-template-columns:92rpx repeat(3,1fr);align-items:center;min-height:148rpx;padding:18rpx;border:1rpx solid rgba(255,114,0,.75);border-radius:20rpx;background:rgba(15,20,25,.96);box-sizing:border-box}.summary-icon{width:72rpx;height:72rpx;display:flex;align-items:center;justify-content:center;border:6rpx solid #ff8312;border-radius:14rpx;color:#ff8b1c;font-size:38rpx;font-weight:900;box-sizing:border-box}.metric{text-align:center;border-left:1rpx solid #30373e}.metric-label{display:block;color:#c4c8cc;font-size:20rpx}.metric-value{margin-top:10rpx;font-weight:800}.metric-value text:first-child{font-size:38rpx}.metric-value text:last-child{margin-left:4rpx;color:#a8afb6;font-size:17rpx}.section-heading{display:flex;align-items:center;justify-content:space-between;margin:28rpx 3rpx 14rpx}.section-heading>view{display:flex;align-items:center;gap:11rpx}.section-heading image{width:31rpx;height:31rpx}.section-heading view text{font-size:27rpx;font-weight:800}.section-heading>text{color:#ff7c08;font-size:23rpx;font-weight:700}.course-card{display:flex;align-items:center;gap:18rpx;min-height:176rpx;margin-bottom:16rpx;padding:22rpx;border:1rpx solid #313840;border-radius:20rpx;background:linear-gradient(135deg,#12181d,#0e1317);box-sizing:border-box}.coach-avatar{flex:0 0 92rpx;width:92rpx;height:92rpx;display:flex;align-items:center;justify-content:center;border:2rpx solid #ff7200;border-radius:50%;background:linear-gradient(145deg,#373d43,#12171b);font-size:33rpx;font-weight:800}.course-main{flex:1;min-width:0}.course-title{display:block;font-size:27rpx;font-weight:800}.course-meta{display:flex;align-items:center;gap:7rpx;margin-top:9rpx;color:#989fa6;font-size:18rpx}.course-meta image{width:24rpx;height:24rpx}.course-side{text-align:right}.overdue-copy{white-space:nowrap;color:#e2e4e6;font-size:19rpx}.overdue-copy text{font-size:32rpx;font-weight:800}.course-side button{height:54rpx;line-height:52rpx;margin:17rpx 0 0;padding:0 20rpx;border:1rpx solid #ff7200;border-radius:13rpx;background:transparent;color:#ff850f;font-size:19rpx}.anomaly-heading{margin-top:24rpx}.anomaly-panel{display:grid;grid-template-columns:repeat(3,1fr);padding:19rpx 0;border:1rpx solid #313840;border-radius:20rpx;background:#10161a}.anomaly-item{text-align:center;border-right:1rpx solid #30373e}.anomaly-item:last-child{border-right:0}.anomaly-symbol{width:47rpx;height:47rpx;line-height:47rpx;margin:0 auto 8rpx;border-radius:50%;font-size:19rpx;font-weight:800}.anomaly-item>text{display:block;color:#b9bec3;font-size:19rpx}.anomaly-value{margin-top:6rpx}.anomaly-value text:first-child{font-size:31rpx;font-weight:800}.anomaly-value text:last-child{margin-left:4rpx;color:#aab0b5;font-size:16rpx}.primary-button{height:84rpx;line-height:84rpx;margin:28rpx 0 0;border-radius:18rpx;background:linear-gradient(135deg,#ff6500,#ff931c);color:#fff;font-size:25rpx;font-weight:800;box-shadow:0 13rpx 26rpx rgba(255,98,0,.24)}.bell{margin-right:10rpx;font-size:32rpx}.safe-space{height:42rpx}.tone-orange{color:#ff7907}.tone-success{color:#61ce40}.tone-danger{color:#ff5357}.tone-warning{color:#ffb12a}.tone-bg-soft-orange{background:rgba(255,121,7,.16)}.tone-bg-soft-success{background:rgba(97,206,64,.14)}.tone-bg-soft-danger{background:rgba(255,83,87,.14)}.tone-bg-soft-warning{background:rgba(255,177,42,.14)}
.task-guide{margin-bottom:18rpx;padding:18rpx 20rpx;border:1rpx solid rgba(255,114,0,.72);border-radius:18rpx;background:linear-gradient(135deg,rgba(36,25,16,.96),rgba(15,20,25,.97))}.task-guide-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12rpx}.task-guide-head>view{display:flex;align-items:center;gap:10rpx;font-size:21rpx;font-weight:800}.task-guide-head>text{color:#ff8a14;font-size:20rpx;font-weight:800}.task-guide-tag{padding:5rpx 9rpx;border-radius:8rpx;background:rgba(255,114,0,.16);color:#ff8a14;font-size:16rpx}.task-guide-row{display:grid;grid-template-columns:34rpx 1fr;align-items:center;gap:10rpx;min-height:50rpx;border-top:1rpx solid rgba(255,255,255,.07);color:#d7dbde;font-size:18rpx}.task-guide-row:first-child{border-top:0}.task-guide-number{display:flex;align-items:center;justify-content:center;width:28rpx;height:28rpx;border-radius:50%;background:#ff7200;color:#fff;font-size:15rpx;font-weight:800;box-sizing:border-box;box-shadow:0 0 0 5rpx rgba(255,114,0,.1)}.task-guide-note{display:block;margin-top:10rpx;color:#828b92;font-size:15rpx;line-height:1.5}.task-guide-complete{padding:13rpx;border-radius:12rpx;background:rgba(97,206,64,.1);color:#78d85a;font-size:18rpx;text-align:center}
