page{height:100%;background:#05090c;color:#f4f6f7;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:radial-gradient(circle at 100% 0,rgba(255,116,0,.13),transparent 25%),#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.95)}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:8rpx;color:#d6d9dc;font-size:23rpx}.back-button image{width:28rpx;height:28rpx}.nav-title{font-size:29rpx;font-weight:700}.page-scroll{height:100%}.content{padding:20rpx 30rpx 0}.coach-card,.current-card,.available-card,.date-card{border:1rpx solid rgba(255,127,0,.45);background:linear-gradient(135deg,#182026,#0d1216);border-radius:22rpx}.coach-card{position:relative;display:flex;align-items:center;padding:26rpx 26rpx 54rpx}.avatar{width:112rpx;height:112rpx;border:3rpx solid #ff7900;border-radius:50%}.coach-copy{flex:1;margin-left:22rpx}.coach-copy text{display:block;color:#aab1b7;font-size:21rpx;margin-top:7rpx}.name-line{display:flex;align-items:center;gap:12rpx}.name-line text:first-child{color:#fff;font-size:34rpx;font-weight:800;margin:0}.name-line text:last-child{color:#61d34d;border:1rpx solid #61d34d;border-radius:10rpx;padding:4rpx 10rpx;margin:0;font-size:18rpx}.lesson-progress{text-align:right}.lesson-progress>text{color:#9da4aa;font-size:20rpx}.lesson-progress view{margin-top:8rpx}.lesson-progress view text:first-child{font-size:38rpx;color:#ff8500;font-weight:800}.lesson-progress view text:last-child{font-size:18rpx;color:#92999f}.progress-track{position:absolute;left:160rpx;right:26rpx;bottom:24rpx;height:8rpx;border-radius:8rpx;background:#30383e}.progress-track view{width:76%;height:100%;border-radius:8rpx;background:linear-gradient(90deg,#ff6500,#ffad1f)}.section-heading{display:flex;align-items:center;justify-content:space-between;margin:30rpx 6rpx 14rpx}.section-heading>view text{display:block}.section-heading>view text:first-child{font-size:29rpx;font-weight:800}.section-heading>view text:last-child{margin-top:5rpx;color:#878f96;font-size:20rpx}.section-heading>text{font-size:36rpx;font-weight:800;color:#ff8500}.current-card{padding:22rpx 24rpx;margin-top:14rpx}.class-title{display:flex;justify-content:space-between;align-items:center}.class-title text:first-child{font-size:29rpx;font-weight:800}.class-title text:last-child{padding:5rpx 12rpx;border:1rpx solid #ff8500;border-radius:10rpx;color:#ff8500;font-size:18rpx}.class-meta{display:flex;align-items:center;gap:9rpx;margin-top:13rpx;color:#abb1b6;font-size:21rpx}.class-meta image{width:25rpx;height:25rpx}.available-card{padding:20rpx 22rpx;margin-top:14rpx;border-color:#384047}.available-card.selected{border-color:#ff8500;box-shadow:0 0 18rpx rgba(255,121,0,.13)}.select-line{display:flex;align-items:center}.check-box{width:34rpx;height:34rpx;border:2rpx solid #7b838a;border-radius:8rpx;display:flex;align-items:center;justify-content:center}.check-box image{width:29rpx;height:29rpx}.select-copy{flex:1;margin-left:16rpx}.select-copy text{display:block}.select-copy text:first-child{font-size:27rpx;font-weight:700}.select-copy text:last-child{margin-top:6rpx;color:#8f979d;font-size:20rpx}.conflict{color:#ff5555;border:1rpx solid #ff5555;border-radius:10rpx;padding:5rpx 10rpx;font-size:18rpx}.role-row{display:flex;justify-content:space-between;align-items:center;margin-top:18rpx;padding-top:16rpx;border-top:1rpx solid rgba(255,255,255,.08);font-size:20rpx;color:#949ba1}.role-pills{display:flex;gap:10rpx}.role-pills text{padding:7rpx 15rpx;border:1rpx solid #454d53;border-radius:18rpx;color:#b9bec2}.role-pills text.active{color:#ff8900;border-color:#ff8900;background:rgba(255,128,0,.1)}.date-card{margin-top:24rpx;padding:22rpx;display:flex;align-items:center;justify-content:space-between}.date-card>view{display:flex;align-items:center}.date-card image{width:40rpx;height:40rpx;margin-right:14rpx}.date-card>view text{display:block}.date-card>view text:first-child{font-size:25rpx;font-weight:700}.date-card>view text:last-child{margin-top:5rpx;color:#858d93;font-size:19rpx}.date-value{color:#ff8900;font-size:23rpx}.tip{display:flex;align-items:flex-start;gap:10rpx;margin:18rpx 5rpx;color:#8e969c;font-size:19rpx;line-height:1.6}.tip image{width:25rpx;height:25rpx;margin-top:3rpx}.primary-button{margin-top:20rpx;height:88rpx;line-height:88rpx;border-radius:18rpx;background:linear-gradient(90deg,#ff6100,#ff9c00);color:#fff;font-size:28rpx;font-weight:800;box-shadow:0 14rpx 30rpx rgba(255,105,0,.28)}.safe-space{height:60rpx}
