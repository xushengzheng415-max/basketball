page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;width:60rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:18rpx 30rpx 0}.page-heading text{display:block}.page-heading text:first-child{font-size:42rpx;font-weight:900}.page-heading text:last-child{margin-top:9rpx;color:#90989e;font-size:20rpx}.student-hero,.section-card{border:1rpx solid #394248;border-radius:18rpx;background:linear-gradient(135deg,#182026,#0d1216)}.student-hero{position:relative;display:flex;align-items:center;margin-top:20rpx;padding:24rpx;border-color:#ff8500;overflow:hidden}.student-hero>image{width:105rpx;height:105rpx;border-radius:50%;border:2rpx solid #5d6469}.student-hero>view:nth-child(2){margin-left:20rpx}.student-hero>view:nth-child(2) text{display:block}.student-hero>view:nth-child(2) text:first-child{font-size:33rpx;font-weight:800}.student-hero>view:nth-child(2) text:nth-child(2){margin-top:8rpx;font-size:23rpx}.student-hero>view:nth-child(2) text:last-child{margin-top:8rpx;color:#9ea5aa;font-size:18rpx}.basketball-mark{position:absolute;right:-30rpx;width:160rpx;height:160rpx;border-radius:50%;background:repeating-radial-gradient(circle,#4a260d 0 5rpx,#20150d 6rpx 14rpx);opacity:.5}.section-card{margin-top:15rpx;padding:22rpx}.section-title{font-size:26rpx;font-weight:800;margin-bottom:15rpx}.performance-row{display:grid;grid-template-columns:70rpx 1fr 185rpx;align-items:center;margin-top:11rpx;padding:17rpx;border-radius:12rpx;background:#141b20}.performance-icon{width:58rpx;height:58rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;border:1rpx solid #ff8500;color:#ff8500;font-size:28rpx}.performance-row>view:nth-child(2) text{display:block}.performance-row>view:nth-child(2) text:first-child{font-size:23rpx;font-weight:800}.performance-row>view:nth-child(2) text:last-child{margin-top:5rpx;color:#8e969c;font-size:17rpx}.performance-row>view:last-child{text-align:right}.performance-row>view:last-child text:first-child{color:#ff8500;font-size:34rpx;font-weight:800}.performance-row>view:last-child text:first-child text{color:#858d93;font-size:21rpx}.performance-row>view:last-child>text:last-child{display:block;margin-top:5rpx;color:#ff8500;font-size:19rpx}.highlight-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx}.highlight-grid text{padding:18rpx;border:1rpx solid #4b555b;border-radius:12rpx;text-align:center;font-size:21rpx}.suggestion{display:block;color:#b2b8bc;font-size:20rpx;line-height:1.65}.send-row{display:flex;justify-content:space-between;padding:18rpx;border-top:1rpx solid #343d43;font-size:20rpx}.send-row text:last-child{color:#90989e}.bottom-actions{display:grid;grid-template-columns:1fr 1fr;gap:15rpx;margin-top:16rpx}.bottom-actions button{height:75rpx;line-height:75rpx;border:1rpx solid #ff8500;border-radius:14rpx;background:transparent;color:#ff8500;font-size:23rpx;font-weight:800}.bottom-actions button:last-child{background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff}.safe-space{height:45rpx}
