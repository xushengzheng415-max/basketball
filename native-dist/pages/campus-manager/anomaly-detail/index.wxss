page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97)}.back-button{position:absolute;left:24rpx;bottom:0;width:68rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:32rpx;height:32rpx}.nav-title{font-size:32rpx;font-weight:800}.page-scroll{height:100%}.content{padding:22rpx 30rpx 0}.alert-card,.section-card{border:1rpx solid #3a444a;border-radius:22rpx;background:linear-gradient(135deg,#182026,#0d1216)}.alert-card{display:flex;align-items:center;padding:24rpx;border-color:rgba(255,76,76,.45);background:linear-gradient(135deg,rgba(72,18,20,.5),#11171b)}.alert-icon{width:105rpx;height:105rpx;display:flex;align-items:center;justify-content:center}.alert-icon image{width:94rpx;height:94rpx}.alert-copy{flex:1;margin-left:16rpx}.alert-copy>text{font-size:34rpx;font-weight:900}.alert-copy>view{display:flex;gap:16rpx;margin-top:17rpx;color:#b1b7bb;font-size:18rpx}.status{padding:8rpx 13rpx;border:1rpx solid #ff5555;border-radius:18rpx;color:#ff5555;font-size:19rpx}.section-card{margin-top:20rpx;padding:24rpx}.section-title{display:flex;align-items:center;gap:10rpx;font-size:28rpx;font-weight:800}.section-title text:first-child{color:#ff8500;font-size:32rpx}.summary{display:block;margin-top:16rpx;color:#c4c9cc;font-size:23rpx}.summary-grid{display:grid;grid-template-columns:repeat(2,1fr);margin-top:20rpx;padding-top:20rpx;border-top:1rpx solid rgba(255,255,255,.08)}.summary-grid>view{text-align:center}.summary-grid>view+view{border-left:1rpx solid #333c42}.summary-grid text{display:inline}.summary-grid text:first-child{display:block;color:#969da2;font-size:19rpx}.summary-grid text:nth-child(2){font-size:35rpx;font-weight:800}.summary-grid text:last-child{margin-left:5rpx;color:#a8afb4;font-size:18rpx}.evidence-row{display:grid;grid-template-columns:76rpx 26rpx 1fr;align-items:start;padding:18rpx 0;border-top:1rpx solid rgba(255,255,255,.07)}.evidence-icon{width:62rpx;height:62rpx;border:1rpx solid #3f484e;border-radius:14rpx;display:flex;align-items:center;justify-content:center}.evidence-icon image{width:38rpx;height:38rpx}.evidence-line{position:relative;align-self:stretch}.evidence-line view{position:absolute;top:0;bottom:-36rpx;left:10rpx;width:2rpx;background:#485158}.evidence-copy>view{display:flex;gap:16rpx;align-items:center}.evidence-copy>view text:first-child{color:#ff8500;font-size:24rpx;font-weight:800}.evidence-copy>view text:last-child{font-size:23rpx;font-weight:800}.evidence-copy>text{display:block;margin-top:8rpx;color:#90989e;font-size:19rpx}.suggestion>view:last-child{display:flex;align-items:center;justify-content:space-between;margin-top:15rpx;color:#b8bdc0;font-size:22rpx}.suggestion image{width:24rpx;height:24rpx}.empty-record{display:flex;flex-direction:column;align-items:center;padding:38rpx 0;color:#737b81}.empty-record view{width:65rpx;height:65rpx;border:5rpx solid #555e64;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:35rpx}.empty-record text{margin-top:15rpx;font-size:21rpx}.bottom-actions{display:grid;grid-template-columns:1fr 1fr;gap:18rpx;margin-top:22rpx}.bottom-actions button{height:80rpx;line-height:80rpx;border:1rpx solid #ff8500;border-radius:15rpx;background:transparent;color:#ff8500;font-size:25rpx;font-weight:800}.bottom-actions button:last-child{background:linear-gradient(90deg,#ff6100,#ff9b00);color:#fff}.safe-space{height:55rpx}
