<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /></view><text class="nav-title">异常详情</text></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content">
  <view class="alert-card"><view class="alert-icon"><image src="{{icons.warning}}" mode="aspectFit" /></view><view class="alert-copy"><text>{{detail.title}}</text><view><text>{{detail.classInfo}}</text><text>{{detail.owner}}</text><text>{{detail.time}}</text></view></view><text class="status">待处理</text></view>
  <view class="section-card"><view class="section-title"><text>▤</text><text>异常摘要</text></view><text class="summary">{{detail.summary}}</text><view class="summary-grid"><view><text>影响</text><text>{{detail.impactValue}}</text><text>{{detail.impactUnit}}</text></view><view><text>需核对</text><text>{{detail.checkValue}}</text><text>{{detail.checkUnit}}</text></view></view></view>
  <view class="section-card"><view class="section-title"><text>♢</text><text>证据链</text></view><view class="evidence-row" wx:for="{{evidence}}" wx:key="time"><view class="evidence-icon"><image src="{{item.icon}}" mode="aspectFit" /></view><view class="evidence-line"><view></view></view><view class="evidence-copy"><view><text>{{item.time}}</text><text>{{item.title}}</text></view><text>{{item.detail}}</text></view></view></view>
  <view class="section-card suggestion" bindtap="approveCorrection"><view class="section-title"><text>◉</text><text>处理建议</text></view><view><text wx:if="{{detail.finance}}">核对付款人并关联正确订单</text><text wx:else>核对课程记录并完成课消更正</text><image src="{{icons.chevron}}" mode="aspectFit" /></view></view>
  <view class="section-card"><view class="section-title"><text>▤</text><text>处理记录</text></view><view class="empty-record"><view>✓</view><text>暂无处理记录</text></view></view>
  <view class="bottom-actions"><button bindtap="returnForCheck">返回核对</button><button bindtap="approveCorrection"><text wx:if="{{detail.finance}}">关联订单</text><text wx:else>通过更正</text></button></view><view class="safe-space"></view>
</view></scroll-view></view>
