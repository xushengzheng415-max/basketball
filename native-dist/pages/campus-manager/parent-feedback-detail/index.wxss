page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;width:60rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:28rpx;height:28rpx}.custom-nav .status{position:absolute;right:165rpx;bottom:14rpx;padding:6rpx 12rpx;border:1rpx solid #ff8500;border-radius:15rpx;color:#ff8500;font-size:16rpx}.page-scroll{height:100%}.content{padding:18rpx 28rpx 0}.section-card{margin-top:15rpx;padding:20rpx;border:1rpx solid #394248;border-radius:16rpx;background:linear-gradient(135deg,#182026,#0d1216)}.section-card:first-child{margin-top:0}.section-title{padding-left:10rpx;border-left:5rpx solid #ff8500;font-size:23rpx;font-weight:800}.student-row{display:flex;align-items:center;margin-top:15rpx}.student-row>image:first-child{width:72rpx;height:72rpx;border-radius:50%}.student-row>view{flex:1;margin-left:15rpx}.student-row>view text{display:block}.student-row>view text:first-child{font-size:25rpx;font-weight:800}.student-row>view text:nth-child(2),.student-row>view text:nth-child(3){margin-top:5rpx;color:#a1a8ad;font-size:17rpx}.student-row>image:last-child{width:22rpx;height:22rpx}.feedback-type,.quote{display:grid;grid-template-columns:120rpx 1fr;gap:16rpx;margin-top:16rpx;padding-top:15rpx;border-top:1rpx solid #343d43;font-size:18rpx}.feedback-type text:last-child{font-weight:700}.quote text:last-child{color:#b2b8bc;line-height:1.55}.compact{padding:0 20rpx}.compact>view{display:flex;align-items:center;justify-content:space-between;padding:17rpx 0;border-top:1rpx solid #343d43;font-size:17rpx}.compact>view:first-child{border-top:0}.compact>view>text:first-child{color:#f1f3f4}.compact>view>text:last-child{color:#9aa1a6}.compact>view>text text{color:#ff8500}.compact button{height:40rpx;line-height:40rpx;border:1rpx solid #ff8500;border-radius:14rpx;background:transparent;color:#ff8500;font-size:15rpx}.timeline{margin-top:15rpx}.timeline>view{position:relative;padding:0 0 17rpx 30rpx;border-left:2rpx solid #444d53}.timeline>view:before{content:"";position:absolute;left:-8rpx;top:2rpx;width:14rpx;height:14rpx;border-radius:50%;background:#ff8500}.timeline text{display:block}.timeline text:first-child{font-size:19rpx}.timeline text:last-child{margin-top:4rpx;color:#858d93;font-size:16rpx}.timeline .pending:before{background:#868e94}.section-title.sub{margin-top:6rpx;padding-top:15rpx;border-top:1rpx solid #343d43;border-left:0}.collab{display:grid;grid-template-columns:58rpx 1fr auto;gap:12rpx;align-items:start;margin-top:13rpx}.collab image{width:52rpx;height:52rpx;border-radius:50%}.collab text{display:block}.collab>view>text:first-child{font-size:18rpx}.collab>view>text:first-child text{display:inline;padding:3rpx 7rpx;border:1rpx solid #ff8500;border-radius:6rpx;color:#ff8500;font-size:14rpx}.collab>view>text:last-child{margin-top:5rpx;color:#9aa1a6;font-size:16rpx;line-height:1.45}.collab>text{color:#777f85;font-size:14rpx}.stars{display:flex}.stars text{color:#ff8500;font-size:31rpx}.stars text.active{color:#ff8500}.upload{width:150rpx;height:95rpx;margin-top:14rpx;border:1rpx dashed #596269;border-radius:9rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#a4abb0;font-size:28rpx}.upload text{font-size:14rpx}.content>textarea{width:100%;height:92rpx;margin-top:15rpx;padding:13rpx;border:1rpx solid #414a50;border-radius:10rpx;box-sizing:border-box;color:#fff;font-size:17rpx}.primary-button{margin-top:15rpx;height:76rpx;line-height:76rpx;border-radius:10rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:24rpx;font-weight:800}.submit-note{text-align:center;margin-top:10rpx;color:#737b81;font-size:15rpx}.safe-space{height:45rpx}
