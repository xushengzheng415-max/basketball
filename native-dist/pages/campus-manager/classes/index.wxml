<view class="page"><view class="nav" style="padding-top:{{navTop}}px;height:{{navHeight}}px"><view class="back" bindtap="goBack"><image src="{{icons.back}}"/><text>返回工作台</text></view><text>班级管理</text><view class="campus" bindtap="showCampus"><image src="{{icons.location}}"/><text>浦东校区⌄</text></view></view><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height:{{navSpacer}}px"></view><view class="content">
<view class="summary"><view><view class="metric-symbol">班</view><view><text>运行班级</text><text>8<text>个</text></text></view></view><view><image src="{{icons.user}}"/><view><text>在班学员</text><text>96<text>人</text></text></view></view><view><view class="ring-small">82</view><view><text>平均满班率</text><text>82<text>%</text></text></view></view><view><image src="{{icons.warning}}"/><view><text>班级预警</text><text>2<text>个</text></text></view></view></view>
<view class="tabs"><view class="tab {{item.activeClass}}" wx:for="{{tabs}}" wx:key="key" data-key="{{item.key}}" bindtap="selectTab">{{item.label}}</view></view>
<view class="class-list"><view class="class-card" wx:for="{{classes}}" wx:key="id" data-id="{{item.id}}" bindtap="openClass"><view class="shield"><text>★★★</text><text>{{item.badge}}</text><text>🏀</text></view><view class="class-main"><text class="class-title">{{item.title}}</text><view class="coach"><image src="{{item.avatar}}" mode="aspectFill"/><text>{{item.coach}}</text><text>主教练</text></view><view class="meta"><image src="{{icons.calendar}}"/><text>{{item.schedule}}</text></view><view class="meta"><image src="{{icons.location}}"/><text>{{item.venue}}</text></view></view><view class="side"><text>容量 {{item.capacity}}</text><view class="capacity"><view style="width:{{item.fill}}%"></view></view><view class="attendance"><text>{{item.attendance}}</text><text>出勤率</text></view><view class="normal">正常　›</view></view></view></view>
<view class="warnings"><view class="warning-head"><view><image src="{{icons.warning}}"/><text>班级预警</text></view><text>查看全部 ›</text></view><view><image src="{{icons.user}}"/><view><text>U10基础训练班　<text>接近满班</text></text><text>当前 18/18 人，建议及时扩班或引导分流</text></view><text>今天 09:20 ›</text></view><view><image src="{{icons.clock}}"/><view><text>U12进阶训练班　<text>出勤偏低</text></text><text>出勤率连续 3 周低于 85%，建议关注学员情况</text></view><text>昨天 18:45 ›</text></view></view>
<button class="new" bindtap="newClass">＋　新建班级</button><view class="safe"></view></view></scroll-view></view>
