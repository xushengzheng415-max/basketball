page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:29rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;width:62rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:30rpx;height:30rpx}.page-scroll{height:100%}.content{padding:20rpx 22rpx 0}.task-hero,.section-card{border:1rpx solid #394248;border-radius:16rpx;background:linear-gradient(135deg,#182026,#0d1216)}.task-hero{display:grid;grid-template-columns:120rpx 1fr;padding:20rpx}.task-badge{width:104rpx;height:120rpx;border:4rpx solid #ff8500;border-radius:34rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#ff8500;font-size:48rpx}.task-badge text{font-size:20rpx}.task-hero>view:nth-child(2)>view{display:flex;align-items:center;gap:12rpx}.task-hero>view:nth-child(2)>view text:first-child{font-size:28rpx;font-weight:800}.task-hero>view:nth-child(2)>view text:last-child{padding:5rpx 9rpx;border:1rpx solid #ff8500;border-radius:8rpx;color:#ff8500;font-size:16rpx}.task-hero>view:nth-child(2)>text{display:block;margin-top:10rpx;color:#a0a7ac;font-size:18rpx}.task-hero>view:nth-child(2)>text text{color:#ff8500}.task-duty{grid-column:1/3;margin-top:16rpx;padding-top:14rpx;border-top:1rpx solid #343d43;color:#929aa0;font-size:16rpx}.section-card{margin-top:14rpx;padding:18rpx}.target{background:linear-gradient(135deg,rgba(74,38,7,.3),#12191e)}.target>text{display:block;margin-top:8rpx;color:#aaa;font-size:17rpx;line-height:1.5}.target>text:first-child{color:#fff;font-size:24rpx;font-weight:800}.target>text text{color:#ff8500}.section-heading{display:flex;justify-content:space-between;align-items:center}.section-heading text:first-child{font-size:24rpx;font-weight:800}.section-heading text:last-child{color:#90989e;font-size:16rpx}.student-row{display:grid;grid-template-columns:54rpx 1fr 1.2fr 1.3fr .75fr;align-items:center;padding:10rpx 0;border-top:1rpx solid #343d43;color:#aeb5ba;font-size:16rpx}.student-row image{width:42rpx;height:42rpx;border-radius:50%}.student-row text:nth-child(2){color:#fff;font-size:19rpx}.student-row text:last-child{padding:4rpx 7rpx;border-radius:6rpx;background:rgba(255,130,0,.12);color:#ff8500;text-align:center}.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:8rpx;margin-top:20rpx}.steps>view{text-align:center}.steps text{display:block}.steps text:first-child{width:32rpx;height:32rpx;margin:auto;border-radius:50%;background:#ff8500;line-height:32rpx}.steps text:nth-child(2){margin-top:8rpx;font-size:18rpx}.steps text:nth-child(3){margin-top:6rpx;color:#858d93;font-size:14rpx;line-height:1.4}.steps text:last-child{margin-top:6rpx;color:#ff8500;font-size:15rpx}.script-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10rpx;margin-top:14rpx}.script-grid>view{padding:12rpx;border:1rpx solid #6a451c;border-radius:8rpx;background:rgba(80,42,8,.18)}.script-grid text{display:block}.script-grid text:first-child{color:#ff8500;font-size:18rpx;font-weight:700}.script-grid text:last-child{margin-top:5rpx;color:#969da3;font-size:14rpx}.upload-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10rpx;margin-top:14rpx}.upload-grid>view{height:78rpx;border:1rpx dashed #525c62;border-radius:8rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#9fa6aa;font-size:25rpx}.upload-grid>view text{font-size:13rpx}.result-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8rpx;margin-top:14rpx}.result-grid text{padding:9rpx 6rpx;border:1rpx solid #414a50;border-radius:7rpx;text-align:center;color:#aeb5ba;font-size:15rpx}.result-grid text.active{border-color:#ff8500;color:#ff8500}.section-card textarea{width:100%;height:90rpx;margin-top:12rpx;padding:12rpx;border:1rpx solid #414a50;border-radius:8rpx;box-sizing:border-box;color:#fff;font-size:17rpx}.primary-button{margin-top:16rpx;height:76rpx;line-height:76rpx;border-radius:10rpx;background:linear-gradient(90deg,#ffa81b,#ff6a00);color:#111;font-size:24rpx;font-weight:800}.safe-space{height:50rpx}
