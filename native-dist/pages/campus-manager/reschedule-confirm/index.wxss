page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:7rpx;color:#d4d8db;font-size:18rpx}.back-button image{width:27rpx;height:27rpx}.page-scroll{height:100%}.content{padding:18rpx 38rpx 0}.subtitle{text-align:center;display:block;color:#8f979d;font-size:20rpx}.compare-grid{display:grid;grid-template-columns:1fr 50rpx 1fr;align-items:center;margin-top:28rpx}.course-card,.notice-card{border:1rpx solid #596269;border-radius:15rpx;background:linear-gradient(135deg,#182026,#0d1216)}.course-card{position:relative;padding:24rpx}.course-card.new{border-color:#ff8500}.course-card>text{display:block;padding:14rpx 0;border-top:1rpx solid #343d43;color:#b8bdc0;font-size:18rpx}.course-card>text:first-child{position:absolute;top:-22rpx;left:50%;transform:translateX(-50%);width:130rpx;height:42rpx;padding:0;border:1rpx solid #596269;border-radius:10rpx;background:#1a2228;line-height:42rpx;text-align:center;color:#fff;font-size:20rpx}.course-card.new>text:first-child{border-color:#ff8500;background:linear-gradient(90deg,#9b3d00,#ff8500)}.course-name{display:flex;align-items:center;gap:12rpx;margin-top:18rpx;padding-bottom:14rpx;border-bottom:1rpx solid #343d43;color:#ff8500;font-size:35rpx}.course-name text{color:#fff;font-size:24rpx}.coach{display:flex;align-items:center;gap:13rpx;padding:14rpx 0;border-bottom:1rpx solid #343d43}.coach image{width:50rpx;height:50rpx;border-radius:50%}.coach text{font-size:21rpx}.course-card>text:last-child text{display:block;margin-top:6rpx;color:#55d15a}.arrow{text-align:center;color:#ff8500;font-size:42rpx}.section-heading{margin-top:25rpx;font-size:25rpx;font-weight:800}.section-caption{display:block;margin-top:6rpx;color:#8f979d;font-size:17rpx}.notice-card{margin-top:13rpx;padding:0 18rpx;border-color:#5d451c}.notice-card>view{display:grid;grid-template-columns:55rpx 1fr 45rpx;align-items:center;padding:16rpx;border-top:1rpx solid #343d43}.notice-card>view:first-child{border-top:0}.notice-card>view>text:first-child{color:#ff8500;font-size:33rpx}.notice-card>view>view text{display:block}.notice-card>view>view text:first-child{font-size:21rpx}.notice-card>view>view text:last-child{margin-top:4rpx;color:#858d93;font-size:15rpx}.notice-card>view>text:last-child{width:30rpx;height:30rpx;border:2rpx solid #ff8500;border-radius:6rpx;color:#ff8500;line-height:30rpx;text-align:center}.content textarea{width:100%;height:115rpx;margin-top:12rpx;padding:15rpx;border:1rpx solid #ff8500;border-radius:12rpx;box-sizing:border-box;color:#fff;font-size:18rpx}.primary-button,.secondary-button{margin-top:18rpx;height:76rpx;line-height:76rpx;border-radius:11rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:25rpx;font-weight:800}.secondary-button{margin-top:12rpx;border:1rpx solid #596269;background:transparent;color:#aeb5ba}.safe-space{height:45rpx}
