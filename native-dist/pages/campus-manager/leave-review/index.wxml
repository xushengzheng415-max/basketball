<view class="page"><view class="nav" style="padding-top:{{navTop}}px;height:{{navHeight}}px"><view bindtap="goBack"><image src="{{icons.back}}"/><text>返回请假补课</text></view></view><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height:{{navSpacer}}px"></view><view class="content"><view class="headline"><text>请假审核详情</text><view></view></view>
<view class="student panel"><image src="{{avatar}}" mode="aspectFill"/><view><view><text>{{application.name}}</text><text>{{application.classInfo}}</text></view><view class="leave-meta"><text>{{application.type}}</text><text>{{application.date}}</text><text>剩余课时：{{application.remaining}}</text></view><view class="reason"><text>请假原因</text><text>{{application.reason}}</text><text>证明材料</text><view class="proof">材料已核验</view></view></view></view>
<view class="panel"><view class="section-title">◇　规则校验</view><view class="check-table"><view wx:for="{{checks}}" wx:key="label"><text>◷　{{item.label}}</text><text>{{item.value}}</text><text>●　{{item.result}}</text></view></view></view>
<view class="panel operations"><view class="section-title">♧　管理操作</view><text>请选择审核结果</text><view class="action-row"><view class="review-action {{item.activeClass}}" wx:for="{{actions}}" wx:key="key" data-key="{{item.key}}" bindtap="selectAction"><text>{{item.icon}}　{{item.title}}</text><text>{{item.note}}</text></view></view><textarea maxlength="100" placeholder="选填：添加审核备注（对学员不可见）" value="{{remark}}" bindinput="inputRemark"/><text class="count">{{remark.length}}/100</text></view>
<view class="panel"><view class="section-title">▣　补课资格预判</view><view class="eligibility"><view><text>补课资格</text><text>可补课</text></view><view><text>剩余可补课时</text><text>{{application.remaining}}</text></view><view><text>有效期</text><text>自请假之日起 180 天内</text></view></view><text class="hint">审核通过后将自动为学员预留补课资格，可在有效期内安排补课。</text></view>
<view class="buttons"><view bindtap="submit">✓　审核通过并进入补课安排</view><view bindtap="reject">×　驳回申请</view></view><view class="safe"></view></view></scroll-view></view>
