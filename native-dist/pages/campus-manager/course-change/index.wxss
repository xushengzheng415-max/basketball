page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:7rpx;color:#d4d8db;font-size:18rpx}.back-button image{width:27rpx;height:27rpx}.page-scroll{height:100%}.content{padding:18rpx 30rpx 0}.tabs{display:grid;grid-template-columns:1fr 1fr;border:1rpx solid #5d451c;border-radius:10rpx;overflow:hidden}.tabs view{height:60rpx;line-height:60rpx;text-align:center;color:#aaa;font-size:21rpx}.tabs view.active{border:1rpx solid #ff8500;background:rgba(255,130,0,.09);color:#fff}.filters{display:grid;grid-template-columns:repeat(3,1fr);gap:18rpx;margin-top:13rpx;padding:13rpx;border:1rpx solid #394248;border-radius:10rpx;background:#11181d}.filters view{padding:12rpx;border:1rpx solid #434c52;border-radius:8rpx;text-align:center;color:#bbc0c3;font-size:17rpx}.request-card,.rules-card{margin-top:13rpx;border:1rpx solid #714b19;border-radius:12rpx;background:linear-gradient(135deg,#182026,#0d1216);overflow:hidden}.request-heading{display:flex;align-items:center;gap:15rpx;padding:12rpx 16rpx;border-bottom:1rpx solid #343d43}.request-heading text:first-child{padding:4rpx 8rpx;border:1rpx solid #ff8500;border-radius:6rpx;color:#ff8500;font-size:15rpx}.request-heading text:nth-child(2){color:#a0a7ac;font-size:16rpx}.request-heading text:last-child{margin-left:auto;color:#ff8500;font-size:17rpx}.request-person{display:flex;align-items:center;padding:14rpx 20rpx}.request-person image{width:58rpx;height:58rpx;border:2rpx solid #ff8500;border-radius:50%}.request-person>view{margin-left:14rpx}.request-person text{display:block}.request-person text:first-child{font-size:23rpx;font-weight:800}.request-person text:last-child{margin-top:5rpx;color:#a0a7ac;font-size:16rpx}.date-compare{display:grid;grid-template-columns:1fr 45rpx 1fr;align-items:center;padding:0 20rpx 14rpx}.date-compare>text{text-align:center;color:#ff8500;font-size:32rpx}.date-compare>view{padding:12rpx}.date-compare>view:last-child{border-left:1rpx solid #343d43}.date-compare>view text{display:block;margin-top:5rpx;color:#b3b8bc;font-size:16rpx}.date-compare>view text:first-child{color:#8f979d;font-size:15rpx}.conflict{padding:11rpx 20rpx;border-top:1rpx solid #343d43;color:#a0a7ac;font-size:15rpx}.conflict>text:first-child{color:#55d15a}.conflict>text:last-child{float:right}.orange{color:#ff8500!important}.request-actions{display:grid;grid-template-columns:repeat(3,1fr);gap:13rpx;padding:12rpx 20rpx}.request-actions button{height:47rpx;line-height:47rpx;border:1rpx solid #596269;border-radius:8rpx;background:transparent;color:#c4c8cb;font-size:16rpx}.request-actions button:nth-child(2){border-color:#55d15a;color:#55d15a}.request-actions button:last-child{border-color:#ff5a30;color:#ff5a30}.rules-card{padding:17rpx}.rules-card text{display:block;margin-top:8rpx;color:#a0a7ac;font-size:16rpx}.rules-card text:first-child{margin-top:0;color:#fff;font-size:21rpx;font-weight:800}.safe-space{height:45rpx}
