page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:radial-gradient(circle at 100% 0,rgba(255,115,0,.13),transparent 25%),#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.96)}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:8rpx;color:#d4d8db;font-size:23rpx}.back-button image{width:28rpx;height:28rpx}.nav-title{font-size:29rpx;font-weight:700}.page-scroll{height:100%}.content{padding:22rpx 30rpx 0}.page-heading text{display:block}.page-heading text:first-child{font-size:42rpx;font-weight:900}.page-heading text:last-child{margin-top:10rpx;color:#8e959b;font-size:22rpx}.metric-grid{display:grid;grid-template-columns:repeat(4,1fr);margin-top:26rpx;border:1rpx solid rgba(255,130,0,.5);border-radius:22rpx;background:linear-gradient(135deg,#182026,#0d1216)}.metric-item{position:relative;padding:22rpx 8rpx;text-align:center}.metric-item+ .metric-item:before{content:"";position:absolute;left:0;top:22rpx;bottom:22rpx;width:1rpx;background:#30383e}.metric-item text{display:block}.metric-item text:first-child{color:#aeb4b9;font-size:19rpx}.metric-item text:last-child{margin-top:8rpx;font-size:34rpx;font-weight:800}.metric-item .orange{color:#ff8500}.metric-item .green{color:#61d449}.metric-item .gray{color:#8d949a}.tabs{white-space:nowrap;margin:22rpx 0 8rpx}.tab{display:inline-flex;align-items:center;justify-content:center;min-width:116rpx;height:58rpx;margin-right:12rpx;padding:0 16rpx;border:1rpx solid #3a4349;border-radius:30rpx;color:#aeb4b8;font-size:22rpx;box-sizing:border-box}.tab.active{border-color:#ff8500;background:#ff7900;color:#fff}.invite-card{margin-top:16rpx;border:1rpx solid rgba(255,129,0,.46);border-radius:22rpx;background:linear-gradient(135deg,#182026,#0d1216);overflow:hidden}.invite-summary{display:flex;align-items:center;padding:22rpx}.avatar{width:92rpx;height:92rpx;border-radius:50%;border:2rpx solid #ff7900}.invite-copy{flex:1;margin-left:18rpx}.invite-copy>text{display:block;color:#939aa0;font-size:20rpx;margin-top:7rpx}.name-row{display:flex;align-items:center;gap:12rpx}.name-row>text:first-child{font-size:29rpx;font-weight:800}.status{padding:5rpx 10rpx;border-radius:10rpx;border:1rpx solid currentColor;font-size:17rpx}.status.orange{color:#ff8500}.status.green{color:#5fd049}.status.gray{color:#838a90}.chevron{width:24rpx;height:24rpx}.invite-meta{display:flex;justify-content:space-between;padding:13rpx 22rpx;border-top:1rpx solid rgba(255,255,255,.07);color:#8c949a;font-size:19rpx}.invite-meta text:last-child{color:#ff8500}.expanded-panel{padding:20rpx 22rpx;background:rgba(0,0,0,.2);border-top:1rpx solid rgba(255,133,0,.22)}.timeline-row{display:grid;grid-template-columns:20rpx 1fr auto;gap:10rpx;align-items:center;color:#d4d8db;font-size:20rpx;margin:12rpx 0}.timeline-row view{width:12rpx;height:12rpx;border-radius:50%;background:#62d44b}.timeline-row text:last-child{color:#828a90;font-size:18rpx}.timeline-row.dim view{background:#555e64}.timeline-row.dim{color:#858d93}.invite-link{display:flex;justify-content:space-between;margin-top:18rpx;padding:16rpx;border-radius:12rpx;background:#0a0f12;color:#a4abb0;font-size:19rpx}.invite-link text:last-child{color:#ff8500}.expanded-panel button{margin-top:18rpx;height:66rpx;line-height:66rpx;border:1rpx solid #ff8500;border-radius:14rpx;background:transparent;color:#ff8a00;font-size:22rpx}.tip{display:flex;align-items:flex-start;gap:10rpx;margin:20rpx 4rpx;color:#858d93;font-size:19rpx}.tip image{width:25rpx;height:25rpx}.primary-button{height:86rpx;line-height:86rpx;border-radius:18rpx;background:linear-gradient(90deg,#ff6100,#ff9d00);color:#fff;font-size:28rpx;font-weight:800;box-shadow:0 14rpx 30rpx rgba(255,105,0,.25)}.safe-space{height:58rpx}
