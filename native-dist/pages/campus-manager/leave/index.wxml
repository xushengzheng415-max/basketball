<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /><text>返回负责人首页</text></view><text>请假补课</text></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content">
  <view class="metric-grid"><view wx:for="{{metrics}}" wx:key="label"><text>{{item.symbol}}</text><view><text>{{item.label}}</text><text>{{item.value}}</text></view></view></view>
  <view class="tabs"><view class="{{item.activeClass}}" wx:for="{{tabs}}" wx:key="key" data-key="{{item.key}}" bindtap="switchTab">{{item.label}}</view></view>
  <view class="section-card"><view class="section-heading"><text>申请列表</text><text>共8条申请　筛选</text></view><view class="application" wx:for="{{applications}}" wx:key="id"><image src="{{item.avatar}}" mode="aspectFill" /><view class="app-copy"><view><text>{{item.name}}</text><text>{{item.classInfo}}</text></view><text><text>{{item.type}}</text>　{{item.date}}</text><text>剩余课时：{{item.remaining}}</text><text>原因：{{item.reason}}</text></view><view class="proof">证</view><view class="app-side"><text>{{item.status}}</text><button data-id="{{item.id}}" bindtap="review">查看 / 审核</button></view></view><view class="no-more">— 没有更多了 —</view></view>
  <view class="section-card"><view class="section-heading"><text>智能补课推荐</text><text>换一批</text></view><view class="recommend" wx:for="{{recommendations}}" wx:key="id"><view class="recommend-icon">课</view><view><text>{{item.name}}</text><text>教练：{{item.coach}}</text><text>{{item.date}}</text><text>场馆：{{item.place}}</text></view><view><text>余位 <text>{{item.seat}}</text></text><text>冲突检查　无时间冲突</text></view><button data-id="{{item.id}}" bindtap="selectMakeup">选择</button></view></view>
  <view class="section-card"><view class="section-heading"><text>请假补课规则</text></view><view class="rule-grid"><view><text>请假时限</text><text>课程开始前24小时可申请，特殊情况联系教务老师。</text></view><view><text>补课时限</text><text>请假后30天内完成补课，逾期视为自动放弃。</text></view><view><text>凭证要求</text><text>病假需提供医疗凭证，事假需说明事由。</text></view></view></view>
  <button class="primary-button" bindtap="batch">批量处理</button><view class="safe-space"></view>
</view></scroll-view></view>
