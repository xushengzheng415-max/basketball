page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}
.page-shell{height:100%;background:radial-gradient(circle at 100% 0,rgba(255,116,0,.12),transparent 24%),#05090c}
.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:90rpx;padding-right:190rpx;background:rgba(5,9,12,.96)}
.back-button{position:absolute;left:24rpx;bottom:0;width:68rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:32rpx;height:32rpx}.nav-title{font-size:30rpx;font-weight:800}
.page-scroll{height:100%}.content{padding:22rpx 30rpx 0}
.summary-card,.detail-card,.export-card{padding:26rpx;border:1rpx solid rgba(255,128,0,.42);border-radius:22rpx;background:linear-gradient(135deg,#182026,#0d1216)}
.summary-title{display:block;font-size:34rpx;font-weight:800}.summary-description{display:block;margin-top:10rpx;color:#90999f;font-size:21rpx}
.metric-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-top:24rpx}.metric-item{padding:20rpx 8rpx;border:1rpx solid #394248;border-radius:14rpx;text-align:center;background:rgba(255,255,255,.02)}.metric-item>text{color:#aeb4b9;font-size:19rpx}.metric-item>view{margin-top:9rpx}.metric-item>view text:first-child{font-size:31rpx;font-weight:800}.metric-item>view text:last-child{margin-left:4rpx;color:#a4abb0;font-size:17rpx}
.filter-bar{display:flex;gap:12rpx;margin-top:18rpx}.filter-picker{flex:1}.filter-item{display:flex;align-items:center;justify-content:center;gap:8rpx;height:70rpx;border:1rpx solid #343d43;border-radius:14rpx;background:#11181d;color:#dce0e2;font-size:21rpx}.filter-item image:first-child{width:27rpx;height:27rpx}.filter-item image:last-child{width:18rpx;height:18rpx}
.detail-card{margin-top:18rpx;padding-bottom:8rpx}.detail-heading{display:flex;align-items:center;justify-content:space-between}.detail-heading text:first-child{font-size:29rpx;font-weight:800}.detail-heading text:last-child{padding:6rpx 13rpx;border-radius:16rpx;background:rgba(255,133,0,.12);color:#ff9200;font-size:19rpx}
.detail-list{margin-top:12rpx}.detail-row{padding:20rpx 0;border-top:1rpx solid rgba(255,255,255,.08)}.detail-row:first-child{border-top:0}.detail-time{color:#818a90;font-size:19rpx}.detail-main{display:flex;align-items:flex-start;justify-content:space-between;margin-top:10rpx}.detail-main>view{padding-right:18rpx}.detail-main>view text{display:block}.detail-main>view text:first-child{font-size:24rpx;font-weight:700}.detail-main>view text:last-child{margin-top:7rpx;color:#8e979d;font-size:19rpx}.detail-main>text{flex:none;color:#ff9200;font-size:27rpx;font-weight:800}.detail-status{display:inline-block;margin-top:12rpx;padding:5rpx 11rpx;border-radius:10rpx;background:rgba(52,196,121,.1);color:#50cf8b;font-size:18rpx}
.empty-state{padding:56rpx 20rpx;text-align:center}.empty-state text{display:block}.empty-state text:first-child{font-size:25rpx;font-weight:700}.empty-state text:last-child{margin-top:10rpx;color:#7f888e;font-size:19rpx}
.export-toggle{display:flex;align-items:center;justify-content:center;gap:10rpx;margin-top:18rpx;height:84rpx;border:1rpx solid rgba(255,133,0,.58);border-radius:18rpx;color:#ff9200;font-size:24rpx;font-weight:700;background:rgba(255,133,0,.05)}.export-toggle image:first-child{width:30rpx;height:30rpx}.export-toggle image:last-child{width:20rpx;height:20rpx}
.export-card{margin-top:18rpx;text-align:center}.export-card>text:first-child{font-size:22rpx}.export-card button{display:flex;align-items:center;justify-content:center;gap:10rpx;margin-top:18rpx;height:80rpx;border-radius:14rpx;background:linear-gradient(90deg,#ff6100,#ff9b00);color:#fff;font-size:27rpx;font-weight:800}.export-card button image{width:31rpx;height:31rpx}.export-card>text:last-child{display:block;margin-top:14rpx;color:#7f878d;font-size:18rpx}.safe-space{height:60rpx}
