page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:radial-gradient(circle at 100% 0,rgba(255,116,0,.12),transparent 24%),#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.96)}.back-button{position:absolute;left:24rpx;bottom:0;width:68rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:32rpx;height:32rpx}.nav-title{font-size:32rpx;font-weight:800}.page-scroll{height:100%}.content{padding:22rpx 30rpx 0}.section-card{margin-top:18rpx;padding:24rpx;border:1rpx solid rgba(255,128,0,.46);border-radius:22rpx;background:linear-gradient(135deg,#182026,#0d1216)}.section-card:first-child{margin-top:0}.section-title{display:flex;align-items:center;gap:12rpx;font-size:29rpx;font-weight:800}.section-title image{width:34rpx;height:34rpx}.title-icon{color:#ff8500;font-size:36rpx}.overview-panel{margin-top:22rpx;padding:20rpx;border:1rpx solid #343d43;border-radius:16rpx;background:rgba(255,255,255,.025)}.panel-label{font-size:23rpx}.metric-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-top:18rpx}.metric-item{padding:20rpx 8rpx;border:1rpx solid #394248;border-radius:14rpx;text-align:center}.metric-item>text{color:#aeb4b9;font-size:19rpx}.metric-item>view{margin-top:9rpx}.metric-item>view text:first-child{font-size:33rpx;font-weight:800}.metric-item>view text:last-child{margin-left:4rpx;color:#a4abb0;font-size:18rpx}.filter-list{margin-top:18rpx;border:1rpx solid #343d43;border-radius:15rpx;overflow:hidden}.filter-row{display:flex;justify-content:space-between;align-items:center;padding:21rpx 18rpx;border-top:1rpx solid rgba(255,255,255,.08)}.filter-row:first-child{border-top:0}.filter-row>view{display:flex;align-items:center;gap:12rpx;color:#aab1b6;font-size:22rpx}.filter-row>view:last-child{color:#f2f4f5}.filter-row image{width:30rpx;height:30rpx}.filter-row>view:last-child image{width:22rpx;height:22rpx}.type-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12rpx;margin-top:18rpx}.type-item{display:flex;flex-direction:column;align-items:center;justify-content:center;height:124rpx;border:1rpx solid #3c454b;border-radius:14rpx;color:#8f969c}.type-item text:first-child{font-size:40rpx}.type-item text:last-child{margin-top:9rpx;font-size:20rpx}.type-item.selected{border-color:#ff8500;color:#ff8500;background:rgba(255,130,0,.08)}.preview-row{display:flex;align-items:center;margin-top:18rpx;padding:20rpx;border:1rpx solid #363f45;border-radius:14rpx}.preview-icon{width:70rpx;height:70rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(255,130,0,.12);color:#ff8500;font-size:34rpx}.preview-row>view:last-child{margin-left:18rpx}.preview-row>view:last-child>text{display:block}.preview-row>view:last-child>text:first-child{font-size:23rpx}.preview-row>view:last-child>text:first-child text{color:#ff8500;font-size:31rpx;font-weight:800}.preview-row>view:last-child>text:last-child{margin-top:7rpx;color:#8c949a;font-size:18rpx}.export-card button{display:flex;align-items:center;justify-content:center;gap:10rpx;margin-top:16rpx;height:80rpx;border-radius:14rpx;background:linear-gradient(90deg,#ff6100,#ff9b00);color:#fff;font-size:27rpx;font-weight:800}.export-card button image{width:31rpx;height:31rpx}.export-note{text-align:center;margin-top:16rpx;color:#7f878d;font-size:18rpx}.safe-space{height:60rpx}
