page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:7rpx;color:#ff8500;font-size:18rpx}.back-button image{width:27rpx;height:27rpx}.page-scroll{height:100%}.content{padding:18rpx 35rpx 0}.subtitle{text-align:center;display:block;color:#8f979d;font-size:19rpx}.warning-card,.section-card{border:1rpx solid #394248;border-radius:14rpx;background:linear-gradient(135deg,#182026,#0d1216)}.warning-card{display:flex;align-items:center;gap:18rpx;margin-top:22rpx;padding:20rpx;border-color:#ff5151;background:linear-gradient(135deg,rgba(79,17,20,.46),#14191d)}.warning-card>text{color:#ff5151;font-size:62rpx}.warning-card>view text{display:block}.warning-card>view text:first-child{color:#ff5151;font-size:27rpx;font-weight:800}.warning-card>view text:last-child{margin-top:7rpx;color:#b0b6ba;font-size:17rpx}.section-card{margin-top:16rpx;padding:20rpx}.section-title{font-size:25rpx;font-weight:800;margin-bottom:15rpx}.course-info{display:grid;grid-template-columns:130rpx 1fr;align-items:center}.course-info image{width:110rpx;height:110rpx;border-radius:50%}.course-info>view text{display:block;margin-top:12rpx;font-size:19rpx}.impact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-top:17rpx}.impact-grid>view{padding:16rpx;border:1rpx solid #3d464c;border-radius:10rpx;text-align:center}.impact-grid text{display:block}.impact-grid text:first-child{color:#a0a7ac;font-size:17rpx}.impact-grid text:nth-child(2){margin-top:6rpx;font-size:26rpx;font-weight:800}.impact-grid>view:last-child text:nth-child(2){color:#ff8500}.impact-grid text:last-child{margin-top:5rpx;color:#858d93;font-size:14rpx}.reason-grid{display:grid;grid-template-columns:1fr 1fr;gap:12rpx}.reason-grid>view,.option-grid>view{padding:16rpx;border:1rpx solid #3d464c;border-radius:10rpx}.reason-grid>view.active,.option-grid>view.active{border-color:#ff8500;background:rgba(255,130,0,.08)}.reason-grid text,.option-grid text{display:block}.reason-grid text:first-child,.option-grid text:first-child{font-size:19rpx}.reason-grid text:last-child,.option-grid text:last-child{margin-top:5rpx;color:#858d93;font-size:14rpx}.option-grid.three{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}.tip{margin-top:14rpx;padding:12rpx;border:1rpx solid #6d4a1d;border-radius:8rpx;background:rgba(255,130,0,.06);color:#a0a7ac;font-size:15rpx}.section-card textarea{width:100%;height:85rpx;margin-top:14rpx;padding:13rpx;border:1rpx solid #6d4a1d;border-radius:9rpx;box-sizing:border-box;color:#fff;font-size:16rpx}.danger-button,.secondary-button{margin-top:18rpx;height:74rpx;line-height:74rpx;border-radius:10rpx;background:linear-gradient(90deg,#ff3139,#ff4e2a);color:#fff;font-size:24rpx;font-weight:800}.secondary-button{margin-top:12rpx;border:1rpx solid #ff8500;background:transparent;color:#ff8500}.safe-space{height:45rpx}
