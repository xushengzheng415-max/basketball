page { height:100%; background:#05080b; color:#f5f7f8; }
.page-shell { height:100vh; overflow:hidden; background:radial-gradient(circle at 82% 15%,rgba(255,112,0,.06),transparent 27%),linear-gradient(180deg,#05080b,#070b0e); }
.custom-nav { position:absolute; z-index:10; left:0; right:0; box-sizing:content-box; display:flex; align-items:center; pointer-events:none; }
.back-button { pointer-events:auto; display:flex; align-items:center; gap:7rpx; min-height:58rpx; margin-left:27rpx; padding:0 15rpx; border:1rpx solid #32383e; border-radius:31rpx; background:rgba(5,8,11,.82); color:#e0e3e5; font-size:20rpx; }
.back-button image { width:23rpx; height:23rpx; }
.page-scroll { height:100%; }
.content { padding:8rpx 34rpx 0; box-sizing:border-box; }
.page-title { display:block; margin:8rpx 0 32rpx 4rpx; font-size:47rpx; line-height:1.1; font-weight:850; letter-spacing:2rpx; }
.search-bar { height:72rpx; padding:0 17rpx; display:flex; align-items:center; border:1rpx solid #3a4148; border-radius:17rpx; background:#11161b; box-sizing:border-box; }
.search-icon { width:31rpx; height:31rpx; }
.search-bar input { flex:1; height:72rpx; margin-left:15rpx; color:#f5f7f8; font-size:20rpx; }
.search-divider { width:1rpx; height:43rpx; margin-right:17rpx; background:#343b42; }
.filter-icon { width:30rpx; height:30rpx; }
.tab-row { display:flex; gap:17rpx; margin:28rpx 0; }
.tab-item { min-width:118rpx; height:58rpx; line-height:58rpx; padding:0 20rpx; text-align:center; border:1rpx solid #3a4148; border-radius:31rpx; background:#11161b; color:#b8bdc1; font-size:21rpx; box-sizing:border-box; }
.tab-item.active { border-color:#ff7200; background:linear-gradient(100deg,#ff6300,#ff8610); color:#fff; box-shadow:0 7rpx 17rpx rgba(255,106,0,.2); }
.summary-grid { display:grid; grid-template-columns:1fr 1fr; gap:21rpx; margin-bottom:22rpx; }
.summary-card { min-height:132rpx; padding:20rpx 34rpx; display:flex; align-items:center; gap:24rpx; border:1rpx solid rgba(255,114,0,.55); border-radius:19rpx; background:linear-gradient(120deg,#13191e,#0b1014); box-sizing:border-box; }
.summary-card>image { width:67rpx; height:67rpx; }
.summary-card>view>text { display:block; }
.summary-card>view>text:first-child { color:#b1b6ba; font-size:20rpx; }
.summary-card>view>text:last-child { margin-top:4rpx; font-size:43rpx; line-height:1; font-weight:850; }
.bell-icon { position:relative; flex:0 0 67rpx; width:67rpx; height:67rpx; }
.bell-body { position:absolute; left:12rpx; top:10rpx; width:42rpx; height:42rpx; border:5rpx solid #ff7900; border-top-left-radius:24rpx; border-top-right-radius:24rpx; border-bottom-width:4rpx; box-sizing:border-box; }
.bell-body::after { content:''; position:absolute; left:-10rpx; bottom:-7rpx; width:52rpx; height:4rpx; border-radius:4rpx; background:#ff7900; }
.bell-clapper { position:absolute; left:29rpx; bottom:5rpx; width:10rpx; height:10rpx; border-radius:50%; background:#ff7900; }
.student-card { min-height:224rpx; margin-bottom:14rpx; padding:25rpx 24rpx; display:flex; align-items:center; gap:25rpx; border:1rpx solid rgba(255,114,0,.8); border-radius:19rpx; background:radial-gradient(circle at 72% 50%,rgba(255,112,0,.045),transparent 28%),linear-gradient(110deg,#13191e,#0a0f13); box-shadow:0 8rpx 24rpx rgba(0,0,0,.28); box-sizing:border-box; }
.student-avatar { flex:0 0 132rpx; width:132rpx; height:132rpx; border:3rpx solid #ff7900; border-radius:50%; background:#1b2126; }
.student-main { flex:1; min-width:0; }
.student-name-line { display:flex; align-items:center; gap:10rpx; white-space:nowrap; }
.student-name { font-size:30rpx; font-weight:850; }
.gender { font-size:28rpx; font-weight:800; }
.gender.male { color:#42a9ff; }
.gender.female { color:#ff69a6; }
.student-age { color:#adb2b6; font-size:20rpx; }
.class-name { display:block; margin-top:8rpx; color:#b7bcc0; font-size:23rpx; }
.student-data { margin-top:23rpx; display:flex; align-items:center; }
.lesson-block { flex:0 0 142rpx; }
.lesson-block>text,.attendance-block>text:first-child { display:block; color:#a8aeb2; font-size:18rpx; }
.lesson-block>view { margin-top:7rpx; color:#ff7900; }
.lesson-block>view text:first-child { font-size:39rpx; line-height:1; font-weight:850; }
.lesson-block>view text:last-child { margin-left:6rpx; color:#eceeef; font-size:20rpx; }
.data-divider { width:1rpx; height:76rpx; margin:0 25rpx 0 0; background:#394047; }
.attendance-block { flex:1; min-width:0; }
.attendance-block>text:nth-child(2) { display:block; margin-top:7rpx; font-size:21rpx; white-space:nowrap; }
.attendance-block>view { margin-top:7rpx; display:flex; align-items:center; gap:8rpx; font-size:17rpx; }
.status-dot { width:14rpx; height:14rpx; border-radius:50%; }
.status-dot.present { background:#50d244; box-shadow:0 0 9rpx rgba(80,210,68,.45); }
.status-dot.absent { background:#ff7800; box-shadow:0 0 9rpx rgba(255,120,0,.45); }
.view-action { flex:0 0 104rpx; height:70rpx; padding-left:22rpx; display:flex; align-items:center; justify-content:flex-end; gap:9rpx; border-left:1rpx solid #394047; color:#ff7900; font-size:23rpx; font-weight:750; }
.view-action image { width:22rpx; height:22rpx; }
.empty-state { padding:70rpx 0; text-align:center; color:#858d94; font-size:21rpx; }
.add-button { width:368rpx; height:82rpx; line-height:82rpx; margin:40rpx auto 0; border-radius:44rpx; background:linear-gradient(100deg,#ff5f00,#ff8c10); color:#fff; font-size:27rpx; box-shadow:0 14rpx 28rpx rgba(255,100,0,.2); }
.add-button text { margin-right:9rpx; font-size:39rpx; font-weight:400; }
.safe-space { height:74rpx; }
