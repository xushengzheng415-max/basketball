page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:radial-gradient(circle at 100% 0,rgba(255,115,0,.13),transparent 25%),#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.96)}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:8rpx;color:#d7dbde;font-size:23rpx}.back-button image{width:28rpx;height:28rpx}.nav-title{font-size:29rpx;font-weight:700}.page-scroll{height:100%}.content{padding:20rpx 30rpx 0}.coach-card,.event-card,.only-abnormal{border:1rpx solid rgba(255,128,0,.46);border-radius:22rpx;background:linear-gradient(135deg,#182026,#0d1216)}.coach-card{display:flex;align-items:center;position:relative;padding:24rpx 24rpx 104rpx}.avatar{width:100rpx;height:100rpx;border:3rpx solid #ff7900;border-radius:50%}.coach-copy{margin-left:18rpx}.coach-copy text{display:block}.coach-copy text:first-child{font-size:30rpx;font-weight:800}.coach-copy text:last-child{margin-top:7rpx;color:#90989e;font-size:20rpx}.metric-row{position:absolute;left:20rpx;right:20rpx;bottom:18rpx;display:grid;grid-template-columns:repeat(3,1fr);border-top:1rpx solid rgba(255,255,255,.08);padding-top:15rpx}.metric-row>view{text-align:center;position:relative}.metric-row>view+view:before{content:"";position:absolute;left:0;top:2rpx;bottom:2rpx;width:1rpx;background:#343c42}.metric-row text{display:block}.metric-row text:first-child{font-size:29rpx;font-weight:800}.metric-row text:last-child{margin-top:3rpx;color:#8e969c;font-size:18rpx}.metric-row .red{color:#ff5454}.metric-row .green{color:#61d349}.filter-bar{display:flex;align-items:center;gap:12rpx;margin:20rpx 0}.filter-bar scroll-view{flex:1;white-space:nowrap}.filter{display:inline-flex;align-items:center;justify-content:center;height:54rpx;margin-right:10rpx;padding:0 20rpx;border:1rpx solid #3c454b;border-radius:28rpx;color:#a8afb4;font-size:20rpx}.filter.active{border-color:#ff8500;background:#ff7900;color:#fff}.date-filter{flex:none;display:flex;align-items:center;gap:7rpx;height:54rpx;padding:0 15rpx;border:1rpx solid #3d454b;border-radius:28rpx;color:#ff8500;font-size:19rpx}.date-filter image{width:24rpx;height:24rpx}.date-heading{margin:24rpx 4rpx 10rpx;color:#aeb4b9;font-size:22rpx;font-weight:700}.event-card{display:grid;grid-template-columns:70rpx 28rpx 62rpx 1fr 24rpx;align-items:start;padding:20rpx;margin-top:12rpx}.event-time{padding-top:9rpx;color:#c5c9cc;font-size:20rpx}.timeline{position:relative;align-self:stretch;display:flex;justify-content:center}.dot{position:relative;z-index:2;width:13rpx;height:13rpx;margin-top:14rpx;border-radius:50%;background:#ff8500;box-shadow:0 0 12rpx rgba(255,133,0,.6)}.dot.green{background:#5fd04b}.dot.red{background:#ff5252}.line{position:absolute;top:27rpx;bottom:-34rpx;width:2rpx;background:#3b444a}.event-icon{width:50rpx;height:50rpx;border-radius:14rpx;background:rgba(255,130,0,.12);display:flex;align-items:center;justify-content:center}.event-icon image{width:30rpx;height:30rpx}.event-copy{padding-left:12rpx}.event-copy text{display:block}.event-copy>text:first-child{font-size:24rpx;font-weight:800}.event-copy>text:nth-child(2){margin-top:7rpx;color:#8e969c;font-size:18rpx;line-height:1.45}.result{margin-top:8rpx;font-size:18rpx;color:#ff8500}.result.green{color:#61d349}.result.red{color:#ff5555}.chevron{width:23rpx;height:23rpx;margin-top:13rpx}.only-abnormal{display:flex;align-items:center;justify-content:space-between;margin-top:24rpx;padding:20rpx 22rpx}.only-abnormal text{display:block}.only-abnormal>view:first-child text:first-child{font-size:23rpx;font-weight:700}.only-abnormal>view:first-child text:last-child{margin-top:5rpx;color:#858d93;font-size:18rpx}.switch{width:72rpx;height:40rpx;padding:4rpx;border-radius:24rpx;background:#3a4248;box-sizing:border-box}.switch view{width:32rpx;height:32rpx;border-radius:50%;background:#91989e}.switch.on{background:#ff7900}.switch.on view{margin-left:32rpx;background:#fff}.safe-space{height:60rpx}
