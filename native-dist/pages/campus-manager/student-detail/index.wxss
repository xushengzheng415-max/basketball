page { height:100%; background:#05080b; color:#f5f7f8; }
.page-shell { height:100vh; overflow:hidden; background:radial-gradient(circle at 82% 23%,rgba(255,112,0,.06),transparent 26%),linear-gradient(180deg,#05080b,#070b0e); }
.custom-nav { position:absolute; z-index:10; left:0; right:0; box-sizing:content-box; display:flex; align-items:center; justify-content:center; pointer-events:none; }
.back-button { position:absolute; left:30rpx; width:58rpx; height:58rpx; display:flex; align-items:center; pointer-events:auto; }
.back-button image { width:32rpx; height:32rpx; }
.nav-title { font-size:34rpx; font-weight:850; letter-spacing:2rpx; }
.page-scroll { height:100%; }
.content { padding:9rpx 31rpx 0; box-sizing:border-box; }
.profile-section { min-height:238rpx; padding:15rpx 17rpx; display:flex; align-items:center; gap:34rpx; box-sizing:border-box; }
.profile-avatar { flex:0 0 188rpx; width:188rpx; height:188rpx; border:3rpx solid #ff7900; border-radius:50%; background:#1b2126; box-shadow:0 10rpx 25rpx rgba(255,110,0,.14); }
.profile-copy { flex:1; }
.student-name { display:block; font-size:46rpx; font-weight:850; letter-spacing:2rpx; }
.identity-line { margin-top:22rpx; display:flex; align-items:center; gap:16rpx; }
.identity-line text:first-child { color:#42a9ff; font-size:34rpx; font-weight:800; }
.identity-line text:nth-child(2) { color:#c6cacf; font-size:24rpx; }
.identity-line view { width:1rpx; height:34rpx; background:#6d747a; }
.identity-line text:last-child { color:#ff7900; font-size:24rpx; font-weight:750; }
.reading-state { margin-top:18rpx; display:flex; align-items:center; gap:13rpx; color:#4bd94a; font-size:23rpx; font-weight:750; }
.reading-state view { width:17rpx; height:17rpx; border-radius:50%; background:#4bd94a; box-shadow:0 0 10rpx rgba(75,217,74,.42); }
.course-summary { position:relative; min-height:258rpx; padding:28rpx 31rpx; display:flex; align-items:stretch; border:1rpx solid rgba(255,114,0,.76); border-radius:19rpx; background:linear-gradient(115deg,#13191e,#090d10); overflow:hidden; box-sizing:border-box; }
.lesson-summary { flex:0 0 232rpx; z-index:1; }
.summary-divider { z-index:1; width:1rpx; margin:0 35rpx; background:#3c4349; }
.next-course { flex:1; z-index:1; min-width:0; }
.summary-heading { display:flex; align-items:center; gap:14rpx; font-size:25rpx; font-weight:800; }
.summary-heading image { width:39rpx; height:39rpx; }
.lesson-value { margin-top:50rpx; color:#ff7900; }
.lesson-value text:first-child { font-size:74rpx; line-height:1; font-weight:850; }
.lesson-value text:last-child { margin-left:13rpx; color:#d2d6d9; font-size:22rpx; }
.date-line { margin-top:48rpx; display:flex; align-items:flex-end; gap:18rpx; white-space:nowrap; }
.date-line text:first-child { font-size:49rpx; line-height:1; font-weight:750; }
.date-line text:nth-child(2),.date-line text:last-child { color:#c3c7ca; font-size:21rpx; }
.location-line { margin-top:25rpx; display:flex; align-items:center; gap:12rpx; color:#bfc4c8; font-size:21rpx; }
.location-line image { width:30rpx; height:30rpx; }
.basketball-mark { position:absolute; right:-59rpx; top:48rpx; width:180rpx; height:180rpx; border:2rpx solid rgba(255,114,0,.13); border-radius:50%; }
.status-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:18rpx; margin-top:22rpx; }
.status-card { min-width:0; min-height:255rpx; padding:27rpx 22rpx; border:1rpx solid rgba(255,114,0,.7); border-radius:18rpx; background:linear-gradient(120deg,#13191e,#0b1014); box-sizing:border-box; }
.card-heading { display:flex; align-items:center; gap:12rpx; color:#cdd1d4; font-size:22rpx; font-weight:750; white-space:nowrap; }
.card-heading image { width:34rpx; height:34rpx; }
.attendance-value { margin-top:47rpx; display:flex; align-items:flex-end; gap:8rpx; }
.attendance-value text:first-child { font-size:55rpx; line-height:1; font-weight:850; }
.attendance-value text:nth-child(2) { color:#aab0b5; font-size:31rpx; }
.attendance-value text:last-child { margin-bottom:5rpx; color:#bfc4c8; font-size:19rpx; }
.report-value,.risk-value { display:block; margin-top:50rpx; font-size:40rpx; font-weight:850; white-space:nowrap; }
.risk-value { color:#ff544b; }
.card-caption { display:block; margin-top:26rpx; color:#999fa5; font-size:18rpx; white-space:nowrap; }
.quick-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:17rpx; margin-top:33rpx; }
.quick-card { min-height:188rpx; padding:30rpx 8rpx 24rpx; display:flex; flex-direction:column; align-items:center; justify-content:space-between; border:1rpx solid rgba(255,114,0,.7); border-radius:17rpx; background:#11171c; box-sizing:border-box; }
.quick-card image { width:62rpx; height:62rpx; }
.quick-card text { font-size:22rpx; font-weight:750; white-space:nowrap; }
.recommend-title { margin:51rpx 3rpx 26rpx; display:flex; align-items:center; gap:16rpx; font-size:30rpx; font-weight:850; }
.recommend-title view { width:8rpx; height:37rpx; border-radius:5rpx; background:#ff7900; }
.recommend-card { min-height:145rpx; padding:25rpx 28rpx; display:flex; align-items:center; gap:25rpx; border:1rpx solid rgba(255,114,0,.72); border-radius:19rpx; background:linear-gradient(110deg,#171611,#0c1115); box-sizing:border-box; }
.send-symbol { flex:0 0 72rpx; width:72rpx; height:72rpx; line-height:72rpx; text-align:center; border:1rpx solid #ff7900; border-radius:50%; background:#2d2115; color:#ff7900; font-size:38rpx; transform:rotate(-18deg); }
.recommend-copy { flex:1; min-width:0; }
.recommend-copy text { display:block; }
.recommend-copy text:first-child { font-size:26rpx; font-weight:800; }
.recommend-copy text:last-child { margin-top:11rpx; color:#9fa5aa; font-size:18rpx; }
.recommend-card>image { width:25rpx; height:25rpx; }
.primary-button { height:92rpx; line-height:92rpx; margin:46rpx 0 0; border-radius:19rpx; background:linear-gradient(100deg,#ff6000,#ff8c10); color:#fff; font-size:29rpx; font-weight:850; box-shadow:0 14rpx 30rpx rgba(255,100,0,.2); }
.safe-space { height:74rpx; }
