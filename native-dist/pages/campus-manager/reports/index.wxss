page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:210rpx;background:rgba(5,9,12,.97);font-size:31rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:7rpx;color:#d4d8db;font-size:19rpx}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:20rpx 36rpx 0}.report-heading text{display:block}.report-heading text:first-child{font-size:38rpx;font-weight:900}.report-heading text:last-child{margin-top:8rpx;color:#8f979d;font-size:20rpx}.selector-grid{display:grid;grid-template-columns:1fr 1fr;gap:20rpx;margin-top:24rpx}.selector-grid picker{width:100%}.selector-grid view{display:flex;align-items:center;justify-content:space-between;padding:20rpx;border:1rpx solid #394248;border-radius:14rpx;background:#141b20;font-size:21rpx}.selector-grid view text:last-child{color:#ff8b24;font-size:25rpx}.report-grid{display:grid;grid-template-columns:1fr 1fr;gap:22rpx;margin-top:24rpx}.report-card{padding:25rpx 26rpx;border:1rpx solid #6d4a1d;border-radius:18rpx;background:linear-gradient(135deg,#182026,#0d1216);box-shadow:0 0 25rpx rgba(255,130,0,.09)}.report-icon{width:68rpx;height:68rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#ffa000,#ff6800);color:#fff;font-size:27rpx;font-weight:900}.report-card>text{display:block}.report-card>text:nth-child(2){margin-top:21rpx;font-size:26rpx;font-weight:800}.report-card>text:nth-child(3){margin-top:28rpx;color:#8f979d;font-size:19rpx}.report-card>view:nth-child(4){display:flex;align-items:baseline;gap:3rpx;margin-top:10rpx}.report-card>view:nth-child(4) text:nth-child(2){font-size:45rpx;font-weight:800}.report-card>view:nth-child(4) text:first-child,.report-card>view:nth-child(4) text:last-child{font-size:23rpx;font-weight:800}.report-card>text:nth-child(5){margin-top:15rpx;color:#8f979d;font-size:17rpx}.report-card>text:nth-child(5) text{display:inline;color:#ff8500;font-size:20rpx}.report-card>text:nth-child(5) text.green{color:#55d15a}.report-card button{margin-top:25rpx;height:58rpx;line-height:58rpx;border:1rpx solid #ff8500;border-radius:12rpx;background:transparent;color:#ff8500;font-size:20rpx}.finance-anomaly-list{margin-top:24rpx}.finance-anomaly-card{padding:26rpx;border:1rpx solid rgba(255,82,82,.45);border-radius:20rpx;background:linear-gradient(145deg,rgba(55,24,25,.92),rgba(18,23,27,.98))}.finance-anomaly-card>view{display:flex;align-items:center;justify-content:space-between;gap:18rpx}.finance-anomaly-card>view:first-child text:first-child{font-size:27rpx;font-weight:900}.finance-anomaly-card>view:first-child text:last-child{padding:6rpx 12rpx;border-radius:999rpx;background:rgba(255,82,82,.14);color:#ff6868;font-size:18rpx}.finance-anomaly-card>text{display:block;margin-top:15rpx;color:#9da4aa;font-size:20rpx;line-height:1.6}.finance-anomaly-card>view:last-child{margin-top:20rpx;padding-top:16rpx;border-top:1rpx solid rgba(255,255,255,.08);color:#737d85;font-size:18rpx}.finance-anomaly-card>view:last-child text:last-child{color:#ff8b24;font-weight:800}.export-button,.analysis-button{margin-top:20rpx;height:76rpx;line-height:76rpx;border:1rpx solid #ff8500;border-radius:12rpx;background:transparent;color:#ff8500;font-size:24rpx;font-weight:800}.analysis-button{margin-top:14rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff}.safe-space{height:45rpx}
