page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97);font-size:31rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:7rpx;color:#d4d8db;font-size:19rpx}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:20rpx 36rpx 0}.selector-grid{display:grid;grid-template-columns:1fr 1fr;gap:30rpx}.selector-grid view{padding:20rpx;border:1rpx solid #394248;border-radius:14rpx;background:#141b20;font-size:21rpx}.report-grid{display:grid;grid-template-columns:1fr 1fr;gap:22rpx;margin-top:24rpx}.report-card{padding:25rpx 26rpx;border:1rpx solid #6d4a1d;border-radius:18rpx;background:linear-gradient(135deg,#182026,#0d1216);box-shadow:0 0 25rpx rgba(255,130,0,.09)}.report-icon{width:68rpx;height:68rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#ffa000,#ff6800);font-size:34rpx}.report-card>text{display:block}.report-card>text:nth-child(2){margin-top:21rpx;font-size:26rpx;font-weight:800}.report-card>text:nth-child(3){margin-top:28rpx;color:#8f979d;font-size:19rpx}.report-card>view:nth-child(4){margin-top:10rpx}.report-card>view:nth-child(4) text:first-child{font-size:57rpx;font-weight:800}.report-card>view:nth-child(4) text:last-child{font-size:25rpx}.report-card>text:nth-child(5){margin-top:15rpx;color:#8f979d;font-size:17rpx}.report-card>text:nth-child(5) text{display:inline;color:#ff8500;font-size:20rpx}.report-card>text:nth-child(5) text.green{color:#55d15a}.report-card button{margin-top:25rpx;height:58rpx;line-height:58rpx;border:1rpx solid #ff8500;border-radius:12rpx;background:transparent;color:#ff8500;font-size:20rpx}.export-button,.analysis-button{margin-top:20rpx;height:76rpx;line-height:76rpx;border:1rpx solid #ff8500;border-radius:12rpx;background:transparent;color:#ff8500;font-size:24rpx;font-weight:800}.analysis-button{margin-top:14rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff}.safe-space{height:45rpx}
