<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /><text>返回工作台</text></view><text>教务报表</text></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content"><view class="selector-grid"><view>⌖ 浦东校区　⌄</view><view>▣ 本月　⌄</view></view><view class="report-grid"><view class="report-card" wx:for="{{reports}}" wx:key="title"><view class="report-icon">{{item.symbol}}</view><text>{{item.title}}</text><text>{{item.metric}}</text><view><text>{{item.value}}</text><text>%</text></view><text>较上月　<text class="{{item.tone}}">{{item.trend}}</text></text><button bindtap="openReport">查看　›</button></view></view><button class="export-button" bindtap="openReport">⇩ 导出报表</button><button class="analysis-button" bindtap="openAnalysis">↗ 查看经营分析</button><view class="safe-space"></view></view></scroll-view></view>
