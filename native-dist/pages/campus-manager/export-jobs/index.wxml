<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /></view><text class="nav-title">导出任务记录</text></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content">
  <view class="page-heading"><text>M41</text><text>导出任务记录</text><text>导出任务管理与下载，生成的文件将保留7天</text></view>
  <view class="metric-grid"><view class="metric-card" wx:for="{{metrics}}" wx:key="label"><text>{{item.label}}</text><text class="{{item.tone}}">{{item.value}}</text></view></view>
  <view class="filter-panel"><view>全部状态⌄</view><view>全部报告类型⌄</view><view>开始日期 → 结束日期</view><view>↻ 重置</view></view>
  <view class="job-card" wx:for="{{jobs}}" wx:key="id"><view class="job-heading"><view><text class="status {{item.tone}}">{{item.status}}</text><text>{{item.name}}</text></view><text>任务ID：{{item.id}}</text></view><view class="job-body"><view class="job-info"><text>时间范围　{{item.range}}</text><text>创建人　　{{item.creator}}</text><text>文件大小　{{item.size}}</text><text>创建时间　{{item.created}}</text><text class="expiry {{item.tone}}">到期/原因　{{item.expiry}}</text></view><view class="job-actions"><view wx:if="{{item.progress}}" class="progress-block"><view><text>{{item.progress}}</text><text>正在生成中…</text></view><view class="progress-track"><view></view></view></view><button wx:if="{{item.action}}" data-action="{{item.action}}" bindtap="runAction">{{item.action}}</button><button class="secondary" bindtap="openDetail">查看详情</button></view></view></view>
  <view class="footer-note">仅保留最近90天的任务记录</view><view class="safe-space"></view>
</view></scroll-view></view>
