page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.97)}.back-button{position:absolute;left:24rpx;bottom:0;width:68rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:32rpx;height:32rpx}.nav-title{font-size:29rpx;font-weight:800}.page-scroll{height:100%}.content{padding:20rpx 28rpx 0}.page-heading text{display:block}.page-heading text:first-child{color:#ff8500;font-size:20rpx}.page-heading text:nth-child(2){margin-top:8rpx;font-size:43rpx;font-weight:900}.page-heading text:last-child{margin-top:8rpx;color:#8e969c;font-size:21rpx}.metric-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12rpx;margin-top:26rpx}.metric-card{padding:20rpx;border:1rpx solid #384148;border-radius:16rpx;background:#141b20}.metric-card text{display:block}.metric-card text:first-child{font-size:20rpx;color:#b2b8bc}.metric-card text:last-child{margin-top:15rpx;font-size:38rpx;font-weight:800}.orange{color:#ff8500}.green{color:#4fd06c}.blue{color:#428bff}.red{color:#ff5559}.filter-panel{display:grid;grid-template-columns:1fr 1fr 1.5fr .65fr;gap:12rpx;margin-top:20rpx;padding:14rpx;border:1rpx solid #343d43;border-radius:15rpx;background:#11181d}.filter-panel view{display:flex;align-items:center;justify-content:center;min-height:56rpx;border:1rpx solid #3a444a;border-radius:10rpx;color:#c1c6c9;font-size:18rpx}.job-card{margin-top:18rpx;padding:20rpx;border:1rpx solid #394248;border-radius:17rpx;background:#12191e}.job-heading{display:flex;align-items:center;justify-content:space-between;padding-bottom:14rpx;border-bottom:1rpx solid rgba(255,255,255,.08)}.job-heading>view{display:flex;align-items:center;gap:12rpx}.job-heading>view>text:last-child{font-size:23rpx;font-weight:800}.job-heading>text{color:#91999f;font-size:17rpx}.status{padding:5rpx 10rpx;border-radius:8rpx;background:rgba(255,255,255,.06);font-size:18rpx}.job-body{display:grid;grid-template-columns:1.4fr .8fr;gap:20rpx;padding-top:15rpx}.job-info text{display:block;margin-top:7rpx;color:#aeb5ba;font-size:18rpx}.job-info .expiry.red{color:#ff5559}.job-info .expiry.green{color:#ff9a00}.job-actions{display:flex;flex-direction:column;justify-content:center;gap:10rpx}.job-actions button{height:60rpx;line-height:60rpx;border-radius:10rpx;background:linear-gradient(90deg,#ff6900,#ff9b00);color:#fff;font-size:20rpx}.job-actions button.secondary{border:1rpx solid #59636a;background:transparent}.progress-block>view:first-child{display:flex;align-items:center;gap:10rpx}.progress-block>view:first-child text:first-child{font-size:32rpx;color:#428bff;font-weight:800}.progress-block>view:first-child text:last-child{font-size:18rpx;color:#aab1b6}.progress-track{height:10rpx;margin-top:10rpx;border-radius:10rpx;background:#4a535a}.progress-track view{width:65%;height:100%;border-radius:10rpx;background:#428bff}.footer-note{text-align:center;margin-top:22rpx;color:#70787e;font-size:18rpx}.safe-space{height:50rpx}
