<view class="page-shell">
  <view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;">
    <view class="back-button" bindtap="goBack" aria-role="button" aria-label="返回员工管理">
      <image src="{{icons.back}}" mode="aspectFit" />
      <text>员工管理</text>
    </view>
    <text class="nav-title">教练详情</text>
  </view>

  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view style="height: {{navSpacer}}px;"></view>
    <view class="content">
      <view class="hero-card">
        <image class="coach-avatar" src="{{avatar}}" mode="aspectFill" />
        <view class="coach-copy">
          <view class="name-line"><text>陈教练</text><text class="role-tag">全职教练</text></view>
          <text class="coach-meta">浦东校区 · 主教练</text>
          <view class="online-line"><view></view><text>当前在岗</text></view>
        </view>
      </view>

      <view class="metric-grid">
        <view class="metric-card" wx:for="{{metrics}}" wx:key="label">
          <text class="metric-label">{{item.label}}</text>
          <view class="metric-value {{item.tone}}"><text>{{item.value}}</text><text>{{item.suffix}}</text></view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-heading"><text>今日课程</text><text>共 2 节</text></view>
        <view class="course-row" wx:for="{{courses}}" wx:key="time">
          <view class="course-time"><text>{{item.time}}</text><text>{{item.status}}</text></view>
          <view class="course-main"><text>{{item.name}}</text><view><image src="{{icons.location}}" mode="aspectFit" /><text>浦东校区 · {{item.place}}</text></view></view>
          <image class="chevron" src="{{icons.chevron}}" mode="aspectFit" />
        </view>
      </view>

      <view class="section-card">
        <view class="section-heading"><text>执行质量</text><text>近 30 天</text></view>
        <view class="quality-grid">
          <view class="quality-item" wx:for="{{qualities}}" wx:key="label">
            <view class="quality-ring {{item.ringClass}}"><text>{{item.value}}</text></view>
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-heading"><text>管理操作</text><text>快捷入口</text></view>
        <view class="action-row" wx:for="{{actions}}" wx:key="label" bindtap="openPage" data-route="{{item.route}}">
          <view class="action-icon"><image src="{{item.icon}}" mode="aspectFit" /></view>
          <view class="action-copy"><text>{{item.label}}</text><text>{{item.caption}}</text></view>
          <image class="chevron" src="{{icons.chevron}}" mode="aspectFit" />
        </view>
      </view>
      <view class="safe-space"></view>
    </view>
  </scroll-view>
</view>
