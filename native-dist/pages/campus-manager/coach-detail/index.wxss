page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:radial-gradient(circle at 95% 0,rgba(255,116,0,.14),transparent 25%),#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:linear-gradient(180deg,rgba(5,9,12,.98),rgba(5,9,12,.9))}.back-button{position:absolute;left:24rpx;bottom:0;height:68rpx;display:flex;align-items:center;gap:8rpx;color:#d6d9dc;font-size:24rpx}.back-button image{width:28rpx;height:28rpx}.nav-title{font-size:30rpx;font-weight:700}.page-scroll{height:100%}.content{padding:22rpx 30rpx 0}.hero-card,.section-card,.metric-card{border:1rpx solid rgba(255,133,22,.46);background:linear-gradient(135deg,rgba(24,31,36,.96),rgba(12,17,21,.96));box-shadow:0 16rpx 40rpx rgba(0,0,0,.24)}.hero-card{display:flex;align-items:center;padding:30rpx;border-radius:24rpx}.coach-avatar{width:142rpx;height:142rpx;border-radius:50%;border:3rpx solid #ff7900}.coach-copy{margin-left:28rpx;flex:1}.name-line{display:flex;align-items:center;gap:18rpx}.name-line>text:first-child{font-size:40rpx;font-weight:800}.role-tag{padding:7rpx 14rpx;border:1rpx solid #ff7900;border-radius:12rpx;color:#ff8a00;font-size:20rpx}.coach-meta{display:block;margin-top:14rpx;color:#aeb4ba;font-size:25rpx}.online-line{display:flex;align-items:center;gap:10rpx;margin-top:16rpx;color:#68d34e;font-size:22rpx}.online-line view{width:12rpx;height:12rpx;border-radius:50%;background:#62d64f;box-shadow:0 0 14rpx rgba(98,214,79,.8)}.metric-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16rpx;margin-top:18rpx}.metric-card{padding:24rpx;border-radius:20rpx}.metric-label{color:#aeb4ba;font-size:23rpx}.metric-value{margin-top:10rpx;font-weight:800}.metric-value text:first-child{font-size:48rpx}.metric-value text:last-child{margin-left:6rpx;font-size:21rpx}.metric-value.green{color:#66d44d}.metric-value.orange{color:#ff8500}.metric-value.red{color:#ff5252}.section-card{margin-top:20rpx;padding:24rpx;border-radius:24rpx}.section-heading{display:flex;align-items:center;justify-content:space-between;margin-bottom:10rpx}.section-heading text:first-child{font-size:30rpx;font-weight:800}.section-heading text:last-child{color:#888f96;font-size:21rpx}.course-row,.action-row{display:flex;align-items:center;padding:22rpx 4rpx;border-top:1rpx solid rgba(255,255,255,.09)}.course-time{width:190rpx;display:flex;flex-direction:column}.course-time text:first-child{font-size:27rpx;font-weight:700}.course-time text:last-child{margin-top:8rpx;color:#ff8500;font-size:20rpx}.course-main{flex:1}.course-main>text{font-size:28rpx;font-weight:700}.course-main view{display:flex;align-items:center;gap:7rpx;margin-top:10rpx;color:#92999f;font-size:21rpx}.course-main image{width:25rpx;height:25rpx}.chevron{width:24rpx;height:24rpx}.quality-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;padding-top:18rpx}.quality-item{display:flex;flex-direction:column;align-items:center;color:#c9cdd0;font-size:21rpx}.quality-ring{width:112rpx;height:112rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:16rpx;background:#12191e;border:12rpx solid #5fd149;box-sizing:border-box}.quality-ring text{font-size:26rpx;font-weight:800}.ring-orange{border-color:#ff8500}.ring-yellow{border-color:#f6ba35}.action-icon{width:70rpx;height:70rpx;border-radius:18rpx;background:rgba(255,125,0,.12);display:flex;align-items:center;justify-content:center}.action-icon image{width:38rpx;height:38rpx}.action-copy{flex:1;margin-left:20rpx}.action-copy text{display:block}.action-copy text:first-child{font-size:27rpx;font-weight:700}.action-copy text:last-child{margin-top:6rpx;color:#8f969c;font-size:20rpx}.safe-space{height:60rpx}
