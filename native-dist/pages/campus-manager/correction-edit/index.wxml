<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /><text>返回</text></view></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content">
  <view class="page-heading"><view><text>M43</text><text>课消出勤更正</text></view><text>更正学生出勤状态或课消时长</text></view>
  <view class="student-card"><image src="{{avatar}}" mode="aspectFill" /><view><view><text>张子轩</text><text>学员</text></view><text>学号：BF20231245　|　校区：蜂巢大学城校区</text></view><image class="chevron" src="{{icons.chevron}}" mode="aspectFit" /></view>
  <view class="compare-heading"><text>更正前后对比</text><text>差异一目了然</text></view><view class="compare-grid"><view class="compare-card before"><text>● 更正前</text><view><text>出勤状态</text><text>缺勤</text></view><view><text>课消时长</text><text>0.0 小时</text></view><view><text>课消金额</text><text>￥0.00</text></view><view><text>记录时间</text><text>2025-05-20 19:00</text></view><view><text>班级 / 教练</text><text>基础班A / 李教练</text></view></view><view class="compare-arrow">→</view><view class="compare-card after"><text>● 更正后（拟更正为）</text><view><text>出勤状态</text><text>{{attendance}}</text></view><view><text>课消时长</text><text>{{hours}} 小时</text></view><view><text>课消金额</text><text>￥135.00</text></view><view><text>记录时间</text><text>2025-05-20 19:00</text></view><view><text>班级 / 教练</text><text>基础班A / 李教练</text></view></view></view>
  <view class="form-card"><view class="card-title">更正信息</view><view class="form-row"><text>出勤状态 *</text><view class="attendance-options"><text class="{{item.activeClass}}" wx:for="{{attendanceOptions}}" wx:key="label" data-label="{{item.label}}" bindtap="selectAttendance">{{item.label}}</text></view></view><view class="form-row"><text>课消时长（小时）*</text><view class="stepper"><text data-delta="-0.5" bindtap="changeHours">−</text><text>{{hours}}</text><text data-delta="0.5" bindtap="changeHours">＋</text></view></view><view class="form-row"><text>课程日期 *</text><view class="select-value">2025-05-20（周二）›</view></view><view class="form-row"><text>班级 *</text><view class="select-value">基础班A　›</view></view><view class="form-row"><text>教练 *</text><view class="select-value">李教练　›</view></view><view class="reason-block"><text>更正原因 *</text><view><text class="{{item.activeClass}}" wx:for="{{reasons}}" wx:key="key" data-key="{{item.key}}" bindtap="selectReason">○ {{item.label}}</text></view></view><view class="note-block"><text>说明（选填）</text><textarea maxlength="100" placeholder="请简要说明更正原因（不超过100字）" value="{{note}}" bindinput="onNoteInput" /></view><view class="upload-title">证据上传（选填，最多5张）</view><view class="upload-grid"><image src="{{courtPhoto}}" mode="aspectFill" /><view>＋<text>上传图片</text></view><view>＋<text>上传图片</text></view></view></view>
  <view class="impact-card"><text>影响计算</text><view><view><text>课消时长影响</text><text>+1.5 小时</text></view><view><text>课消金额影响</text><text>+￥135.00</text></view></view></view>
  <view class="flow-tip"><image src="{{icons.warning}}" mode="aspectFit" /><view><text>提交后将进入审核流程</text><text>审核通过后数据将更新，学员与教练端同步调整</text></view></view><button class="primary-button" bindtap="submitReview">提交审核</button><view class="safe-space"></view>
</view></scroll-view></view>
