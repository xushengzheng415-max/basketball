<view class="page-shell">
  <view class="ambient ambient-top"></view>
  <view class="ambient ambient-side"></view>

  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}" scroll-into-view="{{guideScrollTarget}}" scroll-with-animation>
    <view class="content">
      <view class="role-row" style="height: {{navSpacer}}px; padding-top: {{navTop}}px;">
        <picker mode="selector" range="{{roleOptions}}" value="{{roleIndex}}" bindchange="onRoleChange" disabled="{{rolePickerDisabled}}">
          <view id="guide-role" class="role-pill" aria-role="button" aria-label="预览身份切换">
            <text>校长端</text>
            <text class="role-switch-mark" wx:if="{{showRoleTester}}">⌄</text>
          </view>
        </picker>
      </view>

      <view class="hero">
        <text class="page-title">{{screen.title}}</text>
        <text class="subtitle">{{screen.subtitle}}</text>
      </view>

      <view id="guide-business" class="business-section">
        <view class="business-grid">
          <view class="business-card {{item.toneClass}}" wx:for="{{screen.businessCards}}" wx:key="key" data-route="{{item.route}}" bindtap="openRoute">
            <view class="business-card-glow"></view>
            <view class="business-card-head">
              <text class="business-eyebrow">{{item.eyebrow}}</text>
              <text class="business-trend {{item.trendClass}}">{{item.trend}}</text>
            </view>
            <view class="business-main-value">
              <text class="business-prefix" wx:if="{{item.prefix}}">{{item.prefix}}</text>
              <text class="business-value">{{item.value}}</text>
              <text class="business-unit">{{item.unit}}</text>
            </view>
            <view class="business-amount-row">
              <text>{{item.amountLabel}}</text>
              <text>{{item.amount}}</text>
            </view>
            <view class="business-detail">
              <text>{{item.detail}}</text>
              <text>查看明细 ›</text>
            </view>
          </view>
        </view>

      </view>

      <view id="guide-tasks" class="panel task-panel">
        <view class="section-head task-head">
          <view>
            <view class="task-title-row">
              <text class="section-title">今日待办</text>
              <text class="task-total">{{screen.pendingCount}}</text>
            </view>
            <text class="section-description">4 类任务，处理后自动关闭</text>
          </view>
          <view class="task-legend"><text></text><text>按优先级排序</text></view>
        </view>

        <view class="task-list">
          <view class="task-row" wx:for="{{screen.tasks}}" wx:key="code" data-route="{{item.route}}" bindtap="openRoute">
            <view class="task-symbol tone-{{item.toneClass}}"><image src="{{item.icon}}" mode="aspectFit" /></view>
            <view class="task-copy">
              <view class="task-name-row">
                <text class="task-name">{{item.title}}</text>
                <text class="task-code">{{item.code}}</text>
              </view>
              <text class="task-description">{{item.description}}</text>
            </view>
            <view class="task-count tone-text-{{item.toneClass}}">
              <text>{{item.count}}</text><text>{{item.unit}}</text>
            </view>
            <text class="row-chevron">›</text>
          </view>
        </view>
      </view>

      <view id="guide-management" class="panel management-panel">
        <view class="section-head management-head">
          <text class="section-title">管理中心</text>
          <view class="management-more" bindtap="openMoreManagement">
            <text>更多管理</text>
            <text>查看更多 ›</text>
          </view>
        </view>
        <view class="management-grid">
          <view class="management-item" wx:for="{{screen.management}}" wx:key="key" data-key="{{item.key}}" bindtap="openManagement">
            <text class="management-badge" wx:if="{{item.badge}}">{{item.badge}}</text>
            <view class="management-symbol tone-bg-{{item.toneClass}}"><image src="{{item.icon}}" mode="aspectFit" /></view>
            <view class="management-copy">
              <text class="management-label">{{item.label}}</text>
              <text class="management-description">{{item.caption}}</text>
            </view>
            <text class="management-chevron">›</text>
          </view>
        </view>
      </view>

      <view class="tabbar-space"></view>
    </view>
  </scroll-view>

  <sxf-tabbar active="education" />

  <view class="more-management-layer" wx:if="{{moreManagementVisible}}" catchtouchmove="blockGuideTouch">
    <view class="more-management-mask" bindtap="closeMoreManagement"></view>
    <view class="more-management-sheet" catchtap="blockGuideTouch">
      <view class="more-sheet-handle"></view>
      <view class="more-sheet-head">
        <view><text>更多管理</text><text>低频功能集中放在二级入口</text></view>
        <view class="more-sheet-close" bindtap="closeMoreManagement">×</view>
      </view>
      <view class="more-sheet-toolbar">
        <view class="more-column-switch" aria-label="切换管理入口排列列数">
          <view class="more-column-option {{moreColumnTwoClass}}" data-columns="2" bindtap="changeMoreColumns">2列</view>
          <view class="more-column-option {{moreColumnThreeClass}}" data-columns="3" bindtap="changeMoreColumns">3列</view>
        </view>
        <view class="more-edit-button" bindtap="toggleMoreEdit">{{moreEditLabel}}</view>
      </view>
      <text class="more-sort-hint">{{moreSortHint}}</text>
      <view class="more-management-grid {{moreColumnClass}}">
        <view
          class="more-management-item {{moreItem.dragClass}}"
          wx:for="{{moreManagement}}"
          wx:for-item="moreItem"
          wx:for-index="moreIndex"
          wx:key="key"
          data-index="{{moreIndex}}"
          data-route="{{moreItem.route}}"
          bindtap="openMoreRoute"
          bindlongpress="startMoreDrag"
          catchtouchmove="moveMoreDrag"
          bindtouchend="finishMoreDrag"
          bindtouchcancel="finishMoreDrag"
        >
          <view class="more-management-icon"><image src="{{moreItem.icon}}" mode="aspectFit" /></view>
          <view class="more-management-copy"><text class="more-management-label">{{moreItem.label}}</text><text class="more-management-caption">{{moreItem.caption}}</text></view>
          <view class="more-drag-handle" wx:if="{{moreEditMode}}"><text></text><text></text><text></text></view>
          <text class="more-management-arrow" wx:else>›</text>
        </view>
      </view>
      <view class="more-sheet-safe"></view>
    </view>
  </view>

  <view class="guide-layer" wx:if="{{guideVisible}}" catchtouchmove="blockGuideTouch">
    <view class="guide-spotlight" style="{{guideSpotlightStyle}}"></view>
    <view class="guide-card">
      <view class="guide-meta">
        <text class="guide-kicker">首次使用引导</text>
        <text class="guide-step">{{guide.stepText}}</text>
      </view>
      <text class="guide-title">{{guide.title}}</text>
      <text class="guide-description">{{guide.description}}</text>
      <view class="guide-dots">
        <view class="guide-dot {{item.activeClass}}" wx:for="{{guide.dots}}" wx:key="key"></view>
      </view>
      <view class="guide-actions">
        <text class="guide-exit" bindtap="exitGuide">退出引导</text>
        <view class="guide-nav-actions">
          <view class="guide-button guide-button-secondary" wx:if="{{guide.showPrevious}}" bindtap="previousGuideStep">上一步</view>
          <view class="guide-button guide-button-primary" bindtap="nextGuideStep">{{guide.primaryText}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
