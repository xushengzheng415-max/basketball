.page-shell { position:relative; height:100vh; overflow:hidden; background:linear-gradient(180deg,#05080b 0%,#080c10 60%,#070a0d 100%); color:#f7f8fa; font-family:"PingFang SC","Microsoft YaHei",sans-serif; }
.ambient { position:absolute; pointer-events:none; border-radius:50%; filter:blur(44rpx); }
.ambient-top { width:420rpx; height:320rpx; right:-160rpx; top:-80rpx; background:rgba(255,101,0,.15); }
.ambient-dots { position:absolute; right:-70rpx; top:20rpx; width:390rpx; height:390rpx; opacity:.2; pointer-events:none; background-image:radial-gradient(circle,rgba(255,122,0,.55) 0,rgba(255,122,0,.55) 3rpx,transparent 4rpx); background-size:28rpx 28rpx; transform:rotate(-12deg); }
.page-scroll { position:relative; z-index:2; height:100%; }
.content { padding:0 30rpx; box-sizing:border-box; }

.role-row { display:flex; align-items:flex-start; box-sizing:border-box; }
.role-pill { display:inline-flex; align-items:center; gap:8rpx; padding:10rpx 20rpx; border:2rpx solid #ff7200; border-radius:30rpx; color:#ff8a18; background:rgba(5,8,11,.78); font-size:23rpx; font-weight:700; }
.role-switch-mark { color:#ff9b33; font-size:18rpx; }

.education-mode { display:flex; align-items:center; gap:14rpx; margin-top:12rpx; padding:14rpx 18rpx; border:1rpx solid rgba(255,122,0,.48); border-radius:16rpx; background:rgba(255,122,0,.09); }
.education-mode.active { border-color:rgba(91,207,99,.45); background:rgba(91,207,99,.09); }
.education-mode-dot { width:14rpx; height:14rpx; flex:none; border-radius:50%; background:#ff7a00; box-shadow:0 0 0 7rpx rgba(255,122,0,.12); }
.education-mode.active .education-mode-dot { background:#65d36d; box-shadow:0 0 0 7rpx rgba(101,211,109,.12); }
.education-mode-copy { min-width:0; flex:1; }
.education-mode-copy text { display:block; }
.education-mode-copy text:first-child { color:#ff941f; font-size:23rpx; font-weight:800; }
.education-mode.active .education-mode-copy text:first-child { color:#74db7c; }
.education-mode-copy text:last-child { margin-top:4rpx; overflow:hidden; color:#aeb4ba; font-size:19rpx; text-overflow:ellipsis; white-space:nowrap; }
.education-mode-arrow { color:#ff941f; font-size:34rpx; }

.hero { margin-top:10rpx; }
.greeting,.page-title,.subtitle { display:block; }
.greeting { color:#c8cdd1; font-size:25rpx; }
.page-title { margin-top:12rpx; font-size:52rpx; line-height:1.15; font-weight:800; letter-spacing:1rpx; }
.subtitle { margin-top:12rpx; color:#9ba2a8; font-size:22rpx; }

.metrics-panel { display:grid; grid-template-columns:repeat(3,1fr); margin-top:28rpx; padding:25rpx 8rpx; border:1rpx solid #343b42; border-radius:22rpx; background:linear-gradient(145deg,rgba(20,27,32,.98),rgba(12,17,21,.98)); box-shadow:0 18rpx 42rpx rgba(0,0,0,.24); }
.metric { min-width:0; text-align:center; border-right:1rpx solid #343b42; }
.metric:last-child { border-right:0; }
.metric-label { display:block; color:#aeb4ba; font-size:20rpx; }
.metric-number { margin-top:13rpx; white-space:nowrap; font-weight:800; }
.metric-value { font-size:44rpx; line-height:1; }
.metric-suffix { margin-left:5rpx; font-size:18rpx; font-weight:600; }

.task-notice { display:grid; grid-template-columns:58rpx 1fr auto 24rpx; align-items:center; gap:14rpx; min-height:112rpx; margin-top:20rpx; padding:18rpx 20rpx; box-sizing:border-box; border:1rpx solid rgba(255,122,0,.48); border-radius:20rpx; background:linear-gradient(105deg,rgba(70,35,12,.78),rgba(17,23,28,.98)); }
.task-notice-icon { width:54rpx; height:54rpx; display:flex; align-items:center; justify-content:center; border-radius:16rpx; background:#ff7a00; color:#17110d; font-size:24rpx; font-weight:900; }
.task-notice-title,.task-notice-caption { display:block; }
.task-notice-title { font-size:27rpx; font-weight:800; }
.task-notice-caption { margin-top:7rpx; color:#aeb4ba; font-size:19rpx; }
.task-notice-count { min-width:42rpx; height:42rpx; display:flex; align-items:center; justify-content:center; padding:0 10rpx; box-sizing:border-box; border-radius:999rpx; background:#ff5357; color:#fff; font-size:22rpx; font-weight:900; }
.task-notice-arrow { color:#ff9b33; font-size:34rpx; }

.focus-card { position:relative; display:grid; grid-template-columns:1fr 230rpx; align-items:center; min-height:224rpx; margin-top:22rpx; padding:30rpx 28rpx 30rpx 38rpx; box-sizing:border-box; overflow:hidden; border:1rpx solid rgba(255,122,0,.56); border-radius:24rpx; background:linear-gradient(105deg,rgba(75,37,11,.82),rgba(23,22,20,.98) 50%,rgba(15,20,24,.98)); box-shadow:0 20rpx 48rpx rgba(0,0,0,.3); }
.focus-accent { position:absolute; left:0; top:0; bottom:0; width:7rpx; background:linear-gradient(180deg,#ff9a1f,#ff5e00); }
.focus-copy { position:relative; z-index:1; min-width:0; }
.focus-eyebrow,.focus-title { display:block; }
.focus-eyebrow { font-size:26rpx; font-weight:700; }
.focus-title { margin-top:22rpx; font-size:40rpx; line-height:1.2; font-weight:800; }
.focus-caption { margin-top:24rpx; color:#c4c9cd; font-size:21rpx; }
.focus-amount { color:#ff8513; font-size:27rpx; font-weight:800; }
.focus-side { position:relative; z-index:1; display:flex; flex-direction:column; align-items:stretch; justify-content:center; }
.focus-watermark { position:absolute; z-index:0; right:48rpx; top:30rpx; width:108rpx; height:124rpx; display:flex; align-items:center; justify-content:center; box-sizing:border-box; border:8rpx solid rgba(255,122,0,.09); border-radius:48% 48% 58% 58%; color:rgba(255,122,0,.1); font-size:76rpx; line-height:1; font-weight:900; }
.focus-count { text-align:center; color:#fff; white-space:nowrap; }
.focus-count-value { color:#ff7a00; font-size:64rpx; line-height:1; font-weight:900; }
.focus-count-unit { margin-left:7rpx; font-size:22rpx; }
.focus-action { display:flex; align-items:center; justify-content:center; gap:20rpx; height:66rpx; margin-top:22rpx; border-radius:18rpx; background:linear-gradient(90deg,#ff6b00,#ff8c11); color:#fff; font-size:25rpx; font-weight:800; box-shadow:0 10rpx 24rpx rgba(255,106,0,.18); }
.focus-action-arrow { font-size:36rpx; font-weight:400; }

.panel,.summary-card { border:1rpx solid #303840; border-radius:22rpx; background:linear-gradient(145deg,rgba(18,25,30,.98),rgba(11,16,20,.98)); box-shadow:0 16rpx 38rpx rgba(0,0,0,.22); }
.panel { margin-top:20rpx; padding:20rpx; }
.section-head { padding-bottom:12rpx; }
.section-title { font-size:28rpx; font-weight:800; }
.pending-list { border:1rpx solid #2b333a; border-radius:18rpx; overflow:hidden; background:rgba(11,16,20,.58); }
.pending-row { display:grid; grid-template-columns:42rpx 1fr auto 24rpx; align-items:center; gap:12rpx; min-height:72rpx; padding:0 14rpx; border-bottom:1rpx solid #2a3137; }
.pending-row:last-child { border-bottom:0; }
.pending-icon-wrap { width:40rpx; height:40rpx; display:flex; align-items:center; justify-content:center; border-radius:12rpx; }
.pending-symbol { font-size:24rpx; line-height:1; font-weight:900; }
.pending-label { font-size:25rpx; font-weight:700; }
.pending-value { min-width:34rpx; text-align:right; font-size:30rpx; font-weight:900; }
.row-chevron { color:#92999f; font-size:32rpx; line-height:1; text-align:center; }

.quick-panel { padding:24rpx 22rpx 26rpx; }
.quick-panel .section-title { font-size:30rpx; }
.quick-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14rpx; }
.quick-item { position:relative; min-height:100rpx; display:flex; align-items:center; justify-content:center; gap:14rpx; padding:12rpx 8rpx; box-sizing:border-box; border:1rpx solid #3a434b; border-radius:17rpx; background:linear-gradient(145deg,rgba(21,29,35,.98),rgba(14,20,24,.98)); box-shadow:inset 0 0 0 1rpx rgba(255,255,255,.015); }
.quick-badge { position:absolute; z-index:2; right:8rpx; top:7rpx; min-width:30rpx; height:30rpx; display:flex; align-items:center; justify-content:center; padding:0 7rpx; box-sizing:border-box; border-radius:999rpx; background:#ff5357; color:#fff; font-size:16rpx; font-weight:900; }
.quick-symbol { width:50rpx; height:50rpx; flex:none; display:flex; align-items:center; justify-content:center; color:#ff7a00; }
.quick-icon-core { position:relative; width:32rpx; height:32rpx; color:inherit; box-sizing:border-box; }
.quick-icon-core::before,.quick-icon-core::after { content:""; position:absolute; box-sizing:border-box; }
.quick-icon-course .quick-icon-core::before { left:1rpx; top:4rpx; width:5rpx; height:5rpx; border-radius:2rpx; background:currentColor; box-shadow:0 10rpx 0 currentColor,0 20rpx 0 currentColor; }
.quick-icon-course .quick-icon-core::after { left:10rpx; top:4rpx; width:21rpx; height:5rpx; border-radius:3rpx; background:currentColor; box-shadow:0 10rpx 0 currentColor,0 20rpx 0 currentColor; }
.quick-icon-student .quick-icon-core::before { left:10rpx; top:0; width:13rpx; height:13rpx; border-radius:50%; background:currentColor; }
.quick-icon-student .quick-icon-core::after { left:3rpx; bottom:0; width:27rpx; height:16rpx; border-radius:16rpx 16rpx 5rpx 5rpx; background:currentColor; }
.quick-icon-class .quick-icon-core::before { left:4rpx; top:1rpx; width:11rpx; height:11rpx; border-radius:50%; background:currentColor; box-shadow:14rpx 0 0 currentColor; }
.quick-icon-class .quick-icon-core::after { left:0; bottom:1rpx; width:18rpx; height:15rpx; border-radius:14rpx 14rpx 4rpx 4rpx; background:currentColor; box-shadow:14rpx 0 0 currentColor; }
.quick-icon-schedule .quick-icon-core { border:3rpx solid currentColor; border-radius:5rpx; }
.quick-icon-schedule .quick-icon-core::before { left:-3rpx; right:-3rpx; top:7rpx; height:3rpx; background:currentColor; }
.quick-icon-schedule .quick-icon-core::after { left:6rpx; top:-7rpx; width:3rpx; height:10rpx; border-radius:2rpx; background:currentColor; box-shadow:14rpx 0 0 currentColor; }
.quick-icon-package .quick-icon-core { height:25rpx; margin-top:4rpx; border:3rpx solid currentColor; border-radius:6rpx; }
.quick-icon-package .quick-icon-core::before { left:1rpx; right:1rpx; top:-8rpx; height:8rpx; border:3rpx solid currentColor; border-bottom:0; border-radius:6rpx 6rpx 0 0; }
.quick-icon-package .quick-icon-core::after { right:4rpx; top:7rpx; width:6rpx; height:6rpx; border-radius:50%; background:currentColor; }
.quick-icon-leave .quick-icon-core { border:3rpx solid currentColor; border-radius:6rpx; }
.quick-icon-leave .quick-icon-core::before { left:5rpx; right:5rpx; top:8rpx; height:3rpx; background:currentColor; box-shadow:0 8rpx 0 currentColor; }
.quick-icon-leave .quick-icon-core::after { right:-3rpx; top:-3rpx; width:12rpx; height:12rpx; border:3rpx solid #151b20; border-radius:50%; background:currentColor; }
.quick-icon-staff .quick-icon-core { border:3rpx solid currentColor; border-radius:5rpx; }
.quick-icon-staff .quick-icon-core::before { left:5rpx; top:4rpx; width:9rpx; height:9rpx; border-radius:50%; background:currentColor; }
.quick-icon-staff .quick-icon-core::after { left:3rpx; bottom:4rpx; width:13rpx; height:9rpx; border-radius:8rpx 8rpx 2rpx 2rpx; background:currentColor; box-shadow:17rpx -9rpx 0 -3rpx currentColor,17rpx 0 0 -3rpx currentColor; }
.quick-icon-correction .quick-icon-core { border:3rpx solid currentColor; border-radius:50%; }
.quick-icon-correction .quick-icon-core::before { left:13rpx; top:5rpx; width:3rpx; height:13rpx; background:currentColor; }
.quick-icon-correction .quick-icon-core::after { left:13rpx; bottom:5rpx; width:3rpx; height:3rpx; border-radius:50%; background:currentColor; }
.quick-label { color:#f3f4f5; font-size:25rpx; font-weight:750; white-space:nowrap; }

.opportunity-panel { padding:24rpx 22rpx; }
.opportunity-panel .section-head { display:flex; align-items:center; justify-content:space-between; }
.section-caption { color:#8f979e; font-size:19rpx; }
.opportunity-grid { display:grid; grid-template-columns:1fr 1fr; gap:12rpx; }
.opportunity-item { min-width:0; display:flex; align-items:center; justify-content:space-between; gap:12rpx; min-height:86rpx; padding:14rpx 16rpx; box-sizing:border-box; border:1rpx solid #343d44; border-radius:16rpx; background:#10161b; }
.opportunity-label,.opportunity-value { display:block; }
.opportunity-label { color:#dfe2e4; font-size:22rpx; font-weight:700; }
.opportunity-value { margin-top:7rpx; font-size:20rpx; font-weight:800; }
.opportunity-arrow { color:#7f8991; font-size:30rpx; }

.summary-grid { display:grid; grid-template-columns:1fr 1fr; gap:16rpx; margin-top:20rpx; }
.summary-card { min-width:0; padding:22rpx; }
.summary-head { display:flex; align-items:center; gap:10rpx; font-size:25rpx; font-weight:800; }
.summary-symbol { width:36rpx; height:36rpx; display:flex; align-items:center; justify-content:center; border-radius:50%; background:#ff7200; color:#17110d; font-size:18rpx; font-weight:900; }
.summary-stats { display:grid; grid-template-columns:1fr 1fr; gap:20rpx; margin-top:22rpx; }
.summary-stat { min-width:0; }
.summary-stat + .summary-stat { padding-left:18rpx; border-left:1rpx solid #343b42; }
.summary-label,.summary-value { display:block; }
.summary-label { color:#b1b7bc; font-size:21rpx; white-space:nowrap; }
.summary-value { margin-top:10rpx; font-size:40rpx; line-height:1; font-weight:900; }
.summary-track { height:7rpx; margin-top:18rpx; overflow:hidden; border-radius:5rpx; background:#2d343a; }
.summary-progress { height:100%; border-radius:5rpx; }

.tone-orange { color:#ff7a00; }
.tone-success { color:#72d84e; }
.tone-danger { color:#ff5357; }
.tone-surface-orange { background:rgba(255,122,0,.16); }
.tone-surface-danger { background:rgba(255,83,87,.13); }
.icon-clock { border-radius:50%; background:#ff5357; color:#15191d; }
.icon-shield { border-radius:12rpx 12rpx 16rpx 16rpx; background:#ff7a00; color:#15191d; }
.icon-clipboard { border-radius:9rpx; background:#ff7a00; color:#15191d; }
.tone-bg-orange { background:linear-gradient(90deg,#ff7200,#ff9a1f); }
.tone-bg-success { background:linear-gradient(90deg,#58c93b,#91e95c); }
.tone-bg-danger { background:#ff5357; }
.tabbar-space { height:176rpx; }

.guide-layer { position:fixed; z-index:9999; top:0; right:0; bottom:0; left:0; overflow:hidden; }
.guide-spotlight { position:fixed; z-index:1; border:3rpx solid #ff8614; border-radius:20rpx; box-shadow:0 0 0 2200rpx rgba(0,0,0,.78),0 0 30rpx rgba(255,122,0,.42); pointer-events:none; transition:all .28s ease; }
.guide-card { position:fixed; z-index:2; left:30rpx; right:30rpx; bottom:calc(30rpx + env(safe-area-inset-bottom)); padding:28rpx; border:1rpx solid rgba(255,130,22,.6); border-radius:24rpx; background:linear-gradient(145deg,rgba(25,31,36,.99),rgba(11,16,20,.99)); box-shadow:0 24rpx 70rpx rgba(0,0,0,.55),0 0 28rpx rgba(255,108,0,.12); }
.guide-meta { display:flex; align-items:center; justify-content:space-between; }
.guide-kicker { color:#ff8614; font-size:22rpx; font-weight:800; }
.guide-step { color:#8f979e; font-size:21rpx; }
.guide-title,.guide-description { display:block; }
.guide-title { margin-top:20rpx; color:#fff; font-size:36rpx; line-height:1.25; font-weight:900; }
.guide-description { margin-top:14rpx; color:#bec4c9; font-size:24rpx; line-height:1.6; }
.guide-dots { display:flex; align-items:center; gap:10rpx; margin-top:22rpx; }
.guide-dot { width:10rpx; height:10rpx; border-radius:50%; background:#465059; transition:all .2s ease; }
.guide-dot.active { width:30rpx; border-radius:7rpx; background:#ff7a00; }
.guide-actions { display:flex; align-items:center; justify-content:space-between; gap:20rpx; margin-top:26rpx; }
.guide-exit { padding:16rpx 0; color:#9da4aa; font-size:23rpx; }
.guide-nav-actions { display:flex; align-items:center; gap:14rpx; }
.guide-button { min-width:128rpx; height:68rpx; display:flex; align-items:center; justify-content:center; padding:0 22rpx; box-sizing:border-box; border-radius:18rpx; font-size:24rpx; font-weight:800; }
.guide-button-secondary { border:1rpx solid #4b545c; color:#d8dcdf; background:#151b20; }
.guide-button-primary { color:#fff; background:linear-gradient(90deg,#ff6900,#ff8d12); box-shadow:0 10rpx 22rpx rgba(255,105,0,.22); }

@media (max-width:340px) {
  .page-title { font-size:42rpx; }
  .focus-card { grid-template-columns:1fr 206rpx; }
  .focus-title { font-size:34rpx; }
  .quick-item { gap:8rpx; padding-left:5rpx; padding-right:5rpx; }
  .quick-symbol { width:44rpx; height:44rpx; }
  .quick-label { font-size:22rpx; }
  .summary-card { padding:18rpx; }
  .summary-stats { gap:12rpx; }
  .summary-stat + .summary-stat { padding-left:12rpx; }
  .guide-card { left:20rpx; right:20rpx; padding:24rpx; }
  .guide-title { font-size:32rpx; }
  .guide-description { font-size:22rpx; }
  .guide-button { min-width:112rpx; padding:0 16rpx; }
}
