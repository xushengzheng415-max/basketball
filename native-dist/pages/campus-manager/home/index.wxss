.page-shell {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #05080b 0%, #080c10 58%, #070a0d 100%);
  color: #f7f8fa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.ambient {
  position: absolute;
  pointer-events: none;
  border-radius: 50%;
  filter: blur(16rpx);
}

.ambient-top {
  top: -190rpx;
  right: -180rpx;
  width: 560rpx;
  height: 560rpx;
  background: radial-gradient(circle, rgba(255, 119, 0, .24), rgba(255, 119, 0, 0) 68%);
}

.ambient-side {
  top: 790rpx;
  left: -260rpx;
  width: 520rpx;
  height: 520rpx;
  background: radial-gradient(circle, rgba(255, 107, 0, .1), rgba(255, 107, 0, 0) 70%);
}

.page-scroll {
  position: relative;
  z-index: 2;
  height: 100%;
}

.content {
  padding: 0 28rpx;
  box-sizing: border-box;
}

.role-row {
  display: flex;
  align-items: flex-start;
  padding-right: 210rpx;
  box-sizing: border-box;
}

.role-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 56rpx;
  padding: 0 23rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 129, 19, .72);
  border-radius: 16rpx;
  background: rgba(20, 16, 13, .8);
  color: #ff8a19;
  font-size: 25rpx;
  font-weight: 800;
}

.role-switch-mark {
  font-size: 20rpx;
}

.hero {
  margin-top: 12rpx;
}

.page-title,
.subtitle {
  display: block;
}

.page-title {
  margin-top: 8rpx;
  color: #f8fafb;
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.subtitle {
  margin-top: 10rpx;
  color: #8f979e;
  font-size: 22rpx;
}

.business-section {
  margin-top: 26rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title,
.section-description {
  display: block;
}

.section-title {
  margin-top: 7rpx;
  color: #f4f6f8;
  font-size: 31rpx;
  font-weight: 900;
}

.section-description,
.management-caption {
  color: #778088;
  font-size: 19rpx;
}

.business-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 0;
}

.business-card {
  position: relative;
  min-width: 0;
  min-height: 306rpx;
  padding: 24rpx 22rpx 20rpx;
  box-sizing: border-box;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, .1);
  border-radius: 24rpx;
  box-shadow: 0 20rpx 46rpx rgba(0, 0, 0, .3);
}

.business-card.consumption {
  border-color: rgba(255, 126, 15, .62);
  background: linear-gradient(150deg, rgba(87, 42, 10, .96), rgba(30, 24, 20, .98) 55%, rgba(14, 19, 23, .98));
}

.business-card.finance {
  border-color: rgba(255, 179, 70, .5);
  background: linear-gradient(150deg, rgba(69, 49, 14, .96), rgba(28, 27, 20, .98) 55%, rgba(14, 19, 23, .98));
}

.business-card-glow {
  position: absolute;
  top: -110rpx;
  right: -90rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 131, 19, .14);
}

.business-card-head,
.business-amount-row,
.business-detail {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.business-eyebrow {
  color: #f8fafb;
  font-size: 24rpx;
  font-weight: 800;
}

.business-trend {
  flex: none;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(101, 211, 109, .12);
  color: #72d97a;
  font-size: 17rpx;
  font-weight: 700;
}

.business-main-value {
  position: relative;
  display: flex;
  align-items: baseline;
  min-width: 0;
  margin-top: 28rpx;
}

.business-prefix {
  margin-right: 3rpx;
  color: #ff9a35;
  font-size: 28rpx;
  font-weight: 900;
}

.business-value {
  min-width: 0;
  color: #ff8a19;
  font-size: 52rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
  line-height: 1;
}

.finance .business-value {
  font-size: 43rpx;
}

.business-unit {
  margin-left: 8rpx;
  color: #a4abb1;
  font-size: 18rpx;
  white-space: nowrap;
}

.business-amount-row {
  margin-top: 25rpx;
  color: #b9bfc4;
  font-size: 18rpx;
}

.business-amount-row text:last-child {
  color: #f2f4f5;
  font-weight: 800;
}

.business-detail {
  margin-top: 16rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid rgba(255, 255, 255, .08);
  color: #737c84;
  font-size: 17rpx;
}

.business-detail text:last-child {
  flex: none;
  color: #ff9630;
}

.panel {
  margin-top: 24rpx;
  padding: 24rpx 22rpx;
  box-sizing: border-box;
  border: 1rpx solid #2d353c;
  border-radius: 24rpx;
  background: linear-gradient(145deg, rgba(18, 25, 30, .98), rgba(10, 15, 19, .98));
  box-shadow: 0 16rpx 38rpx rgba(0, 0, 0, .22);
}

.task-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.task-title-row .section-title {
  margin-top: 0;
}

.task-total {
  min-width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #ff5a57;
  color: #fff;
  font-size: 21rpx;
  font-weight: 900;
}

.section-description {
  margin-top: 8rpx;
  line-height: 1.5;
}

.task-legend {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #747d84;
  font-size: 18rpx;
}

.task-legend text:first-child {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #ff6f00;
  box-shadow: 0 0 0 5rpx rgba(255, 111, 0, .1);
}

.task-list {
  margin-top: 18rpx;
}

.task-row {
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr) auto 18rpx;
  align-items: center;
  gap: 14rpx;
  min-height: 108rpx;
  padding: 16rpx 0;
  box-sizing: border-box;
  border-top: 1rpx solid #242b31;
}

.task-row:first-child {
  border-top: 0;
}

.task-symbol {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 17rpx;
  border: 1rpx solid rgba(255, 255, 255, .05);
}

.task-symbol image {
  width: 34rpx;
  height: 34rpx;
}

.tone-danger {
  background: rgba(255, 78, 82, .13);
  color: #ff6467;
}

.tone-warning {
  background: rgba(255, 137, 27, .13);
  color: #ff942f;
}

.tone-normal {
  background: rgba(97, 142, 174, .13);
  color: #8db7d2;
}

.task-copy {
  min-width: 0;
}

.task-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.task-name {
  flex: none;
  color: #e9ecef;
  font-size: 24rpx;
  font-weight: 800;
}

.task-code {
  min-width: 0;
  overflow: hidden;
  color: #59636b;
  font-size: 16rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-description {
  display: block;
}

.task-description {
  margin-top: 6rpx;
  overflow: hidden;
  color: #8d959c;
  font-size: 19rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-count {
  display: flex;
  align-items: baseline;
  gap: 3rpx;
  white-space: nowrap;
}

.task-count text:first-child {
  font-size: 32rpx;
  font-weight: 900;
}

.task-count text:last-child {
  font-size: 17rpx;
}

.tone-text-danger {
  color: #ff6467;
}

.tone-text-warning {
  color: #ff922c;
}

.tone-text-normal {
  color: #88abc1;
}

.row-chevron {
  color: #59636b;
  font-size: 28rpx;
}

.management-head {
  align-items: center;
}

.management-head .section-title {
  margin-top: 0;
}

.management-more {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 52rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(255, 122, 0, .34);
  border-radius: 999rpx;
  background: rgba(255, 122, 0, .07);
}

.management-more text:first-child {
  color: #a5adb3;
  font-size: 18rpx;
}

.management-more text:last-child {
  color: #ff922d;
  font-size: 19rpx;
  font-weight: 800;
}

.management-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.management-item {
  position: relative;
  display: grid;
  grid-template-columns: 78rpx minmax(0, 1fr) 18rpx;
  align-items: center;
  gap: 16rpx;
  min-height: 156rpx;
  padding: 24rpx 20rpx;
  box-sizing: border-box;
  border: 1rpx solid #283138;
  border-radius: 22rpx;
  background: linear-gradient(145deg, rgba(24, 33, 39, .96), rgba(14, 21, 26, .96));
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, .18);
}

.management-badge {
  position: absolute;
  z-index: 2;
  top: -10rpx;
  right: -8rpx;
  min-width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-sizing: border-box;
  border: 3rpx solid #10171b;
  border-radius: 999rpx;
  background: #ff5a57;
  color: #fff;
  font-size: 19rpx;
  font-weight: 900;
}

.management-symbol {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 142, 46, .17);
  box-shadow: inset 0 0 24rpx rgba(255, 126, 15, .06), 0 8rpx 18rpx rgba(0, 0, 0, .18);
}

.management-symbol image {
  width: 52rpx;
  height: 52rpx;
}

.tone-bg-orange { background: linear-gradient(145deg, rgba(255, 137, 30, .16), rgba(255, 103, 0, .07)); }
.tone-bg-blue { background: linear-gradient(145deg, rgba(72, 153, 255, .14), rgba(30, 91, 170, .07)); }

.management-copy {
  min-width: 0;
}

.management-label,
.management-description {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.management-label {
  color: #e7eaec;
  font-size: 28rpx;
  font-weight: 800;
}

.management-description {
  margin-top: 10rpx;
  color: #818b93;
  font-size: 19rpx;
}

.management-chevron {
  color: #68737b;
  font-size: 30rpx;
}

.more-management-layer {
  position: fixed;
  z-index: 8000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
}

.more-management-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, .72);
}

.more-management-sheet {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 16rpx 28rpx 0;
  box-sizing: border-box;
  border: 1rpx solid #313940;
  border-bottom: 0;
  border-radius: 32rpx 32rpx 0 0;
  background: linear-gradient(180deg, #151c21, #090e12);
  box-shadow: 0 -26rpx 80rpx rgba(0, 0, 0, .48);
}

.more-sheet-handle {
  width: 72rpx;
  height: 7rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: #414950;
}

.more-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.more-sheet-head text {
  display: block;
}

.more-sheet-head view:first-child text:first-child {
  color: #f3f5f6;
  font-size: 34rpx;
  font-weight: 900;
}

.more-sheet-head view:first-child text:last-child {
  margin-top: 8rpx;
  color: #747e86;
  font-size: 20rpx;
}

.more-sheet-close {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #252d33;
  color: #aab1b6;
  font-size: 38rpx;
  line-height: 1;
}

.more-sheet-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
}

.more-column-switch {
  display: inline-grid;
  grid-template-columns: repeat(2, 1fr);
  padding: 5rpx;
  border: 1rpx solid #303941;
  border-radius: 16rpx;
  background: #0d1317;
}

.more-column-option {
  min-width: 78rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  color: #778189;
  font-size: 19rpx;
  font-weight: 700;
}

.more-column-option.active {
  background: linear-gradient(135deg, #ff6b00, #ff9418);
  color: #fff;
  box-shadow: 0 7rpx 18rpx rgba(255, 112, 0, .24);
}

.more-edit-button {
  min-width: 116rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 133, 31, .38);
  border-radius: 15rpx;
  background: rgba(255, 126, 15, .08);
  color: #ff932d;
  font-size: 20rpx;
  font-weight: 800;
}

.more-sort-hint {
  display: block;
  margin-top: 15rpx;
  color: #68727a;
  font-size: 18rpx;
}

.more-management-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.more-management-grid.columns-2 {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.more-management-grid.columns-3 {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.more-management-item {
  position: relative;
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr) 16rpx;
  align-items: center;
  gap: 12rpx;
  min-height: 112rpx;
  padding: 17rpx 14rpx;
  box-sizing: border-box;
  border: 1rpx solid #2b343b;
  border-radius: 19rpx;
  background: linear-gradient(145deg, rgba(24, 33, 39, .96), rgba(14, 21, 26, .96));
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, .16);
  transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease;
}

.more-management-item.is-dragging {
  z-index: 3;
  border-color: rgba(255, 139, 35, .88);
  background: linear-gradient(145deg, rgba(61, 39, 21, .98), rgba(22, 26, 29, .98));
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, .36), 0 0 0 4rpx rgba(255, 126, 15, .12);
  transform: scale(1.04);
}

.more-management-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 141, 43, .14);
  background: linear-gradient(145deg, rgba(255, 137, 30, .15), rgba(255, 103, 0, .06));
}

.more-management-icon image {
  width: 38rpx;
  height: 38rpx;
}

.more-management-copy {
  min-width: 0;
}

.more-management-label,
.more-management-caption {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.more-management-label {
  color: #e8ebed;
  font-size: 22rpx;
  font-weight: 800;
}

.more-management-caption {
  margin-top: 6rpx;
  color: #69737b;
  font-size: 16rpx;
}

.more-management-arrow {
  color: #616c74;
  font-size: 25rpx;
}

.more-drag-handle {
  width: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 5rpx;
}

.more-drag-handle text {
  display: block;
  height: 3rpx;
  border-radius: 999rpx;
  background: #ff8d26;
}

.columns-3 .more-management-item {
  grid-template-columns: minmax(0, 1fr);
  justify-items: center;
  gap: 10rpx;
  min-height: 150rpx;
  padding: 18rpx 10rpx 16rpx;
  text-align: center;
}

.columns-3 .more-management-icon {
  width: 64rpx;
  height: 64rpx;
}

.columns-3 .more-management-icon image {
  width: 42rpx;
  height: 42rpx;
}

.columns-3 .more-management-label {
  font-size: 20rpx;
}

.columns-3 .more-management-caption,
.columns-3 .more-management-arrow {
  display: none;
}

.columns-3 .more-drag-handle {
  position: absolute;
  top: 13rpx;
  right: 13rpx;
}

.more-sheet-safe {
  height: calc(30rpx + env(safe-area-inset-bottom));
}

.tabbar-space {
  height: 184rpx;
}

.guide-layer {
  position: fixed;
  z-index: 9999;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  overflow: hidden;
}

.guide-layer::before {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, .76);
}

.guide-spotlight {
  position: absolute;
  z-index: 1;
  box-sizing: border-box;
  border: 3rpx solid #ff7a00;
  border-radius: 24rpx;
  box-shadow: 0 0 0 3000rpx rgba(0, 0, 0, .15), 0 0 34rpx rgba(255, 122, 0, .52);
  transition: all .24s ease;
}

.guide-card {
  position: absolute;
  z-index: 2;
  right: 28rpx;
  bottom: calc(154rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 130, 20, .64);
  border-radius: 26rpx;
  background: linear-gradient(145deg, #1a2025, #0e1317);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, .56);
}

.guide-meta,
.guide-actions,
.guide-nav-actions {
  display: flex;
  align-items: center;
}

.guide-meta,
.guide-actions {
  justify-content: space-between;
}

.guide-kicker {
  color: #ff8a19;
  font-size: 20rpx;
  font-weight: 800;
}

.guide-step {
  color: #757e85;
  font-size: 20rpx;
}

.guide-title,
.guide-description {
  display: block;
}

.guide-title {
  margin-top: 20rpx;
  color: #f4f6f7;
  font-size: 34rpx;
  font-weight: 900;
}

.guide-description {
  margin-top: 12rpx;
  color: #9da4aa;
  font-size: 22rpx;
  line-height: 1.7;
}

.guide-dots {
  display: flex;
  gap: 10rpx;
  margin-top: 23rpx;
}

.guide-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #41484e;
}

.guide-dot.active {
  width: 34rpx;
  border-radius: 999rpx;
  background: #ff7a00;
}

.guide-actions {
  margin-top: 26rpx;
}

.guide-exit {
  color: #777f86;
  font-size: 21rpx;
}

.guide-nav-actions {
  gap: 12rpx;
}

.guide-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 64rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.guide-button-secondary {
  border: 1rpx solid #454d54;
  color: #b8bec3;
}

.guide-button-primary {
  background: linear-gradient(135deg, #ff6a00, #ff9200);
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(255, 112, 0, .24);
}
