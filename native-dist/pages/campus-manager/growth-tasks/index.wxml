<view class="page-shell"><view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /></view><text class="nav-title">增长任务</text><view class="notice">♢<text>8</text></view></view><scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content"><view class="hero"><text>增长任务中心</text><text>把经营机会变成可执行任务</text><view class="hero-art">↗</view></view><view class="overview"><text>核心概览</text><view><view wx:for="{{metrics}}" wx:key="label"><text>{{item.symbol}} {{item.label}}</text><text>{{item.value}}</text></view></view></view><scroll-view class="tabs" scroll-x enhanced show-scrollbar="{{false}}"><view class="tab {{item.activeClass}}" wx:for="{{tabs}}" wx:key="key" data-key="{{item.key}}" bindtap="switchTab">{{item.label}}</view></scroll-view><view class="task-card" wx:for="{{tasks}}" wx:key="id"><view class="task-icon"><image src="{{item.icon}}" mode="aspectFit" /></view><view class="task-copy"><text>{{item.title}}</text><text>● 来源：{{item.source}}　　截止：<text>{{item.deadline}}</text></text><text>♙ 负责人：{{item.owner}}</text></view><view class="task-side"><text class="{{item.tone}}">· {{item.status}}</text><button bindtap="openTask">去处理</button></view></view><view class="task-note">任务由校区负责人分配、督促与复盘</view><view class="tabbar-space"></view></view></scroll-view><sxf-tabbar active="education" /></view>
