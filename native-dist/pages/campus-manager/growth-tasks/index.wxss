page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.96)}.back-button{position:absolute;left:24rpx;bottom:0;width:60rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:28rpx;height:28rpx}.nav-title{font-size:28rpx;font-weight:700}.notice{position:absolute;right:165rpx;bottom:14rpx;font-size:30rpx}.notice text{position:absolute;right:-10rpx;top:-8rpx;width:27rpx;height:27rpx;border-radius:50%;background:#ff7900;text-align:center;line-height:27rpx;font-size:14rpx}.page-scroll{height:100%}.content{padding:20rpx 24rpx 0}.hero{position:relative;padding:26rpx 10rpx 45rpx;overflow:hidden}.hero>text{display:block}.hero>text:first-child{font-size:47rpx;font-weight:900}.hero>text:first-child::first-letter{color:#ff7900}.hero>text:nth-child(2){margin-top:14rpx;color:#8f979d;font-size:23rpx}.hero-art{position:absolute;right:20rpx;top:5rpx;color:#ff7900;font-size:130rpx;font-weight:900;opacity:.7}.overview{padding:22rpx;border:1rpx solid #384148;border-radius:20rpx;background:linear-gradient(135deg,#182026,#0d1216)}.overview>text{font-size:27rpx;font-weight:800}.overview>view{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;margin-top:18rpx}.overview>view>view{padding:20rpx 12rpx;border:1rpx solid #3c454b;border-radius:14rpx;background:rgba(255,255,255,.025)}.overview>view text{display:block}.overview>view text:first-child{color:#aeb4b9;font-size:19rpx}.overview>view text:last-child{margin-top:10rpx;color:#ff7900;font-size:42rpx;font-weight:800}.tabs{white-space:nowrap;margin-top:18rpx;padding:0 8rpx;border:1rpx solid #384148;border-radius:16rpx;background:#11181d}.tab{display:inline-flex;align-items:center;justify-content:center;height:66rpx;margin-right:28rpx;color:#9ca3a8;font-size:21rpx}.tab.active{color:#ff8500;border-bottom:5rpx solid #ff8500}.task-card{display:grid;grid-template-columns:76rpx 1fr 110rpx;gap:14rpx;align-items:center;margin-top:15rpx;padding:20rpx;border:1rpx solid #394248;border-radius:18rpx;background:linear-gradient(135deg,#182026,#0d1216)}.task-icon{width:72rpx;height:72rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#ff9a00,#ff5f27)}.task-icon image{width:39rpx;height:39rpx}.task-copy text{display:block}.task-copy>text:first-child{font-size:24rpx;font-weight:800}.task-copy>text:nth-child(2),.task-copy>text:nth-child(3){margin-top:8rpx;color:#8e969c;font-size:17rpx}.task-copy>text:nth-child(2) text{color:#ff8500}.task-side{text-align:right}.task-side>text{font-size:17rpx;color:#ff8500}.task-side .blue{color:#4e8cff}.task-side button{margin-top:18rpx;height:54rpx;line-height:54rpx;border-radius:10rpx;background:linear-gradient(90deg,#ff6800,#ff9b00);color:#fff;font-size:20rpx}.task-note{text-align:center;margin-top:16rpx;color:#858d93;font-size:17rpx}.tabbar-space{height:150rpx}
