page{height:100%;background:#05090c;color:#f5f7f8;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}.page-shell{height:100%;background:radial-gradient(circle at 100% 0,rgba(255,120,0,.12),transparent 25%),#05090c}.custom-nav{position:fixed;z-index:30;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;padding-left:24rpx;padding-right:190rpx;background:rgba(5,9,12,.96);font-size:28rpx;font-weight:800}.back-button{position:absolute;left:24rpx;bottom:0;width:60rpx;height:68rpx;display:flex;align-items:center}.back-button image{width:28rpx;height:28rpx}.page-scroll{height:100%}.content{padding:20rpx 28rpx 0}.hero text{display:block}.hero text:first-child{font-size:45rpx;font-weight:900}.hero text:last-child{margin-top:12rpx;color:#929aa0;font-size:21rpx}.metric-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;margin-top:22rpx}.metric-card,.feedback-card,.trend-card,.category-card,.visit-card{border:1rpx solid #394248;border-radius:16rpx;background:linear-gradient(135deg,#182026,#0d1216)}.metric-card{display:grid;grid-template-columns:48rpx 1fr;padding:18rpx}.metric-card>text:first-child{grid-row:1/3;font-size:34rpx;color:#ff8500}.metric-card>view text{display:block}.metric-card>view text:first-child{color:#aeb5ba;font-size:19rpx}.metric-card>view text:last-child{font-size:35rpx;font-weight:800}.metric-card>text:last-child{grid-column:1/3;margin-top:10rpx;color:#858d93;font-size:16rpx}.red{color:#ff5151!important}.green{color:#5fcf4c!important}.tabs{display:grid;grid-template-columns:repeat(4,1fr);gap:12rpx;margin-top:18rpx}.tab{height:58rpx;line-height:58rpx;border:1rpx solid #3d464c;border-radius:12rpx;text-align:center;color:#aeb5ba;font-size:19rpx}.tab.active{border-color:#ff8500;color:#ff8500;background:rgba(255,130,0,.08)}.feedback-card{display:grid;grid-template-columns:70rpx 1.2fr 1.1fr .8fr 92rpx;align-items:center;gap:12rpx;margin-top:12rpx;padding:17rpx}.feedback-card>image{width:62rpx;height:62rpx;border-radius:50%}.feedback-card text{display:block}.student-copy>text:first-child{font-size:19rpx;font-weight:800}.student-copy>text:first-child text,.student-copy>text:last-child,.feedback-type>text:last-child,.owner>text:nth-child(2){color:#858d93;font-size:14rpx}.student-copy>text:nth-child(2),.feedback-type>text:first-child,.owner>text:first-child{margin-top:6rpx;font-size:16rpx}.feedback-type,.owner{padding-left:12rpx;border-left:1rpx solid #3c454b}.feedback-type>text:nth-child(2){margin-top:6rpx;color:#c8cccf;font-size:16rpx}.owner>text:last-child{display:inline-block;margin-top:6rpx;padding:3rpx 7rpx;border-radius:6rpx;background:rgba(255,130,0,.12);color:#ff8500;font-size:14rpx}.feedback-card button{height:48rpx;line-height:48rpx;border:1rpx solid #ff8500;border-radius:18rpx;background:transparent;color:#ff8500;font-size:16rpx}.chart-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:14rpx;margin-top:18rpx}.trend-card,.category-card{padding:18rpx}.trend-card>view:first-child,.category-card>view:first-child,.visit-card>view:first-child{display:flex;justify-content:space-between}.trend-card>view:first-child text:first-child,.category-card>view:first-child text:first-child,.visit-card>view:first-child text:first-child{font-size:22rpx;font-weight:800}.trend-card>view:first-child text:last-child,.category-card>view:first-child text:last-child,.visit-card>view:first-child text:last-child{color:#8d959b;font-size:16rpx}.line-chart{position:relative;height:150rpx;margin-top:15rpx;background:linear-gradient(180deg,transparent,rgba(255,130,0,.12));border-bottom:1rpx solid #4a5359}.line-chart view{position:absolute;left:15rpx;right:15rpx;top:70rpx;height:4rpx;background:#ff8500;transform:rotate(-7deg)}.line-chart text{position:absolute;right:12rpx;top:28rpx;padding:4rpx 7rpx;border-radius:6rpx;background:#ff7900;font-size:16rpx}.category-row{display:grid;grid-template-columns:80rpx 1fr 40rpx;gap:8rpx;align-items:center;margin-top:12rpx;font-size:15rpx}.category-row>view{height:7rpx;border-radius:7rpx;background:#343d43}.category-row>view>view{height:100%;border-radius:7rpx;background:#ff8500}.visit-card{margin-top:18rpx;padding:18rpx}.visit-row{display:grid;grid-template-columns:46rpx .8fr 1.2fr .9fr 75rpx;gap:10rpx;align-items:center;padding:10rpx 0;border-top:1rpx solid #343d43;font-size:15rpx}.visit-row image{width:38rpx;height:38rpx;border-radius:50%}.visit-row button{height:40rpx;line-height:40rpx;border:1rpx solid #ff8500;border-radius:14rpx;background:transparent;color:#ff8500;font-size:14rpx}.work-tip{margin-top:16rpx;padding:14rpx;border-radius:10rpx;background:rgba(255,130,0,.09);color:#9ea5aa;font-size:16rpx}.safe-space{height:50rpx}
