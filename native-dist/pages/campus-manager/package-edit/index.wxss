page{height:100%;background:#05080b;color:#f3f4f5}.page{height:100vh;overflow:hidden;background:linear-gradient(180deg,#070a0d,#05080b)}.nav{position:absolute;z-index:8;left:0;right:0;box-sizing:content-box;display:flex;align-items:center}.nav>view{margin-left:31rpx;display:flex;align-items:center;gap:9rpx;font-size:17rpx}.nav image{width:26rpx;height:26rpx}.scroll{height:100%}.content{padding:0 28rpx}.headline{padding:17rpx 10rpx 27rpx}.headline text{display:block}.headline text:first-child{font-size:45rpx;font-weight:900}.headline text:last-child{margin-top:12rpx;color:#a9afb4;font-size:18rpx}.form-card{position:relative;min-height:126rpx;margin-bottom:12rpx;padding:27rpx 25rpx;box-sizing:border-box;display:grid;grid-template-columns:1.05fr 1.35fr;align-items:center;gap:27rpx;border:1rpx solid #353e44;border-radius:13rpx;background:linear-gradient(105deg,#11181d,#0e1418)}.field-copy text{display:block}.field-copy>text:first-child{font-size:22rpx;font-weight:750}.field-copy>text:first-child text{display:inline;color:#ff5149}.field-copy>text:last-child{margin-top:12rpx;color:#9da4a9;font-size:15rpx}.input{height:69rpx;padding:0 18rpx;box-sizing:border-box;display:flex;align-items:center;border:1rpx solid #485158;border-radius:8rpx;background:#151b20}.input input{flex:1;height:69rpx;color:#fff;font-size:18rpx}.input>text{color:#a5acb1;font-size:17rpx}.picker{justify-content:space-between}.picker>text:nth-child(2){flex:1}.unit{gap:13rpx}.unit>text:last-child{color:#e3e5e7}.choice-row{display:grid;grid-template-columns:1fr 1fr;gap:13rpx}.choice{min-height:70rpx;padding:13rpx 16rpx;box-sizing:border-box;border:1rpx solid #485158;border-radius:8rpx}.choice text{display:block}.choice text:first-child{font-size:17rpx}.choice text:last-child{margin-top:7rpx;color:#999fa4;font-size:13rpx}.choice.active{border-color:#ff7900;background:linear-gradient(100deg,rgba(255,96,0,.24),rgba(255,137,0,.1));color:#ff7900}.gift{grid-template-columns:1fr 90rpx}.gift switch{transform:scale(