<view class="page-shell">
  <view class="custom-nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;"><view class="back-button" bindtap="goBack"><image src="{{icons.back}}" mode="aspectFit" /></view><text>续费风险中心</text></view>
  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}"><view style="height: {{navSpacer}}px;"></view><view class="content">
    <view class="risk-tip">及时跟进高风险学员，降低流失率，提升续费转化　<text>风险规则</text></view>
    <view class="metric-grid"><view class="metric-card {{item.tone}}" wx:for="{{metrics}}" wx:key="label"><text>{{item.label}}</text><text>{{item.value}}<text>人</text></text></view></view>
    <view class="filters"><view><text>筛选班级</text><text>全部班级</text></view><view><text>到期时间</text><text>全部时间</text></view><view><text>风险等级</text><text>全部等级</text></view></view>
    <view class="list-card"><view class="list-heading"><text>风险学员列表　<text>共33人</text></text><text>按到期日排序</text></view>
      <view class="student-card {{item.tone}}" wx:for="{{students}}" wx:key="id"><view class="student-top"><image src="{{item.avatar}}" mode="aspectFill" /><view><view><text>{{item.name}}</text><text class="{{item.tone}}">{{item.risk}}</text></view><text>{{item.classInfo}}</text></view><view><text>剩余课时</text><text class="{{item.tone}}">{{item.remaining}}<text>节</text></text></view><view><text>到期日</text><text class="{{item.tone}}">{{item.expiry}}</text></view></view><view class="student-bottom"><view><text>风险原因</text><text>{{item.reason}}</text></view><view><text>负责人</text><text>{{item.owner}}</text></view><view><text>状态</text><text class="{{item.tone}}">{{item.status}}</text></view><button data-id="{{item.id}}" bindtap="openStudent">查看跟进</button></view></view>
    </view>
    <view class="chart-grid"><view><text>续费趋势</text><view class="line-chart"><view></view><text>68%</text></view></view><view><text>任务完成率</text><view class="donut">75%<text>已完成</text></view><view class="legend">已完成 15/20　未完成 5/20</view></view></view>
    <view class="tabbar-space"></view>
  </view></scroll-view><sxf-tabbar active="education" />
</view>
