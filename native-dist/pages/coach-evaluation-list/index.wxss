page{background:#05090c;color:#f7f7f7}.page{min-height:100vh;background:radial-gradient(circle at 50% 15%,rgba(255,110,0,.10),transparent 30%),#070b0e}.scroll{height:calc(100vh - 120rpx);padding:100rpx 38rpx 20rpx;box-sizing:border-box}.title{font-size:54rpx;font-weight:900}.subtitle{color:#aaa;font-size:26rpx;margin:14rpx 0 32rpx}.subtitle text{color:#ff7800}.progress-card{height:140rpx;width:430rpx;border:1rpx solid #7f430d;border-radius:23rpx;display:flex;align-items:center;padding:22rpx;background:#13181b;box-shadow:0 0 18rpx rgba(255,120,0,.18)}.progress-icon{width:82rpx;height:82rpx;border:2rpx solid #ff7800;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#ff7800;font-size:45rpx;margin-right:28rpx}.progress-card text{font-size:31rpx}.progress-card .strong{color:#ff7800;font-size:50rpx}.track{height:12rpx;width:230rpx;background:#282d31;border-radius:8rpx;margin-top:16rpx}.track view{height:100%;background:linear-gradient(90deg,#ff6500,#ff931e);border-radius:8rpx}.student{height:115rpx;border:1rpx solid #353b3f;border-radius:18rpx;background:linear-gradient(135deg,#191e21,#0d1215);display:flex;align-items:center;padding:18rpx 24rpx;margin-top:14rpx}.student image{width:76rpx;height:76rpx;border-radius:50%;border:2rpx solid #ff7800;margin-right:26rpx}.name{font-size:31rpx;font-weight:800}.status{margin-left:20rpx;padding:8rpx 17rpx;border-radius:20rpx;background:#49290d;color:#ff920f}.status.done{background:#153d20;color:#44cb61}.action{margin-left:auto;color:#ff8008;font-size:25rpx}.package{display:flex;align-items:center;border:1rpx solid #674017;border-radius:18rpx;background:rgba(255,120,0,.07);padding:24rpx;margin-top:24rpx;color:#ff7b00;font-size:36rpx}.package view{margin-left:20rpx}.package text,.package .small{display:block}.package text{font-size:27rpx;color:#eee}.package .small{color:#aaa;font-size:20rpx;margin-top:8rpx}.safe{height:30rpx}.footer{height:90rpx;margin:14rpx 38rpx 20rpx;border-radius:16rpx;background:linear-gradient(100deg,#ff6500,#ff8f1c);display:flex;align-items:center;justify-content:center;font-size:31rpx;font-weight:900}

.title.has-back{display:flex;align-items:center;gap:18rpx}.title .back{font-size:58rpx;font-weight:400;line-height:1}

.status.returned{background:#4a1e12;color:#ff5b35}
