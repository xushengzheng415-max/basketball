page{background:#05080b;color:#f4f6f7;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 85% 0,rgba(255,112,0,.23),transparent 28%),#05080b}.nav{height:198rpx;padding:106rpx 28rpx 0;box-sizing:border-box;display:flex;align-items:center}.back{width:68rpx;height:68rpx;display:flex;align-items:center;font-size:62rpx}.nav-title,.nav-sub,.eyebrow,.hero-title,.hero-sub,.ring text,.notice text,.section-head text,.hint,.rule-card text{display:block}.nav-title{font-size:32rpx;font-weight:900}.nav-sub{margin-top:4rpx;color:#7d858b;font-size:19rpx}.count{margin-left:auto;color:#ff8a19;font-size:23rpx;font-weight:900}.scroll{height:calc(100vh - 198rpx)}.hero{position:relative;margin:8rpx 28rpx 16rpx;padding:25rpx 24rpx 32rpx;border-radius:22rpx;background:linear-gradient(145deg,#27170b,#11171a 58%,#0b0f12);border:1rpx solid rgba(255,122,0,.58)}.eyebrow{color:#ff8a19;font-size:19rpx}.hero-title{margin-top:6rpx;width:490rpx;font-size:30rpx;font-weight:900}.hero-sub{margin-top:7rpx;color:#858d92;font-size:18rpx}.ring{position:absolute;right:24rpx;top:24rpx;width:92rpx;height:92rpx;border:9rpx solid #ff7a00;border-left-color:#3a4044;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center}.ring text:first-child{font-size:28rpx;font-weight:900}.ring text:last-child{color:#81898e;font-size:14rpx}.track{position:absolute;left:24rpx;right:24rpx;bottom:16rpx;height:7rpx;border-radius:999rpx;background:#30363a;overflow:hidden}.track view{height:100%;background:linear-gradient(90deg,#ff5b00,#ffb128)}.notice{margin:0 28rpx 16rpx;padding:18rpx 20rpx;border-radius:16rpx;background:rgba(255,177,28,.08);border:1rpx solid rgba(255,177,28,.26)}.notice text:first-child{color:#e9be68;font-size:19rpx;font-weight:800}.notice text:last-child{margin-top:5rpx;color:#a18c63;font-size:17rpx;line-height:1.5}.section-head{display:flex;align-items:flex-end;justify-content:space-between;margin:0 28rpx 11rpx}.section-head>view text:first-child{font-size:27rpx;font-weight:900}.section-head>view text:last-child{margin-top:4rpx;color:#767e84;font-size:17rpx}.section-head>text{color:#ff8a19;font-size:18rpx}.list{margin:0 28rpx;border-radius:20rpx;background:linear-gradient(145deg,#171d21,#0b0f12);border:1rpx solid rgba(255,255,255,.11);overflow:hidden}.student{min-height:132rpx;padding:19rpx;display:flex;align-items:center;border-top:1rpx solid rgba(255,255,255,.08)}.student:first-child{border-top:0}.student image{width:72rpx;height:72rpx;margin-right:15rpx;border-radius:50%;border:2rpx solid rgba(255,126,20,.7)}.student-main{flex:1;min-width:0}.student-main>view{display:flex;align-items:center}.name{font-size:24rpx;font-weight:900}.number{margin-left:7rpx;color:#8d959a;font-size:17rpx}.attendance{margin-left:9rpx;padding:3rpx 8rpx;border-radius:999rpx;background:#20272b;color:#9ba2a7;font-size:14rpx}.hint{margin-top:7rpx;color:#747c82;font-size:16rpx}.student-side{text-align:right}.status{padding:5rpx 9rpx;border-radius:999rpx;font-size:16rpx}.status.pending{background:rgba(255,122,0,.13);color:#ff8a19}.status.done{background:rgba(82,207,117,.12);color:#55d779}.action{display:block;margin-top:11rpx;color:#ff8a19;font-size:17rpx}.rule-card{margin:16rpx 28rpx 0;padding:20rpx;border-radius:17rpx;background:#11171a;border:1rpx solid rgba(255,255,255,.1)}.rule-card text:first-child{font-size:21rpx;font-weight:800}.rule-card text:last-child{margin-top:6rpx;color:#7d858b;font-size:17rpx;line-height:1.55}.safe{height:135rpx}.footer{position:fixed;z-index:5;left:0;right:0;bottom:0;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:rgba(7,10,12,.97);border-top:1rpx solid rgba(255,255,255,.1)}.finish{height:80rpx;border-radius:17rpx;display:flex;align-items:center;justify-content:center;background:linear-gradient(90deg,#ff5b00,#ff9a20);font-size:24rpx;font-weight:900}
