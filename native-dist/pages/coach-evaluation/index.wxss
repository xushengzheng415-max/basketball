page{background:#05080b;color:#f7f8f9;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 85% 0,rgba(255,112,0,.23),transparent 25%),#05080b}.nav{height:198rpx;padding:106rpx 30rpx 0;display:flex;align-items:center}.back{width:68rpx;font-size:62rpx}.nav-title,.nav-sub,.name,.meta,.eyebrow,.lesson-title,.lesson-meta,.title,.ai-title,.ai-sub,.version-title{display:block}.nav-title{font-size:32rpx;font-weight:800}.nav-sub{margin-top:4rpx;color:#7f878d;font-size:19rpx}.progress{margin-left:auto;transform:translateY(70rpx);color:#ff8a19;font-weight:800}.scroll{height:calc(100vh - 198rpx)}.student{display:flex;align-items:center;margin:8rpx 28rpx 14rpx;padding:20rpx;border-radius:20rpx;background:linear-gradient(145deg,#181e22,#0b0f12);border:1rpx solid rgba(255,122,0,.5)}.student image{width:76rpx;height:76rpx;margin-right:16rpx;border-radius:50%;border:2rpx solid #ff7a00}.student>view:nth-child(2){flex:1}.name{font-size:25rpx;font-weight:800}.meta{margin-top:6rpx;color:#848c92;font-size:18rpx}.switch{color:#ff8a19;font-size:19rpx}.lesson{display:flex;align-items:center;justify-content:space-between;margin:0 28rpx 14rpx;padding:20rpx;border-radius:18rpx;background:#12181c;border:1rpx solid rgba(255,255,255,.1)}.eyebrow{color:#ff8a19;font-size:18rpx}.lesson-title{margin-top:5rpx;font-size:23rpx;font-weight:800}.lesson-meta{color:#858d93;font-size:17rpx;text-align:right}.tag-card,.ai-card,.version{margin:0 28rpx 14rpx;padding:22rpx;border-radius:20rpx;background:linear-gradient(145deg,#171d21,#0b0f12);border:1rpx solid rgba(255,255,255,.11)}.head,.ai-head,.editor-foot{display:flex;align-items:center;justify-content:space-between}.title{font-size:26rpx;font-weight:800}.hint{color:#747c82;font-size:18rpx}.tags{display:flex;flex-wrap:wrap;gap:10rpx;margin-top:16rpx}.tag{padding:10rpx 16rpx;border-radius:999rpx;background:#22282c;border:1rpx solid transparent;color:#9ba2a7;font-size:19rpx}.tag.active{background:rgba(255,122,0,.14);border-color:#ff7a00;color:#ff8a19}.ai-card{border-color:rgba(255,122,0,.5)}.ai-title{font-size:27rpx;font-weight:800}.ai-sub{margin-top:5rpx;color:#7f878d;font-size:18rpx}.generate{padding:10rpx 15rpx;border:1rpx solid #ff7a00;border-radius:12rpx;color:#ff8a19;font-size:18rpx}.editor{box-sizing:border-box;width:100%;min-height:270rpx;margin-top:18rpx;padding:18rpx;border-radius:16rpx;background:#0b1013;border:1rpx solid rgba(255,255,255,.12);color:#e8eaeb;font-size:22rpx;line-height:1.65}.editor-foot{margin-top:10rpx;color:#6f777d;font-size:16rpx}.version{background:rgba(255,177,28,.07);border-color:rgba(255,177,28,.32);color:#a8925d;font-size:18rpx;line-height:1.55}.version-title{margin-bottom:5rpx;color:#ddb663;font-weight:800}.safe{height:136rpx}.footer{position:fixed;z-index:5;left:0;right:0;bottom:0;display:flex;gap:15rpx;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:rgba(7,10,12,.97);border-top:1rpx solid rgba(255,255,255,.1)}.draft,.publish{height:80rpx;border-radius:17rpx;display:flex;align-items:center;justify-content:center;font-size:25rpx;font-weight:800}.draft{width:220rpx;border:1rpx solid #ff7a00;color:#ff8a19}.publish{flex:1;background:linear-gradient(90deg,#ff5b00,#ff9a20)}

.back{height:70rpx;display:flex;align-items:center;justify-content:flex-start;line-height:1}

.rating-card,.report-card{margin:0 28rpx 14rpx;padding:22rpx;border-radius:20rpx;background:linear-gradient(145deg,#171d21,#0b0f12);border:1rpx solid rgba(255,255,255,.11)}
.rating-card{border-color:rgba(255,122,0,.4)}.rating-head,.report-head,.report-name,.history-head{display:flex;align-items:center;justify-content:space-between}.rating-title,.rating-sub,.dimension-label,.dimension-desc,.report-title,.report-sub,.report-name text,.report-copy text,.copy-label{display:block}.rating-title,.report-title{font-size:27rpx;font-weight:800}.rating-sub,.report-sub{margin-top:5rpx;color:#7f878d;font-size:18rpx}.overall{text-align:right}.overall-score{color:#ff8a19;font-size:38rpx;font-weight:900}.overall-unit{color:#8b9398;font-size:17rpx}.overall-grade{display:block;margin-top:2rpx;color:#54d779;font-size:18rpx}.overall-track{height:8rpx;margin-top:18rpx;border-radius:999rpx;background:#2b3236;overflow:hidden}.overall-value{height:100%;border-radius:999rpx;background:linear-gradient(90deg,#ff5b00,#ffb128)}.overall-foot{display:flex;justify-content:space-between;margin:8rpx 0 12rpx;color:#7b8388;font-size:16rpx}.rating-row{min-height:94rpx;display:flex;align-items:center;border-top:1rpx solid rgba(255,255,255,.08)}.rating-copy{width:230rpx}.dimension-label{font-size:21rpx;font-weight:800}.dimension-desc{margin-top:5rpx;color:#737b81;font-size:15rpx}.stars{display:flex;gap:2rpx;flex:1;justify-content:flex-end}.star{position:relative;width:36rpx;height:42rpx}.star-base,.star-fill{position:absolute;left:0;top:0;width:36rpx;line-height:42rpx;font-size:34rpx;white-space:nowrap}.star-base{color:#343b3f}.star-fill{overflow:hidden;color:#ff9b1f;text-shadow:0 0 9rpx rgba(255,139,24,.26)}.star-fill.empty{width:0}.star-fill.half{width:18rpx}.star-fill.full{width:36rpx}.star-hit{position:absolute;z-index:2;top:0;bottom:0;width:50%}.star-left{left:0}.star-right{right:0}.dimension-score{width:48rpx;margin-left:8rpx;color:#ff9b1f;text-align:right;font-size:20rpx;font-weight:800}
.report-card{border-color:rgba(255,138,25,.48)}.report-status{padding:7rpx 13rpx;border-radius:999rpx;background:rgba(255,122,0,.13);color:#ff8a19;font-size:17rpx}.report-tabs{height:66rpx;margin-top:18rpx;padding:5rpx;display:flex;border-radius:15rpx;background:#0b1013}.report-tab{flex:1;display:flex;align-items:center;justify-content:center;border-radius:12rpx;color:#838b90;font-size:21rpx;font-weight:700}.report-tab.active{background:linear-gradient(90deg,#ff5b00,#ff951d);color:#fff}.report-preview{margin-top:16rpx;padding:20rpx;border:1rpx solid rgba(255,255,255,.1);border-radius:17rpx;background:#0c1114}.report-name>view:first-child{flex:1}.report-name>view:first-child text:first-child{font-size:23rpx;font-weight:800}.report-name>view:first-child text:last-child{margin-top:6rpx;color:#747d82;font-size:17rpx}.report-score{width:88rpx;height:88rpx;border-radius:18rpx;background:rgba(255,122,0,.12);display:flex;flex-direction:column;align-items:center;justify-content:center}.report-score text:first-child{color:#ff8a19;font-size:27rpx;font-weight:900}.report-score text:last-child{margin-top:2rpx;color:#8a9297;font-size:15rpx}.report-metrics{display:grid;grid-template-columns:repeat(4,1fr);margin-top:17rpx;padding:14rpx 0;border-top:1rpx solid rgba(255,255,255,.08);border-bottom:1rpx solid rgba(255,255,255,.08)}.report-metrics>view{text-align:center;border-right:1rpx solid rgba(255,255,255,.08)}.report-metrics>view:last-child{border-right:0}.report-metrics>view>view text:first-child{color:#ff9b1f;font-size:22rpx;font-weight:800}.report-metrics>view>view text:last-child{margin-left:2rpx;color:#a1a7ab;font-size:14rpx}.report-metrics>view>text{display:block;margin-top:5rpx;color:#6f787d;font-size:15rpx}.report-copy{margin-top:15rpx;padding:14rpx 16rpx;border-radius:13rpx;background:#11171a;color:#aeb4b7;font-size:18rpx;line-height:1.6}.report-copy.highlight{border-left:4rpx solid #53ce75}.report-copy.suggestion{border-left:4rpx solid #ff9b1f}.copy-label{margin-bottom:4rpx;color:#f0f2f3!important;font-weight:800}.report-actions{display:flex;gap:12rpx;margin-top:16rpx}.report-generate,.report-publish{height:70rpx;border-radius:14rpx;display:flex;align-items:center;justify-content:center;font-size:21rpx;font-weight:800}.report-generate{width:220rpx;border:1rpx solid #ff7a00;color:#ff8a19}.report-publish{flex:1;background:linear-gradient(90deg,#ff5b00,#ff9a20)}.history{margin-top:18rpx}.history-head{padding-bottom:10rpx;color:#81898e;font-size:17rpx}.history-head text:first-child{color:#d5d8da;font-size:20rpx;font-weight:700}.history-row{min-height:58rpx;display:grid;grid-template-columns:1fr 1fr .7fr .8fr;align-items:center;border-top:1rpx solid rgba(255,255,255,.07);color:#858d92;font-size:17rpx}.history-row text:nth-child(3){color:#ff9b1f}.history-row text:last-child{text-align:right;color:#53cf76}
