page{background:#05090c;color:#f7f7f7}.page{min-height:100vh;background:radial-gradient(circle at 90% 8%,rgba(255,112,0,.12),transparent 28%),#070b0e}.scroll{height:calc(100vh - 118rpx);padding:48rpx 38rpx 20rpx;box-sizing:border-box}.title{font-size:50rpx;font-weight:900}.title.with-back{display:flex;gap:24rpx;align-items:center}.title.with-back>text{font-size:58rpx}.subtitle{color:#aaa;font-size:25rpx;margin:10rpx 0 28rpx}.subtitle>text,.warning{color:#ff7800}.student,.rating,.panel,.summary-card,.return-card{border:1rpx solid #373d41;border-radius:20rpx;background:linear-gradient(135deg,#191e21,#0d1215)}.student{display:flex;align-items:center;padding:20rpx;border-color:#81430d}.student image{width:92rpx;height:92rpx;border-radius:50%;border:2rpx solid #ff7800;margin-right:26rpx}.name,.meta{display:block}.name{font-size:32rpx;font-weight:800}.meta{color:#aaa;font-size:21rpx;margin-top:7rpx}.rating{display:flex;align-items:center;padding:22rpx;margin-top:16rpx}.rating-copy{flex:1}.rating-title,.panel-title{font-size:29rpx;font-weight:900}.scores{display:flex;gap:8rpx}.score{width:48rpx;height:56rpx;border:1rpx solid #454b50;border-radius:9rpx;display:flex;align-items:center;justify-content:center;font-size:27rpx}.score:active{background:#ff7800;color:#fff}.panel{padding:24rpx;margin-top:18rpx}.panel .small{color:#aaa;font-size:20rpx}.tags{display:flex;flex-wrap:wrap;gap:12rpx;margin-top:18rpx}.tag{padding:12rpx 20rpx;border:1rpx solid #6e3c10;border-radius:25rpx}.tag.active{border-color:#ff7800;color:#ff7800;background:rgba(255,120,0,.08)}.panel-head{display:flex;justify-content:space-between}.generate{border:1rpx solid #ff7800;border-radius:12rpx;color:#ff7800;padding:9rpx 15rpx}.draft{width:100%;height:190rpx;border:1rpx solid #343a3e;border-radius:13rpx;box-sizing:border-box;padding:20rpx;margin-top:18rpx;line-height:1.6}.counter{display:block;text-align:right;color:#888}.preview{border:1rpx solid #4a3c31;border-radius:13rpx;padding:20rpx;margin-top:18rpx;line-height:1.6}.summary-card{display:flex;align-items:center;padding:28rpx;border-color:#8a470e}.package-icon{width:100rpx;height:100rpx;border:2rpx solid #ff7800;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#ff7800;font-size:48rpx;margin-right:28rpx}.summary-card>view:nth-child(2){flex:1}.summary-grid{display:flex;gap:18rpx;margin-top:20rpx;color:#aaa;font-size:19rpx}.summary-grid .strong{display:block;color:#ff7800;font-size:34rpx}.pending{color:#ff8b12;background:rgba(255,120,0,.1);border-radius:22rpx;padding:8rpx 16rpx}.section-title{font-size:31rpx;font-weight:900;margin:28rpx 0 10rpx}.confirm-row{display:flex;align-items:center;gap:20rpx;padding:21rpx 4rpx;border-bottom:1rpx solid #333}.confirm-row:last-child{border:0}.confirm-row>view{flex:1}.confirm-row text,.confirm-row .small{display:block}.confirm-row>text:last-child{color:#ff7800}.risk{color:#f05145!important}.return-card{padding:28rpx;border-color:#a64c13}.return-card text,.return-card .small{display:block;line-height:1.6}.return-card .warning{font-size:30rpx;font-weight:900}.safe{height:30rpx}.footer{height:118rpx;display:flex;gap:20rpx;padding:18rpx 38rpx;box-sizing:border-box}.outline,.primary{height:78rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:800}.outline{width:300rpx;border:2rpx solid #ff7800;color:#ff7800}.primary{flex:1;background:linear-gradient(100deg,#ff6500,#ff901d)}

.title.has-back{display:flex;align-items:center;gap:18rpx}.title .back{font-size:58rpx;font-weight:400;line-height:1}.score.active{background:linear-gradient(135deg,#ff6500,#ff901d);border-color:#ff7800;color:#fff;box-shadow:0 0 14rpx rgba(255,120,0,.45)}
