<view class="page"><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}">
<block wx:if="{{isEvaluate}}"><view class="title has-back"><text class="back" bindtap="goBack">‹</text>课后评价</view><view class="subtitle">U10提高班 · <text>本节课评价</text></view><view class="student"><image src="{{avatar}}" mode="aspectFill"/><view><text class="name">{{studentName}} #{{studentNumber}}</text><text class="meta">U10提高班</text></view></view><view class="rating" wx:for="{{ratings}}" wx:key="key"><view class="rating-copy"><text class="rating-title">{{item.label}}</text><text class="meta">{{item.desc}}</text></view><view class="scores"><text class="score {{star.activeClass}}" wx:for="{{item.stars}}" wx:for-item="star" wx:key="value" data-key="{{item.key}}" data-value="{{star.fullValue}}" bindtap="rateDimension">{{star.value}}</text></view></view><view class="panel"><view class="panel-title">成长亮点 <text class="small">（可多选）</text></view><view class="tags"><text class="tag {{item.activeClass}}" wx:for="{{highlightTags}}" wx:key="label" data-label="{{item.label}}" bindtap="toggleTag">{{item.label}}</text></view></view><view class="panel"><view class="panel-head"><text class="panel-title">教练建议</text><text class="generate" bindtap="generate">↻ 重新生成</text></view><textarea class="draft" value="{{draft}}" bindinput="onDraftInput" maxlength="200"/><text class="counter">{{draftLength}}/200</text></view><view class="panel"><view class="panel-title">家长将看到 <text class="small">（预览）</text></view><view class="preview">{{draft}}</view></view></block>
<block wx:elif="{{isConfirm}}"><view class="title with-back"><text bindtap="backToEdit">‹</text>课后增长包确认</view><view class="subtitle">U10提高班 · 5月23日训练</view><view class="summary-card"><view class="package-icon">▣</view><view><text class="rating-title">本次成长包</text><view class="summary-grid"><text><text class="strong">5</text>名学员</text><text><text class="strong">5</text>份训练日报</text><text><text class="strong">1</text>份班级动态</text><text><text class="strong">2</text>项风险提醒</text></view></view><text class="pending">待确认</text></view><view class="section-title">▤　家长将收到</view><view class="panel"><view class="confirm-row">▤ <view><text>训练日报</text><text class="small">每位学员的训练完成情况与课堂表现</text></view><text>查看　›</text></view><view class="confirm-row">☆ <view><text>成长标签</text><text class="small">基于课堂表现生成的个性化成长标签</text></view><text>查看　›</text></view><view class="confirm-row">☵ <view><text>教练建议</text><text class="small">针对学员的提升建议与后续训练重点</text></view><text>查看　›</text></view></view><view class="section-title">▣　班级内容</view><view class="panel confirm-row">● <view><text>U10提高班 · 今日训练动态</text><text class="small">控球强化　攻防转换　团队协作</text></view><text>预览内容　›</text></view><view class="section-title warning">⚠　需要关注</view><view class="panel"><view class="confirm-row"><text class="risk">●</text><view><text>刘宇辰 · 连续2次缺勤</text><text class="small">近2次训练未到课，请及时跟进了解情况</text></view></view><view class="confirm-row"><text class="risk">●</text><view><text>赵子墨 · 家长报告未读3次</text><text class="small">该学员家长已连续3次未阅读报告</text></view></view></view></block>
<block wx:else><view class="title with-back"><text bindtap="goBack">‹</text>评价退回修改</view><view class="subtitle">林浩 · 5月23日训练日报</view><view class="return-card"><text class="warning">⚠　负责人退回</text><text class="small">退回时间 5月23日 18:42</text><text>成长建议过于笼统，请补充控球稳定性的具体表现，并确认家长摘要不包含内部训练术语。</text></view><view class="panel"><view class="panel-title">▣　需要修改 <text class="strong">2</text>项</view><view class="confirm-row"><text>1　成长建议</text><text class="pending">待修改　›</text></view><view class="confirm-row"><text>2　家长摘要</text><text class="pending">待修改　›</text></view><view class="confirm-row"><text>3　课堂六维评分</text><text>无需修改</text></view></view><view class="panel"><view class="panel-title">✎　成长建议</view><textarea class="draft" value="{{draft}}" bindinput="onDraftInput" maxlength="300"/></view><view class="panel"><view class="panel-title">✎　家长摘要</view><textarea class="draft" value="{{reportData.summary}}" maxlength="200"/></view></block><view class="safe"></view></scroll-view><view class="footer"><view class="outline" bindtap="backToEdit">保存草稿</view><view wx:if="{{isEvaluate}}" class="primary" bindtap="previewConfirm">完成评价</view><view wx:elif="{{isConfirm}}" class="primary" bindtap="publish">确认并发送</view><view wx:else class="primary" bindtap="publish">重新提交</view></view></view>
