page {
  min-height: 100%;
  background: #020609;
}

.player-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #111820;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 0;
  width: 100vw;
  height: 100vh;
}

.page-content {
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  min-height: 100vh;
  padding: 30rpx 26rpx 154rpx;
}

.status-bar {
  display: block;
  width: 672rpx;
  height: 26rpx;
  margin: 0 auto 32rpx;
}

.top-header {
  display: flex;
  height: 70rpx;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.brand-title {
  width: 240rpx;
  height: 66rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 22rpx;
}

.search-box {
  display: flex;
  box-sizing: border-box;
  width: 560rpx;
  height: 73rpx;
  align-items: center;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 0 26rpx rgba(255, 255, 255, 0.06);
}

.search-icon {
  width: 35rpx;
  height: 35rpx;
  margin-right: 16rpx;
  opacity: 0.72;
}

.search-input {
  flex: 1;
  height: 72rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.64);
}

.filter-button {
  display: flex;
  height: 52rpx;
  align-items: center;
  gap: 8rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.filter-icon {
  width: 34rpx;
  height: 34rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 14rpx;
  margin: 0 2rpx 18rpx;
}

.quick-action {
  display: flex;
  height: 62rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 32rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.12);
  font-size: 24rpx;
  font-weight: 900;
  white-space: nowrap;
}

.primary-action {
  gap: 8rpx;
  border: 0;
  background: linear-gradient(180deg, #ff6a18 0%, #ff4f05 100%);
  box-shadow: 0 8rpx 18rpx rgba(255, 86, 8, 0.3);
}

.quick-add-icon {
  width: 29rpx;
  height: 29rpx;
}

.category-scroll {
  width: 100%;
  height: 64rpx;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.category-track {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 2rpx 0;
}

.category-chip {
  display: inline-flex;
  height: 55rpx;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 25rpx;
  border-radius: 30rpx;
  color: #202733;
  background: #f7f8fa;
  box-shadow: 0 5rpx 14rpx rgba(0, 0, 0, 0.18);
  font-size: 24rpx;
  font-weight: 900;
  white-space: nowrap;
}

.category-chip.active {
  color: #ffffff;
  background: linear-gradient(180deg, #ff6718 0%, #ff4d00 100%);
}

.category-count {
  display: flex;
  min-width: 28rpx;
  height: 28rpx;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border-radius: 16rpx;
  color: #7a808b;
  background: rgba(0, 0, 0, 0.08);
  font-size: 18rpx;
  font-weight: 900;
}

.category-chip.active .category-count {
  color: #ff5a0c;
  background: #ffffff;
}

.summary-card {
  display: grid;
  box-sizing: border-box;
  grid-template-columns: 1fr 1rpx 1fr 1rpx 1fr;
  width: 698rpx;
  height: 149rpx;
  align-items: center;
  margin: 0 auto 14rpx;
  padding: 0 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.22);
}

.summary-item {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.summary-item.compact {
  gap: 16rpx;
}

.summary-icon.total {
  width: 43rpx;
  height: 39rpx;
}

.summary-icon.assigned,
.summary-icon.unassigned {
  width: 48rpx;
  height: 55rpx;
}

.summary-copy {
  display: flex;
  flex-direction: column;
  line-height: 1;
}

.summary-label {
  margin-bottom: 10rpx;
  color: #232936;
  font-size: 25rpx;
  font-weight: 500;
  white-space: nowrap;
}

.summary-number {
  color: #0f1722;
  font-family: Arial, sans-serif;
  font-size: 50rpx;
  font-weight: 900;
}

.summary-number.orange {
  color: #ff5a0c;
}

.summary-number.muted {
  color: #5e6269;
}

.summary-divider {
  width: 1rpx;
  height: 67rpx;
  background: #e8e8e8;
}

.player-list {
  height: calc(100vh - 656rpx);
}

.player-card {
  display: flex;
  position: relative;
  box-sizing: border-box;
  width: 698rpx;
  min-height: 180rpx;
  align-items: center;
  margin: 0 auto 14rpx;
  padding: 20rpx 25rpx 20rpx 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(0, 0, 0, 0.2);
}

.avatar {
  width: 129rpx;
  height: 129rpx;
  flex-shrink: 0;
  margin-right: 22rpx;
  border-radius: 65rpx;
  background: #eef0f2;
}

.player-main {
  min-width: 0;
  flex: 1;
}

.name-row {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.jersey {
  color: #ff5a0c;
  font-family: Arial, sans-serif;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.player-name {
  max-width: 250rpx;
  overflow: hidden;
  color: #080b10;
  font-size: 32rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-row {
  display: flex;
  height: 33rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.team-logo {
  width: 35rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.team-name {
  color: #202733;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-row {
  display: flex;
  gap: 10rpx;
}

.player-tag {
  display: flex;
  min-width: 62rpx;
  height: 36rpx;
  align-items: center;
  justify-content: center;
  padding: 0 14rpx;
  border-radius: 20rpx;
  color: #222b37;
  background: #f1f2f4;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 36rpx;
}

.card-actions {
  display: flex;
  width: 142rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: flex-end;
  gap: 14rpx;
  color: #4c535e;
}

.delete-button {
  display: flex;
  width: 44rpx;
  height: 36rpx;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #ff4d00;
  background: rgba(255, 77, 0, 0.1);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 36rpx;
}

.edit-icon {
  width: 39rpx;
  height: 39rpx;
}

.chevron {
  height: 50rpx;
  font-family: Arial, sans-serif;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 45rpx;
}

.empty-state {
  width: 698rpx;
  margin: 0 auto 14rpx;
  padding: 42rpx 0;
  border-radius: 16rpx;
  color: #6a717d;
  background: #ffffff;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
}

.loaded-text {
  padding: 4rpx 0 18rpx;
  color: rgba(255, 255, 255, 0.58);
  text-align: center;
  font-size: 22rpx;
}


.modal-mask {
  display: flex;
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 9;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.58);
}

.add-modal {
  box-sizing: border-box;
  width: 620rpx;
  padding: 34rpx 30rpx 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.modal-title {
  display: block;
  margin-bottom: 24rpx;
  color: #101820;
  font-size: 34rpx;
  font-weight: 900;
}

.modal-input {
  box-sizing: border-box;
  width: 100%;
  height: 78rpx;
  margin-bottom: 16rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d7dee8;
  border-radius: 12rpx;
  color: #101820;
  background: #f8fafc;
  font-size: 26rpx;
}

.number-hint {
  display: block;
  margin-bottom: 24rpx;
  color: #667085;
  font-size: 22rpx;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.modal-cancel,
.modal-confirm {
  display: flex;
  height: 76rpx;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.modal-cancel {
  color: #303846;
  background: #f1f3f6;
}

.modal-confirm {
  color: #ffffff;
  background: linear-gradient(180deg, #ff6718 0%, #ff4d00 100%);
}

.manager-modal {
  box-sizing: border-box;
  width: 650rpx;
  max-height: 78vh;
  padding: 32rpx 28rpx 26rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.manager-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.manager-desc,
.manager-name,
.manager-meta {
  display: block;
}

.manager-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.35;
}

.manager-close {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  border-radius: 26rpx;
  color: #49505a;
  background: #f1f3f6;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 48rpx;
  text-align: center;
}

.manager-list {
  display: grid;
  gap: 14rpx;
  max-height: calc(78vh - 170rpx);
  overflow-y: auto;
}

.manager-row {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: #f7f8fa;
}

.manager-name {
  color: #111820;
  font-size: 27rpx;
  font-weight: 900;
}

.manager-meta {
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
  font-weight: 600;
}

.manager-badge {
  display: flex;
  height: 36rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  padding: 0 14rpx;
  border-radius: 18rpx;
  color: #ff5a0c;
  background: #fff1e8;
  font-size: 21rpx;
  font-weight: 900;
}
.delete-confirm-modal {
  box-sizing: border-box;
  width: 610rpx;
  padding: 40rpx 34rpx 30rpx;
  border-radius: 22rpx;
  background: #ffffff;
}

.delete-confirm-title {
  display: block;
  color: #111820;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
}

.delete-confirm-desc {
  display: block;
  margin-top: 18rpx;
  color: #6a717d;
  font-size: 26rpx;
  line-height: 1.5;
  text-align: center;
}

.delete-confirm-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 34rpx;
}

.delete-confirm-cancel,
.delete-confirm-submit {
  display: flex;
  height: 74rpx;
  align-items: center;
  justify-content: center;
  border-radius: 37rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.delete-confirm-cancel {
  color: #5d6470;
  background: #eef0f3;
}

.delete-confirm-submit {
  color: #ffffff;
  background: linear-gradient(180deg, #ff6a18 0%, #ff4d00 100%);
}
