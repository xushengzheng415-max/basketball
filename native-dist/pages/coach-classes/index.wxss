page{background:#05090c;color:#f7f7f7;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC",sans-serif}
.page{min-height:100vh;background:radial-gradient(circle at 85% 12%,rgba(255,104,0,.12),transparent 28%),linear-gradient(145deg,#070b0e,#05090b)}
.scroll{height:100vh;box-sizing:border-box;padding:42rpx 34rpx}
.brand{height:78rpx;display:flex;align-items:center;color:#ff7600;font-size:34rpx;font-weight:800;gap:14rpx}
.brand text{letter-spacing:2rpx}
.dashboard-title{font-size:62rpx;font-weight:900;margin-top:34rpx}
.greeting{font-size:28rpx;color:#9ca0a5;margin:12rpx 0 30rpx}
.greeting text,.link,.class-count,.strong{color:#ff7700}
.next-card,.panel,.class-card{border:1rpx solid #343a3f;border-radius:24rpx;background:linear-gradient(135deg,rgba(24,29,32,.94),rgba(10,14,16,.95));box-shadow:0 12rpx 34rpx rgba(0,0,0,.32)}
.next-card{padding:26rpx;border-color:#e66a00;box-shadow:0 0 22rpx rgba(255,112,0,.24)}
.orange-label{display:block;color:#ff7600;font-size:30rpx}
.next-title{display:block;font-size:42rpx;font-weight:800;margin:14rpx 0}
.meta{display:block;color:#a8abb0;font-size:24rpx;line-height:1.8}
.primary{margin-top:18rpx;height:74rpx;border-radius:15rpx;background:linear-gradient(100deg,#ff6500,#ff8b19);display:flex;align-items:center;justify-content:center;font-size:32rpx;font-weight:700}
.panel{padding:20rpx;margin-top:18rpx}
.panel-title{font-size:31rpx;font-weight:800}
.panel-head{display:flex;justify-content:space-between;align-items:center}
.link{font-size:24rpx}
.task{display:flex;justify-content:space-between;padding:18rpx 12rpx;border-bottom:1rpx solid #333;font-size:27rpx}
.task:last-child{border-bottom:0}
.task text:last-child{color:#ff7600;font-size:32rpx}
.mini-class{display:flex;align-items:center;padding:16rpx 4rpx;border-bottom:1rpx solid #2f3438}
.mini-class:last-child{border-bottom:0}
.ball{width:72rpx;height:72rpx;border:1rpx solid #704018;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#ff7600;font-size:58rpx;margin-right:18rpx}
.grow{flex:1}
.class-name{display:block;font-size:29rpx;font-weight:750}
.report-row{display:flex;gap:20rpx;margin-top:16rpx}
.report{flex:1;min-height:100rpx;border:1rpx solid #77400d;border-radius:18rpx;padding:16rpx;background:rgba(255,112,0,.09);box-sizing:border-box}
.report text{display:block}
.report text:first-child{font-size:30rpx;font-weight:800}
.report text:last-child{font-size:20rpx;color:#ffb26b;margin-top:12rpx}
.nav-title{display:flex;gap:28rpx;align-items:center;font-size:38rpx;font-weight:800;margin:38rpx 0}
.nav-title>text{font-size:58rpx}
.coach{display:flex;align-items:center;gap:26rpx;margin-bottom:26rpx}
.coach-avatar{width:120rpx;height:120rpx;border-radius:50%;border:3rpx solid #ff7600;background:#20252a;display:flex;align-items:center;justify-content:center;font-size:40rpx}
.coach-name{display:block;font-size:34rpx;font-weight:800}
.coach-stats{display:flex;gap:22rpx;margin-top:22rpx;color:#bbb;font-size:23rpx}
.class-card{padding:24rpx;margin-bottom:22rpx}
.class-top{display:flex;align-items:center}
.class-count{display:block;font-size:29rpx;font-weight:800}
.outline{border:2rpx solid #ff7600;color:#ff7600;border-radius:14rpx;padding:16rpx 22rpx;font-size:23rpx;font-weight:700}
.divider{height:1rpx;background:#30353a;margin:20rpx 0}
.class-meta{display:grid;grid-template-columns:1fr 1fr;color:#b5b7ba;font-size:23rpx}
.class-meta>view{display:flex;flex-direction:column;gap:10rpx}
.class-meta>view+view{border-left:1rpx solid #30353a;padding-left:24rpx}
.full{height:72rpx;display:flex;align-items:center;justify-content:center;margin-top:12rpx}
.safe{height:48rpx}
