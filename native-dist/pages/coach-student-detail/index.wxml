<view class="page"><view class="nav"><view class="back" bindtap="goBack"><text>‹</text></view><text class="nav-title">学员详情</text><text class="edit">编辑</text></view><scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}">
<view class="profile"><image class="avatar" src="{{avatar}}" mode="aspectFill"/><view class="profile-main"><view><text class="name">林浩</text><text class="number">#23</text></view><text class="meta">9岁　|　浦东校区　|　U10提高班</text><view class="badges"><text>保险有效</text><text>可参赛</text><text class="orange">待续费30天</text></view><text class="student-no">学员编号：000123　　入学时间：2024-03-12</text></view></view>
<view class="tabs"><view class="tab {{item.activeClass}}" wx:for="{{tabs}}" wx:key="key" data-key="{{item.key}}" bindtap="selectTab">{{item.label}}</view></view>
<view class="card"><view class="head"><text class="title">赛事数据</text><text class="link">本赛季数据 ›</text></view><view class="stats"><view wx:for="{{stats}}" wx:key="label"><text class="label">{{item.label}}</text><text class="stat-number">{{item.value}}</text><text class="stat-unit">{{item.unit}}</text></view></view></view>
<view class="card"><view class="head"><text class="title">课程记录</text><text class="link">查看全部 ›</text></view><view class="course-grid"><view class="balance"><text>剩余课时</text><text class="course-number">18</text><text class="course-unit">课时</text></view><view class="attendance"><text>出勤率</text><text class="course-number">92%</text><view class="mini-ring">92%</view><text class="course-unit">本月出勤 11/12次</text></view><view class="chart"><text class="chart-title">课消趋势（课时）</text><view class="bars"><view class="bar-item" wx:for="{{courses}}" wx:key="month"><text>{{item.used}}</text><view class="bar" style="height:{{item.height}}"></view><text class="bar-label">{{item.month}}</text></view></view></view></view></view>
<view class="card"><view class="head"><text class="title">课堂 + 赛事联动</text><text class="link">最近90天</text></view><view class="linkage"><view><text class="linkage-title">控球课堂评价　A</text><text class="linkage-sub">上月评分：A（优秀）</text></view><text>→</text><view class="growth"><text class="linkage-title">比赛失误下降　24%</text><text class="linkage-sub">场均失误：3.2 → 2.4次</text></view></view><view class="linkage"><view><text class="linkage-title">防守积极性　A</text><text class="linkage-sub">上月评分：A（优秀）</text></view><text>→</text><view class="growth"><text class="linkage-title">抢断提升　18%</text><text class="linkage-sub">场均抢断：1.6 → 1.9次</text></view></view></view>
<view class="card"><view class="head"><text class="title">最近课堂评价</text><text class="link" bindtap="openEvaluationHistory">查看全部 ›</text></view><view class="review"><text class="review-title">控球稳定性持续提升</text><text class="review-copy">弱侧手控球时重心更稳定，面对防守时开始主动观察队友位置。下一阶段继续强化变向后的快速出球。</text><view class="review-tags"><text>弱侧手进步</text><text>专注积极</text><text>建议提升观察</text></view></view></view><view class="safe"></view></scroll-view><view class="footer"><view class="outline" bindtap="openEvaluationHistory">课后评价</view><view class="primary" bindtap="reserve">预约下一课</view></view></view>
