page{background:#05080b;color:#f7f8f9;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 15% 8%,rgba(255,111,0,.22),transparent 24%),#05080b}.nav{height:192rpx;padding:106rpx 30rpx 0;display:flex;align-items:center}.back{width:68rpx;font-size:62rpx}.nav-title{font-size:34rpx;font-weight:800}.edit{margin-left:auto;transform:translateY(70rpx);color:#ff8a19}.scroll{height:calc(100vh - 192rpx)}.profile{display:flex;padding:18rpx 30rpx 28rpx}.avatar{width:156rpx;height:156rpx;border-radius:50%;border:5rpx solid #ff7a00}.profile-main{flex:1;margin-left:22rpx}.name{font-size:43rpx;font-weight:800}.number{margin-left:12rpx;padding:4rpx 10rpx;border:1rpx solid #ff7a00;border-radius:9rpx;color:#ff8a19;font-size:20rpx}.meta,.student-no{display:block}.meta{margin-top:9rpx;font-size:22rpx}.badges{display:flex;gap:8rpx;margin-top:12rpx}.badges text{padding:5rpx 9rpx;border:1rpx solid #41bd5c;border-radius:999rpx;color:#52d46c;font-size:16rpx}.badges text.orange{border-color:#ff7a00;color:#ff8a19}.student-no{margin-top:12rpx;color:#777f85;font-size:17rpx}.tabs{display:grid;grid-template-columns:repeat(4,1fr);margin:0 22rpx;border:1rpx solid rgba(255,255,255,.15);border-radius:18rpx 18rpx 0 0;background:#11161a}.tab{padding:20rpx 0;text-align:center;color:#8d959b;border-bottom:4rpx solid transparent}.tab.active{color:#ff8a19;border-bottom-color:#ff7a00;font-weight:800}.card{margin:16rpx 22rpx 0;padding:22rpx;border-radius:20rpx;background:linear-gradient(145deg,#171d21,#0a0e11);border:1rpx solid rgba(255,255,255,.12)}.head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx}.title{font-size:28rpx;font-weight:800}.link{color:#ff8a19;font-size:20rpx}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10rpx}.stats view{padding:18rpx 8rpx;text-align:center;border:1rpx solid rgba(255,122,0,.45);border-radius:16rpx;background:#11161a}.stats .label,.stat-number,.stat-unit{display:block}.stats .label{font-size:18rpx;color:#a1a8ad}.stat-number{margin-top:8rpx;font-size:38rpx;font-weight:800}.stat-unit{color:#8d959b;font-size:17rpx}.course-grid{display:grid;grid-template-columns:140rpx 220rpx 1fr;gap:12rpx}.balance,.attendance,.chart{padding:17rpx;border:1rpx solid rgba(255,122,0,.38);border-radius:16rpx;background:#11161a}.balance text,.attendance text,.chart-title{display:block}.balance text,.attendance text{color:#9ba2a7;font-size:18rpx}.course-number{margin-top:11rpx!important;color:#ff8a19!important;font-size:38rpx!important;font-weight:800}.course-unit{margin-top:5rpx!important;color:#858d93!important;font-size:17rpx!important}.mini-ring{width:82rpx;height:82rpx;margin:10rpx auto;border:9rpx solid #ff7a00;border-left-color:#30373c;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20rpx}.chart-title{font-size:18rpx;font-weight:700}.bars{height:128rpx;display:flex;align-items:flex-end;gap:10rpx;margin-top:10rpx}.bar-item{flex:1;height:100%;display:flex;flex-direction:column;justify-content:flex-end;align-items:center;font-size:15rpx}.bar{width:24rpx;min-height:18rpx;margin-top:4rpx;background:linear-gradient(180deg,#ff9a20,#ff5b00)}.bar-item small{margin-top:5rpx;color:#858d93;font-size:14rpx}.linkage{display:grid;grid-template-columns:1fr 32rpx 1fr;gap:8rpx;align-items:center;padding:14rpx 0;border-top:1rpx solid rgba(255,255,255,.08)}.linkage>text{text-align:center;color:#777;font-size:28rpx}.linkage-title,.linkage-sub{display:block}.linkage-title{font-size:20rpx;font-weight:800}.linkage-sub{margin-top:6rpx;color:#858d93;font-size:17rpx}.growth .linkage-title{color:#4dd06e}.review{padding:18rpx;border:1rpx solid rgba(255,122,0,.35);border-radius:16rpx;background:#10161a}.review-title,.review-copy{display:block}.review-title{font-size:22rpx;font-weight:800}.review-copy{margin-top:9rpx;color:#a7adb1;font-size:19rpx;line-height:1.6}.review-tags{display:flex;gap:8rpx;margin-top:12rpx}.review-tags text{padding:5rpx 9rpx;border-radius:999rpx;background:rgba(255,122,0,.13);color:#ff8a19;font-size:16rpx}.safe{height:136rpx}.footer{position:fixed;z-index:5;left:0;right:0;bottom:0;display:flex;gap:15rpx;padding:18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));background:rgba(7,10,12,.97)}.outline,.primary{height:78rpx;display:flex;align-items:center;justify-content:center;border-radius:16rpx;font-size:25rpx;font-weight:800}.outline{width:220rpx;border:1rpx solid #ff7a00;color:#ff8a19}.primary{flex:1;background:linear-gradient(90deg,#ff5b00,#ff9a20)}

.back{height:70rpx;display:flex;align-items:center;justify-content:flex-start;line-height:1}
.nav{padding-right:210rpx;box-sizing:border-box}.edit{transform:none}
