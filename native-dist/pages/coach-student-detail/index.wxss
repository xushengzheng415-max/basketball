page{background:#05090c;color:#f7f7f7}.page{min-height:100vh}.scroll{height:calc(100vh - 120rpx);padding:36rpx 32rpx;box-sizing:border-box}.brand{height:74rpx;color:#ff7800;font-size:30rpx;font-weight:800}.title{font-size:38rpx;font-weight:900;margin:30rpx 0}.title>text{font-size:56rpx;margin-right:24rpx}.profile,.panel{border:1rpx solid #373d41;border-radius:22rpx;background:linear-gradient(135deg,#191e21,#0d1215)}.profile{padding:28rpx;display:flex;align-items:center;flex-wrap:wrap}.profile image{width:142rpx;height:142rpx;border-radius:50%;border:3rpx solid #ff7800;margin-right:34rpx}.name{display:block;font-size:44rpx;font-weight:900}.class-tag{display:block;border:2rpx solid #ff7800;color:#ff7800;border-radius:24rpx;padding:8rpx 18rpx;margin-top:16rpx}.profile-stats{width:100%;display:grid;grid-template-columns:repeat(4,1fr);margin-top:26rpx;border-top:1rpx solid #333;padding-top:24rpx}.profile-stats view{display:flex;flex-direction:column;align-items:center;border-right:1rpx solid #333}.profile-stats view:last-child{border:0}.profile-stats text{color:#aaa}.profile-stats .strong{color:#ff7800;font-size:28rpx;margin-top:9rpx}.profile-stats .green{color:#3ac056}.panel{padding:24rpx;margin-top:22rpx}.panel-title{font-size:31rpx;font-weight:800}.growth{display:grid;grid-template-columns:repeat(3,1fr);margin-top:24rpx}.growth view{display:flex;flex-direction:column;align-items:center;border-right:1rpx solid #333}.growth view:last-child{border:0}.growth .icon{width:62rpx;height:62rpx;border:1rpx solid #6f3a0b;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#ff7800;font-size:48rpx}.growth text{margin-top:10rpx}.growth .strong{color:#ff7800;margin-top:8rpx}.row,.suggest{border:1rpx solid #333;border-radius:15rpx;padding:24rpx;margin-top:20rpx;font-size:27rpx}.row{display:flex;justify-content:space-between}.row text{color:#aaa}.suggest{font-size:26rpx}.safe{height:30rpx}.footer{height:120rpx;display:flex;gap:20rpx;padding:18rpx 32rpx;box-sizing:border-box}.footer view{height:78rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:800}.outline{width:330rpx;border:2rpx solid #ff7800;color:#ff7800}.primary{flex:1;background:linear-gradient(100deg,#ff6500,#ff8f1b)}
