page {
  height: 100vh;
  overflow: hidden;
  background: #f4f7fa;
}
.setup {
  height: 100vh;
  box-sizing: border-box;
  padding: 10px 16px 12px;
  overflow: hidden;
  background: #f4f7fa;
}
.setup-card {
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  padding: 14px 16px;
  border-radius: 10px;
  background: #fff;
}
.setup-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.setup-title,
.setup-desc,
.field text,
.team-name,
.team-score,
.period,
.clock-mode {
  display: block;
}
.setup-title {
  color: #101820;
  font-size: 24px;
  font-weight: 900;
  line-height: 1.1;
}
.setup-desc {
  margin-top: 4px;
  color: #667085;
  font-size: 14px;
  line-height: 1.25;
}
.start {
  display: flex;
  width: 124px;
  height: 42px;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  color: #fff;
  background: #f05a28;
  font-size: 17px;
  font-weight: 900;
}
.form-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px 14px;
  margin-top: 12px;
}
.field text {
  color: #18212f;
  font-size: 15px;
  font-weight: 900;
  line-height: 1.15;
}
.field input {
  box-sizing: border-box;
  width: 100%;
  height: 36px;
  margin-top: 5px;
  padding: 0 11px;
  border: 1px solid #d7dee8;
  border-radius: 7px;
  background: #f8fafc;
  font-size: 16px;
}
.number-control {
  display: grid;
  grid-template-columns: 36px 1fr 36px;
  gap: 7px;
  align-items: center;
  margin-top: 5px;
}
.step-btn,
.foul-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 7px;
  color: #fff;
  background: #344054;
  font-weight: 900;
}
.step-btn {
  height: 34px;
  font-size: 20px;
}
.number-value {
  display: flex;
  height: 34px;
  align-items: center;
  justify-content: center;
  border: 1px solid #d7dee8;
  border-radius: 7px;
  color: #101820;
  background: #f8fafc;
  font-size: 16px;
  font-weight: 900;
}
.preset-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
  margin-top: 6px;
}
.period-preset-row {
  grid-template-columns: repeat(3, 1fr);
}
.preset,
.mode {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #d7dee8;
  border-radius: 7px;
  color: #18212f;
  background: #fff;
  font-weight: 900;
}
.preset {
  height: 28px;
  font-size: 13px;
}
.preset.active,
.mode.active {
  border-color: #f05a28;
  color: #fff;
  background: #f05a28;
}
.mode-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 5px;
}
.mode {
  height: 36px;
  font-size: 15px;
}
.scoreboard {
  display: grid;
  grid-template-rows: 40px 62px minmax(0, 1fr) 34px;
  gap: 8px;
  height: 100vh;
  box-sizing: border-box;
  padding: 8px 16px 10px;
  overflow: hidden;
  color: #fff;
  background: #101820;
}
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 17px;
  font-weight: 900;
}
.finish {
  display: flex;
  width: 116px;
  height: 34px;
  align-items: center;
  justify-content: center;
  border-radius: 7px;
  background: #d83b01;
  font-size: 16px;
}
.clock-card {
  display: grid;
  grid-template-columns: minmax(120px, 1fr) 116px 230px;
  gap: 10px;
  align-items: center;
  min-height: 0;
  padding: 8px 10px;
  border-radius: 10px;
  background: rgba(255,255,255,0.1);
}
.period {
  color: #f8d568;
  font-size: 20px;
  font-weight: 900;
  line-height: 1.05;
}
.clock-mode {
  margin-top: 4px;
  color: #d7dee8;
  font-size: 13px;
  line-height: 1.1;
}
.clock {
  color: #fff;
  font-family: DIN Alternate, Arial, sans-serif;
  font-size: 36px;
  font-weight: 900;
  line-height: 1;
  text-align: center;
}
.clock-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 7px;
}
.clock-btn {
  display: flex;
  height: 38px;
  align-items: center;
  justify-content: center;
  border-radius: 7px;
  color: #101820;
  background: #fff;
  font-size: 15px;
  font-weight: 900;
}
.primary-clock {
  color: #101820;
  background: #f8d568;
}
.main {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 96px minmax(0, 1fr);
  gap: 10px;
  min-height: 0;
}
.team-card {
  display: grid;
  grid-template-rows: 24px minmax(0, 1fr) 34px 40px;
  align-items: center;
  min-height: 0;
  box-sizing: border-box;
  padding: 9px 10px;
  border-radius: 10px;
  color: #101820;
  background: #fff;
}
.team-name {
  max-width: 100%;
  overflow: hidden;
  font-size: 18px;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.team-score {
  align-self: center;
  color: #f05a28;
  font-family: DIN Alternate, Arial, sans-serif;
  font-size: 58px;
  font-weight: 900;
  line-height: 0.95;
  text-align: center;
}
.foul-line {
  display: grid;
  grid-template-columns: 82px 1fr;
  gap: 8px;
  align-items: center;
  color: #18212f;
  font-size: 15px;
  font-weight: 900;
}
.foul-actions {
  display: grid;
  grid-template-columns: 34px 1fr;
  gap: 6px;
}
.foul-btn {
  height: 30px;
  font-size: 16px;
}
.foul-btn.add {
  background: #101820;
  font-size: 14px;
}
.score-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}
.score-btn {
  display: flex;
  height: 38px;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  color: #fff;
  background: #f05a28;
  font-size: 20px;
  font-weight: 900;
}
.center {
  display: grid;
  grid-template-rows: 1fr 34px 34px 1fr;
  align-items: center;
  justify-items: center;
  min-height: 0;
}
.vs {
  align-self: end;
  font-size: 28px;
  font-weight: 900;
  line-height: 1;
}
.undo,
.reset {
  display: flex;
  width: 82px;
  height: 30px;
  align-items: center;
  justify-content: center;
  border-radius: 7px;
  font-size: 16px;
  font-weight: 900;
}
.undo {
  color: #101820;
  background: #f8d568;
}
.reset {
  color: #fff;
  background: #344054;
}
.events {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 0;
  padding: 0 12px;
  border-radius: 8px;
  color: #d7dee8;
  background: rgba(255,255,255,0.08);
  font-size: 15px;
}
@media (max-height: 330px) {
  .setup-card { padding: 11px 14px; }
  .setup-title { font-size: 22px; }
  .setup-desc { font-size: 13px; }
  .form-grid { gap: 8px 12px; margin-top: 10px; }
  .preset { height: 25px; }
  .scoreboard { grid-template-rows: 34px 54px minmax(0, 1fr) 30px; gap: 6px; padding-top: 6px; padding-bottom: 8px; }
  .clock-card { grid-template-columns: minmax(110px, 1fr) 104px 210px; padding: 6px 9px; }
  .clock { font-size: 32px; }
  .team-score { font-size: 48px; }
  .score-btn { height: 32px; font-size: 18px; }
  .foul-line { grid-template-columns: 76px 1fr; font-size: 14px; }
  .foul-btn { height: 28px; }
}