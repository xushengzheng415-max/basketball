page { height: 100vh; overflow: hidden; background: #f4f7fa; }
.setup { height: 100vh; box-sizing: border-box; padding: 10px 16px 12px; overflow: hidden; background: #f4f7fa; }
.setup-card { box-sizing: border-box; width: 100%; height: 100%; padding: 14px 16px; border-radius: 10px; background: #fff; }
.setup-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
.setup-title, .setup-desc, .field text, .team-name, .team-score, .period, .clock-mode { display: block; }
.setup-title { color: #101820; font-size: 24px; font-weight: 900; line-height: 1.1; }
.setup-desc { margin-top: 4px; color: #667085; font-size: 14px; line-height: 1.25; }
.start { display: flex; width: 124px; height: 42px; flex-shrink: 0; align-items: center; justify-content: center; border-radius: 8px; color: #fff; background: #f05a28; font-size: 17px; font-weight: 900; }
.form-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px 14px; margin-top: 12px; }
.field text { color: #18212f; font-size: 15px; font-weight: 900; line-height: 1.15; }
.field input { box-sizing: border-box; width: 100%; height: 36px; margin-top: 5px; padding: 0 11px; border: 1px solid #d7dee8; border-radius: 7px; background: #f8fafc; font-size: 16px; }
.number-control { display: grid; grid-template-columns: 36px 1fr 36px; gap: 7px; align-items: center; margin-top: 5px; }
.step-btn, .foul-btn { display: flex; align-items: center; justify-content: center; border-radius: 7px; color: #fff; background: #344054; font-weight: 900; }
.step-btn { height: 34px; font-size: 20px; }
.number-value { display: flex; height: 34px; align-items: center; justify-content: center; border: 1px solid #d7dee8; border-radius: 7px; color: #101820; background: #f8fafc; font-size: 16px; font-weight: 900; }
.preset-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-top: 6px; }
.period-preset-row { grid-template-columns: repeat(3, 1fr); }
.preset, .mode { display: flex; align-items: center; justify-content: center; border: 1px solid #d7dee8; border-radius: 7px; color: #18212f; background: #fff; font-weight: 900; }
.preset { height: 28px; font-size: 13px; }
.preset.active, .mode.active { border-color: #f05a28; color: #fff; background: #f05a28; }
.mode-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 5px; }
.mode { height: 36px; font-size: 15px; }
.scoreboard { position: relative; display: grid; grid-template-rows: 36px 58px minmax(0, 1fr) 32px; gap: 8px; height: 100vh; box-sizing: border-box; padding: 7px 14px 8px; overflow: hidden; color: #fff; background: #101820; }
.topbar { display: grid; grid-template-columns: 1fr auto 116px; align-items: center; gap: 10px; font-size: 16px; font-weight: 900; }
.mc-status { padding: 5px 10px; border-radius: 999px; color: #f8d568; background: rgba(248,213,104,0.12); font-size: 12px; }
.mc-status.unlocked { color: #21d19f; background: rgba(33,209,159,0.16); }
.finish { display: flex; height: 32px; align-items: center; justify-content: center; border-radius: 7px; background: #d83b01; font-size: 15px; }
.clock-card { display: grid; grid-template-columns: minmax(120px, 1fr) 116px 230px; gap: 10px; align-items: center; min-height: 0; padding: 7px 10px; border-radius: 10px; background: rgba(255,255,255,0.1); }
.period { color: #f8d568; font-size: 19px; font-weight: 900; line-height: 1.05; }
.clock-mode { margin-top: 4px; color: #d7dee8; font-size: 13px; line-height: 1.1; }
.clock { color: #fff; font-family: DIN Alternate, Arial, sans-serif; font-size: 34px; font-weight: 900; line-height: 1; text-align: center; }
.clock-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 7px; }
.clock-btn { display: flex; height: 36px; align-items: center; justify-content: center; border-radius: 7px; color: #101820; background: #fff; font-size: 15px; font-weight: 900; }
.primary-clock { color: #101820; background: #f8d568; }
.mc-shade { position: fixed; inset: 0; z-index: 18; background: rgba(0,0,0,0.18); }
.mc-sidebar { position: fixed; left: -248px; top: 78px; z-index: 20; display: flex; align-items: flex-start; transition: left 0.22s ease; }
.mc-sidebar.open { left: 10px; }
.mc-edge-tab { display: flex; width: 34px; height: 92px; margin-top: 46px; flex-shrink: 0; flex-direction: column; align-items: center; justify-content: center; gap: 7px; border: 1px solid rgba(255,255,255,0.18); border-left: 0; border-radius: 0 12px 12px 0; color: #f8d568; background: rgba(16,24,32,0.9); box-shadow: 8px 10px 20px rgba(0,0,0,0.28); font-size: 12px; font-weight: 900; }
.tab-signal { width: 8px; height: 8px; border-radius: 3px; background: #21d19f; box-shadow: 0 0 10px rgba(33,209,159,0.7); }
.mc-drawer { box-sizing: border-box; width: 248px; padding: 11px; border: 1px solid rgba(255,255,255,0.14); border-radius: 0 14px 14px 0; background: rgba(16,24,32,0.95); box-shadow: 0 12px 30px rgba(0,0,0,0.35); backdrop-filter: blur(8px); }
.drawer-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; color: #fff; font-size: 15px; font-weight: 900; }
.drawer-close { display: flex; width: 24px; height: 24px; align-items: center; justify-content: center; border-radius: 6px; color: #d7dee8; background: rgba(255,255,255,0.1); font-size: 18px; line-height: 1; }
.quick-custom { margin-bottom: 10px; padding: 9px; border-radius: 10px; background: rgba(255,255,255,0.07); }
.quick-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 7px; }
.quick-title { display: block; color: #d7dee8; font-size: 12px; font-weight: 900; }
.quick-edit { display: flex; height: 22px; min-width: 36px; align-items: center; justify-content: center; border-radius: 6px; color: #101820; background: #f8d568; font-size: 11px; font-weight: 900; }
.quick-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
.quick-chip { display: flex; height: 26px; align-items: center; justify-content: center; border-radius: 6px; color: #98a2b3; background: rgba(255,255,255,0.08); font-size: 11px; font-weight: 900; }
.quick-chip.active { color: #101820; background: #f8d568; }
.quick-chip.empty { color: #667085; background: rgba(255,255,255,0.06); }
.pad-row { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; margin-bottom: 9px; }
.pad-grid { display: grid; grid-template-columns: 1fr; gap: 8px; }
.pad-btn { display: flex; height: 38px; align-items: center; justify-content: center; border-radius: 999px; color: #fff; background: #243244; box-shadow: inset 0 -3px 0 rgba(0,0,0,0.18); font-size: 14px; font-weight: 900; }
.pad-btn.attack { background: #243244; }
.pad-btn.defense { background: #344054; }
.pad-btn.playing { color: #101820; background: #f8d568; }
.voice-center { display: grid; gap: 5px; width: 86px; align-self: start; justify-items: center; margin-top: 5px; }
.voice-tabs { display: grid; grid-template-columns: 1fr; gap: 4px; width: 86px; }
.voice-style, .voice-btn { display: flex; height: 32px; align-items: center; justify-content: center; border-radius: 999px; font-size: 12px; font-weight: 900; }
.voice-style { color: #d7dee8; background: #1b2838; }
.voice-style.active { color: #101820; background: #f8d568; }
.voice-btn { width: 86px; color: #fff; background: #f05a28; font-size: 13px; }
.three-progress { position: fixed; left: 50%; top: 102px; z-index: 9; width: 260px; margin-left: -130px; padding: 8px 10px; border-radius: 9px; color: #fff; background: rgba(16,24,32,0.92); font-size: 13px; font-weight: 900; text-align: center; }
.progress-track { height: 8px; margin-top: 6px; border-radius: 999px; background: rgba(255,255,255,0.22); overflow: hidden; }
.progress-bar { height: 8px; border-radius: 999px; background: #f05a28; transition: width 0.06s linear; }
.main { display: grid; grid-template-columns: minmax(0, 1fr) 92px minmax(0, 1fr); gap: 10px; min-height: 0; }
.team-card { display: grid; grid-template-rows: 22px minmax(0, 1fr) 32px 38px; align-items: center; min-height: 0; box-sizing: border-box; padding: 8px 10px; border-radius: 10px; color: #101820; background: #fff; }
.team-name { max-width: 100%; overflow: hidden; font-size: 17px; font-weight: 900; line-height: 1; text-align: center; text-overflow: ellipsis; white-space: nowrap; }
.team-score { align-self: center; color: #f05a28; font-family: DIN Alternate, Arial, sans-serif; font-size: 52px; font-weight: 900; line-height: 0.92; text-align: center; }
.foul-line { display: grid; grid-template-columns: minmax(58px, 1fr) 76px; gap: 8px; align-items: center; color: #18212f; font-size: 14px; font-weight: 900; }
.foul-actions { display: grid; grid-template-columns: 34px 34px; gap: 8px; justify-content: end; }
.foul-btn { height: 28px; font-size: 15px; }
.foul-btn.add { background: #101820; font-size: 18px; }
.score-buttons { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
.score-btn { display: flex; height: 36px; align-items: center; justify-content: center; border-radius: 8px; color: #fff; background: #f05a28; font-size: 18px; font-weight: 900; }
.score-btn.hold { background: #d83b01; font-size: 15px; }
.center { display: grid; grid-template-rows: minmax(18px, 1fr) 32px 32px auto minmax(0, 1fr); align-items: center; justify-items: center; min-height: 0; }
.vs { align-self: end; font-size: 27px; font-weight: 900; line-height: 1; }
.undo, .reset { display: flex; width: 78px; height: 29px; align-items: center; justify-content: center; border-radius: 7px; font-size: 15px; font-weight: 900; }
.undo { color: #101820; background: #f8d568; }
.reset { color: #fff; background: #344054; }
.events { display: flex; align-items: center; justify-content: space-between; min-height: 0; padding: 0 12px; border-radius: 8px; color: #d7dee8; background: rgba(255,255,255,0.08); font-size: 14px; }
@media (max-height: 330px) {
  .scoreboard { grid-template-rows: 32px 50px minmax(0, 1fr) 28px; gap: 6px; padding-top: 5px; padding-bottom: 6px; }
  .clock-card { grid-template-columns: minmax(110px, 1fr) 104px 210px; padding: 5px 9px; }
  .clock { font-size: 30px; }
  .team-card { grid-template-rows: 20px minmax(0, 1fr) 29px 33px; }
  .team-score { font-size: 44px; }
  .score-btn { height: 31px; font-size: 16px; }
  .foul-line { grid-template-columns: minmax(54px, 1fr) 70px; font-size: 13px; }
  .foul-btn { height: 25px; }
  .foul-actions { grid-template-columns: 31px 31px; gap: 7px; }
  .mc-sidebar { top: 64px; left: -226px; }
  .mc-sidebar.open { left: 8px; }
  .mc-edge-tab { width: 30px; height: 78px; margin-top: 42px; }
  .mc-drawer { width: 226px; padding: 9px; }
  .pad-btn { height: 34px; font-size: 13px; }
  .voice-center { width: 78px; gap: 4px; margin-top: 3px; }
  .voice-tabs { width: 78px; gap: 3px; }
  .voice-style, .voice-btn { height: 24px; font-size: 10px; }
  .voice-btn { width: 78px; }
}
