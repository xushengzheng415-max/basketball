<view wx:if="{{!started}}" class="setup">
  <view class="setup-card">
    <view class="setup-head">
      <view>
        <text class="setup-title">快速开始比赛</text>
        <text class="setup-desc">设置主客队、比赛节数、每节时长和计时方式。</text>
      </view>
      <view class="start" bindtap="startMatch">开始比赛</view>
    </view>

    <view class="form-grid">
      <view class="field">
        <text>主队名称</text>
        <input value="{{homeName}}" placeholder="主队" bindinput="onHomeInput" />
      </view>
      <view class="field">
        <text>客队名称</text>
        <input value="{{awayName}}" placeholder="客队" bindinput="onAwayInput" />
      </view>
      <view class="field mode-field">
        <text>计时方式</text>
        <view class="mode-row">
          <view class="mode {{timerMode == 'down' ? 'active' : ''}}" data-mode="down" bindtap="setTimerMode">倒计时</view>
          <view class="mode {{timerMode == 'up' ? 'active' : ''}}" data-mode="up" bindtap="setTimerMode">正计时</view>
        </view>
      </view>
      <view class="field duration-field">
        <text>每节时长</text>
        <view class="number-control">
          <view class="step-btn" bindtap="decreasePeriodMinutes">-</view>
          <text class="number-value">{{periodMinutes}} 分钟</text>
          <view class="step-btn" bindtap="increasePeriodMinutes">+</view>
        </view>
        <view class="preset-row">
          <view wx:for="{{durationOptions}}" wx:key="*this" class="preset {{periodMinutes == item ? 'active' : ''}}" data-value="{{item}}" bindtap="setPeriodPreset">{{item}}分</view>
        </view>
      </view>
      <view class="field period-count-field">
        <text>比赛节数</text>
        <view class="number-control">
          <view class="step-btn" bindtap="decreasePeriodCount">-</view>
          <text class="number-value">{{totalPeriods}} 节</text>
          <view class="step-btn" bindtap="increasePeriodCount">+</view>
        </view>
        <view class="preset-row period-preset-row">
          <view wx:for="{{periodOptions}}" wx:key="*this" class="preset {{totalPeriods == item ? 'active' : ''}}" data-value="{{item}}" bindtap="setPeriodCountPreset">{{item}}节</view>
        </view>
      </view>
    </view>
  </view>
</view>

<view wx:else class="scoreboard">
  <view class="topbar">
    <text>赛小蜂篮球计分盘</text>
    <view class="mc-status {{mcUnlocked ? 'unlocked' : ''}}">{{mcStatus}}</view>
    <view class="finish" bindtap="finishMatch">结束比赛</view>
  </view>

  <view class="clock-card">
    <view>
      <text class="period">第 {{period}} / {{totalPeriods}} 节</text>
      <text class="clock-mode">{{timerModeText}} · {{periodMinutes}} 分钟</text>
    </view>
    <text class="clock">{{clockText}}</text>
    <view class="clock-actions">
      <view class="clock-btn primary-clock" bindtap="toggleClock">{{clockRunning ? '暂停' : '开始'}}</view>
      <view class="clock-btn" bindtap="resetClock">复位</view>
      <view class="clock-btn" bindtap="nextPeriod">下一节</view>
    </view>
  </view>

  <view wx:if="{{longPressActive}}" class="three-progress">
    <text>{{longPressText}}</text>
    <view class="progress-track"><view class="progress-bar" style="width: {{longPressProgress}}%;"></view></view>
  </view>

  <view wx:if="{{mcPanelOpen}}" class="mc-shade" bindtap="closeMcPanel"></view>
  <view class="mc-sidebar {{mcPanelOpen ? 'open' : ''}}">
    <view class="mc-drawer">
      <view class="drawer-head">
        <text>MC 控制台</text>
        <view class="drawer-close" bindtap="closeMcPanel">×</view>
      </view>
      <view class="quick-custom">
        <view class="quick-head">
          <text class="quick-title">快捷自定义</text>
          <view class="quick-edit">编辑</view>
        </view>
        <view class="quick-strip">
          <view class="quick-chip active">欢呼</view>
          <view class="quick-chip empty">空</view>
          <view class="quick-chip empty">空</view>
          <view class="quick-chip empty">空</view>
        </view>
      </view>
      <view class="pad-row">
        <view class="pad-btn attack {{bgmType == 'attack' ? 'playing' : ''}}" bindtap="playAttackMusic">进攻</view>
        <view class="pad-btn defense {{bgmType == 'defense' ? 'playing' : ''}}" bindtap="playDefenseMusic">防守</view>
      </view>
      <view class="pad-grid">
        <view class="pad-btn" bindtap="playTwoSound">2分有效</view>
        <view class="pad-btn" bindtap="playMissSound">投篮未进</view>
        <view class="pad-btn" bindtap="playCheerSound">欢呼声</view>
      </view>
    </view>
    <view class="mc-edge-tab" bindtap="toggleMcPanel">
      <view class="tab-signal"></view>
      <text>MC</text>
    </view>
  </view>

  <view class="main">
    <view class="team-card">
      <text class="team-name">{{homeName}}</text>
      <text class="team-score {{homeScorePulse ? 'pulse' : ''}}">{{homeScore}}</text>
      <view class="foul-line">
        <text>犯规 {{homeFouls}}</text>
        <view class="foul-actions">
          <view class="foul-btn" bindtap="subtractHomeFoul">-</view>
          <view class="foul-btn add" bindtap="addHomeFoul">+</view>
        </view>
      </view>
      <view class="score-buttons">
        <view class="score-btn" bindtap="addHome1">+1</view>
        <view class="score-btn" bindtap="addHome2">+2</view>
        <view class="score-btn hold" bindtouchstart="startHome3Press" bindtouchend="stopLongPress" bindtouchcancel="stopLongPress">长按+3</view>
      </view>
    </view>

    <view class="center">
      <text class="vs">VS</text>
      <view class="undo" bindtap="undo">撤销</view>
      <view class="reset" bindtap="resetMatch">重开</view>
      <view class="voice-center">
        <view class="voice-tabs">
          <view wx:for="{{voiceStyles}}" wx:key="id" class="voice-style {{voiceStyle == item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="setVoiceStyle">{{item.name}}</view>
        </view>
        <view class="voice-btn" bindtap="announceScore">{{voiceButtonText}}</view>
      </view>
    </view>

    <view class="team-card">
      <text class="team-name">{{awayName}}</text>
      <text class="team-score {{awayScorePulse ? 'pulse' : ''}}">{{awayScore}}</text>
      <view class="foul-line">
        <text>犯规 {{awayFouls}}</text>
        <view class="foul-actions">
          <view class="foul-btn" bindtap="subtractAwayFoul">-</view>
          <view class="foul-btn add" bindtap="addAwayFoul">+</view>
        </view>
      </view>
      <view class="score-buttons">
        <view class="score-btn" bindtap="addAway1">+1</view>
        <view class="score-btn" bindtap="addAway2">+2</view>
        <view class="score-btn hold" bindtouchstart="startAway3Press" bindtouchend="stopLongPress" bindtouchcancel="stopLongPress">长按+3</view>
      </view>
    </view>
  </view>

  <view class="events">
    <text>最近记录</text>
    <text>{{latestEvent}}</text>
  </view>
</view>
