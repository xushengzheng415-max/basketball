<view wx:if="{{!started}}" class="setup-page">
  <image class="setup-bg" src="/assets/pages/scorer-v2/background/pad-scoreboard-bg-clean.png" mode="aspectFill" />
  <view class="setup-nav">
    <view class="setup-back" bindtap="goBack">{{text.back}}</view>
  </view>
  <view class="setup-card">
    <view class="setup-title-row">
      <view>
        <text class="setup-eyebrow">{{text.appName}}</text>
        <text class="setup-title">{{text.quickStart}}</text>
        <text class="setup-desc">{{text.setupDesc}}</text>
      </view>
      <view class="setup-start" bindtap="startMatch">{{text.startMatch}}</view>
    </view>
    <view class="setup-grid">
      <view class="setup-field">
        <text>{{text.homeName}}</text>
        <input value="{{homeName}}" placeholder="{{text.homePlaceholder}}" bindinput="onHomeInput" adjust-position="{{true}}" cursor-spacing="120" />
      </view>
      <view class="setup-field">
        <text>{{text.awayName}}</text>
        <input value="{{awayName}}" placeholder="{{text.awayPlaceholder}}" bindinput="onAwayInput" adjust-position="{{true}}" cursor-spacing="120" />
      </view>
      <view class="setup-field">
        <text>{{text.periodMinutes}}</text>
        <view class="stepper">
          <view bindtap="decreasePeriodMinutes">-</view>
          <text>{{periodMinutes}} {{text.minute}}</text>
          <view bindtap="increasePeriodMinutes">+</view>
        </view>
        <view class="preset-row">
          <view wx:for="{{durationOptions}}" wx:key="*this" class="preset {{periodMinutes == item ? 'active' : ''}}" data-value="{{item}}" bindtap="setPeriodPreset">{{item}}{{text.minuteShort}}</view>
        </view>
      </view>
      <view class="setup-field">
        <text>{{text.totalPeriods}}</text>
        <view class="stepper">
          <view bindtap="decreasePeriodCount">-</view>
          <text>{{totalPeriods}} {{text.periodUnit}}</text>
          <view bindtap="increasePeriodCount">+</view>
        </view>
        <view class="preset-row">
          <view wx:for="{{periodOptions}}" wx:key="*this" class="preset {{totalPeriods == item ? 'active' : ''}}" data-value="{{item}}" bindtap="setPeriodCountPreset">{{item}}{{text.periodUnit}}</view>
        </view>
      </view>
      <view class="setup-field wide">
        <text>{{text.timerMode}}</text>
        <view class="mode-row">
          <view class="mode {{timerMode == 'down' ? 'active' : ''}}" data-mode="down" bindtap="setTimerMode">{{text.countdown}}</view>
          <view class="mode {{timerMode == 'up' ? 'active' : ''}}" data-mode="up" bindtap="setTimerMode">{{text.countup}}</view>
        </view>
      </view>
    </view>
  </view>
</view>

<view wx:else class="score-page {{isLandscape ? 'landscape' : 'portrait'}}">
  <image class="score-bg" src="/assets/pages/scorer-v2/background/pad-scoreboard-bg-clean.png" mode="aspectFill" />
  <view class="top-bar">
    <view class="top-icon" bindtap="goBack">{{text.back}}</view>
    <text class="page-title">{{titleText}}</text>
    <view class="top-meta">
      <text class="live-badge">LIVE</text>
      <text>{{matchName}}</text>
      <text class="period-text">{{text.periodPrefix}}{{period}}{{text.periodUnit}}</text>
      <text>{{clockText}}</text>
    </view>
    <view class="top-pill">{{text.networkGood}}</view>
    <view class="top-pill">{{text.synced}}</view>
    <view class="top-icon" bindtap="goSettings">SET</view>
  </view>

  <view class="board-grid">
    <view class="lineup-drawer left">
      <view class="drawer-title">{{homeName}}{{text.starter}}</view>
      <view wx:for="{{homeStarters}}" wx:key="id" class="player-card">
        <image src="{{item.avatar}}" mode="aspectFill" />
        <view><text class="number">#{{item.number}}</text><text class="player-name">{{item.name}}</text><text class="position">{{item.position}}</text></view>
      </view>
      <view class="bench-list"><text>{{homeName}}{{text.bench}}</text><text wx:for="{{homeBench}}" wx:key="id">#{{item.number}} {{item.name}}</text></view>
    </view>

    <view class="team-panel home">
      <view class="team-head"><image class="team-logo" src="{{homeLogo}}" mode="aspectFit" /><text class="team-name">{{homeName}}</text></view>
      <text class="big-score {{homeScorePulse ? 'pulse' : ''}}">{{homeScore}}</text>
      <view class="team-meta"><text>{{text.totalFouls}} <text class="orange">{{homeFouls}}</text></text><text>{{text.timeout}} <text class="orange">{{homeTimeouts}}</text></text></view>
      <view class="score-grid"><view bindtap="addHome1">+1</view><view bindtap="addHome2">+2</view><view bindtouchstart="startHome3Press" bindtouchend="stopLongPress" bindtouchcancel="stopLongPress">+3</view><view bindtap="addHomeFoul">{{text.foul}}</view><view bindtap="addHomeTimeout">{{text.timeout}}</view><view bindtap="openHomeSub">{{text.substitution}}</view></view>
    </view>

    <view class="center-panel">
      <text class="main-clock">{{clockText}}</text>
      <view class="center-actions"><view class="primary" bindtap="toggleClock">{{clockRunning ? text.pause : text.start}}</view><view bindtap="confirmReset">{{text.reset}}</view></view>
      <view class="quarter-row"><view bindtap="prevPeriod">{{text.prevPeriod}}</view><view bindtap="selectPeriod">Q{{period}}</view><view bindtap="nextPeriod">{{text.nextPeriod}}</view></view>
      <view class="swap-btn" bindtap="swapSides">{{text.swapCourt}}</view>
      <view class="recent-list"><view class="recent-head"><text>{{text.recentActions}}</text><text bindtap="clearEvents">{{text.clear}}</text></view><view wx:for="{{events}}" wx:key="id" class="event-row"><text>{{item.time}}</text><text>{{item.team}}</text><text>{{item.action}}</text><text>{{item.score}}</text></view></view>
    </view>

    <view class="team-panel away">
      <view class="team-head"><image class="team-logo" src="{{awayLogo}}" mode="aspectFit" /><text class="team-name">{{awayName}}</text></view>
      <text class="big-score {{awayScorePulse ? 'pulse' : ''}}">{{awayScore}}</text>
      <view class="team-meta"><text>{{text.totalFouls}} <text class="orange">{{awayFouls}}</text></text><text>{{text.timeout}} <text class="orange">{{awayTimeouts}}</text></text></view>
      <view class="score-grid away-score-grid"><view bindtap="addAway1">+1</view><view bindtap="addAway2">+2</view><view bindtouchstart="startAway3Press" bindtouchend="stopLongPress" bindtouchcancel="stopLongPress">+3</view><view bindtap="addAwayFoul">{{text.foul}}</view><view bindtap="addAwayTimeout">{{text.timeout}}</view><view bindtap="openAwaySub">{{text.substitution}}</view></view>
    </view>

    <view class="lineup-drawer right">
      <view class="drawer-title">{{awayName}}{{text.starter}}</view>
      <view wx:for="{{awayStarters}}" wx:key="id" class="player-card"><image src="{{item.avatar}}" mode="aspectFill" /><view><text class="number">#{{item.number}}</text><text class="player-name">{{item.name}}</text><text class="position">{{item.position}}</text></view></view>
      <view class="bench-list"><text>{{awayName}}{{text.bench}}</text><text wx:for="{{awayBench}}" wx:key="id">#{{item.number}} {{item.name}}</text></view>
    </view>
  </view>

  <view wx:if="{{longPressActive}}" class="three-progress"><text>{{longPressText}}</text><view class="progress-track"><view class="progress-bar" style="width: {{longPressProgress}}%;"></view></view></view>

  <view class="bottom-panels">
    <view class="tech-panel"><view wx:for="{{techActions}}" wx:key="key" class="tech-btn" data-key="{{item.key}}" bindtap="recordTech"><image src="{{item.icon}}" mode="aspectFit" /><text>{{item.name}}</text></view></view>
    <view class="mc-panel">
      <view class="mc-title"><text>{{text.mcManager}}</text><text>{{text.currentPlaying}}{{currentAudioName ? currentAudioName : noAudioText}}</text></view>
      <view class="mc-actions"><view class="{{playingType == 'attack' ? 'active' : ''}}" bindtap="playAttack">{{text.attackSound}}</view><view class="{{playingType == 'defense' ? 'active' : ''}}" bindtap="playDefense">{{text.defenseSound}}</view><view bindtap="announceScore">{{text.scoreVoice}}</view><view class="{{playingType == 'rest' ? 'active' : ''}}" bindtap="playRestMusic">{{text.restMusic}}</view><view bindtap="playSubSound">{{text.subSound}}</view><view bindtap="playMvpSound">{{text.mvpSound}}</view></view>
      <view class="volume-row"><text>{{text.volume}}</text><slider value="{{volume}}" min="0" max="100" bindchange="setVolume" /><view bindtap="stopAudio">{{text.stopAudio}}</view></view>
    </view>
  </view>
</view>