page{background:#05080b;color:#f5f6f7;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 85% 0,rgba(255,112,0,.2),transparent 27%),#05080b}.nav{height:202rpx;padding:106rpx 30rpx 0;display:flex;align-items:center}.back{width:70rpx;height:70rpx;display:flex;align-items:center;font-size:62rpx;line-height:1}.nav-title,.nav-sub,.eyebrow,.course-title,.course-meta,.package,.empty text{display:block}.nav-title{font-size:32rpx;font-weight:800}.nav-sub{margin-top:4rpx;color:#7d858b;font-size:19rpx}.count{margin-left:auto;padding:9rpx 17rpx;border:1rpx solid rgba(255,122,0,.65);border-radius:999rpx;color:#ff8a19;font-size:20rpx}.scroll{height:calc(100vh - 202rpx)}.course-card{margin:8rpx 28rpx 18rpx;padding:25rpx;display:flex;align-items:center;border:1rpx solid rgba(255,122,0,.5);border-radius:22rpx;background:linear-gradient(145deg,#191e22,#0b0f12)}.course-card>view:first-child{flex:1}.eyebrow{color:#ff8a19;font-size:20rpx}.course-title{margin-top:7rpx;font-size:29rpx;font-weight:800}.course-meta{margin-top:10rpx;color:#858d92;font-size:20rpx}.summary{width:112rpx;height:112rpx;border-radius:20rpx;background:rgba(255,122,0,.12);display:flex;flex-direction:column;align-items:center;justify-content:center}.summary text:first-child{font-size:36rpx;font-weight:800;color:#ff8a19}.summary text:last-child{margin-top:4rpx;color:#959ca1;font-size:17rpx}.search{height:76rpx;margin:0 28rpx;display:flex;align-items:center;padding:0 22rpx;border:1rpx solid rgba(255,255,255,.12);border-radius:16rpx;background:#11161a}.search>text{margin-right:13rpx;color:#ff8a19;font-size:34rpx}.search input{flex:1;color:#f4f5f6;font-size:22rpx}.filters{display:flex;gap:12rpx;margin:18rpx 28rpx 24rpx}.filter{padding:10rpx 17rpx;border-radius:999rpx;background:#151b1f;color:#8e969b;font-size:19rpx}.filter.active{background:rgba(255,122,0,.16);color:#ff8a19;border:1rpx solid rgba(255,122,0,.55)}.list-head{margin:0 30rpx 13rpx;display:flex;justify-content:space-between;align-items:center}.list-head text:first-child{font-size:27rpx;font-weight:800}.list-head text:last-child{color:#747d82;font-size:19rpx}.student-list{margin:0 28rpx;border:1rpx solid rgba(255,255,255,.11);border-radius:22rpx;background:linear-gradient(145deg,#171d21,#0b0f12);overflow:hidden}.student{min-height:104rpx;padding:14rpx 18rpx;display:flex;align-items:center;border-bottom:1rpx solid rgba(255,255,255,.08)}.student:last-child{border-bottom:0}.student image{width:68rpx;height:68rpx;margin-right:16rpx;border-radius:50%;border:2rpx solid rgba(255,122,0,.7)}.student-main{flex:1}.student-main>view{display:flex;align-items:center}.student-name{font-size:23rpx;font-weight:800}.number{margin-left:10rpx;color:#ff8a19;font-size:19rpx}.package{margin-top:7rpx;color:#7f888d;font-size:19rpx}.status{padding:7rpx 13rpx;border-radius:999rpx;font-size:18rpx}.status.normal{background:rgba(65,197,103,.12);color:#51d578}.status.leave{background:rgba(255,179,31,.12);color:#ffb31f}.status.makeup{background:rgba(67,145,255,.14);color:#6fa9ff}.arrow{margin-left:12rpx;color:#747b80;font-size:38rpx}.empty{padding:80rpx 20rpx;text-align:center}.empty text:first-child{font-size:24rpx}.empty text:last-child{margin-top:10rpx;color:#747d82;font-size:19rpx}.safe{height:50rpx}
