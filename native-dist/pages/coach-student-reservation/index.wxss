page{background:#05080b;color:#f6f7f8;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 84% 0,rgba(255,110,0,.22),transparent 27%),#05080b}.nav{height:202rpx;padding:106rpx 210rpx 0 30rpx;display:flex;align-items:center;box-sizing:border-box}.back{width:70rpx;height:70rpx;display:flex;align-items:center;font-size:62rpx;line-height:1}.nav-title,.nav-sub,.student-name,.student-meta,.section-title,.section-sub,.date,.time,.course-title,.topic,.notice text{display:block}.nav-title{font-size:32rpx;font-weight:900}.nav-sub{margin-top:4rpx;color:#7c858b;font-size:18rpx}.scroll{height:calc(100vh - 202rpx)}.student-card{margin:8rpx 28rpx 22rpx;padding:20rpx;display:flex;align-items:center;border:1rpx solid rgba(255,122,0,.45);border-radius:20rpx;background:linear-gradient(140deg,rgba(255,122,0,.13),#11171b 48%,#080c0f)}.avatar{width:82rpx;height:82rpx;margin-right:16rpx;display:flex;align-items:center;justify-content:center;border:3rpx solid #ff7a00;border-radius:50%;background:#20282d;color:#ff8a19;font-size:30rpx;font-weight:900}.student-card>view:nth-child(2){flex:1}.student-name{font-size:26rpx;font-weight:900}.student-meta{margin-top:7rpx;color:#8a9399;font-size:18rpx}.valid{padding:7rpx 12rpx;border-radius:999rpx;background:rgba(66,199,104,.12);color:#50d176;font-size:17rpx}.section-head{margin:0 30rpx 13rpx;display:flex;align-items:center;justify-content:space-between}.section-title{font-size:28rpx;font-weight:900}.section-sub{margin-top:5rpx;color:#747d83;font-size:18rpx}.count{color:#ff8a19;font-size:19rpx}.week-tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:10rpx;margin:0 28rpx 25rpx}.week{padding:16rpx 8rpx;border:1rpx solid rgba(255,255,255,.1);border-radius:15rpx;background:#11171b;text-align:center}.week text{display:block}.week text:first-child{font-size:21rpx;font-weight:800}.week text:last-child{margin-top:5rpx;color:#788187;font-size:15rpx}.week.active{border-color:#ff7a00;background:rgba(255,122,0,.12)}.week.active text:first-child{color:#ff8a19}.course{margin:0 28rpx 16rpx;padding:22rpx;border:1rpx solid rgba(255,255,255,.11);border-radius:21rpx;background:linear-gradient(145deg,#171d21,#0a0e11)}.course.active{border-color:#ff7a00;box-shadow:0 0 0 2rpx rgba(255,122,0,.08)}.course-head{display:flex;align-items:center;justify-content:space-between}.date{font-size:23rpx;font-weight:800}.time{margin-top:5rpx;color:#ff9628;font-size:19rpx}.select{padding:8rpx 13rpx;border:1rpx solid rgba(255,122,0,.52);border-radius:999rpx;color:#ff8a19;font-size:17rpx}.course.active .select{background:#ff7a00;color:white}.course-title{margin-top:17rpx;font-size:28rpx;font-weight:900}.topic{margin-top:6rpx;color:#9ba2a7;font-size:19rpx}.course-meta{display:flex;gap:18rpx;margin-top:17rpx;padding-top:15rpx;border-top:1rpx solid rgba(255,255,255,.08);color:#838c92;font-size:18rpx}.available{margin-left:auto;color:#50d176}.notice{margin:4rpx 28rpx 0;padding:19rpx;border-left:5rpx solid #ff7a00;border-radius:14rpx;background:rgba(255,122,0,.07)}.notice text:first-child{color:#ff9628;font-size:19rpx;font-weight:800}.notice text:last-child{margin-top:7rpx;color:#858e94;font-size:18rpx;line-height:1.5}.safe{height:150rpx}.footer{position:fixed;left:0;right:0;bottom:0;padding:16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));background:rgba(6,9,11,.97)}.primary{height:78rpx;display:flex;align-items:center;justify-content:center;border-radius:16rpx;background:#242b30;color:#7d858b;font-size:24rpx;font-weight:900}.primary.ready{background:linear-gradient(90deg,#ff5b00,#ff9a20);color:white}
