<view class="products">
  <view class="hero">
    <text class="kicker">{{copy.kicker}}</text>
    <text class="title">{{copy.title}}</text>
    <text class="desc">{{copy.desc}}</text>
  </view>

  <view wx:if="{{mode == 'mc'}}">
    <text class="section-title">{{copy.shareTitle}}</text>
    <view class="plan-card" bindtap="selectSharePlan">
      <view class="plan-main">
        <view class="plan-top">
          <text class="plan-name">{{sharePlan.name}}</text>
          <text class="promo">{{sharePlan.badge}}</text>
        </view>
        <text class="plan-desc">{{sharePlan.desc}}</text>
      </view>
      <view class="price-block">
        <text class="price">{{sharePlan.price}}</text>
        <text class="buy">{{sharePlan.action}}</text>
      </view>
    </view>

    <view wx:if="{{showMcPay}}" class="hidden-pay">
      <view class="hidden-head">
        <view>
          <text class="hidden-kicker">{{copy.directKicker}}</text>
          <text class="hidden-title">{{copy.directTitle}}</text>
        </view>
        <view class="hidden-close" bindtap="closeMcPay">{{copy.fold}}</view>
      </view>
      <view wx:for="{{mcPaidPlans}}" wx:key="id" class="hidden-plan" data-id="{{item.id}}" bindtap="selectMcPaidPlan">
        <view>
          <view class="hidden-line"><text class="hidden-name">{{item.name}}</text><text class="hidden-badge">{{item.badge}}</text></view>
          <text class="hidden-desc">{{item.desc}}</text>
        </view>
        <text class="hidden-price">{{item.priceText}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{mode == 'voice'}}">
    <text class="section-title">{{copy.voiceTitle}}</text>
    <view class="voice-grid">
      <view wx:for="{{voicePlans}}" wx:key="id" class="voice-card" data-id="{{item.id}}" bindtap="selectVoicePlan">
        <text class="voice-name">{{item.name}}</text>
        <text class="voice-price">{{item.priceText}}</text>
        <text class="voice-desc">{{item.desc}}</text>
        <text class="voice-count">{{item.countText}}</text>
        <text class="voice-action">{{item.action}}</text>
      </view>
    </view>
  </view>

  <view class="notice">
    <text>{{copy.noticeTitle}}</text>
    <text>{{copy.notice}}</text>
  </view>
</view>
