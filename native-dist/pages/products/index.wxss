.products {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
  background: #f4f7fa;
}
.hero {
  padding: 34rpx 28rpx;
  border-radius: 12rpx;
  color: #fff;
  background: #101820;
}
.kicker,
.title,
.desc,
.section-title,
.feature-tag,
.feature-name,
.feature-desc,
.plan-name,
.plan-desc,
.price,
.buy,
.voice-name,
.voice-price,
.voice-desc,
.voice-action,
.notice text {
  display: block;
}
.kicker {
  color: #f8d568;
  font-size: 24rpx;
  font-weight: 900;
}
.title {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
}
.desc {
  margin-top: 12rpx;
  color: #d7dee8;
  font-size: 25rpx;
  line-height: 1.55;
}
.section-title {
  margin: 32rpx 0 14rpx;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
}
.feature-card,
.plan-card,
.voice-card {
  margin-top: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e5eaf0;
  border-radius: 12rpx;
  background: #fff;
  box-shadow: 0 6rpx 18rpx rgba(16, 24, 32, 0.04);
}
.feature-head,
.plan-card,
.plan-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}
.feature-tag,
.promo {
  display: inline-flex;
  width: fit-content;
  align-items: center;
  border-radius: 999rpx;
  color: #d83b01;
  background: #fff3ed;
  padding: 6rpx 14rpx;
  font-size: 21rpx;
  font-weight: 900;
}
.feature-name,
.plan-name {
  margin-top: 10rpx;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
}
.preview {
  display: flex;
  width: 96rpx;
  height: 56rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  color: #fff;
  background: #344054;
  font-size: 23rpx;
  font-weight: 900;
}
.feature-desc,
.plan-desc,
.voice-desc {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}
.point {
  margin-top: 12rpx;
  color: #18212f;
  font-size: 23rpx;
  font-weight: 800;
}
.point::before {
  content: '';
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  margin-right: 10rpx;
  border-radius: 5rpx;
  background: #f05a28;
  vertical-align: middle;
}
.plan-main {
  min-width: 0;
  flex: 1;
}
.plan-top {
  justify-content: flex-start;
}
.plan-name {
  margin-top: 0;
}
.price-block {
  flex: 0 0 154rpx;
  text-align: right;
}
.price {
  color: #f05a28;
  font-family: DIN Alternate, Arial, sans-serif;
  font-size: 36rpx;
  font-weight: 900;
}
.buy,
.voice-action {
  margin-top: 8rpx;
  color: #101820;
  font-size: 22rpx;
  font-weight: 900;
}
.voice-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}
.voice-card {
  margin-top: 0;
}
.voice-name {
  color: #18212f;
  font-size: 28rpx;
  font-weight: 900;
}
.voice-price {
  margin-top: 8rpx;
  color: #f05a28;
  font-size: 34rpx;
  font-weight: 900;
}
.voice-action {
  display: inline-flex;
  width: fit-content;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  margin-top: 14rpx;
  border-radius: 8rpx;
  color: #fff;
  background: #101820;
  padding: 0 22rpx;
}
.notice {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 10rpx;
  color: #667085;
  background: #fff7ed;
  font-size: 24rpx;
  line-height: 1.5;
}
.notice text:first-child {
  margin-bottom: 6rpx;
  color: #d83b01;
  font-weight: 900;
}

.hidden-pay {
  margin-top: 18rpx;
  padding: 22rpx;
  border: 1rpx dashed #ffd6cc;
  border-radius: 12rpx;
  background: #fffaf7;
}
.hidden-head,
.hidden-line,
.hidden-plan {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.hidden-kicker,
.hidden-title,
.hidden-desc,
.hidden-price,
.hidden-name {
  display: block;
}
.hidden-kicker {
  color: #d83b01;
  font-size: 22rpx;
  font-weight: 900;
}
.hidden-title {
  margin-top: 6rpx;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
}
.hidden-close {
  display: flex;
  height: 48rpx;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  color: #667085;
  background: #fff;
  padding: 0 16rpx;
  font-size: 22rpx;
  font-weight: 900;
}
.hidden-plan {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 10rpx;
  background: #fff;
}
.hidden-line {
  justify-content: flex-start;
}
.hidden-name {
  color: #18212f;
  font-size: 26rpx;
  font-weight: 900;
}
.hidden-badge {
  display: inline-flex;
  border-radius: 999rpx;
  color: #d83b01;
  background: #fff3ed;
  padding: 4rpx 10rpx;
  font-size: 20rpx;
  font-weight: 900;
}
.hidden-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.4;
}
.hidden-price {
  flex-shrink: 0;
  color: #f05a28;
  font-size: 30rpx;
  font-weight: 900;
}

.voice-count { display: inline-flex; width: fit-content; margin-top: 10rpx; border-radius: 999rpx; color: #101820; background: #f8d568; padding: 6rpx 14rpx; font-size: 22rpx; font-weight: 900; }
