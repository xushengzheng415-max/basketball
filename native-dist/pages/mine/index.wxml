<view class="page-wrap">
  <view class="profile-card">
    <view class="profile-main">
      <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{profile.avatarUrl}}" class="avatar" src="{{profile.avatarUrl}}" mode="aspectFill" />
        <text wx:else class="avatar-placeholder">蜂</text>
      </button>
      <view class="profile-info">
        <text class="eyebrow">我的账号</text>
        <text class="title">{{profile.nickName}}</text>
        <text class="desc">{{profile.loggedIn ? '已登录，可编辑头像和昵称' : '登录后可保存个人资料'}}</text>
      </view>
    </view>
    <view wx:if="{{!profile.loggedIn}}" class="login-btn" bindtap="login">微信授权登录</view>
    <view wx:else class="logout-btn" bindtap="logout">退出登录</view>
  </view>

  <view class="settings-card">
    <view class="section-head">
      <text class="section-title no-margin">会员兑换</text>
      <text class="count">{{membership ? '已解锁' : '未兑换'}}</text>
    </view>
    <view wx:if="{{membership}}" class="member-status">
      <text>{{membership.productName || '赛小蜂 Pro 会员'}}</text>
      <text>{{membership.expiresAt ? '有效期内' : '长期有效'}}</text>
    </view>
    <input value="{{redeemCode}}" placeholder="请输入会员兑换码" bindinput="onRedeemInput" />
    <view class="primary" bindtap="redeemMembership">{{redeemLoading ? '兑换中...' : '兑换会员'}}</view>
  </view>

  <view class="settings-card">
    <text class="section-title">个人资料</text>
    <view class="field">
      <text class="label">昵称</text>
      <input type="nickname" value="{{draftNickName}}" placeholder="请输入昵称" bindinput="onNicknameInput" />
    </view>
    <view class="auth-row">
      <text>微信授权标识</text>
      <text>{{profile.wxOpenId || profile.wxUnionId ? '已授权' : '登录后由系统获取'}}</text>
    </view>
    <view class="auth-row">
      <text>授权手机号</text>
      <text>{{profile.phoneNumber || '登录授权后同步'}}</text>
    </view>
    <view class="primary" bindtap="saveProfile">确认修改</view>
  </view>

  <view class="settings-card">
    <view class="section-head">
      <text class="section-title no-margin">意见反馈</text>
      <text class="count">已提交 {{feedbackCount}} 条</text>
    </view>
    <view class="type-row">
      <view wx:for="{{feedbackTypes}}" wx:key="*this" class="type-pill {{feedbackType == item ? 'active' : ''}}" data-type="{{item}}" bindtap="setFeedbackType">{{item}}</view>
    </view>
    <textarea value="{{feedbackContent}}" placeholder="告诉我们哪里不好用，或者你希望增加什么功能" maxlength="300" bindinput="onFeedbackInput" />
    <input value="{{contact}}" placeholder="联系方式（选填）" bindinput="onContactInput" />
    <view class="primary" bindtap="submitFeedback">提交反馈</view>
  </view>

  <view class="settings-card">
    <text class="section-title">关于赛小蜂篮球</text>
    <view class="info-row">
      <text>当前版本</text>
      <text>原型版 0.1.0</text>
    </view>
    <view class="info-row">
      <text>服务内容</text>
      <text>赛事、计分、球员管理</text>
    </view>
  </view>
</view>
