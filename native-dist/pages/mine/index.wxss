page {
  min-height: 100%;
  background: #05070a;
}

.mine-profile-page {
  position: relative;
  min-height: 1900rpx;
  padding-bottom: 132rpx;
  overflow: hidden;
  color: #1f2329;
}

.page-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 750rpx;
  height: 1900rpx;
  z-index: 0;
}

.top-area,
.content-area {
  position: relative;
  z-index: 1;
}

.top-area {
  height: 194rpx;
  padding-top: 29rpx;
  box-sizing: border-box;
}

.status-bar {
  display: block;
  width: 668rpx;
  height: 29rpx;
  margin-left: 46rpx;
}

.nav-row {
  position: relative;
  display: flex;
  align-items: center;
  height: 86rpx;
  margin-top: 25rpx;
  padding: 0 20rpx;
}

.back-hit {
  display: flex;
  width: 80rpx;
  height: 80rpx;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 25rpx;
  height: 31rpx;
}

.nav-title {
  position: absolute;
  left: 236rpx;
  right: 236rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 44rpx;
  text-align: center;
}

.wechat-capsule {
  position: absolute;
  right: 20rpx;
  top: 8rpx;
  width: 170rpx;
  height: 62rpx;
}

.content-area {
  padding: 26rpx 35rpx 0;
}

.profile-card {
  display: flex;
  align-items: center;
  width: 679rpx;
  height: 207rpx;
  padding: 28rpx 60rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.22);
}

.avatar-button {
  display: flex;
  width: 151rpx;
  height: 151rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
}

.avatar-img {
  width: 151rpx;
  height: 151rpx;
  border-radius: 50%;
}

.profile-copy {
  min-width: 0;
  margin-left: 42rpx;
}

.profile-name-input {
  width: 300rpx;
  height: 44rpx;
  padding: 0;
  color: #202225;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.change-avatar {
  display: flex;
  width: 167rpx;
  height: 51rpx;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  border: 2rpx solid #ff6a1a;
  border-radius: 26rpx;
  color: #ff5b08;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.form-panel,
.settings-panel {
  width: 679rpx;
  margin-top: 27rpx;
  padding: 17rpx 31rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.12);
}

.form-panel {
  min-height: 460rpx;
}

.settings-panel {
  min-height: 258rpx;
  padding: 24rpx 21rpx 21rpx;
}

.support-panel {
  margin-top: 27rpx;
}

.form-row,
.settings-row {
  display: flex;
  align-items: center;
  min-height: 90rpx;
  border-bottom: 1rpx solid #eef1f5;
}

.form-row:last-child,
.settings-row:last-child {
  border-bottom: 0;
}

.row-icon {
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.row-label {
  flex-shrink: 0;
  color: #333840;
  font-size: 27rpx;
  font-weight: 800;
}

.row-input,
.row-value,
.unused-value {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
  color: #8a9099;
  font-size: 25rpx;
  font-weight: 700;
  text-align: right;
}



.row-value.muted {
  color: #b4bac3;
}

.row-chevron {
  width: 18rpx;
  height: 31rpx;
  flex-shrink: 0;
  margin-left: 19rpx;
  opacity: 0.72;
}

.settings-title-row {
  display: flex;
  align-items: center;
  height: 52rpx;
  margin-bottom: 20rpx;
}

.settings-title-mark {
  width: 7rpx;
  height: 30rpx;
  margin-right: 15rpx;
  border-radius: 4rpx;
  background: #ff5b08;
}

.settings-title {
  color: #202225;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.settings-list {
  padding: 0 22rpx;
  border: 1rpx solid #e7ebef;
  border-radius: 18rpx;
  background: #ffffff;
}

.settings-row {
  min-height: 104rpx;
  border-bottom: 1rpx solid #eef1f5;
}

.settings-icon {
  width: 50rpx;
  height: 50rpx;
  flex-shrink: 0;
  margin-right: 28rpx;
  opacity: 0.9;
}

.settings-icon-accent {
  opacity: 1;
}

.settings-label {
  flex: 1;
  min-width: 0;
  color: #111318;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.settings-chevron {
  width: 18rpx;
  height: 31rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
  opacity: 0.72;
}

.save-button {
  display: flex;
  width: 679rpx;
  height: 84rpx;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 26rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #ff5b08;
  box-shadow: 0 12rpx 24rpx rgba(255, 91, 8, 0.26);
  font-size: 31rpx;
  font-weight: 900;
}

.save-icon {
  width: 34rpx;
  height: 34rpx;
  filter: brightness(0) invert(1);
}
