page {
  min-height: 100vh;
  background: #101820;
}
.home {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}
.home-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
}
.home-bg::after {
  display: none;
}
.home-content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(16, 24, 32, 0.06) 0%, rgba(244, 247, 250, 0.92) 46%, #f4f7fa 100%);
}
.hero {
  display: grid;
  grid-template-columns: 184rpx 1fr;
  gap: 18rpx;
  align-items: center;
  min-height: 292rpx;
  padding: 30rpx 26rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 16rpx;
  color: #fff;
  background: rgba(16, 24, 32, 0.9);
  box-shadow: 0 18rpx 42rpx rgba(16, 24, 32, 0.22);
}
.hero-logo {
  width: 184rpx;
  height: 184rpx;
  filter: drop-shadow(0 12rpx 22rpx rgba(240, 90, 40, 0.38));
}
.hero-copy {
  min-width: 0;
}
.brand, .title, .desc, .shortcut-title, .shortcut-desc, .time, .pay-title, .pay-desc {
  display: block;
}
.brand {
  color: #f8d568;
  font-size: 24rpx;
  font-weight: 900;
}
.title {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}
.desc {
  margin-top: 12rpx;
  color: #d7dee8;
  font-size: 23rpx;
  line-height: 1.45;
}
.hero-action {
  display: flex;
  width: 176rpx;
  height: 60rpx;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  border-radius: 8rpx;
  color: #101820;
  background: #f8d568;
  font-size: 25rpx;
  font-weight: 900;
}
.pay-entry {
  display: grid;
  grid-template-columns: 72rpx 1fr 34rpx;
  gap: 16rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 22rpx 20rpx;
  border: 1rpx solid #fed7aa;
  border-radius: 12rpx;
  background: rgba(255, 247, 237, 0.96);
  box-shadow: 0 10rpx 24rpx rgba(154, 52, 18, 0.08);
}
.entry-icon {
  width: 72rpx;
  height: 72rpx;
}
.entry-copy {
  min-width: 0;
}
.pay-title {
  color: #9a3412;
  font-size: 28rpx;
  font-weight: 900;
}
.pay-desc {
  margin-top: 8rpx;
  color: #9a6b42;
  font-size: 22rpx;
}
.pay-arrow {
  color: #f05a28;
  font-size: 44rpx;
  font-weight: 900;
}
.section-title {
  margin: 34rpx 0 16rpx;
  color: #18212f;
  font-size: 32rpx;
  font-weight: 900;
}
.result-swipe {
  position: relative;
  overflow: hidden;
  border-radius: 10rpx;
}
.delete-action {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  width: 150rpx;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: #d83b01;
  font-size: 28rpx;
  font-weight: 900;
}
.result-card, .empty, .shortcut {
  border: 1rpx solid #e5eaf0;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 8rpx 20rpx rgba(16, 24, 32, 0.05);
}
.result-card {
  position: relative;
  z-index: 1;
  padding: 24rpx;
  transition: transform 0.18s ease;
}
.result-card.show-delete {
  transform: translateX(-150rpx);
}
.result-fouls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  font-weight: 800;
}
.result-row {
  display: flex;
  min-height: 74rpx;
  align-items: center;
  justify-content: space-between;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
}
.score {
  color: #f05a28;
  font-family: DIN Alternate, Arial, sans-serif;
  font-size: 52rpx;
}
.time {
  margin-top: 14rpx;
  color: #667085;
  font-size: 22rpx;
}
.empty {
  padding: 34rpx 24rpx;
  color: #667085;
  font-size: 26rpx;
}
.shortcuts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}
.shortcut {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 126rpx;
  padding: 22rpx 18rpx;
}
.shortcut-icon {
  width: 54rpx;
  height: 54rpx;
  flex-shrink: 0;
}
.shortcut-title {
  color: #18212f;
  font-size: 28rpx;
  font-weight: 900;
}
.shortcut-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.3;
}