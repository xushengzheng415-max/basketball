page {
  min-height: 100vh;
  background: #071017;
  color: #111827;
}

.home-page {
  position: relative;
  display: flex;
  width: 100%;
  height: 100vh;
  min-height: 0;
  flex-direction: column;
  overflow: hidden;
  background: #071017;
  box-sizing: border-box;
}

.top-hero {
  position: relative;
  flex: 0 0 auto;
  min-height: 560rpx;
  padding: 72rpx 28rpx 28rpx;
  overflow: hidden;
  color: #ffffff;
  background: radial-gradient(circle at 86% 50%, rgba(255, 88, 12, 0.44), transparent 30%), radial-gradient(circle at 20% 0%, rgba(255, 122, 24, 0.12), transparent 34%), linear-gradient(135deg, #020405 0%, #071017 58%, #0b0c0e 100%);
}

.top-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0.22;
  background-image: linear-gradient(30deg, rgba(255, 94, 0, 0.14) 12%, transparent 12.5%, transparent 87%, rgba(255, 94, 0, 0.14) 87.5%), linear-gradient(150deg, rgba(255, 94, 0, 0.12) 12%, transparent 12.5%, transparent 87%, rgba(255, 94, 0, 0.12) 87.5%);
  background-size: 74rpx 128rpx;
}

.brand-row,
.section-label,
.quick-card,
.panel,
.custom-tabbar {
  position: relative;
  z-index: 1;
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.brand-logo {
  display: block;
  width: 430rpx;
  height: 142rpx;
  max-width: 100%;
}

.login-guide {
  position: relative;
  z-index: 1;
  display: flex;
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(255, 132, 42, 0.45);
  border-radius: 16rpx;
  background: rgba(11, 17, 22, 0.76);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.18);
}

.login-guide-copy {
  min-width: 0;
  flex: 1;
}

.login-guide-title,
.login-guide-desc {
  display: block;
}

.login-guide-title {
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
}

.login-guide-desc {
  margin-top: 5rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.66);
  font-size: 20rpx;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.login-guide-action {
  margin-left: 18rpx;
  flex: 0 0 auto;
  color: #ff8a22;
  font-size: 23rpx;
  font-weight: 900;
}
.campus-pill {
  display: flex;
  align-items: center;
  height: 58rpx;
  padding: 0 18rpx;
  border: 2rpx solid #ff6a16;
  border-radius: 999rpx;
  color: #ff8a22;
  font-size: 25rpx;
  font-weight: 800;
  background: rgba(0, 0, 0, 0.28);
}

.campus-arrow {
  margin-left: 8rpx;
  font-size: 22rpx;
}

.section-label {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.section-label.light {
  margin-top: 54rpx;
  color: #ffffff;
}

.section-line {
  width: 8rpx;
  height: 34rpx;
  margin-right: 14rpx;
  border-radius: 99rpx;
  background: linear-gradient(180deg, #ff8a18, #ff4b00);
}

.quick-card {
  position: relative;
  min-height: 312rpx;
  padding: 34rpx 28rpx 28rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 92, 0, 0.92);
  border-radius: 18rpx;
  background: radial-gradient(circle at 82% 42%, rgba(255, 94, 0, 0.34), transparent 30%), linear-gradient(135deg, rgba(5, 7, 9, 0.94), rgba(13, 16, 18, 0.9));
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.28);
}

.quick-copy {
  position: relative;
  z-index: 2;
  width: 430rpx;
}

.quick-title,
.quick-desc,
.stat-label,
.stat-number,
.team-name,
.match-meta {
  display: block;
}

.quick-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
}

.quick-desc {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 178rpx;
  height: 64rpx;
  margin: 30rpx 0 0;
  padding: 0;
  border: 0;
  border-radius: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ff4b00, #ff7418);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.primary-btn::after {
  border: 0;
}

.court-art {
  position: absolute;
  right: 18rpx;
  top: 36rpx;
  width: 310rpx;
  height: 210rpx;
  opacity: 0.95;
}

.court-board {
  position: absolute;
  right: 8rpx;
  top: 34rpx;
  width: 168rpx;
  height: 120rpx;
  border: 6rpx solid #ff6a00;
  box-shadow: 0 0 22rpx rgba(255, 100, 0, 0.8);
}

.court-board::after {
  content: "";
  position: absolute;
  left: 42rpx;
  top: 28rpx;
  width: 72rpx;
  height: 52rpx;
  border: 5rpx solid #ff6a00;
}

.court-ball {
  position: absolute;
  left: 18rpx;
  top: 96rpx;
  width: 112rpx;
  height: 112rpx;
  border: 6rpx solid #ff8a18;
  border-radius: 50%;
  box-shadow: 0 0 26rpx rgba(255, 90, 0, 0.72);
}

.light-line {
  position: absolute;
  height: 4rpx;
  border-radius: 99rpx;
  background: #ff5a12;
  box-shadow: 0 0 18rpx rgba(255, 90, 0, 0.8);
}

.light-line.one {
  left: 0;
  right: 20rpx;
  top: 30rpx;
  transform: rotate(-16deg);
}

.light-line.two {
  left: 38rpx;
  right: 0;
  bottom: 30rpx;
  transform: rotate(-16deg);
}

.quick-stats {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 22rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 16rpx;
  background: rgba(8, 12, 16, 0.88);
}

.stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  padding: 0 16rpx;
}

.stat-button {
  min-height: 74rpx;
  margin: 0 7rpx;
  border: 1rpx solid rgba(255, 112, 18, 0.14);
  border-radius: 13rpx;
  background: linear-gradient(180deg, rgba(255, 112, 18, 0.06), rgba(255, 255, 255, 0.015));
  box-sizing: border-box;
}

.stat-button:active {
  border-color: rgba(255, 112, 18, 0.68);
  background: rgba(255, 105, 12, 0.16);
  transform: translateY(1rpx);
}

.stat-icon {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
  border: 4rpx solid #ff6a00;
  border-radius: 50%;
}

.stat-icon.whistle {
  border-radius: 16rpx;
}

.stat-icon.done {
  border-radius: 10rpx;
}

.stat-label {
  color: #ffffff;
  font-size: 22rpx;
}

.stat-number {
  color: #ff6a00;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-divider {
  flex-shrink: 0;
  width: 1rpx;
  height: 66rpx;
  background: rgba(255, 255, 255, 0.22);
}

.content-scroll {
  position: relative;
  z-index: 2;
  display: flex;
  height: auto;
  min-height: 0;
  flex: 1;
  margin-top: -2rpx;
  padding: 12rpx 28rpx calc(120rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  background: radial-gradient(circle at 92% 5%, rgba(255, 87, 0, 0.14), transparent 32%), linear-gradient(180deg, #071017 0%, #05090c 100%);
  box-sizing: border-box;
}

.panel {
  margin-bottom: 24rpx;
  padding: 26rpx 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.08);
}

.version-panel {
  position: relative;
  display: flex;
  width: 100%;
  min-height: 0;
  flex: 1;
  margin: 0;
}

.version-panel:active {
  transform: scale(0.992);
}

.version-ad {
  position: relative;
  display: flex;
  width: 100%;
  height: 100%;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  padding: 30rpx 30rpx 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 107, 22, 0.78);
  border-radius: 24rpx;
  color: #ffffff;
  background: radial-gradient(circle at 86% 22%, rgba(255, 94, 0, 0.38), transparent 30%), linear-gradient(135deg, #090d12 0%, #111922 58%, #251109 100%);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.34);
  box-sizing: border-box;
}

.version-ad::before {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0.22;
  background-image: linear-gradient(120deg, transparent 0%, transparent 46%, rgba(255, 105, 24, 0.22) 46.5%, transparent 47%), linear-gradient(30deg, rgba(255, 255, 255, 0.05) 12%, transparent 12.5%, transparent 87%, rgba(255, 255, 255, 0.05) 87.5%);
  background-size: 190rpx 190rpx, 72rpx 124rpx;
}

.version-ad-head,
.version-kicker,
.version-title,
.version-desc,
.version-features,
.version-footer {
  position: relative;
  z-index: 2;
}

.version-ad-head,
.version-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.version-badge {
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(255, 126, 42, 0.72);
  border-radius: 999rpx;
  color: #ff8a2a;
  background: rgba(255, 92, 0, 0.1);
  font-size: 23rpx;
  font-weight: 900;
}

.version-status {
  color: rgba(255, 255, 255, 0.58);
  font-family: Arial, sans-serif;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.version-kicker,
.version-title,
.version-desc {
  display: block;
}

.version-kicker {
  margin-top: 26rpx;
  color: #ff7a20;
  font-size: 27rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.version-title {
  margin-top: 4rpx;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.08;
  letter-spacing: 2rpx;
}

.version-title text {
  display: block;
}

.version-title-accent {
  margin-top: 4rpx;
  color: #ff7a16;
  text-shadow: 0 8rpx 24rpx rgba(255, 92, 0, 0.2);
}

.version-desc {
  max-width: 510rpx;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  line-height: 1.55;
}

.version-features {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
}

.version-benefits {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 24rpx;
  margin-bottom: 18rpx;
}

.version-benefit {
  min-width: 0;
  padding: 16rpx 10rpx;
  border: 1rpx solid rgba(255, 126, 32, 0.24);
  border-radius: 13rpx;
  background: rgba(5, 10, 14, 0.56);
  text-align: center;
}

.version-benefit text {
  display: block;
}

.version-benefit text:first-child {
  color: #f4f6f7;
  font-size: 23rpx;
  font-weight: 900;
  white-space: nowrap;
}

.version-benefit text:last-child {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 18rpx;
  line-height: 1.35;
}

.version-feature {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 23rpx;
  font-weight: 700;
}

.version-feature:last-child {
  margin-right: 0;
}

.feature-dot {
  width: 8rpx;
  height: 8rpx;
  margin-right: 9rpx;
  border-radius: 50%;
  background: #ff6a16;
  box-shadow: 0 0 14rpx rgba(255, 106, 22, 0.9);
}

.version-footer {
  margin-top: auto;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.36);
  font-family: Arial, sans-serif;
  font-size: 17rpx;
  letter-spacing: 2rpx;
}

.version-expect {
  color: #ff8a2a;
  font-family: sans-serif;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.paid-entry {
  border-color: rgba(255, 132, 35, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(255, 91, 0, 0.16);
}

.version-conversion {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding: 20rpx 20rpx 20rpx 22rpx;
  border: 1rpx solid rgba(255, 125, 28, 0.52);
  border-radius: 14rpx;
  background: linear-gradient(100deg, rgba(255, 91, 0, 0.17), rgba(255, 137, 30, 0.05));
}

.version-conversion-label,
.version-conversion-note {
  display: block;
}

.version-conversion-label {
  color: #f5f6f7;
  font-size: 23rpx;
  font-weight: 900;
}

.version-conversion-note {
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 17rpx;
}

.version-conversion-action {
  min-width: 192rpx;
  padding: 15rpx 18rpx;
  border-radius: 12rpx;
  color: #fff;
  background: linear-gradient(90deg, #ff5700, #ff951d);
  box-shadow: 0 10rpx 24rpx rgba(255, 83, 0, 0.3);
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.version-watermark {
  position: absolute;
  z-index: 1;
  right: 12rpx;
  top: 44rpx;
  color: rgba(255, 255, 255, 0.055);
  font-family: "Arial Black", Arial, sans-serif;
  font-size: 190rpx;
  font-weight: 900;
  line-height: 1;
}

.version-orbit {
  position: absolute;
  z-index: 1;
  border: 1rpx solid rgba(255, 112, 28, 0.24);
  border-radius: 50%;
}

.orbit-one {
  right: -78rpx;
  top: -90rpx;
  width: 310rpx;
  height: 310rpx;
}

.orbit-two {
  right: 18rpx;
  top: 14rpx;
  width: 180rpx;
  height: 180rpx;
}

@media (max-height: 740px) {
  .top-hero {
    min-height: 520rpx;
    padding-top: 58rpx;
    padding-bottom: 20rpx;
  }

  .brand-logo {
    height: 112rpx;
  }

  .section-label.light {
    margin-top: 34rpx;
    margin-bottom: 16rpx;
  }

  .quick-card {
    min-height: 286rpx;
    padding-top: 28rpx;
    padding-bottom: 22rpx;
  }

  .version-ad {
    padding-top: 20rpx;
    padding-bottom: 18rpx;
  }

  .version-kicker {
    margin-top: 16rpx;
  }

  .version-features,
  .version-benefits,
  .version-conversion {
    margin-top: 14rpx;
  }

  .version-title {
    font-size: 46rpx;
  }

  .version-conversion {
    padding: 13rpx 14rpx 13rpx 16rpx;
  }

  .version-conversion-label {
    font-size: 21rpx;
  }

  .version-conversion-action {
    min-width: 170rpx;
    padding: 11rpx 14rpx;
    font-size: 24rpx;
  }
}

.match-list {
  overflow: hidden;
  border: 1rpx solid #eceff3;
  border-radius: 16rpx;
}

.match-row {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 124rpx;
  padding: 10rpx 12rpx;
  border-bottom: 1rpx solid #eef0f3;
  box-sizing: border-box;
}

.match-row:last-child {
  border-bottom: 0;
}

.match-content {
  flex: 1;
  min-width: 0;
}

.match-main {
  display: flex;
  align-items: center;
  min-width: 0;
}

.team-side {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  gap: 6rpx;
}

.team-side.right {
  justify-content: flex-start;
  text-align: left;
}

.team-logo {
  display: block;
  flex-shrink: 0;
  width: 50rpx;
  height: 50rpx;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.team-name {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-side.home .team-name {
  text-align: right;
}

.score-side {
  flex: 0 0 128rpx;
  min-width: 0;
  text-align: center;
}

.score-line {
  display: flex;
  align-items: baseline;
  justify-content: center;
  font-family: Arial, sans-serif;
  font-weight: 900;
}

.score-main {
  color: #ff4b00;
  font-size: 42rpx;
}

.score-away,
.score-split {
  color: #111827;
  font-size: 42rpx;
}

.score-split {
  margin: 0 6rpx;
}

.match-meta {
  display: block;
  width: 100%;
  margin-top: 6rpx;
  color: #727984;
  font-size: 19rpx;
  line-height: 1.35;
  text-align: center;
  white-space: normal;
  word-break: break-all;
}

.status-icon {
  display: block;
  flex-shrink: 0;
  width: 54rpx;
  height: 50rpx;
}

.row-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  gap: 6rpx;
  margin-right: 6rpx;
}

.delete-match-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #fff3ed;
  color: #ff4b00;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.delete-match-btn::after {
  border: 0;
}

.row-arrow {
  flex-shrink: 0;
  width: 18rpx;
  margin-left: 2rpx;
  color: #8c929c;
  font-size: 34rpx;
}

.more-link {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  color: #727984;
  font-size: 24rpx;
}

.empty-card {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 130rpx;
  color: #727984;
  font-size: 24rpx;
}

.bottom-safe {
  height: 150rpx;
}

.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  padding: 12rpx 0 calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(5, 9, 12, 0.96);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #aeb4bd;
  font-size: 21rpx;
}

.tab-item.active {
  color: #ff6a00;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
}

.tab-icon.home { background-image: url('cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/tabbar/tab-home.png'); }
.tab-item.active .tab-icon.home { background-image: url('cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/tabbar/tab-home-selected.png'); }
.tab-icon.trophy { background-image: url('cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/tabbar/tab-tournament.png'); }
.tab-item.active .tab-icon.trophy { background-image: url('cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/tabbar/tab-tournament-selected.png'); }
.tab-icon.user { background-image: url('cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/tabbar/tab-team.png'); }
