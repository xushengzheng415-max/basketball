page {
  min-height: 100vh;
  background: #071017;
  color: #111827;
}

.home-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #f4f6f8;
}

.top-hero {
  position: relative;
  min-height: 560rpx;
  padding: 72rpx 28rpx 28rpx;
  overflow: hidden;
  color: #ffffff;
  background: radial-gradient(circle at 86% 50%, rgba(255, 88, 12, 0.44), transparent 30%), radial-gradient(circle at 20% 0%, rgba(255, 122, 24, 0.12), transparent 34%), linear-gradient(135deg, #020405 0%, #071017 58%, #0b0c0e 100%);
}

.top-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0.22;
  background-image: linear-gradient(30deg, rgba(255, 94, 0, 0.14) 12%, transparent 12.5%, transparent 87%, rgba(255, 94, 0, 0.14) 87.5%), linear-gradient(150deg, rgba(255, 94, 0, 0.12) 12%, transparent 12.5%, transparent 87%, rgba(255, 94, 0, 0.12) 87.5%);
  background-size: 74rpx 128rpx;
}

.brand-row,
.section-label,
.quick-card,
.panel,
.custom-tabbar {
  position: relative;
  z-index: 1;
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.brand-logo {
  display: block;
  width: 430rpx;
  height: 142rpx;
  max-width: 100%;
}
.campus-pill {
  display: flex;
  align-items: center;
  height: 58rpx;
  padding: 0 18rpx;
  border: 2rpx solid #ff6a16;
  border-radius: 999rpx;
  color: #ff8a22;
  font-size: 25rpx;
  font-weight: 800;
  background: rgba(0, 0, 0, 0.28);
}

.campus-arrow {
  margin-left: 8rpx;
  font-size: 22rpx;
}

.section-label {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.section-label.light {
  margin-top: 54rpx;
  color: #ffffff;
}

.section-line {
  width: 8rpx;
  height: 34rpx;
  margin-right: 14rpx;
  border-radius: 99rpx;
  background: linear-gradient(180deg, #ff8a18, #ff4b00);
}

.quick-card {
  position: relative;
  min-height: 312rpx;
  padding: 34rpx 28rpx 28rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 92, 0, 0.92);
  border-radius: 18rpx;
  background: radial-gradient(circle at 82% 42%, rgba(255, 94, 0, 0.34), transparent 30%), linear-gradient(135deg, rgba(5, 7, 9, 0.94), rgba(13, 16, 18, 0.9));
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.28);
}

.quick-copy {
  position: relative;
  z-index: 2;
  width: 430rpx;
}

.quick-title,
.quick-desc,
.stat-label,
.stat-number,
.shortcut-title,
.shortcut-desc,
.team-name,
.match-meta {
  display: block;
}

.quick-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
}

.quick-desc {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 178rpx;
  height: 64rpx;
  margin: 30rpx 0 0;
  padding: 0;
  border: 0;
  border-radius: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #ff4b00, #ff7418);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.primary-btn::after {
  border: 0;
}

.court-art {
  position: absolute;
  right: 18rpx;
  top: 36rpx;
  width: 310rpx;
  height: 210rpx;
  opacity: 0.95;
}

.court-board {
  position: absolute;
  right: 8rpx;
  top: 34rpx;
  width: 168rpx;
  height: 120rpx;
  border: 6rpx solid #ff6a00;
  box-shadow: 0 0 22rpx rgba(255, 100, 0, 0.8);
}

.court-board::after {
  content: "";
  position: absolute;
  left: 42rpx;
  top: 28rpx;
  width: 72rpx;
  height: 52rpx;
  border: 5rpx solid #ff6a00;
}

.court-ball {
  position: absolute;
  left: 18rpx;
  top: 96rpx;
  width: 112rpx;
  height: 112rpx;
  border: 6rpx solid #ff8a18;
  border-radius: 50%;
  box-shadow: 0 0 26rpx rgba(255, 90, 0, 0.72);
}

.light-line {
  position: absolute;
  height: 4rpx;
  border-radius: 99rpx;
  background: #ff5a12;
  box-shadow: 0 0 18rpx rgba(255, 90, 0, 0.8);
}

.light-line.one {
  left: 0;
  right: 20rpx;
  top: 30rpx;
  transform: rotate(-16deg);
}

.light-line.two {
  left: 38rpx;
  right: 0;
  bottom: 30rpx;
  transform: rotate(-16deg);
}

.quick-stats {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 22rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 16rpx;
  background: rgba(8, 12, 16, 0.88);
}

.stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  padding: 0 16rpx;
}

.stat-icon {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
  border: 4rpx solid #ff6a00;
  border-radius: 50%;
}

.stat-icon.whistle {
  border-radius: 16rpx;
}

.stat-icon.done {
  border-radius: 10rpx;
}

.stat-label {
  color: #ffffff;
  font-size: 22rpx;
}

.stat-number {
  color: #ff6a00;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-divider {
  flex-shrink: 0;
  width: 1rpx;
  height: 66rpx;
  background: rgba(255, 255, 255, 0.22);
}

.content-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - 500rpx);
  margin-top: -2rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.panel {
  margin-bottom: 24rpx;
  padding: 26rpx 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.08);
}

.shortcut-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -9rpx;
}

.shortcut-card {
  position: relative;
  width: calc(33.333% - 18rpx);
  min-height: 166rpx;
  margin: 9rpx;
  padding: 24rpx 10rpx 20rpx;
  border: 1rpx solid rgba(255, 92, 0, 0.22);
  border-radius: 16rpx;
  text-align: center;
  background: #ffffff;
  box-sizing: border-box;
}

.shortcut-icon {
  display: block;
  width: 78rpx;
  height: 78rpx;
  margin: 0 auto 14rpx;
}
.shortcut-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.shortcut-desc {
  margin-top: 8rpx;
  color: #727984;
  font-size: 21rpx;
}

.match-list {
  overflow: hidden;
  border: 1rpx solid #eceff3;
  border-radius: 16rpx;
}

.match-row {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 124rpx;
  padding: 10rpx 12rpx;
  border-bottom: 1rpx solid #eef0f3;
  box-sizing: border-box;
}

.match-row:last-child {
  border-bottom: 0;
}

.team-side {
  width: 130rpx;
  min-width: 0;
}

.team-side.right {
  text-align: center;
}

.team-logo {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 8rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #ff6a00, #101820);
}

.team-name {
  color: #111827;
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-side {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.score-line {
  display: flex;
  align-items: baseline;
  justify-content: center;
  font-family: Arial, sans-serif;
  font-weight: 900;
}

.score-main {
  color: #ff4b00;
  font-size: 42rpx;
}

.score-away,
.score-split {
  color: #111827;
  font-size: 42rpx;
}

.score-split {
  margin: 0 12rpx;
}

.match-meta {
  margin-top: 6rpx;
  color: #727984;
  font-size: 19rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-width: 82rpx;
  height: 42rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.status-done {
  color: #18a957;
  background: #e8f8ef;
}

.status-pending {
  color: #ff4b00;
  background: #fff0e9;
}

.row-arrow {
  flex-shrink: 0;
  margin-left: 8rpx;
  color: #8c929c;
  font-size: 42rpx;
}

.more-link {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  color: #727984;
  font-size: 24rpx;
}

.empty-card {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 130rpx;
  color: #727984;
  font-size: 24rpx;
}

.bottom-safe {
  height: 150rpx;
}

.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  padding: 12rpx 0 calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(5, 9, 12, 0.96);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #aeb4bd;
  font-size: 21rpx;
}

.tab-item.active {
  color: #ff6a00;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
}

.tab-icon.home { background-image: url('/assets/tabbar/tab-home.png'); }
.tab-item.active .tab-icon.home { background-image: url('/assets/tabbar/tab-home-selected.png'); }
.tab-icon.trophy { background-image: url('/assets/tabbar/tab-tournament.png'); }
.tab-item.active .tab-icon.trophy { background-image: url('/assets/tabbar/tab-tournament-selected.png'); }
.tab-icon.user { background-image: url('/assets/tabbar/tab-team.png'); }
.tab-item.active .tab-icon.user { background-image: url('/assets/tabbar/tab-team-selected.png'); }
.tab-icon.edu { background-image: url('/assets/tabbar/tab-education.png'); }
.tab-item.active .tab-icon.edu { background-image: url('/assets/tabbar/tab-education-selected.png'); }
.tab-icon.data { background-image: url('/assets/tabbar/tab-data.png'); }
.tab-item.active .tab-icon.data { background-image: url('/assets/tabbar/tab-data-selected.png'); }
.tab-icon.mine { background-image: url('/assets/tabbar/tab-mine.png'); }
.tab-item.active .tab-icon.mine { background-image: url('/assets/tabbar/tab-mine-selected.png'); }
.quick-card {
  background: #05080b;
}
.quick-card-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.court-art {
  display: none;
}
.stat-icon {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
}
.tab-icon {
  display: block;
  width: 44rpx;
  height: 44rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
}
