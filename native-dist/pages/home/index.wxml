<view class="home-page">
  <view class="top-hero">
    <view class="brand-row">
      <view class="brand-left">
        <image class="brand-logo" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/brand-horizontal-logo.png" mode="aspectFit" />
      </view>

    </view>

    <view wx:if="{{showLoginGuide}}" class="login-guide" bindtap="goLogin">
      <view class="login-guide-copy">
        <text class="login-guide-title">当前未登录</text>
        <text class="login-guide-desc">登录后可云端保存赛事、球队与比赛数据</text>
      </view>
      <text class="login-guide-action">去登录  ›</text>
    </view>

    <view class="section-label light">
      <view class="section-line"></view>
      <text>快速比赛</text>
    </view>

    <view class="quick-card">
      <image class="quick-card-bg" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/quick-match/home-hero-bg.png" mode="aspectFill" />
      <view class="quick-copy">
        <text class="quick-title">快速开始一场比赛</text>
        <text class="quick-desc">设置队伍、节次和时长，立即进入计分</text>
        <button class="primary-btn" bindtap="goQuickMatch">开始比赛</button>
      </view>


      <view class="quick-stats">
        <view class="stat-item stat-button" data-filter="all" bindtap="openRecentMatches">
          <image class="stat-icon" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/quick-match/stat-today.png" mode="aspectFit" />
          <view>
            <text class="stat-label">全部比赛</text>
            <text class="stat-number">{{todayStats.total}}</text>
          </view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item stat-button" data-filter="pending" bindtap="openRecentMatches">
          <image class="stat-icon" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/quick-match/stat-pending.png" mode="aspectFit" />
          <view>
            <text class="stat-label">未结束</text>
            <text class="stat-number">{{todayStats.pending}}</text>
          </view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item stat-button" data-filter="finished" bindtap="openRecentMatches">
          <image class="stat-icon" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/quick-match/stat-finished.png" mode="aspectFit" />
          <view>
            <text class="stat-label">已完成</text>
            <text class="stat-number">{{todayStats.finished}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="content-scroll">
    <view class="version-panel" bindtap="openEducationProduct">
      <view class="version-ad growth-entry">
        <view class="version-orbit orbit-one"></view>
        <view class="version-orbit orbit-two"></view>
        <text class="version-watermark">GROW</text>

        <view class="version-ad-head">
          <view class="version-badge">机构训赛经营增长平台</view>
          <text class="version-status">TRAIN · GAME · GROW</text>
        </view>

        <text class="version-kicker">不只是记录，更要推动下一步</text>
        <view class="version-title"><text>让训练与比赛</text><text class="version-title-accent">持续转化为增长</text></view>
        <text class="version-desc">把每一次训练和比赛，连接到家长认可、续费行动与机构经营。</text>

        <view class="version-chain">
          <view class="version-chain-item"><text class="version-chain-no">01</text><text class="version-chain-title">训练</text><text class="version-chain-note">计划 · 出勤 · 评价</text></view>
          <view class="version-chain-item"><text class="version-chain-no">02</text><text class="version-chain-title">比赛</text><text class="version-chain-note">计分 · 统计 · 高光</text></view>
          <view class="version-chain-item"><text class="version-chain-no">03</text><text class="version-chain-title">家长价值</text><text class="version-chain-note">报告 · 周报</text></view>
          <view class="version-chain-item"><text class="version-chain-no">04</text><text class="version-chain-title">经营动作</text><text class="version-chain-note">续费 · 召回</text></view>
        </view>

        <view class="version-benefits">
          <view class="version-benefit"><text>校区负责人</text><text>先看结果再行动</text></view>
          <view class="version-benefit"><text>教练工作端</text><text>聚焦把课上好</text></view>
          <view class="version-benefit"><text>PC主控台</text><text>角色权限与数据</text></view>
        </view>

        <view class="version-conversion">
          <view><text class="version-conversion-label">从一个校区开始试点</text><text class="version-conversion-note">识别 · 分配 · 执行 · 复盘</text></view>
          <text class="version-conversion-action">了解平台 ›</text>
        </view>
      </view>
    </view>
  </view>

  <sxf-tabbar active="home" />
</view>
