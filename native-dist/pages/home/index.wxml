<view class="home-page">
  <view class="top-hero">
    <view class="brand-row">
      <view class="brand-left">
        <image class="brand-logo" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/brand-horizontal-logo.png" mode="aspectFit" />
      </view>

    </view>

    <view class="section-label light">
      <view class="section-line"></view>
      <text>快速比赛</text>
    </view>

    <view class="quick-card">
      <image class="quick-card-bg" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/quick-match/home-hero-bg.png" mode="aspectFill" />
      <view class="quick-copy">
        <text class="quick-title">快速开始一场比赛</text>
        <text class="quick-desc">设置队伍、节次和时长，立即进入计分</text>
        <button class="primary-btn" bindtap="goQuickMatch">开始比赛</button>
      </view>


      <view class="quick-stats">
        <view class="stat-item">
          <image class="stat-icon" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/quick-match/stat-today.png" mode="aspectFit" />
          <view>
            <text class="stat-label">全部比赛</text>
            <text class="stat-number">{{todayStats.total}}</text>
          </view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <image class="stat-icon" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/quick-match/stat-pending.png" mode="aspectFit" />
          <view>
            <text class="stat-label">未结束</text>
            <text class="stat-number">{{todayStats.pending}}</text>
          </view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <image class="stat-icon" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/quick-match/stat-finished.png" mode="aspectFit" />
          <view>
            <text class="stat-label">已完成</text>
            <text class="stat-number">{{todayStats.finished}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="version-panel">
      <view class="version-ad">
        <view class="version-orbit orbit-one"></view>
        <view class="version-orbit orbit-two"></view>
        <text class="version-watermark">2.0</text>

        <view class="version-ad-head">
          <view class="version-badge">赛小蜂篮球 2.0</view>
          <text class="version-status">COMING SOON</text>
        </view>

        <text class="version-kicker">全新教务系统</text>
        <text class="version-title">即将上线</text>
        <text class="version-desc">连接校区、课程与学员成长，让日常教务管理更简单、更高效。</text>

        <view class="version-features">
          <view class="version-feature">
            <view class="feature-dot"></view>
            <text>智能排课</text>
          </view>
          <view class="version-feature">
            <view class="feature-dot"></view>
            <text>销课统计</text>
          </view>
          <view class="version-feature">
            <view class="feature-dot"></view>
            <text>课后评价</text>
          </view>
        </view>

        <view class="version-footer">
          <text>TEACHING MANAGEMENT</text>
          <text class="version-expect">敬请期待</text>
        </view>
      </view>
    </view>

    <view class="panel match-panel">
      <view class="section-label">
        <view class="section-line"></view>
        <text>最近对阵比分</text>
      </view>

      <view class="match-list" wx:if="{{hasRecentMatches}}">
        <view wx:for="{{recentMatches}}" wx:key="id" class="match-row" data-id="{{item.id}}" bindtap="goMatchDetail">
          <view class="match-content">
            <view class="match-main">
              <view class="team-side home">
                <text class="team-name">{{item.homeName}}</text>
                <image class="team-logo" src="{{item.homeLogo}}" mode="aspectFit" />
              </view>

              <view class="score-side">
                <view class="score-line">
                  <text class="score-main">{{item.homeScore}}</text>
                  <text class="score-split">-</text>
                  <text class="score-away">{{item.awayScore}}</text>
                </view>
              </view>

              <view class="team-side right">
                <image class="team-logo" src="{{item.awayLogo}}" mode="aspectFit" />
                <text class="team-name">{{item.awayName}}</text>
              </view>
            </view>

            <text class="match-meta">{{item.time}}  {{item.venue}}</text>
          </view>

          <view class="row-actions">
            <image class="status-icon" src="{{item.statusIcon}}" mode="aspectFit" aria-label="{{item.statusText}}" />
            <button class="delete-match-btn" data-id="{{item.id}}" catchtap="deleteRecentMatch">删</button>
          </view>
          <text class="row-arrow">›</text>
        </view>

        <view class="more-link" bindtap="goMoreMatches">
          <text>查看更多</text>
          <text>›</text>
        </view>
      </view>

      <view class="empty-card" wx:else>
        <text>暂无最近对阵比分</text>
      </view>
    </view>

    <view class="bottom-safe"></view>
  </scroll-view>

  <sxf-tabbar active="home" />
</view>
