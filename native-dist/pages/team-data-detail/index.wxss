page { min-height: 100%; background: #020b18; }
.detail-page { position: relative; min-height: 100vh; padding: 0 24rpx 46rpx; overflow: hidden; color: #fff; box-sizing: border-box; font-family: -apple-system,BlinkMacSystemFont,"PingFang SC",sans-serif; }
.page-background { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; }
.nav-bar,.team-hero,.tabs,.stats-card,.section-card,.section-heading,.empty-panel { position: relative; z-index: 1; }
.nav-bar { display: flex; align-items: center; justify-content: space-between; height: 96rpx; padding-top: env(safe-area-inset-top); box-sizing: content-box; }
.back-button,.nav-placeholder { display: flex; align-items: center; width: 70rpx; height: 70rpx; }.back-button image { width: 32rpx; height: 48rpx; }.nav-title { font-size: 31rpx; font-weight: 900; letter-spacing: 2rpx; }
.team-hero { display: flex; align-items: center; height: 205rpx; padding: 8rpx 38rpx 10rpx; box-sizing: border-box; }
.hero-logo { width: 170rpx; height: 178rpx; }.hero-copy { margin-left: 32rpx; }.hero-name { display: block; font-size: 48rpx; line-height: 62rpx; font-weight: 1000; }.hero-meta { display: flex; align-items: center; margin-top: 13rpx; color: #adb5c5; font-size: 28rpx; }.status-dot { margin: 0 13rpx; color: #6fc94f; }
.hero-logo-empty { flex-shrink: 0; background: transparent; }
.tabs { display: flex; height: 65rpx; padding: 3rpx; border: 3rpx solid rgba(142,154,173,.38); border-radius: 36rpx; background: rgba(8,22,39,.72); box-sizing: border-box; }
.tab { display: flex; flex: 1; align-items: center; justify-content: center; border-radius: 31rpx; color: #aeb6c5; font-size: 28rpx; font-weight: 800; }.tab.active { color: #fff; background: linear-gradient(100deg,#ff8d13,#ff5308); box-shadow: 0 5rpx 15rpx rgba(255,84,8,.28); }
.stats-card { display: flex; flex-wrap: wrap; margin-top: 18rpx; padding: 23rpx 18rpx; border: 1rpx solid rgba(148,162,184,.4); border-radius: 22rpx; background: linear-gradient(120deg,rgba(9,26,46,.96),rgba(6,23,42,.86)); box-sizing: border-box; }
.stat-cell { display: flex; align-items: center; flex-direction: column; width: 20%; min-height: 117rpx; border-right: 1rpx solid rgba(139,157,181,.28); box-sizing: border-box; }.stat-cell:nth-child(5) { border-right: 0; }.stat-cell.wide { width: 25%; min-height: 112rpx; padding-top: 12rpx; }.stat-cell:last-child { border-right: 0; }
.stat-cell image { width: 38rpx; height: 38rpx; }.stat-label { margin-top: 8rpx; color: #a9b3c3; font-size: 21rpx; white-space: nowrap; }.stat-value { margin-top: 7rpx; font-size: 39rpx; line-height: 45rpx; font-weight: 900; }.stat-value.small { font-size: 34rpx; }.green { color: #6dcc47; }.red { color: #ff4e48; }.orange { color: #ff7b18; }.blue { color: #68a0ff; }
.stats-separator { width: 100%; height: 1rpx; margin: 12rpx 4rpx 8rpx; background: rgba(148,162,184,.34); }
.section-card { border: 1rpx solid rgba(148,162,184,.38); border-radius: 22rpx; background: linear-gradient(120deg,rgba(8,25,45,.96),rgba(6,22,39,.88)); overflow: hidden; box-sizing: border-box; }
.trend-card { margin-top: 17rpx; padding: 18rpx 22rpx 15rpx; }.section-card-title { display: block; font-size: 28rpx; font-weight: 900; }.chart-area { position: relative; height: 235rpx; margin-top: 10rpx; }.trend-canvas { width: 100%; height: 170rpx; }.trend-labels { display: flex; align-items: flex-start; justify-content: space-around; }.trend-label { display: flex; flex: 1; flex-direction: column; align-items: center; color: #9ca8ba; font-size: 17rpx; line-height: 23rpx; }.trend-result { display: flex; align-items: center; justify-content: center; width: 28rpx; height: 28rpx; margin-bottom: 3rpx; border-radius: 50%; color: #fff; font-size: 16rpx; }.trend-result.result-badge { position: static; }.chart-empty { position: absolute; inset: 70rpx 0 auto; color: #8390a2; text-align: center; font-size: 23rpx; }
.section-heading { margin: 22rpx 10rpx 10rpx; font-size: 29rpx; line-height: 39rpx; font-weight: 900; }
.tournament-row { position: relative; display: flex; align-items: center; min-height: 116rpx; padding: 14rpx 42rpx 14rpx 16rpx; border-bottom: 1rpx solid rgba(134,151,175,.24); box-sizing: border-box; }.tournament-row:last-child { border-bottom: 0; }.tournament-logo { width: 112rpx; height: 96rpx; flex-shrink: 0; }.tournament-copy { flex: 1; min-width: 0; margin-left: 14rpx; }.tournament-name { display: block; font-size: 27rpx; font-weight: 900; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }.tournament-record { display: block; margin-top: 7rpx; color: #aab4c3; font-size: 21rpx; }.score-tags { display: flex; gap: 8rpx; margin-top: 7rpx; }.score-tag { padding: 2rpx 12rpx; border-radius: 16rpx; color: #aeb7c5; background: rgba(122,139,163,.16); font-size: 18rpx; }.tournament-link { color: #aeb7c6; font-size: 20rpx; white-space: nowrap; }.row-chevron { position: absolute; right: 14rpx; width: 19rpx; height: 31rpx; opacity: .9; }
.match-row { display: grid; grid-template-columns: 122rpx 1fr 76rpx 1fr 38rpx; align-items: center; min-height: 58rpx; padding: 0 14rpx; border-bottom: 1rpx solid rgba(139,157,181,.22); box-sizing: border-box; }.match-row:last-child { border-bottom: 0; }.match-date { color: #9aa6b8; font-size: 18rpx; }.match-team { display: flex; align-items: center; min-width: 0; color: #aeb8c8; font-size: 20rpx; }.match-team.left { justify-content: flex-end; }.match-team image { width: 37rpx; height: 37rpx; margin: 0 7rpx; }.match-team text { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }.match-score { color: #fff; font-size: 24rpx; font-weight: 900; text-align: center; }.match-score.win { color: #ff7418; }
.result-badge { display: flex; align-items: center; justify-content: center; width: 30rpx; height: 30rpx; border: 2rpx solid; border-radius: 50%; font-size: 17rpx; font-weight: 800; box-sizing: border-box; }.result-badge.w { color: #8fdd62; border-color: #73d241; }.result-badge.l { color: #ff625d; border-color: #ff4944; }.result-badge.d { color: #9eb4c9; border-color: #7790a6; }
.list-empty,.empty-panel { padding: 50rpx 20rpx; color: #8592a4; font-size: 23rpx; text-align: center; }.empty-panel { margin-top: 20rpx; border: 1rpx dashed rgba(148,162,184,.38); border-radius: 22rpx; background: rgba(8,25,45,.8); }

/* Workbench-aligned black/orange theme and visible navigation. */
page { background: #05080b; }
.back-button { justify-content: center; width: 68rpx; height: 68rpx; border: 1rpx solid rgba(255,122,32,.74); border-radius: 50%; color: #ffffff; background: rgba(5,8,11,.86); box-shadow: 0 0 20rpx rgba(255,91,8,.2); box-sizing: border-box; }
.back-arrow { display: block; margin-top: -7rpx; font-family: Arial,sans-serif; font-size: 58rpx; line-height: 58rpx; font-weight: 300; }
.nav-title { text-shadow: 0 4rpx 14rpx rgba(0,0,0,.72); }
.tabs { border-color: rgba(255,122,32,.48); background: rgba(5,8,11,.82); }
.tab { color: rgba(255,255,255,.7); }.tab.active { background: linear-gradient(100deg,#ff4b00,#ff7418); }
.stats-card,.section-card { border-color: rgba(255,255,255,.17); background: linear-gradient(135deg,rgba(7,11,15,.97),rgba(17,25,34,.95) 68%,rgba(34,16,8,.9)); box-shadow: 0 12rpx 30rpx rgba(0,0,0,.24); }
.stats-card { border-top-color: rgba(255,106,22,.54); }
.stat-cell,.stats-separator,.tournament-row,.match-row { border-color: rgba(255,255,255,.15); }
.stat-label,.tournament-record,.match-date,.match-team { color: rgba(255,255,255,.62); }
.stat-value,.tournament-name { color: #ffffff; }
.section-heading,.section-card-title { color: #ffffff; }
.tournament-row { background: rgba(5,8,11,.12); }
.score-tag { color: rgba(255,255,255,.7); background: rgba(255,106,22,.12); }
.empty-panel { border-color: rgba(255,106,22,.3); background: rgba(8,12,16,.9); }
