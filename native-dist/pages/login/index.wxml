<view class="login-page">
  <image class="login-bg" src="/assets/home/home-bg.jpg" mode="aspectFill" />
  <view class="login-mask"></view>

  <view class="login-content">
    <view class="brand-zone">
      <image class="main-logo" src="/assets/home/main-logo.png" mode="aspectFit" />
      <text class="brand-name">赛小蜂篮球</text>
      <text class="brand-en">BASKETBALL</text>
      <text class="slogan">热爱上场 · 蜂行无畏</text>
    </view>

    <view class="action-panel">
      <image class="panel-ball" src="/assets/home/basketball-icon.png" mode="aspectFit" />
      <view class="image-button" bindtap="loginByWechat">
        <image src="/assets/login/login-button.png" mode="widthFix" />
      </view>
      <view class="image-button guest" bindtap="enterAsGuest">
        <image src="/assets/login/guest-button.png" mode="widthFix" />
      </view>
      <view class="agreement" bindtap="toggleAgreement">
        <view class="check {{agreed ? 'active' : ''}}">✓</view>
        <text>登录即代表同意</text>
        <text class="link">用户协议</text>
        <text>和</text>
        <text class="link">隐私政策</text>
      </view>
    </view>
  </view>
</view>