<view class="login-page">
  <image class="login-bg" src="./home-bg.jpg" mode="aspectFill" />
  <view class="login-mask"></view>
  <view class="orange-glow orange-glow-left"></view>
  <view class="orange-glow orange-glow-right"></view>

  <view class="login-content">
    <view class="brand-zone">
      <image class="main-logo" src="./main-logo.png" mode="aspectFit" />
    </view>

    <view class="login-card">
      <text class="login-title">登录赛小蜂篮球</text>
      <text class="login-description">登录后可同步赛事、计分与教务数据</text>

      <button wx:if="{{agreed}}" class="phone-login-button" open-type="getPhoneNumber" bindgetphonenumber="loginByPhone" loading="{{loggingIn}}" disabled="{{loggingIn}}">
        <text class="phone-login-text">{{buttonText}}</text>
      </button>
      <button wx:else class="phone-login-button phone-login-button-locked" bindtap="promptAgreement">
        <text class="phone-login-text">{{buttonText}}</text>
      </button>

      <view class="agreement-row">
        <view class="agreement-checkbox {{agreementCheckClass}}" bindtap="toggleAgreement">
          <text wx:if="{{agreed}}">✓</text>
        </view>
        <text class="agreement-copy" bindtap="toggleAgreement">我已阅读并同意</text>
        <text class="agreement-link" catchtap="showUserAgreement">《用户服务协议》</text>
        <text class="agreement-copy">和</text>
        <text class="agreement-link" catchtap="openPrivacyPolicy">《隐私政策》</text>
      </view>
      <text class="agreement-hint">未勾选协议前不会发起手机号授权</text>
    </view>
  </view>
</view>
