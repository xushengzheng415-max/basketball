<view class="login-page">
  <image class="login-bg" src="./home-bg.jpg" mode="aspectFill" />
  <view class="login-mask"></view>

  <view class="login-content">
    <view class="brand-zone">
      <image class="main-logo" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/main-logo.png" mode="aspectFit" />
    </view>

    <view class="action-panel">
      <image class="panel-ball" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/home/basketball-icon.png" mode="aspectFit" />
      <button wx:if="{{hasSavedWechat}}" class="image-button login-button-float" bindtap="loginWithSavedWechat">
        <image src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/login/login-button.png" mode="widthFix" />
      </button>
      <button wx:else class="image-button login-button-float" open-type="getPhoneNumber" bindgetphonenumber="loginByWechat">
        <image src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/login/login-button.png" mode="widthFix" />
      </button>
      <view class="image-button guest guest-button-float" bindtap="enterAsGuest">
        <image src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/login/guest-button.png" mode="widthFix" />
      </view>
      <view class="agreement" bindtap="toggleAgreement">
        <view class="check {{agreed ? 'active' : ''}}">✓</view>
        <text>登录即代表同意</text>
        <text class="link">用户协议</text>
        <text>和</text>
        <text class="link">隐私政策</text>
      </view>
    </view>
  </view>
</view>
