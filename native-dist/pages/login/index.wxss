page {
  min-height: 100vh;
  background: #080d11;
}

.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #080d11;
}

.login-bg,
.login-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.login-bg {
  opacity: 0.82;
}

.login-mask {
  background:
    linear-gradient(180deg, rgba(3, 7, 10, 0.16) 0%, rgba(3, 7, 10, 0.3) 48%, rgba(3, 7, 10, 0.96) 100%),
    linear-gradient(90deg, rgba(8, 13, 17, 0.3), rgba(255, 90, 0, 0.05), rgba(8, 13, 17, 0.3));
}

.orange-glow {
  position: fixed;
  z-index: 0;
  width: 420rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 90, 0, 0.2);
  filter: blur(70rpx);
}

.orange-glow-left {
  left: -220rpx;
  bottom: 350rpx;
}

.orange-glow-right {
  right: -240rpx;
  top: 330rpx;
}

.login-content {
  position: relative;
  z-index: 1;
  display: flex;
  min-height: 100vh;
  box-sizing: border-box;
  flex-direction: column;
  padding: calc(24rpx + env(safe-area-inset-top)) 38rpx calc(28rpx + env(safe-area-inset-bottom));
}

.brand-zone {
  display: flex;
  min-height: 640rpx;
  flex: 1;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 34rpx;
}

.main-logo {
  width: 610rpx;
  height: 610rpx;
  filter: drop-shadow(0 22rpx 30rpx rgba(0, 0, 0, 0.36));
  animation: logo-enter 0.72s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.login-card {
  flex: 0 0 auto;
  box-sizing: border-box;
  padding: 58rpx 42rpx 38rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 54rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 26rpx 70rpx rgba(0, 0, 0, 0.34);
  animation: card-enter 0.72s cubic-bezier(0.16, 1, 0.3, 1) 0.08s both;
}

.login-title,
.login-description,
.agreement-hint {
  display: block;
  text-align: center;
}

.login-title {
  color: #111820;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1.2;
}

.login-description {
  margin-top: 22rpx;
  color: #7b8188;
  font-size: 26rpx;
  line-height: 1.55;
}

.phone-login-button {
  position: relative;
  display: flex;
  height: 106rpx;
  margin: 44rpx 0 0;
  padding: 0 42rpx;
  overflow: hidden;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 30rpx;
  background: #151b20;
  box-shadow: 0 14rpx 30rpx rgba(238, 76, 0, 0.24);
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.phone-login-button::after {
  border: 0;
}

.phone-login-button-locked {
  opacity: 0.78;
}

.phone-login-button[disabled] {
  color: #fff;
  opacity: 0.72;
}

.phone-login-bg {
  position: absolute;
  z-index: 0;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.phone-login-text {
  position: relative;
  z-index: 1;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.42);
}

.agreement-row {
  display: flex;
  margin-top: 34rpx;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  color: #747b82;
  font-size: 22rpx;
  line-height: 1.8;
}

.agreement-checkbox {
  display: flex;
  width: 30rpx;
  height: 30rpx;
  margin-right: 12rpx;
  box-sizing: border-box;
  flex: 0 0 30rpx;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #9aa0a6;
  border-radius: 7rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
}

.agreement-checkbox.checked {
  border-color: #ff5a00;
  background: #ff5a00;
}

.agreement-copy {
  margin-right: 4rpx;
}

.agreement-link {
  margin-right: 4rpx;
  color: #ff5a00;
  font-weight: 700;
}

.agreement-hint {
  margin-top: 12rpx;
  color: #a0a5aa;
  font-size: 20rpx;
  line-height: 1.4;
}

@keyframes logo-enter {
  from {
    opacity: 0;
    transform: translateY(32rpx) scale(0.94);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes card-enter {
  from {
    opacity: 0;
    transform: translateY(90rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
