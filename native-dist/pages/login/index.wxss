page {
  min-height: 100vh;
  background: #101820;
}
.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #101820;
}
.login-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
}
.login-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(16, 24, 32, 0.08) 0%, rgba(16, 24, 32, 0.04) 44%, rgba(16, 24, 32, 0.18) 100%);
}
.login-content {
  position: relative;
  z-index: 1;
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: space-between;
  padding: 72rpx 32rpx 0;
}
.brand-zone {
  display: flex;
  align-items: center;
  flex-direction: column;
  padding-top: 34rpx;
}
.main-logo {
  width: 430rpx;
  height: 430rpx;
  filter: drop-shadow(0 18rpx 24rpx rgba(16, 24, 32, 0.28));
}
.brand-name, .brand-en, .slogan {
  display: block;
}
.brand-name {
  margin-top: -8rpx;
  color: #fff;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 8rpx 0 rgba(16, 24, 32, 0.36), 0 18rpx 28rpx rgba(16, 24, 32, 0.32);
}
.brand-en {
  margin-top: 24rpx;
  color: #ff9e16;
  font-family: DIN Alternate, Arial, sans-serif;
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: 12rpx;
}
.slogan {
  margin-top: 24rpx;
  color: #f8d568;
  font-size: 26rpx;
  font-weight: 900;
}
.action-panel {
  position: relative;
  padding: 82rpx 38rpx 42rpx;
  border-radius: 54rpx 54rpx 0 0;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -18rpx 46rpx rgba(16, 24, 32, 0.24);
}
.panel-ball {
  position: absolute;
  top: -48rpx;
  left: 50%;
  width: 96rpx;
  height: 96rpx;
  transform: translateX(-50%);
  filter: drop-shadow(0 8rpx 16rpx rgba(16, 24, 32, 0.22));
}
.image-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.image-button image {
  width: 100%;
}
.image-button.guest {
  margin-top: 24rpx;
}
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 28rpx;
  color: #727272;
  font-size: 22rpx;
  line-height: 1.5;
}
.check {
  display: flex;
  width: 32rpx;
  height: 32rpx;
  flex: 0 0 32rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #f05a28;
  border-radius: 50%;
  color: transparent;
  font-size: 20rpx;
  font-weight: 900;
}
.check.active {
  color: #fff;
  background: #f05a28;
}
.link {
  color: #f05a28;
  font-weight: 900;
}