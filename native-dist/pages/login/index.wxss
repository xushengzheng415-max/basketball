page {
  min-height: 100vh;
  background: #101820;
}
.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #101820;
}
.login-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
}
.login-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(16, 24, 32, 0.08) 0%, rgba(16, 24, 32, 0.04) 42%, rgba(16, 24, 32, 0.2) 100%);
}
.login-content {
  position: relative;
  z-index: 1;
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: space-between;
  padding: 64rpx 32rpx 0;
}
.brand-zone {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 30rpx 0 220rpx;
}
.main-logo {
  width: 500rpx;
  height: 500rpx;
  animation: logoFloat 3.6s ease-in-out infinite;
  filter: drop-shadow(0 18rpx 24rpx rgba(16, 24, 32, 0.3));
}
.action-panel {
  position: relative;
  padding: 82rpx 38rpx 42rpx;
  border-radius: 54rpx 54rpx 0 0;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -18rpx 46rpx rgba(16, 24, 32, 0.24);
  animation: panelRise 0.72s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.panel-ball {
  position: absolute;
  top: -48rpx;
  left: 50%;
  width: 96rpx;
  height: 96rpx;
  animation: ballRise 0.72s cubic-bezier(0.16, 1, 0.3, 1) both, ballFloat 2.8s ease-in-out 0.78s infinite;
  transform: translateX(-50%);
  filter: drop-shadow(0 8rpx 16rpx rgba(16, 24, 32, 0.22));
}
.image-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  will-change: transform;
}
.image-button image {
  width: 100%;
}
.login-button-float {
  animation: buttonRise 0.72s cubic-bezier(0.16, 1, 0.3, 1) 0.12s both, buttonFloat 2.4s ease-in-out 0.92s infinite;
}
.image-button.guest {
  margin-top: 24rpx;
}
.guest-button-float {
  animation: buttonRise 0.72s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both, buttonFloat 2.4s ease-in-out 1.16s infinite;
}
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 28rpx;
  color: #727272;
  font-size: 22rpx;
  line-height: 1.5;
}
.check {
  display: flex;
  width: 32rpx;
  height: 32rpx;
  flex: 0 0 32rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #f05a28;
  border-radius: 50%;
  color: transparent;
  font-size: 20rpx;
  font-weight: 900;
}
.check.active {
  color: #fff;
  background: #f05a28;
}
.link {
  color: #f05a28;
  font-weight: 900;
}
@keyframes panelRise {
  0% {
    transform: translateY(110%);
  }
  100% {
    transform: translateY(0);
  }
}
@keyframes buttonRise {
  0% {
    opacity: 0;
    transform: translateY(72rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}
@keyframes ballRise {
  0% {
    opacity: 0;
    transform: translateX(-50%) translateY(72rpx) rotate(-18deg);
  }
  100% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) rotate(0deg);
  }
}
@keyframes logoFloat {
  0%, 100% {
    transform: translateY(0) scale(1);
  }
  50% {
    transform: translateY(-14rpx) scale(1.018);
  }
}
@keyframes buttonFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}
@keyframes ballFloat {
  0%, 100% {
    transform: translateX(-50%) translateY(0) rotate(0deg);
  }
  50% {
    transform: translateX(-50%) translateY(-8rpx) rotate(8deg);
  }
}