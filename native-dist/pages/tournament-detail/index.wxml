<view class="page-wrap" wx:if="{{tournament}}">
  <view class="hero">
    <text class="eyebrow">当前赛事</text>
    <text class="title">{{tournament.name}}</text>
    <text class="desc">{{tournament.location || '未填写地点'}} · {{tournament.date || '未选择日期'}}</text>
  </view>

  <text class="section">创建场次</text>
  <view class="form-card">
    <input value="{{gameName}}" placeholder="场次名称，例如：小组赛第 1 场" bindinput="onGameNameInput" />
    <picker mode="date" value="{{gameDate}}" bindchange="onGameDateChange">
      <view class="date-picker {{gameDate ? 'has-value' : ''}}">{{gameDate || '选择场次日期'}}</view>
    </picker>
    <view class="team-grid">
      <input value="{{homeTeamName}}" placeholder="主队名称" bindinput="onHomeTeamInput" />
      <input value="{{awayTeamName}}" placeholder="客队名称" bindinput="onAwayTeamInput" />
    </view>
    <view class="primary" bindtap="saveGame">保存场次</view>
  </view>

  <text class="section">赛事场次</text>
  <view wx:if="{{games.length === 0}}" class="empty">暂无场次，先创建一场。</view>
  <view wx:for="{{games}}" wx:key="id" class="item" data-id="{{item.id}}" bindtap="openGame">
    <view>
      <text class="item-title">{{item.name}}</text>
      <text class="item-desc">{{item.homeTeamName}} vs {{item.awayTeamName}}</text>
      <text class="item-desc">{{item.date || '未选择日期'}} · 已选 {{item.homePlayers.length + item.awayPlayers.length}} 人</text>
    </view>
    <text class="item-action">添加球员</text>
  </view>
</view>

<view class="page-wrap" wx:else>
  <view class="empty">没有找到这个赛事，请返回赛事页重新进入。</view>
</view>