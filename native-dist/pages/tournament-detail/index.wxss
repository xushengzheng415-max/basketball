.page-wrap {
  padding: 28rpx;
}
.hero {
  padding: 28rpx;
  border-radius: 12rpx;
  background: #101820;
}
.eyebrow,
.title,
.desc,
.section,
.item-title,
.item-desc {
  display: block;
}
.eyebrow {
  color: #ffd65a;
  font-size: 22rpx;
  font-weight: 900;
}
.title {
  margin-top: 12rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
}
.desc {
  margin-top: 10rpx;
  color: #cbd5e1;
  font-size: 26rpx;
  line-height: 1.45;
}
.section {
  margin: 32rpx 0 16rpx;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
}
.form-card {
  display: grid;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #fff;
}
.team-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
input,
.date-picker {
  box-sizing: border-box;
  width: 100%;
  height: 78rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d7dee8;
  border-radius: 10rpx;
  background: #f8fafc;
  color: #98a2b3;
  font-size: 26rpx;
  line-height: 78rpx;
}
.date-picker.has-value {
  color: #18212f;
}
.primary {
  display: flex;
  height: 84rpx;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #fff;
  background: #f05a28;
  font-size: 28rpx;
  font-weight: 900;
}
.empty,
.item {
  padding: 24rpx;
  border-radius: 10rpx;
  background: #fff;
  color: #667085;
  font-size: 26rpx;
}
.item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}
.item-title {
  color: #18212f;
  font-size: 28rpx;
  font-weight: 900;
}
.item-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.35;
}
.item-action {
  flex-shrink: 0;
  color: #f05a28;
  font-size: 24rpx;
  font-weight: 900;
}

.hero-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}
.hero-head > view:first-child {
  min-width: 0;
}
.hero-actions {
  display: flex;
  flex-shrink: 0;
  gap: 10rpx;
}
.small-btn {
  display: flex;
  min-width: 88rpx;
  height: 50rpx;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.14);
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
}
.small-btn.danger {
  background: rgba(240,90,40,0.95);
}
.edit-card {
  margin-top: 18rpx;
}
.form-actions {
  display: grid;
  grid-template-columns: 1fr 160rpx;
  gap: 14rpx;
}
.secondary {
  display: flex;
  height: 84rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #d7dee8;
  border-radius: 10rpx;
  color: #344054;
  background: #fff;
  font-size: 28rpx;
  font-weight: 900;
}
