page{background:#05080b;color:#f4f6f7;font-family:"PingFang SC","Microsoft YaHei",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 88% 0,rgba(255,112,0,.24),transparent 28%),#05080b}.nav{height:190rpx;padding:102rpx 28rpx 0;box-sizing:border-box;display:flex;align-items:center}.back{width:72rpx;height:70rpx;display:flex;align-items:center;font-size:62rpx;line-height:1}.nav-title,.nav-sub,.eyebrow,.hero-title,.period,.trigger text,.summary-grid text,.rule-card text,.list-head text,.student-meta,.student-score text,.editor-head text,.source-tip text,.field-label{display:block}.nav-title{font-size:32rpx;font-weight:800}.nav-sub{margin-top:4rpx;color:#7e868c;font-size:19rpx}.campus{margin-left:auto;padding:9rpx 15rpx;border:1rpx solid rgba(255,122,0,.6);border-radius:999rpx;color:#ff8a19;font-size:19rpx}.scroll{height:calc(100vh - 190rpx)}.tabs{height:72rpx;margin:8rpx 28rpx 16rpx;padding:5rpx;display:flex;border-radius:17rpx;background:#11171a;border:1rpx solid rgba(255,255,255,.1)}.tab{flex:1;display:flex;align-items:center;justify-content:center;border-radius:13rpx;color:#858d92;font-size:23rpx;font-weight:800}.tab.active{background:linear-gradient(90deg,#ff5b00,#ff9b20);color:#fff}.hero-card{margin:0 28rpx 16rpx;padding:24rpx;border-radius:22rpx;background:linear-gradient(145deg,rgba(45,26,12,.96),#11171a 58%,#0b0f12);border:1rpx solid rgba(255,126,20,.6)}.hero-card.monthly{background:linear-gradient(145deg,#1a2024,#0b0f12);border-color:rgba(255,255,255,.14)}.hero-head{display:flex;justify-content:space-between;align-items:flex-start}.eyebrow{color:#ff8a19;font-size:19rpx}.monthly .eyebrow{color:#9ba2a7}.hero-title{margin-top:6rpx;font-size:32rpx;font-weight:900}.period{margin-top:5rpx;color:#8b9398;font-size:19rpx}.report-mark{width:72rpx;height:82rpx;padding-top:22rpx;box-sizing:border-box;border:4rpx solid #ff8a19;border-radius:10rpx;transform:rotate(4deg)}.report-mark view{width:42rpx;height:4rpx;margin:0 auto 8rpx;border-radius:4rpx;background:#ff8a19}.monthly .report-mark{border-color:#788086}.monthly .report-mark view{background:#788086}.trigger{display:flex;align-items:flex-start;margin-top:20rpx;padding:15rpx;border-radius:13rpx;background:rgba(0,0,0,.26);color:#a9afb3;font-size:18rpx;line-height:1.5}.trigger-dot{flex:none;width:13rpx;height:13rpx;margin:7rpx 12rpx 0 0;border-radius:50%;background:#52cf75;box-shadow:0 0 0 6rpx rgba(82,207,117,.12)}.monthly .trigger-dot{background:#838b90;box-shadow:none}.summary-grid{display:grid;grid-template-columns:repeat(3,1fr);margin-top:18rpx}.summary-grid>view{text-align:center;border-right:1rpx solid rgba(255,255,255,.09)}.summary-grid>view:last-child{border-right:0}.summary-grid text:first-child{color:#ff941d;font-size:30rpx;font-weight:900}.monthly .summary-grid text:first-child{color:#c1c6c9}.summary-grid text:last-child{margin-top:4rpx;color:#7d858b;font-size:17rpx}.progress-track{height:8rpx;margin-top:18rpx;border-radius:999rpx;background:#30363a;overflow:hidden}.progress-value{height:100%;border-radius:999rpx;background:linear-gradient(90deg,#ff5b00,#ffb129)}.rule-card{display:flex;align-items:flex-start;margin:0 28rpx 16rpx;padding:20rpx;border-radius:18rpx;background:rgba(255,177,28,.07);border:1rpx solid rgba(255,177,28,.3)}.rule-icon{flex:none;width:42rpx;height:42rpx;margin-right:15rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:#ff981d;color:#101316;font-size:24rpx;font-weight:900}.rule-card>view:last-child{flex:1}.rule-card text:first-child{font-size:21rpx;font-weight:800;color:#edc16c}.rule-card text:last-child{margin-top:5rpx;color:#a89163;font-size:17rpx;line-height:1.5}.list-head{display:flex;align-items:flex-end;justify-content:space-between;margin:0 28rpx 11rpx}.list-head>view text:first-child{font-size:27rpx;font-weight:800}.list-head>view text:last-child{margin-top:4rpx;color:#747c82;font-size:17rpx}.list-head>text{color:#ff8a19;font-size:19rpx}.student-list{margin:0 28rpx;border-radius:20rpx;background:linear-gradient(145deg,#171d21,#0b0f12);border:1rpx solid rgba(255,255,255,.11);overflow:hidden}.student{min-height:126rpx;padding:18rpx;display:flex;align-items:center;border-top:1rpx solid rgba(255,255,255,.08)}.student:first-child{border-top:0}.student image{width:68rpx;height:68rpx;margin-right:14rpx;border-radius:50%;border:2rpx solid rgba(255,126,20,.65)}.student-main{flex:1;min-width:0}.student-main>view{display:flex;align-items:center}.student-name{font-size:23rpx;font-weight:800}.number{margin-left:7rpx;color:#8f979c;font-size:17rpx}.status{margin-left:10rpx;padding:3rpx 8rpx;border-radius:999rpx;font-size:15rpx}.status.pending{background:rgba(255,122,0,.13);color:#ff8a19}.status.done{background:rgba(74,204,112,.12);color:#55d779}.student-meta{margin-top:6rpx;color:#7e868c;font-size:17rpx}.student-score{width:76rpx;text-align:center}.student-score text:first-child{color:#ff9b1f;font-size:24rpx;font-weight:900}.student-score text:last-child{margin-top:2rpx;color:#6f777d;font-size:14rpx}.upload-btn{width:86rpx;height:55rpx;margin-left:8rpx;border-radius:12rpx;display:flex;align-items:center;justify-content:center;background:linear-gradient(90deg,#ff5b00,#ff951d);font-size:18rpx;font-weight:800}.upload-btn.disabled{background:#242a2e;color:#747c82}.safe{height:80rpx}.mask{position:fixed;z-index:10;inset:0;display:flex;align-items:flex-end;background:rgba(0,0,0,.72)}.editor-sheet{width:100%;padding:14rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));box-sizing:border-box;border-radius:30rpx 30rpx 0 0;background:#12181c;border-top:1rpx solid rgba(255,122,0,.6)}.sheet-handle{width:78rpx;height:7rpx;margin:0 auto 18rpx;border-radius:999rpx;background:#444b50}.editor-head{display:flex;align-items:center;justify-content:space-between}.editor-head>view:first-child text:first-child{font-size:29rpx;font-weight:900}.editor-head>view:first-child text:last-child{margin-top:4rpx;color:#7d858b;font-size:18rpx}.close{width:52rpx;height:52rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:#292f33;color:#aeb4b8;font-size:38rpx}.source-tip{margin-top:18rpx;padding:16rpx;border-radius:14rpx;background:rgba(255,122,0,.09);border:1rpx solid rgba(255,122,0,.25)}.source-tip text:first-child{color:#ff941d;font-size:19rpx;font-weight:800}.source-tip text:last-child{margin-top:5rpx;color:#8e969b;font-size:16rpx}.field-label{margin:17rpx 0 9rpx;color:#d9dcde;font-size:19rpx;font-weight:800}.editor-sheet textarea{box-sizing:border-box;width:100%;height:230rpx;padding:17rpx;border-radius:15rpx;background:#0a0f12;border:1rpx solid rgba(255,255,255,.12);color:#e8eaeb;font-size:20rpx;line-height:1.6}.attachment{height:68rpx;padding:0 16rpx;border-radius:14rpx;display:flex;align-items:center;border:1rpx dashed rgba(255,139,25,.5);color:#8f979c;font-size:18rpx}.attachment text:first-child{flex:1;color:#d9dcde;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.attachment text:nth-child(2){flex:1}.attachment text:last-child{color:#ff8a19;font-size:30rpx}.submit{height:78rpx;margin-top:20rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;background:linear-gradient(90deg,#ff5b00,#ff9b20);font-size:24rpx;font-weight:900}
