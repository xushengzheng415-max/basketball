page{background:#05090c;color:#f7f7f7}.page{min-height:100vh;background:#070b0e}.scroll{height:calc(100vh - 118rpx);padding:70rpx 35rpx 20rpx;box-sizing:border-box}.title{font-size:50rpx;font-weight:900}.subtitle{font-size:25rpx;color:#aaa;margin:10rpx 0 18rpx}.tabs{display:flex;gap:12rpx;margin-bottom:20rpx}.tabs text{padding:10rpx 26rpx;border-radius:24rpx;color:#999}.tabs .active{background:#ff7800;color:#fff}.hero,.panel,.report-card{border:1rpx solid #373d41;border-radius:22rpx;background:linear-gradient(135deg,#191e21,#0d1215)}.hero{height:190rpx;display:grid;grid-template-columns:repeat(3,1fr);border-color:#8c480d;box-shadow:0 0 18rpx rgba(255,120,0,.17)}.hero view{display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative}.hero view+view:before{content:"";position:absolute;left:0;height:90rpx;border-left:1rpx solid #343a3e}.hero .strong{font-size:58rpx;color:#ff7800}.hero text{color:#bbb;font-size:25rpx;margin-top:8rpx}.panel{padding:24rpx;margin-top:20rpx}.panel-title{font-size:31rpx;font-weight:900}.tags{display:flex;gap:15rpx;margin-top:22rpx}.tags text{flex:1;border:2rpx solid #ff7800;border-radius:28rpx;padding:14rpx;text-align:center}.person{display:flex;align-items:center;padding:18rpx 0;border-bottom:1rpx solid #333}.person:last-child{border:0}.person image{width:64rpx;height:64rpx;border-radius:50%;border:2rpx solid #ff7800;margin-right:20rpx}.person view{flex:1}.person text,.person .small{display:block}.person .small{color:#aaa;margin-top:6rpx}.person>text{color:#ff7800;border:1rpx solid #ff7800;border-radius:24rpx;padding:8rpx 25rpx}.report-card{padding:28rpx;margin-top:20rpx;border-color:#82430e;display:flex;align-items:center;flex-wrap:wrap}.report-icon{font-size:64rpx;color:#ff7800;margin-right:26rpx}.report-card>view:nth-child(2){flex:1}.report-card view>text,.report-card .small{display:block}.report-card view>text{font-size:31rpx;font-weight:800}.report-card .small{color:#aaa;margin-top:8rpx}.report-card .primary{width:100%;flex:auto;margin-top:22rpx}.class-growth{display:grid;grid-template-columns:1fr auto;gap:10rpx;padding:18rpx 0;border-bottom:1rpx solid #333}.class-growth>view{grid-column:1/3;height:10rpx;background:#282d31;border-radius:8rpx}.class-growth view{display:block;height:100%;background:#ff7800;border-radius:8rpx}.bullet{display:block;margin:20rpx 0;color:#ccc}.link{color:#ff7800}.safe{height:30rpx}.footer{height:118rpx;display:flex;gap:20rpx;padding:18rpx 35rpx;box-sizing:border-box}.outline,.primary{height:78rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:800}.outline{width:300rpx;border:2rpx solid #ff7800;color:#ff7800}.primary{flex:1;background:linear-gradient(100deg,#ff6500,#ff901d)}

.title.has-back{display:flex;align-items:center;gap:18rpx}.title .back{font-size:58rpx;font-weight:400;line-height:1}
