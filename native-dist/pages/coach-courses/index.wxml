<view class="page">
  <view class="nav"><view class="back" bindtap="goBack"><text>‹</text></view><text class="nav-title">我的课程</text></view>
  <scroll-view class="scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="calendar-toolbar">
      <view><text class="calendar-kicker">课程日历</text><text class="calendar-hint">点击日期查看当日课程</text></view>
      <view class="month" bindtap="toggleMonthView"><text>{{monthLabel}}</text><text class="month-chevron">{{monthArrow}}</text></view>
    </view>
    <view class="date-strip">
      <view wx:for="{{dates}}" wx:key="iso" class="date-item {{item.activeClass}}" data-iso="{{item.iso}}" bindtap="selectDate"><text>{{item.week}}</text><text class="day">{{item.day}}</text><view class="date-dot {{item.courseClass}}"></view></view>
    </view>
    <view class="month-toggle" bindtap="toggleMonthView"><text>{{monthToggleText}}</text><text class="toggle-arrow">{{monthArrow}}</text></view>
    <view class="month-calendar" wx:if="{{monthExpanded}}">
      <view class="month-head"><text bindtap="previousMonth">‹</text><text>{{monthLabel}}课程计划</text><text bindtap="nextMonth">›</text></view>
      <view class="weekday-row"><text wx:for="{{weekdayLabels}}" wx:key="*this">{{item}}</text></view>
      <view class="month-grid">
        <view wx:for="{{calendarDays}}" wx:key="key" class="calendar-day {{item.emptyClass}} {{item.activeClass}} {{item.courseClass}}" data-iso="{{item.iso}}" bindtap="selectMonthDate"><text>{{item.day}}</text><text class="course-count">{{item.courseCount}}</text></view>
      </view>
    </view>
    <view class="summary-grid"><view class="summary-item" wx:for="{{summary}}" wx:key="label"><text class="summary-value">{{item.value}}</text><text class="summary-label">{{item.label}}</text></view></view>
    <view class="filter-row"><view wx:for="{{filters}}" wx:key="key" class="filter {{item.activeClass}}" data-key="{{item.key}}" bindtap="selectFilter">{{item.label}}</view></view>
    <view class="day-title"><view><text class="title">{{selectedDateLabel}}</text><text class="subtitle">浦东校区 · 陈教练</text></view><text class="weather">☀ 26°C</text></view>
    <view class="course-card" wx:for="{{courses}}" wx:key="id" data-id="{{item.id}}" bindtap="openCourse">
      <view class="time"><text class="start">{{item.time}}</text><text class="end">{{item.end}}</text></view>
      <view class="rail"><view class="dot {{item.statusClass}}"></view></view>
      <view class="course-main"><view><text class="course-title">{{item.title}}</text><text class="level">{{item.level}}</text></view><text class="meta">{{item.venue}}　·　{{item.students}}人</text><view class="course-foot"><text class="status {{item.statusClass}}">{{item.status}}</text><text class="action">{{item.action}} ›</text></view></view>
    </view>
    <view class="empty-day" wx:if="{{emptyVisible}}"><text>当天没有安排课程</text><text>可展开整月课程计划选择其他日期</text></view>
    <view class="week-panel"><view><text class="panel-title">本周教学概览</text><text class="panel-sub">累计 16 课时 · 评价完成率 82%</text></view><view class="ring"><text>82%</text></view></view>
    <view class="safe"></view>
  </scroll-view>
</view>
