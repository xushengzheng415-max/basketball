page{background:#05080b;color:#f5f6f7;font-family:"PingFang SC",sans-serif}.page{min-height:100vh;background:radial-gradient(circle at 85% 5%,rgba(255,109,0,.2),transparent 28%),#05080b}.nav{height:198rpx;padding:108rpx 210rpx 0 30rpx;display:flex;align-items:center;box-sizing:border-box}.back{width:70rpx;font-size:62rpx}.nav-title{font-size:34rpx;font-weight:800}.scroll{height:calc(100vh - 198rpx)}.calendar-toolbar{display:flex;align-items:center;justify-content:space-between;padding:14rpx 28rpx 4rpx}.calendar-kicker,.calendar-hint{display:block}.calendar-kicker{font-size:24rpx;font-weight:800}.calendar-hint{margin-top:5rpx;color:#737c82;font-size:17rpx}.month{display:flex;align-items:center;gap:9rpx;padding:11rpx 16rpx;border:1rpx solid #ff7a00;border-radius:14rpx;color:#ff8a19;background:rgba(255,122,0,.08);font-size:21rpx}.month-chevron{font-size:25rpx}.date-strip{display:grid;grid-template-columns:repeat(7,1fr);padding:12rpx 22rpx 8rpx}.date-item{text-align:center;color:#7f878d;font-size:20rpx;padding:13rpx 0;border-radius:18rpx}.day{display:block;margin-top:8rpx;font-size:29rpx;color:#dfe2e4}.date-item.active{background:linear-gradient(180deg,#ff8a18,#ff5b00);color:white}.date-item.active .day{color:white;font-weight:800}.date-dot{width:6rpx;height:6rpx;margin:7rpx auto 0;border-radius:50%;background:transparent}.date-dot.has-course{background:#ff7a00}.date-item.active .date-dot{background:white}.month-toggle{display:flex;align-items:center;justify-content:center;gap:8rpx;padding:2rpx 0 15rpx;color:#899197;font-size:17rpx}.toggle-arrow{color:#ff8a19;font-size:24rpx}.month-calendar{margin:0 28rpx 18rpx;padding:17rpx;border:1rpx solid rgba(255,122,0,.36);border-radius:20rpx;background:rgba(14,19,23,.97)}.month-head{display:flex;align-items:center;justify-content:space-between;color:#f4f5f6;font-size:21rpx;font-weight:800}.month-head text:first-child,.month-head text:last-child{width:62rpx;height:52rpx;display:flex;align-items:center;justify-content:center;border-radius:12rpx;background:rgba(255,122,0,.1);color:#ff8a19;font-size:38rpx}.weekday-row,.month-grid{display:grid;grid-template-columns:repeat(7,1fr)}.weekday-row{margin-top:12rpx;color:#737c82;font-size:16rpx;text-align:center}.month-grid{margin-top:8rpx;gap:6rpx}.calendar-day{min-height:66rpx;padding:8rpx 2rpx;border:1rpx solid transparent;border-radius:11rpx;color:#b9bec2;text-align:center;box-sizing:border-box}.calendar-day>text{display:block}.calendar-day.empty{opacity:0;pointer-events:none}.calendar-day.has-course{background:rgba(255,122,0,.06)}.calendar-day.active{border-color:#ff7a00;background:linear-gradient(180deg,rgba(255,138,24,.28),rgba(255,91,0,.14));color:white}.course-count{margin-top:3rpx;color:#ff8a19;font-size:13rpx}.summary-grid{margin:0 28rpx;display:grid;grid-template-columns:repeat(4,1fr);border:1rpx solid rgba(255,125,20,.42);border-radius:20rpx;background:rgba(18,23,27,.96)}.summary-item{text-align:center;padding:22rpx 4rpx;border-right:1rpx solid rgba(255,255,255,.1)}.summary-item:last-child{border:0}.summary-value,.summary-label{display:block}.summary-value{font-size:36rpx;font-weight:800;color:#ff8a19}.summary-label{margin-top:6rpx;color:#92999f;font-size:18rpx}.filter-row{display:flex;gap:12rpx;padding:22rpx 28rpx;overflow:hidden}.filter{white-space:nowrap;padding:10rpx 20rpx;border-radius:999rpx;background:#151a1e;color:#8e969c;font-size:20rpx}.filter.active{background:rgba(255,122,0,.18);border:1rpx solid #ff7a00;color:#ff8a19}.day-title,.week-panel{display:flex;align-items:center;justify-content:space-between;margin:0 28rpx 16rpx}.title,.subtitle,.panel-title,.panel-sub{display:block}.title{font-size:29rpx;font-weight:800}.subtitle,.panel-sub{margin-top:6rpx;color:#777f85;font-size:20rpx}.weather{color:#ff9a22;font-size:22rpx}.course-card{display:flex;margin:0 28rpx 16rpx;padding:24rpx 22rpx;border-radius:22rpx;background:linear-gradient(145deg,#171d22,#0b0f12);border:1rpx solid rgba(255,255,255,.12)}.time{width:90rpx}.start,.end{display:block}.start{font-size:28rpx;font-weight:800}.end{margin-top:8rpx;color:#737b81;font-size:20rpx}.rail{position:relative;width:30rpx;border-left:2rpx solid #343a3e}.dot{position:absolute;left:-9rpx;top:10rpx;width:14rpx;height:14rpx;border-radius:50%;background:#6c7378}.dot.next{background:#ff7a00;box-shadow:0 0 0 7rpx rgba(255,122,0,.12)}.dot.done{background:#43c66a}.dot.todo{background:#ffb11c}.course-main{flex:1}.course-title{font-size:29rpx;font-weight:800}.level{margin-left:12rpx;padding:3rpx 10rpx;border:1rpx solid #ff7a00;border-radius:8rpx;color:#ff8a19;font-size:17rpx}.meta{display:block;margin-top:13rpx;color:#9ba2a7;font-size:21rpx}.course-foot{display:flex;justify-content:space-between;margin-top:20rpx}.status{font-size:20rpx}.status.done{color:#48ce6e}.status.next{color:#ff8a19}.status.todo{color:#ffb21c}.action{color:#ff8a19;font-size:21rpx}.empty-day{margin:0 28rpx 16rpx;padding:48rpx 20rpx;border:1rpx dashed rgba(255,255,255,.13);border-radius:20rpx;text-align:center}.empty-day text{display:block}.empty-day text:first-child{font-size:23rpx;font-weight:800}.empty-day text:last-child{margin-top:8rpx;color:#747d82;font-size:18rpx}.week-panel{padding:24rpx;border:1rpx solid rgba(255,122,0,.4);border-radius:22rpx;background:#11171b}.panel-title{font-size:26rpx;font-weight:800}.ring{width:84rpx;height:84rpx;border-radius:50%;border:10rpx solid #ff7a00;border-left-color:#333b40;display:flex;align-items:center;justify-content:center;font-size:19rpx;font-weight:700}.safe{height:44rpx}

.back{height:70rpx;display:flex;align-items:center;justify-content:flex-start;line-height:1}
