page{background:#05090c;color:#f7f7f7}.page{min-height:100vh;background:linear-gradient(145deg,#070b0e,#05090b)}.scroll{height:100vh;padding:36rpx 30rpx;box-sizing:border-box}.brand{height:76rpx;color:#ff7800;font-size:31rpx;font-weight:800}.title{font-size:40rpx;font-weight:900;margin:36rpx 0}.title text{font-size:56rpx;margin-right:24rpx}.summary{height:112rpx;border:1rpx solid #363b3f;border-radius:20rpx;display:grid;grid-template-columns:repeat(3,1fr);background:#13181b}.summary>view{display:grid;grid-template-columns:45rpx 1fr;grid-template-rows:1fr 1fr;align-items:center;padding:18rpx;color:#ff7800;font-size:30rpx}.summary text{font-size:20rpx;color:#aaa}.summary .strong{font-size:23rpx;color:#f7f7f7}.section-title{font-size:32rpx;font-weight:800;border-left:7rpx solid #ff7800;padding-left:14rpx;margin:34rpx 0 18rpx}.date-tabs{display:flex;justify-content:flex-end;gap:12rpx;margin-top:-60rpx;margin-bottom:24rpx}.date-tabs text{padding:13rpx 20rpx;border-radius:28rpx;background:#151a1e;color:#96999d;font-size:21rpx}.date-tabs .active{border:1rpx solid #ff7800;color:#ff8209}.course{display:flex;align-items:center;border:1rpx solid #363b3f;border-radius:21rpx;background:linear-gradient(135deg,#181d21,#0e1316);padding:26rpx;margin-bottom:18rpx}.ball{width:82rpx;height:82rpx;border-radius:50%;border:1rpx solid #74400f;display:flex;align-items:center;justify-content:center;color:#ff7800;font-size:65rpx;margin-right:26rpx}.course-main{flex:1}.course-title,.meta{display:block}.course-title{font-size:34rpx;font-weight:800}.meta{color:#aaa;font-size:22rpx;margin-top:9rpx}.orange{color:#ff7800}.outline{border:2rpx solid #ff7800;color:#ff7800;border-radius:14rpx;padding:16rpx;font-weight:700}.done-actions{display:flex;gap:10rpx}.done-actions text{padding:13rpx;border:1rpx solid #60656a;border-radius:9rpx}.done-actions text:last-child{border-color:#ff7800;background:#ff7800;color:#111}.safe{height:40rpx}
