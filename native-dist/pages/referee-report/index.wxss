page { background: #05080b; color: #101010; }
.report-page { min-height: 100vh; padding: 0 22rpx calc(34rpx + env(safe-area-inset-bottom)); box-sizing: border-box; background: radial-gradient(circle at 80% 15%, #152028 0, #05080b 34%, #020405 100%); }
.custom-nav { height: 88rpx; padding-top: env(safe-area-inset-top); display: flex; align-items: center; justify-content: space-between; color: #fff; }
.nav-back,.nav-space { width: 80rpx; }.nav-back { font-size: 64rpx; line-height: 1; font-weight: 200; }.nav-title { font-size: 30rpx; font-weight: 700; }
.hero-card { height: 146rpx; margin-top: 4rpx; border: 1rpx solid rgba(255,255,255,.3); border-radius: 16rpx; overflow: hidden; position: relative; display: flex; align-items: center; padding: 0 32rpx; color: #fff; }
.hero-bg,.hero-shade { position: absolute; inset: 0; width: 100%; height: 100%; }.hero-shade { background: linear-gradient(90deg,rgba(0,0,0,.96),rgba(0,0,0,.7) 48%,rgba(0,0,0,.2)); }
.group-badge { width: 100rpx; height: 110rpx; z-index: 1; border: 3rpx solid #ff6a00; clip-path: polygon(50% 0,100% 18%,100% 72%,50% 100%,0 72%,0 18%); display: flex; flex-direction: column; align-items: center; justify-content: center; color: #ff7700; font-weight: 800; box-sizing: border-box; }.group-badge-image { width: 106rpx; height: 118rpx; z-index: 1; flex: none; }
.group-badge-main { font-size: 24rpx; }.group-badge-sub { font-size: 15rpx; }.group-ball { font-size: 17rpx; }.hero-copy { z-index: 1; margin-left: 34rpx; }.hero-title { font-size: 34rpx; font-weight: 800; }.hero-subtitle { margin-top: 12rpx; color: #bbb; font-size: 21rpx; }
.status-pill { z-index: 1; margin-left: auto; border: 2rpx solid #ff8a00; border-radius: 40rpx; padding: 12rpx 22rpx; color: #ff9b17; font-weight: 700; }.status-pill.signed { color: #36cc6a; border-color: #36cc6a; }
.main-card { margin-top: 10rpx; padding: 22rpx 24rpx 20rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 12rpx 28rpx rgba(0,0,0,.35); }
.section-title { display: flex; align-items: center; font-size: 28rpx; font-weight: 800; margin-bottom: 20rpx; }.section-mark { width: 6rpx; height: 26rpx; border-radius: 4rpx; background: #ff5900; margin-right: 14rpx; }
.meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx 26rpx; font-size: 20rpx; color: #444; }.meta-label { color: #181818; font-weight: 700; }.dash-line { border-top: 1rpx dashed #d6d6d6; margin: 22rpx 0; }.meta-divider { margin: 16rpx 0; }
.score-block { display: grid; grid-template-columns: 1fr 1.25fr 1fr; align-items: center; text-align: center; }.team-logo { width: 88rpx; height: 88rpx; transform: scale(1.38); transform-origin: center center; }.team-fallback { width: 82rpx; height: 82rpx; margin: auto; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 30rpx; font-weight: 800; }.home-fallback { background: #ff5b00; }.away-fallback { background: #20252b; }.team-name { margin-top: 8rpx; font-size: 22rpx; font-weight: 700; }.home-name { color: #f45112; }.score-row { font-size: 60rpx; font-weight: 900; }.home-score { color: #f45112; }.score-colon { margin: 0 20rpx; color: #111; }.ended-pill { display: inline-block; padding: 5rpx 18rpx; border-radius: 24rpx; background: #fff1e4; color: #f45112; font-size: 17rpx; }
.score-divider { margin: 14rpx 0; }.period-section-title { margin-bottom: 12rpx; }.period-scroll { width: 100%; }.period-table { border: 1rpx solid #ddd; border-radius: 10rpx; overflow: hidden; }.period-row { display: flex; min-height: 44rpx; }.period-row + .period-row { border-top: 1rpx solid #ddd; }.period-cell,.period-team-cell { min-width: 82rpx; flex: 1; display: flex; align-items: center; justify-content: center; border-right: 1rpx solid #ddd; font-size: 19rpx; }.period-team-cell { min-width: 140rpx; font-weight: 700; }.period-row > view:last-child { border-right: 0; }.header-row { background: #fafafa; font-weight: 700; }.total-cell { font-weight: 800; }
.summary-title { margin-top: 10rpx; }.summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }.summary-card { border: 1rpx solid #ddd; border-radius: 10rpx; padding: 9rpx; text-align: center; }.summary-team { font-size: 21rpx; font-weight: 800; border-bottom: 1rpx solid #eee; padding-bottom: 12rpx; }.summary-values { display: grid; grid-template-columns: 1fr 1fr; margin-top: 12rpx; }.summary-values view + view { border-left: 1rpx dashed #ddd; }.summary-values text { display: block; color: #666; font-size: 17rpx; }.summary-values .summary-number { display: block; margin-top: 5rpx; color: #111; font-size: 50rpx; font-weight: 700; }.summary-values .home-name { color: #f45112; }.record-tip { margin: 8rpx 0; text-align: center; color: #777; font-size: 17rpx; }
.confirmation-card { padding: 18rpx 16rpx; border: 1rpx solid #ffc575; border-radius: 12rpx; background: linear-gradient(135deg,#fff8ed,#fff3df); }.confirmation-card .section-title { margin-bottom: 9rpx; }.name-row { display: flex; align-items: center; gap: 18rpx; font-size: 20rpx; }.name-input { flex: 1; height: 42rpx; padding: 0 20rpx; border: 1rpx solid #d4d9df; border-radius: 8rpx; background: #fff; }.sign-label { margin: 16rpx 0 8rpx; font-size: 19rpx; }.signature-wrap { height: 165rpx; position: relative; overflow: hidden; border: 2rpx dashed #ffa22e; border-radius: 12rpx; background: #fff; }.signature-canvas { width: 100%; height: 100%; }.clear-sign { position: absolute; right: 16rpx; bottom: 12rpx; color: #ff5600; font-size: 18rpx; }.locked-signature { display: flex; align-items: center; justify-content: center; }.signature-preview { width: 80%; height: 82%; }.signed-stamp { position: absolute; right: 16rpx; bottom: 12rpx; color: #22a951; font-weight: 700; }.confirm-check { margin-top: 14rpx; display: flex; align-items: center; justify-content: center; gap: 10rpx; font-size: 19rpx; }.checkbox { width: 25rpx; height: 25rpx; border: 2rpx solid #ff6a00; border-radius: 4rpx; color: transparent; display: flex; align-items: center; justify-content: center; }.checkbox.checked { color: #fff; background: #ff6200; }.report-meta { margin-top: 14rpx; text-align: center; color: #777; font-size: 15rpx; }
.warning-bar { height: 48rpx; margin-top: 18rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #a96300; border-radius: 10rpx; color: #ffad20; background: #20170d; font-weight: 700; font-size: 20rpx; }.submit-button { height: 90rpx; min-height: 90rpx; padding: 0; line-height: normal; box-sizing: border-box; margin: 18rpx 0 0; border: 0; border-radius: 14rpx; color: #fff; background: linear-gradient(90deg,#f45100,#ff7b00); display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 10rpx 24rpx rgba(255,91,0,.25); }.submit-button::after { border: 0; }.submit-title { font-size: 29rpx; font-weight: 800; }.submit-subtitle { font-size: 17rpx; font-weight: 400; }.retry-button { background: linear-gradient(90deg,#cc5200,#f58500); }.report-canvas { position: fixed; left: -2000px; top: -2000px; width: 1240px; height: 1754px; pointer-events: none; }
@media (max-width: 340px) { .meta-grid { grid-template-columns: 1fr; }.hero-title { font-size: 29rpx; }.status-pill { padding: 10rpx 14rpx; }.summary-grid { grid-template-columns: 1fr; } }
