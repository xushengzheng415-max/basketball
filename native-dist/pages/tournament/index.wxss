.page-wrap {
  padding: 28rpx;
}
.title, .desc, .section, .item-title, .item-desc {
  display: block;
}
.title {
  color: #101820;
  font-size: 44rpx;
  font-weight: 900;
}
.desc {
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
}
.form-card {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #fff;
}
input {
  height: 78rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d7dee8;
  border-radius: 10rpx;
  background: #f8fafc;
  font-size: 26rpx;
}
.primary {
  display: flex;
  height: 84rpx;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #fff;
  background: #f05a28;
  font-size: 28rpx;
  font-weight: 900;
}
.section {
  margin: 32rpx 0 16rpx;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
}
.empty, .item {
  padding: 24rpx;
  border-radius: 10rpx;
  background: #fff;
  color: #667085;
  font-size: 26rpx;
}
.item {
  margin-bottom: 14rpx;
}
.item-title {
  color: #18212f;
  font-size: 28rpx;
  font-weight: 900;
}
.item-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}
