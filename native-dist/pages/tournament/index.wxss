page {
  min-height: 100vh;
  background: #02070a;
}

.tournament-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #02070a;
}

.page-bg {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(115deg, rgba(255, 98, 0, 0.26) 0%, rgba(255, 98, 0, 0.06) 28%, rgba(0, 0, 0, 0) 52%),
    radial-gradient(circle at 8% 12%, rgba(255, 106, 0, 0.18) 0, rgba(255, 106, 0, 0) 22%),
    linear-gradient(180deg, #07090a 0%, #03080b 48%, #02070a 100%);
}

.page-bg::after {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  width: 70%;
  height: 260rpx;
  background: linear-gradient(135deg, rgba(255, 106, 0, 0) 20%, rgba(255, 106, 0, 0.24) 70%, rgba(255, 106, 0, 0.08) 100%);
  transform: skewY(-12deg);
  transform-origin: top right;
}

.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  padding: 108rpx 24rpx 0;
  background:
    linear-gradient(115deg, rgba(255, 91, 0, 0.24), rgba(255, 91, 0, 0) 48%),
    linear-gradient(180deg, #090b0c 0%, #120b07 100%);
  box-shadow: 0 12rpx 26rpx rgba(0, 0, 0, 0.34);
}

.page-content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 268rpx 24rpx 184rpx;
}

.topbar {
  display: grid;
  grid-template-columns: 202rpx 1fr 202rpx;
  align-items: center;
  min-height: 72rpx;
}

.page-title,
.panel-title,
.empty-card text {
  display: block;
}

.page-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 0;
  text-align: center;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.45);
}

.create-row {
  display: flex;
  justify-content: flex-start;
  min-height: 64rpx;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

.create-entry {
  display: flex;
  justify-content: flex-start;
}

.create-img {
  width: 202rpx;
  height: 64rpx;
}

.tabs-panel {
  position: relative;
  height: 116rpx;
  margin-top: 0;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 18rpx 18rpx 0 0;
  background: rgba(4, 8, 10, 0.92);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.25);
}

.tabs-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  height: 116rpx;
  align-items: center;
  padding: 0 34rpx;
}

.tab {
  display: flex;
  height: 86rpx;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.55);
  font-size: 30rpx;
  font-weight: 900;
}

.tab.active {
  color: #ff6a00;
}

.tab.active text {
  padding-bottom: 14rpx;
  border-bottom: 6rpx solid #ff6a00;
  border-radius: 6rpx;
}

.recent-score-panel {
  margin: 14rpx 0 0;
  overflow: hidden;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.28);
}

.recent-score-head {
  display: flex;
  height: 72rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #edf0f3;
}

.recent-score-title {
  display: flex;
  align-items: center;
  color: #161b22;
  font-size: 27rpx;
  font-weight: 900;
}

.recent-score-line {
  width: 7rpx;
  height: 28rpx;
  margin-right: 10rpx;
  border-radius: 5rpx;
  background: linear-gradient(180deg, #ff9c25, #ff4d00);
}

.recent-score-count {
  color: #8a929b;
  font-size: 18rpx;
}

.recent-score-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 134rpx minmax(0, 1fr) 86rpx;
  min-height: 106rpx;
  align-items: center;
  padding: 8rpx 12rpx 8rpx 16rpx;
  border-bottom: 1rpx solid #edf0f3;
  box-sizing: border-box;
}

.recent-team {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 6rpx;
}

.recent-team.home {
  justify-content: flex-end;
}

.recent-team.away {
  justify-content: flex-start;
}

.recent-team text {
  min-width: 0;
  overflow: hidden;
  color: #20262d;
  font-size: 19rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-team image {
  flex: none;
  width: 40rpx;
  height: 40rpx;
}

.recent-score-main {
  min-width: 0;
  text-align: center;
}

.recent-score-main > view {
  display: flex;
  align-items: baseline;
  justify-content: center;
  color: #171c22;
  font-family: Arial, sans-serif;
  font-size: 34rpx;
  font-weight: 900;
}

.recent-home-score {
  color: #ff4f00;
}

.recent-score-split {
  margin: 0 6rpx;
}

.recent-score-meta {
  display: block;
  margin-top: 2rpx;
  overflow: hidden;
  color: #9299a1;
  font-size: 14rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-row-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 5rpx;
}

.recent-row-actions image {
  width: 36rpx;
  height: 36rpx;
}

.recent-row-actions button {
  display: flex;
  width: 32rpx;
  height: 32rpx;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  color: #ff5a0a;
  background: #fff0e8;
  font-size: 15rpx;
  line-height: 32rpx;
}

.recent-row-actions button::after {
  border: 0;
}

.recent-row-actions > text {
  color: #a0a7af;
  font-size: 28rpx;
}

.recent-score-empty {
  display: flex;
  height: 104rpx;
  align-items: center;
  justify-content: center;
  color: #8d959e;
  font-size: 21rpx;
}

.recent-score-more {
  display: flex;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #6f7781;
  background: #fafbfc;
  font-size: 21rpx;
  font-weight: 700;
}

.event-list {
  margin-top: 14rpx;
  padding: 12rpx 8rpx 14rpx;
  background: rgba(0, 0, 0, 0.78);
}

.event-card {
  width: 94%;
  margin: 0 auto 9rpx;
}

.event-card-img {
  display: block;
  width: 100%;
  height: 318rpx;
}

.list-footer {
  display: block;
  width: 238rpx;
  height: 34rpx;
  margin: 16rpx auto 0;
}

.empty-card {
  display: flex;
  min-height: 300rpx;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
  color: rgba(255, 255, 255, 0.62);
  background: rgba(0, 0, 0, 0.78);
  font-size: 28rpx;
}

.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  height: 118rpx;
  padding: 12rpx 12rpx calc(env(safe-area-inset-bottom) + 10rpx);
  border-top: 1rpx solid rgba(148, 163, 184, 0.2);
  box-sizing: content-box;
  background: rgba(7, 16, 23, 0.96);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #a9b1bc;
  font-size: 22rpx;
  font-weight: 700;
}

.tab-item.active {
  color: #ff6a1a;
}

.tab-icon {
  display: block;
  width: 44rpx;
  height: 44rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
}

.create-mask {
  position: fixed;
  z-index: 9;
  inset: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.58);
}

.create-panel {
  width: 100%;
  padding: 30rpx 28rpx 48rpx;
  border-radius: 24rpx 24rpx 0 0;
  background: #fff;
  box-shadow: 0 -18rpx 40rpx rgba(0, 0, 0, 0.28);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.panel-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.panel-close {
  display: flex;
  width: 56rpx;
  height: 56rpx;
  align-items: center;
  justify-content: center;
  color: #7b8491;
  font-size: 44rpx;
  line-height: 1;
}

input,
.date-picker {
  width: 100%;
  height: 82rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e1e6ee;
  border-radius: 12rpx;
  color: #17202b;
  background: #f8fafc;
  font-size: 26rpx;
  line-height: 82rpx;
}

.primary {
  display: flex;
  height: 86rpx;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  border-radius: 43rpx;
  color: #fff;
  background: #ff5a00;
  font-size: 28rpx;
  font-weight: 900;
}


.event-card {
  position: relative;
}

.detail-hit {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  z-index: 2;
  width: 142rpx;
  height: 58rpx;
  opacity: 0;
}
