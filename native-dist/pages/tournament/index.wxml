<view class="page-wrap">
  <text class="title">创建赛事</text>
  <text class="desc">记录赛事名称、地点、日期，先把赛事建起来。</text>
  <view class="form-card">
    <input value="{{name}}" placeholder="赛事名称，例如：暑期篮球联赛" bindinput="onNameInput" />
    <input value="{{location}}" placeholder="比赛地点，例如：蜂巢 1 号场" bindinput="onLocationInput" />
    <input value="{{date}}" placeholder="比赛日期，例如：2026-07-20" bindinput="onDateInput" />
    <view class="primary" bindtap="saveTournament">保存赛事</view>
  </view>
  <text class="section">已创建赛事</text>
  <view wx:if="{{tournaments.length === 0}}" class="empty">暂无赛事</view>
  <view wx:for="{{tournaments}}" wx:key="id" class="item">
    <text class="item-title">{{item.name}}</text>
    <text class="item-desc">{{item.location || '未填写地点'}} · {{item.date || '未填写日期'}}</text>
  </view>
</view>
