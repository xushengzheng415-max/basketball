<view class="tournament-page">
  <view class="page-bg"></view>

  <view class="page-content">
    <view class="topbar">
      <view class="nav-spacer"></view>
      <text class="page-title">赛事</text>
      <view class="create-entry" bindtap="showCreateTournament">
        <image class="create-img" src="/assets/tournament/button-create-tournament.png" mode="aspectFit" />
      </view>
    </view>

    <view class="tabs-panel">
      <view class="tabs-row">
        <view wx:for="{{tabs}}" wx:key="key" class="{{item.className}}" data-status="{{item.key}}" bindtap="changeStatus">
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="event-list" wx:if="{{hasVisibleTournaments}}">
      <view wx:for="{{visibleTournaments}}" wx:key="id" class="event-card" data-id="{{item.id}}" bindtap="openTournament">
        <image class="event-card-img" src="{{item.cardImage}}" mode="widthFix" />
      </view>
      <image class="list-footer" src="/assets/tournament/list-footer-no-more.png" mode="aspectFit" />
    </view>

    <view class="empty-card" wx:else>
      <text>当前筛选暂无赛事</text>
    </view>
  </view>

  <view class="create-mask" wx:if="{{showCreatePanel}}" bindtap="hideCreateTournament">
    <view class="create-panel" catchtap="noop">
      <view class="panel-head">
        <text class="panel-title">创建赛事</text>
        <text class="panel-close" bindtap="hideCreateTournament">×</text>
      </view>
      <input value="{{name}}" placeholder="赛事名称，例如：暑期篮球联赛" bindinput="onNameInput" />
      <input value="{{location}}" placeholder="赛事地点，例如：蜂巢 1 号场" bindinput="onLocationInput" />
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="date-picker">{{dateLabel}}</view>
      </picker>
      <view class="primary" bindtap="saveTournament">保存赛事</view>
    </view>
  </view>

  <sxf-tabbar active="tournament" />
</view>
