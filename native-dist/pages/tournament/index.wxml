<view class="page-wrap">
  <text class="title">创建赛事</text>
  <text class="desc">先建立赛事档案，进入赛事后再创建场次。</text>

  <view class="form-card">
    <input value="{{name}}" placeholder="赛事名称，例如：暑期篮球联赛" bindinput="onNameInput" />
    <input value="{{location}}" placeholder="赛事地点，例如：蜂巢 1 号场" bindinput="onLocationInput" />
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="date-picker {{date ? 'has-value' : ''}}">{{date || '选择赛事日期'}}</view>
    </picker>
    <view class="primary" bindtap="saveTournament">保存赛事</view>
  </view>

  <text class="section">已创建赛事</text>
  <view wx:if="{{tournaments.length === 0}}" class="empty">暂无赛事</view>
  <view wx:for="{{tournaments}}" wx:key="id" class="item" data-id="{{item.id}}" bindtap="openTournament">
    <view>
      <text class="item-title">{{item.name}}</text>
      <text class="item-desc">{{item.location || '未填写地点'}} · {{item.date || '未选择日期'}}</text>
    </view>
    <text class="item-action">进入</text>
  </view>
</view>