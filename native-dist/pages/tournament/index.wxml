<view class="tournament-page">
  <view class="page-bg"></view>

  <view class="fixed-header">
    <view class="topbar">
      <view class="nav-spacer"></view>
      <text class="page-title">赛事</text>
      <view class="nav-spacer"></view>
    </view>

    <view class="create-row">
      <view class="create-entry" bindtap="goCreateTournament">
        <image class="create-img" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/tournament/button-create-tournament.png" mode="aspectFit" />
      </view>
    </view>
  </view>

  <view class="page-content">

    <view class="tabs-panel">
      <view class="tabs-row">
        <view wx:for="{{tabs}}" wx:key="key" class="{{item.className}}" data-status="{{item.key}}" bindtap="changeStatus">
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="event-list" wx:if="{{hasVisibleTournaments}}">
      <view wx:for="{{visibleTournaments}}" wx:key="id" class="event-card" data-id="{{item.id}}" bindtap="openTournament">
        <image class="event-card-img" src="{{item.cardImage}}" mode="scaleToFill" data-id="{{item.id}}" />
        <view class="detail-hit" data-id="{{item.id}}" catchtap="openTournament">杩涘叆璇︽儏</view>
      </view>
      <image class="list-footer" src="cloud://cloudbase-d4g93f0re5f3274c1.636c-cloudbase-d4g93f0re5f3274c1-1446269281/ui-assets/assets/tournament/list-footer-no-more.png" mode="aspectFit" />
    </view>

    <view class="empty-card" wx:else>
      <text>当前筛选暂无赛事</text>
    </view>
  </view>
  <sxf-tabbar active="tournament" />
</view>
