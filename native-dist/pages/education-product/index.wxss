page {
  min-height: 100vh;
  background: #05080b;
  color: #f6f7f8;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}
.product-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #05080b;
}
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 640rpx;
  opacity: 0.42;
}
.page-shade {
  position: fixed;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(2, 4, 6, 0.12) 0,
    #05080b 590rpx,
    #05080b 100%
  );
}
.nav {
  position: fixed;
  z-index: 20;
  top: 0;
  left: 0;
  right: 0;
  height: 184rpx;
  padding: 92rpx 28rpx 0;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  background: linear-gradient(180deg, rgba(3, 5, 7, 0.82), rgba(3, 5, 7, 0));
}
.nav > text {
  text-align: center;
  font-size: 29rpx;
  font-weight: 900;
}
.back {
  height: 70rpx;
  display: flex;
  align-items: center;
  font-size: 60rpx;
  line-height: 1;
}
.page-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}
.hero {
  padding: 208rpx 32rpx 34rpx;
}
.brand-logo {
  display: block;
  width: 308rpx;
  height: 84rpx;
}
.hero-badge {
  display: flex;
  width: max-content;
  margin-top: 34rpx;
  padding: 8rpx 10rpx 8rpx 16rpx;
  align-items: center;
  gap: 12rpx;
  border: 1rpx solid rgba(255, 124, 22, 0.66);
  border-radius: 999rpx;
  background: rgba(255, 94, 0, 0.12);
  color: #ff9228;
  font-size: 19rpx;
  font-weight: 800;
}
.hero-badge text:last-child {
  padding: 3rpx 9rpx;
  border-radius: 999rpx;
  background: #ff6a00;
  color: #fff;
  font-size: 15rpx;
}
.hero-kicker,
.hero-title,
.hero-desc,
.section-kicker,
.section-title,
.capability-order,
.capability-title,
.capability-desc,
.role-row text,
.unlock-eyebrow,
.unlock-title,
.unlock-note,
.footer text {
  display: block;
}
.hero-kicker {
  margin-top: 28rpx;
  color: #ff7c18;
  font-family: Arial, sans-serif;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}
.hero-title {
  max-width: 640rpx;
  margin-top: 10rpx;
  font-size: 52rpx;
  font-weight: 950;
  line-height: 1.18;
}
.hero-title text {
  display: block;
}
.hero-title-accent {
  margin-top: 5rpx;
  color: #ff7615;
  text-shadow: 0 10rpx 28rpx rgba(255, 91, 0, 0.22);
}
.hero-desc {
  max-width: 650rpx;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  line-height: 1.65;
}
.hero-points {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 24rpx;
}
.hero-points text {
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  background: rgba(7, 11, 15, 0.65);
  color: #d6dadd;
  font-size: 18rpx;
}
.content {
  padding: 0 28rpx;
}
.result-card {
  display: grid;
  grid-template-columns: 1fr 54rpx 1fr;
  align-items: center;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 124, 22, 0.45);
  border-radius: 20rpx;
  background: linear-gradient(
    135deg,
    rgba(255, 104, 0, 0.14),
    rgba(14, 20, 24, 0.94) 55%
  );
}
.result-card > view:first-child text:first-child,
.result-card > view:last-child text:first-child {
  display: block;
  font-size: 22rpx;
  font-weight: 900;
}
.result-card > view:first-child text:last-child,
.result-card > view:last-child text:last-child {
  display: block;
  margin-top: 5rpx;
  color: #8f979d;
  font-size: 16rpx;
  line-height: 1.4;
}
.result-arrow {
  text-align: center;
  color: #ff7713;
  font-size: 38rpx;
}
.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 38rpx;
}
.section-kicker {
  color: #ff7b16;
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}
.section-title {
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 900;
}
.section-no {
  color: rgba(255, 122, 18, 0.22);
  font-family: "Arial Black", Arial, sans-serif;
  font-size: 58rpx;
  font-weight: 900;
}
.capability-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}
.capability-card {
  position: relative;
  min-height: 198rpx;
  padding: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.11);
  border-radius: 18rpx;
  background: linear-gradient(145deg, #151b1f, #0b1013);
  box-sizing: border-box;
}
.capability-order {
  color: #ff7510;
  font-family: Arial, sans-serif;
  font-size: 18rpx;
  font-weight: 900;
}
.capability-title {
  margin-top: 16rpx;
  font-size: 25rpx;
  font-weight: 900;
}
.capability-desc {
  margin-top: 8rpx;
  color: #868f95;
  font-size: 17rpx;
  line-height: 1.55;
}
.role-panel {
  margin-top: 32rpx;
  padding: 4rpx 22rpx 20rpx;
  border: 1rpx solid rgba(255, 122, 16, 0.35);
  border-radius: 22rpx;
  background: radial-gradient(
      circle at 100% 0,
      rgba(255, 92, 0, 0.18),
      transparent 36%
    ),
    #10161a;
}
.role-panel .section-head {
  margin-top: 20rpx;
}
.role-row {
  display: flex;
  min-height: 92rpx;
  align-items: center;
  border-top: 1rpx solid rgba(255, 255, 255, 0.09);
}
.role-dot {
  flex: none;
  width: 10rpx;
  height: 10rpx;
  margin-right: 14rpx;
  border-radius: 50%;
  background: #ff720d;
  box-shadow: 0 0 14rpx rgba(255, 114, 13, 0.8);
}
.role-row > view:nth-child(2) {
  flex: 1;
}
.role-row text:first-child {
  font-size: 22rpx;
  font-weight: 900;
}
.role-row text:last-child {
  margin-top: 4rpx;
  color: #879096;
  font-size: 16rpx;
}
.role-check {
  color: #ff7812 !important;
  font-size: 24rpx !important;
}
.unlock-card {
  margin-top: 30rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 126, 26, 0.72);
  border-radius: 22rpx;
  background: linear-gradient(135deg, #21130b, #11171b 58%, #251004);
}
.unlock-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.unlock-eyebrow {
  color: #ff8a21;
  font-size: 18rpx;
  font-weight: 900;
}
.unlock-title {
  max-width: 500rpx;
  margin-top: 6rpx;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.4;
}
.unlock-mark {
  padding: 7rpx 11rpx;
  border-radius: 9rpx;
  background: #ff6500;
  color: #fff;
  font-family: Arial, sans-serif;
  font-size: 17rpx;
  font-weight: 900;
}
.unlock-list {
  display: grid;
  gap: 10rpx;
  margin-top: 20rpx;
}
.unlock-list text {
  position: relative;
  padding-left: 23rpx;
  color: #d7dbde;
  font-size: 18rpx;
}
.unlock-list text::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: #ff7a16;
  font-weight: 900;
}
.unlock-note {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #858e94;
  font-size: 16rpx;
}
.safe-space {
  height: 190rpx;
}
.footer {
  position: fixed;
  z-index: 30;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(7, 11, 14, 0.96);
  box-shadow: 0 -12rpx 30rpx rgba(0, 0, 0, 0.36);
}
.footer > view:first-child {
  flex: 1;
}
.footer text:first-child {
  font-size: 21rpx;
  font-weight: 900;
}
.footer text:last-child {
  margin-top: 4rpx;
  color: #777f85;
  font-size: 15rpx;
}
.unlock-button {
  display: flex;
  width: 220rpx;
  height: 70rpx;
  margin: 0;
  padding: 0;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 14rpx;
  background: linear-gradient(90deg, #ff5200, #ff971f);
  box-shadow: 0 10rpx 24rpx rgba(255, 85, 0, 0.28);
  color: #fff;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 70rpx;
}
.unlock-button::after {
  border: 0;
}
