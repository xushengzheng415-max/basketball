<view class="order">
  <text class="title">确认订单</text>

  <view class="card">
    <text class="label">购买项目</text>
    <text class="product-name">{{product.name}}</text>
    <text class="product-desc">{{product.featureSummary}}</text>
    <text class="product-desc">{{product.desc}}</text>
  </view>

  <view class="card">
    <text class="label">账号信息</text>
    <text class="product-name">{{profile.nickName || '微信用户'}}</text>
    <text class="product-desc">授权手机号：{{profile.phoneNumber || '支付接入后同步'}}</text>
  </view>

  <view class="summary">
    <view>
      <text class="summary-label">应付金额</text>
      <text class="summary-desc">{{product.promoLabel || '优惠价'}} · 微信支付接入前为模拟订单</text>
    </view>
    <view class="amount-wrap">
      <text class="original">¥{{product.originalPrice}}</text>
      <text class="amount">¥{{product.price}}</text>
    </view>
  </view>

  <view class="pay-button" bindtap="payNow">确认支付</view>
</view>